//@version=6
indicator("Commander Recovery Screener [v2.0 Wyckoff]", overlay=true)
// ==========================================
// CHANGELOG v2.0 (2026-05-20) — Wyckoff Spring/SOS/JAC catalysts
// ==========================================
// WHY: Legacy REV-CB / REV-RS / REV-EARLY edges failed Nifty 500 backtest
//   (-5.25% cumulative alpha, -28% worst DD). A pure-RSI mean-reversion v2
//   also failed (-25.52%). Wyckoff Spring/SOS/JAC framework — designed by
//   smart-money tape readers — delivered +6.39% cumulative alpha in same test.
//
// NEW (added as priority catalysts above legacy REV-* edges):
//   • WYC-SPRING+SOS (signal_val=8) — Spring + SOS confluence, highest conviction
//   • WYC-JAC        (signal_val=7) — Jump Across the Creek (close > base high)
//   • WYC-SOS        (signal_val=6) — Sign of Strength alone (only one that
//                                       fired in Python 12-anchor backtest)
//   • WYC-SPRING     (signal_val=5) — Spring alone (false breakdown + recovery)
//
// KEPT (now lower priority — legacy fallback only):
//   • REV-EARLY, REV-RS, REV-CB, WATCH(Climax)
//
// INDICATORS USED: OHLC bars + volume + 50-bar volume SMA + 20-bar spread SMA.
//   NO oscillators (no RSI, no MACD, no Stochastic).
//
// ==========================================

// ==========================================
// CHANGELOG v1.7 — COMPOSITE-MERGE PASS
// ==========================================
// FOLLOW-UP to v1.6: v1.6 removed duplicate rows but didn't merge the remaining
// rows. v1.7 applies Dashboard-style composite merging:
//
// MERGED:
//   ── RECOVERY VERDICT (was 5 rows: Signal · Score · Regime · RFF · Correction)
//      → 1 compound VERDICT row:
//          "NONE · Score 5/12 [C] · ✓ In Recovery · RFF 1/2 NI✗ OCF✓ · DD 4.1%"
//   ── RECOVERY GATES (was 10 individual rows: G1 … G10)
//      → 5 paired rows (G1+G2, G3+G4, G5+G6, G7+G8, G9+G10).
//   ── TRADE PLAN (was 5 rows: Price · SL · T1 · T2 · R:R)
//      → 1 compound LEVELS row:
//          "P 3569.90 · SL 3456.92 (3.1%) · T1 3548.13 (-1.1%) · T2 3727.69 · R:R 0.1:1"
//   ── CAPITULATION (was 2 rows: RSI(3) FEAR · 60-bar DD)
//      → 1 compound row
//
// LAYOUT (v1.7, ~14 rows total):
//   Title row (full width)
//   🎯 RECOVERY VERDICT header                    (1)
//   VERDICT compound                              (1)
//   🛡 RECOVERY GATES X/10 header w/ status pill (1)
//   G1+G2 paired                                  (1)
//   G3+G4 paired                                  (1)
//   G5+G6 paired                                  (1)
//   G7+G8 paired                                  (1)
//   G9+G10 paired                                 (1)
//   → See Dashboard footer                        (1)
//   📋 TRADE PLAN header                          (1)
//   LEVELS compound                               (1)
//   CAPITULATION compound                         (1)
//   🛠 WATCH MODE / HOW TO TRADE header           (1)
//   ENTRY / SIZE                                  (1)
//   CONFIRM / MANAGE                              (1)
//   RISK / ENTRY DETAIL                           (1)
//
// NEW HELPERS: drawRowC (full-width composite row), drawGatePair (two-gate row).
// LOGIC UNCHANGED — display-layer-only compression.
// ==========================================

// ============================================================================
//  CROSS-TOOL ARCHITECTURE — v1.6 (Decision-Mode Compression Pass)
// ============================================================================
//  The Dashboard (Weinstein & Swing Pro Dashboard v67.3.0+) is now the canonical
//  source for: RS engine · Stage anchors · Strict trend · Price Action Structure
//  · Portfolio · Persona / Style · Volume Trend · Momentum (RSI 14).
//
//  This Screener stays canonical for: Capitulation detection (4-pillar CB) ·
//  REV-CB / REV-RS / REV-EARLY edges · RFF Lite fundamental gate · Recovery-
//  specific 10-gate stack · Correction-depth metric · RSI(3) fear signal.
//
//  Result: rows that duplicated the Dashboard's display were REMOVED.
// ============================================================================

// ==========================================
// CHANGELOG v1.6 — DECISION-MODE COMPRESSION + RS ENGINE MIRROR
// ==========================================
// ARCHITECTURAL: Dashboard is now the canonical source for the RS / Mansfield
//   engine. f_mansfield() replaced with Dashboard's f_calc_rs_logic — dual-SMA
//   (26w slope-mansfield + 52w level-mansfield, canonical Weinstein), 8w slope
//   window, 4-bar momentum, 130-bar warm-up. The 4-bar momentum (Recovery's
//   primary RS consumer) is unchanged; only the LEVEL calc is more canonical.
//
// CHANGE: rs_val now anchored on the canonical 52w Mansfield SMA (was 26w).
//   Effect: rs_positive flips slightly later on stocks recovering from drawdown
//   — matches the structural "real recovery" reading per Weinstein.
//
// REMOVED (Dashboard owns these — read them there):
//   STAGE (Weekly) row    · RS N500 row    · RS MOMENTUM row    · RSI(14) row
//   Net: 4 rows removed. Recovery-unique rows (60-bar DD, RSI(3) FEAR,
//   Correction depth, 10 gates) all preserved.
//
// REORGANIZED — table now follows the capitulation-hunt workflow:
//   LEFT  COLUMN (DIAGNOSIS):
//     ── RECOVERY VERDICT ── (Signal → Score → Regime → RFF → Correction)
//     ── 10 RECOVERY GATES ── (G1 … G10)
//     → See Dashboard for: Stage · RS · Trend · Vol · Momentum (footer)
//   RIGHT COLUMN (CAPITULATION CONTEXT + TRADE PLAN):
//     ── CAPITULATION CONTEXT ── (60-bar DD, RSI(3) FEAR)
//     ── TRADE LEVELS ── (Price → SL → T1 → T2 → R:R)
//     ── HOW TO TRADE / WATCH MODE ── (Entry · Confirm · Risk · Size · Manage · Key Level)
// ==========================================

// ══════════════════════════════════════════════════════════════════════════════
// COMMANDER RECOVERY SCREENER v1.3
// Aligned with: Weinstein Recovery Strategy v1.4
//
// CHANGELOG v1.3 (from v1.0)
//   • REV-CB Pillar 1: replaced %below-SMA200 stretch with 60-bar drawdown.
//   • REV-CB Pillar 2: replaced RSI14<30 + RSI3<15 with red-bar count + bottom-quartile.
//   • REV-CB Pillar 3: replaced ATR×1.5 range with widest-range AND bearish.
//   • REV-RS: stricter trend gate (higher-low + strict-trend port from v1.4 strategy).
//   • REV-EARLY: replaced near-GC + ATR-VCP with NR7/inside-3 + 20-bar reclaim.
//   • 3-way regime gate: market death-cross OR market reclaim OR stock corrected.
//   • Mansfield ×100 textbook scale (RRG-compatible) + RS-Momentum + RRG quadrant.
//   • Param defaults aligned with v1.4: cb_vol_mult 2.5→2.0, climax_window 5→10.
//   • L187 Mansfield call: lookahead_off (was lookahead_on, repaint-prone).
//
// SECURITY CALLS : 3   FINANCIAL CALLS: 2   (Pine Screener limit = 5 total)
// ══════════════════════════════════════════════════════════════════════════════


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 1: INPUTS
// ─────────────────────────────────────────────────────────────────────────────

grp_master = "Master Filters"
min_daily_turnover = input.float(50000000.0,
     title="Min Daily Turnover (INR)",
     step=10000000.0, group=grp_master,
     tooltip="Liquidity gate — only flags stocks above this INR daily turnover.\n50M = ₹5 Cr daily. Raise to 100–200M for large-cap focus.\nCalculated as: Close × Volume.")
use_regime_gate = input.bool(true,
     title="Require Recovery Market Regime?",
     group=grp_master,
     tooltip="ON: signal fires if any of (mkt_corrected | mkt_reclaim | stock_corrected) is true.\nOFF: signals fire in any market.")
min_correction_pct = input.float(10.0,
     title="Min Correction from 52W High (%)",
     minval=1.0, step=1.0, group=grp_master,
     tooltip="Stock corrected ≥ this % from its 52W high passes the regime gate.") / 100
signal_hold_days = input.int(5,
     title="Signal Hold Window (Trading Days)",
     minval=1, maxval=20, group=grp_master,
     tooltip="Days the signal stays visible after firing. Set 1 for same-bar-only mode.")
rff_min_score = input.int(0,
     title="Min Fundamental Score — RFF Lite (0=Off, 1=NI>0, 2=NI+OCF>0)",
     minval=0, maxval=2, group=grp_master)

grp_cb = "Edge: REV-CB (Climax Bottom Bounce)"
cb_drawdown_pct = input.float(-25.0,
     title="Max Drawdown — 60-bar (%)",
     maxval=-5.0, step=1.0, group=grp_cb,
     tooltip="Pillar 1: 60-bar drawdown ≤ this. Default −25 = 25% off the 60-day high.")
cb_red_count = input.int(5,
     title="Min Red Bars in Lookback Window",
     minval=2, group=grp_cb,
     tooltip="Pillar 2a: red bars in cb_range_lookback bars. Default 5 of 10.")
cb_range_lookback = input.int(10,
     title="Range / Red-Bar Lookback (Bars)",
     minval=5, group=grp_cb,
     tooltip="Window for red-bar count, bottom-quartile and widest-range tests.")
cb_vol_mult = input.float(2.0,
     title="Min Climax Volume Multiplier (× avg)",
     minval=1.5, step=0.1, group=grp_cb,
     tooltip="Climax volume threshold (used inside Pillar 3 widest+bearish frame).")
cb_climax_window = input.int(10,
     title="Climax Detection Window (Bars)",
     minval=2, maxval=20, group=grp_cb,
     tooltip="Bars after climax in which the turn signal can occur. v1.4 default 10.")

grp_rs = "Edge: REV-RS / REV-EARLY"
rs_bo_len = input.int(20,
     title="RS Breakout Lookback (Days)",
     minval=5, group=grp_rs)
piv_d_right = input.int(2,
     title="Strict-Trend Confirmation Lag (bars)",
     minval=1, maxval=5, group=grp_rs,
     tooltip="Right-bars for f_getStrictTrend pivot confirmation (matches v1.4 strategy).")
vol_confirm_mult = input.float(1.5,
     title="Volume Confirmation — RS/EARLY Breakouts (× avg)",
     minval=1.0, step=0.1, group=grp_rs)

grp_vcp = "VCP Settings (REV-EARLY)"
vol_avg_len = input.int(50,
     title="Volume Average Length",
     minval=10, group=grp_vcp)

// Webhook Alerts Group
grp_alert = "Webhook Alerts"
use_webhook_json = input.bool(false, title="Send JSON Webhook Alerts (Ngrok + Webhook)", group=grp_alert, tooltip="If enabled, alerts will be formatted as JSON for the webhook server.")
portfolio_capital = input.float(100000.0, title="Total Capital (INR)", step=10000.0, group=grp_alert)
risk_per_trade_pct = input.float(0.50, title="Risk per Trade (%)", minval=0.1, step=0.05, group=grp_alert) // Note: recovery defaults to 0.50% risk per trade
max_alloc = input.float(25000.0, title="Max Allocation per Trade", step=5000.0, group=grp_alert)

grp_disp = "Display"
tbl_pos_input = input.string("Top Right", title="Table Position",
     options=["Top Right", "Top Left", "Top Center",
              "Middle Right", "Middle Center", "Middle Left",
              "Bottom Right", "Bottom Left", "Bottom Center"],
     group=grp_disp)


f_get_sector_ticker() =>
    string s = str.lower(str.tostring(syminfo.sector))
    string i = str.lower(str.tostring(syminfo.industry))
    string t = "NSE:CNX500" // Default fallback
    string n = "Nifty 500"
    
    if str.contains(i, "bank") or str.contains(s, "finance")
        t := "NSE:BANKNIFTY"
        n := "Bank Nifty"
    else if str.contains(s, "technology") or str.contains(i, "software") or str.contains(i, "it")
        t := "NSE:CNXIT"
        n := "Nifty IT"
    else if str.contains(s, "health") or str.contains(i, "pharma")
        t := "NSE:CNXPHARMA"
        n := "Pharma"
    else if str.contains(i, "auto") or str.contains(s, "consumer durables")
        t := "NSE:CNXAUTO"
        n := "Nifty Auto"
    else if str.contains(s, "consumer non") or str.contains(i, "food") or str.contains(i, "beverage")
        t := "NSE:CNXFMCG"
        n := "FMCG"
    else if str.contains(s, "minerals") or str.contains(i, "steel") or str.contains(i, "metal")
        t := "NSE:CNXMETAL"
        n := "Metal"
    else if str.contains(s, "energy") or str.contains(i, "oil") or str.contains(i, "gas")
        t := "NSE:CNXENERGY"
        n := "Energy"
    else if str.contains(s, "real estate") or str.contains(i, "construction")
        t := "NSE:CNXREALTY"
        n := "Realty"
    else if str.contains(s, "infrastructure")
        t := "NSE:CNXINFRA"
        n := "Infra"
    [t, n]

