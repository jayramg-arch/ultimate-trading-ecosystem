//@version=6
indicator("Weinstein Swing Zigzag [Strict v6.3]", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// CHANGELOG v6.3 — audit fixes + enhancements (2026-06-14)
// ==========================================
// FIX (A) Bootstrap asymmetry: Section 2 now seeds from the FIRST pivot when it is a low
//   (na(activePivotType) branch added). Previously the engine could only boot from a high,
//   so on a chart that opened in a downtrend the first swing low was silently dropped until
//   a high formed. The na branch only SEEDS state (lock low, set type "L"); it does not force
//   a direction-change leg. Same-bar ph+pl is handled by Section 1 running first (seeds "H"),
//   so Section 2 then takes the normal H→L path — no zero-length leg.
// PERF (C1) flipBars is now trimmed to the choppiness window each bar (drops entries older
//   than the largest possible lookback) so the array can't grow unbounded over a chart's life.
// PERF (C2) Daily anchor securities (ema20_daily/atr14_daily) are only requested on intraday
//   TFs (return na otherwise) — two fewer security calls on Daily/Weekly/Monthly charts.
// PERF (C3) MTF2 no longer issues a duplicate security call when there is no second HTF
//   (Monthly chart): mtfTrendState2 reuses mtfTrendState in that case.
// ENH (6) Hidden machine-readable plots added (trendState/confirmedTrend/bosUp/bosDn) so a
//   screener or another script can consume this engine via request.security. No visual change.
// ENH (7) New input "Confirmed-bar projection (non-repainting)" (default OFF = live behaviour).
//   When ON, Section 3's developing-BoS writes and the projection extremes only update on
//   closed bars (barstate.isconfirmed) — calmer panel + non-repainting alert path.
// DOC (B) BoS alert messages note the live-projection (repainting intrabar) nature.
// CLEANUP (D) pivot_len no longer declared `var` (re-derived every bar anyway); panel colour
//   literals #1A237E / #131722 extracted to named consts C_PANEL_HDR / C_PANEL_BG.
// ==========================================
//
// ==========================================
// CHANGELOG v6.2 — panel/projection consistency addendum (2026-06-08)
// ==========================================
// FIX: TREND row now derives from the SAME structure pair the STRUCTURE row prints
//   (dispHigh/dispLow), so they can never contradict. Previously TREND read the
//   persisted `trendState` var, which could be stale (e.g. structure HH/LL is
//   broadening → SIDEWAYS, but a leftover trendState=-1 rendered DOWNTREND over it).
//   ALIGNMENT's chart leg (_t0) also switched to this structure-consistent trend.
// FIX: BOS LEVEL (panel + chart line) now uses the MOST RECENT swing high:
//   activePivotType=="H" → activePivotPrice (the fresh peak being pulled back from),
//   else lockedHigh. The chart BoS line also anchors at the pivot BAR (lockedHighBar /
//   activePivotIndex) instead of bar_index-1, so it ties to the marked pivot instead of
//   floating onto whatever candle sits at that price near the right edge.
// NOTE: A CHoCH/devDir attempt (flip the projection + developing trend when price clears
//   prevLockedHigh/Low against the expected side) was tried and REVERTED. When
//   activePivotType=="H", projSyncHigh IS the active pivot's own high, so the gate
//   collapsed to "is the active high above the prior high?" and fired on an EQUAL HIGH
//   (EH sits a hair above its predecessor) → ASIANPAINT 125m falsely read UPTREND (HH/HL)
//   on an EH/HL top. Front-running the strict pivot machine from projSync extremes cannot
//   separate a real breakout from equal-high chop without a confirmed intervening pullback;
//   the lag is intentional. Section 3 keeps its v6.2 activePivotType gating (see below).
// ==========================================
//
// ==========================================
// CHANGELOG v6.2
// ==========================================
// FIX: Section 3 now GATES on activePivotType. When activePivotType=="L"
//   (developing upward from a confirmed low), ONLY the high side is evaluated
//   for developing HH BoS. When activePivotType=="H" (developing downward from
//   a confirmed high), ONLY the low side is evaluated for developing LL BoS.
//   Previously Section 3 evaluated BOTH sides regardless, causing false HH
//   detection when a confirmed high had extended (activePivotPrice > lockedHigh)
//   → NEULANDLAB showed Sideways (HH/LL) instead of Uptrend (HH/HL).
// FIX: syncBars now includes the pivot bar itself (bar_index - activePivotIndex + 1).
//   Previously the +1 was missing, so projSyncLow/projSyncHigh measured from
//   the bar AFTER the pivot, missing the pivot bar's own extreme. This caused
//   projSyncLow > lockedLow (the pivot's low) → false "HL" classification
//   → GRSE/RRKABEL showed Uptrend (HH/HL) instead of Sideways (LL/HH).
// FIX: Developing opposite-side classification now uses the CONFIRMED
//   lastLowClass/lastHighClass instead of re-classifying against prevLocked*.
//   The confirmed classification (from Sections 1/2) already computed the
//   correct structural class using the right reference at direction-change time.
//   Re-classifying in Section 3 could produce a different result because
//   projSyncLow might differ slightly from the actual pivot price.
// ==========================================
//
// CHANGELOG v6.1
// ==========================================
// FIX: Structure panel now reflects DEVELOPING pivot structure.
// FIX: Developing classification uses structural predecessor.
// ==========================================

// --- INPUTS ---
grp_mtf = "MTF Pivot Settings (Left/Right)"
piv_m    = input.int(1, title="Monthly Pivot Length",  minval=1, group=grp_mtf)
piv_w    = input.int(5, title="Weekly Pivot Length",   minval=1, group=grp_mtf)
piv_d    = input.int(2, title="Daily Pivot Length",    minval=1, group=grp_mtf)
piv_intra = input.int(2, title="Intraday Pivot Length", minval=1, group=grp_mtf)

grp_display = "Display Settings"
show_panel        = input.bool(true,  title="Show Trend State Panel",          group=grp_display)
show_proj         = input.bool(true,  title="Show Projection Line",             group=grp_display)
show_pivot_labels = input.bool(true,  title="Show Pivot Labels (HH/HL/LH/LL/EH/EL)", group=grp_display)
show_pivot_pct    = input.bool(true,  title="Show Pivot % Change",              group=grp_display)
panelPos         = input.string(position.top_right, title="Panel Position",
                   options=[position.top_right, position.top_left, position.bottom_right, position.bottom_left],
                   group=grp_display)
pivotCountWeeks  = input.int(26, title="Choppiness Lookback (weeks)", minval=4, maxval=260, step=4,
                   tooltip="Rolling window for Pivot Count (choppiness). Default 26 = half year. Converts to bars automatically per timeframe.",
                   group=grp_display)
show_invalidation = input.bool(true,  title="Show Invalidation & BoS Level Lines", group=grp_display,
                   tooltip="Dotted horizontal lines at the structural stop (latest swing low) and BoS level (latest swing high).")
longsOnlyMode    = input.bool(true, title="Longs-Only Mode", group=grp_display,
                   tooltip="When ON: Invalidation = latest swing low, BoS Level = latest swing high, Vol Confirm captures bullish BoS only. When OFF: original behaviour (active pivot as invalidation, both BoS directions captured).")
volConfirmMult   = input.float(1.5, title="Volume Confirmation Multiplier", minval=0.5, maxval=5.0, step=0.1,
                   tooltip="A BoS bar is ✅ when its volume ≥ this × 50-bar volume SMA. Default 1.5× = Weinstein's volume-confirmation threshold.",
                   group=grp_display)
mtfTfChoice      = input.string("Auto", title="MTF Trend Timeframe",
                   options=["Auto", "D", "W", "M", "3M"],
                   tooltip="Higher-timeframe trend confluence. Auto: intraday→D, D→W, W→M, M→3M.",
                   group=grp_display)
adaptiveChop     = input.bool(true, title="Adaptive Choppiness Regime",
                   tooltip="ON: choppiness clean/moderate thresholds adapt to instrument class — ETFs use 25/12 (trend longer), high-vol stocks use 15/8 (churn faster), standard stocks use 20/10. OFF: universal 20/10 thresholds.",
                   group=grp_display)
mtfReadMode      = input.string("Live (match HTF chart)", title="MTF Read Mode",
                   options=["Live (match HTF chart)", "Backtest-safe (last closed HTF bar only)"],
                   tooltip="Live: MTF rows mirror what you'd see on the HTF chart RIGHT NOW (uses lookahead_on; safe here because the panel only renders at barstate.islast — no historical bias). Backtest-safe: returns only the most-recently-CLOSED HTF bar's trendState (lookahead_off). Switch to Backtest-safe if you embed this script in a strategy/backtest harness that scans historical bars.",
                   group=grp_display)
confirmedProjOnly = input.bool(false, title="Confirmed-bar projection (non-repainting)",
                   tooltip="OFF (default): developing structure / projection update LIVE intrabar (the panel and BoS alerts can flip and un-flip within a bar). ON: Section 3's developing-BoS detection and the projection extremes only update on CLOSED bars (barstate.isconfirmed) — calmer panel and a non-repainting alert path, at the cost of one-bar lag.",
                   group=grp_display)
anchorIntradayDaily = input.bool(true, title="Anchor EMA20/ATR to Daily on Intraday",
                   tooltip="When ON (default): on 75/125-min charts, the TREND row's EMA20-distance-in-ATR uses Daily EMA20 and Daily ATR(14) — matching the standard workflow of overlaying Daily EMA20 on intraday charts. Both numerator AND denominator come from the same Daily reference, keeping the ATR distance dimensionally meaningful. When OFF: uses chart-TF values (intraday EMA20 / intraday ATR). No effect on Daily/Weekly/Monthly charts (always chart-TF). Panel suffix shows source: '+2.1 ATR(D)' when anchored, '+2.1 ATR' otherwise.",
                   group=grp_display)

grp_fib = "Fibonacci Levels"
show_fib     = input.bool(false, title="Show 50% & 61.8% Retracement", group=grp_fib)
show_fib_ext = input.bool(false, title="Show 1.272 & 1.618 Extensions (Long Targets)", group=grp_fib,
                   tooltip="Upward extensions of the locked swing — profit objectives for long entries.")
fib_ext      = input.int(20,   title="Extend Lines (bars right)", minval=1, maxval=100, group=grp_fib)

grp_major = "Major / Minor Pivot"
majorMode      = input.string("Auto", title="Major Pivot Mode",
                  options=["Auto", "Stock (>=8%)", "ETF (>=4%)", "Custom"],
                  tooltip="Auto detects ETFs via syminfo.type (fund). Override if needed.",
                  group=grp_major)
majorCustomPct = input.float(8.0, title="Custom Threshold (%)", minval=0.1, step=0.5, group=grp_major)

grp_eq = "Equal High / Equal Low (EH/EL)"
eq_pct = input.float(0.2,  title="Equal Pivot Threshold (%)", minval=0.05, maxval=5.0, step=0.05,
          tooltip="Two consecutive pivots on the same side are classified as Equal High (EH) or Equal Low (EL) when they are within this % of each other. Default 0.2%. Increase for wider instruments; decrease for precision.",
          group=grp_eq)

// Resolve major pivot threshold once (inputs are constant per run)
majorThresh = majorMode == "Auto" ? (syminfo.type == "fund" ? 4.0 : 8.0) : majorMode == "Stock (>=8%)" ? 8.0 : majorMode == "ETF (>=4%)" ? 4.0 : majorCustomPct

// --- LOGIC ---
// Dynamically resolve the pivot length based on the current chart timeframe.
// (timeframe is constant per run, so a plain series assignment is sufficient — no `var`.)
int pivot_len = timeframe.ismonthly ? piv_m :
               timeframe.isweekly  ? piv_w :
               timeframe.isdaily   ? piv_d :
               piv_intra

pivotLeft  = pivot_len
pivotRight = pivot_len

ph = ta.pivothigh(high, pivotLeft, pivotRight)
pl = ta.pivotlow(low,   pivotLeft, pivotRight)

// --- Momentum / quality-of-trend baselines (used by panel folds B1/B2/B4/B6/B7) ---
// Chart-TF values always computed (cheap, no security call).
ema20_chart = ta.ema(close, 20)
atr14_chart = ta.atr(14)
// Resolve the active reference frame: chart-TF on Daily+, optionally Daily on intraday.
bool _isIntradayTF = not (timeframe.isdaily or timeframe.isweekly or timeframe.ismonthly)
bool _useDailyRef  = _isIntradayTF and anchorIntradayDaily
// Daily-anchored values via request.security — only CONSULTED on intraday TFs when the anchor
// toggle is ON. Gated behind _isIntradayTF so the result is na (and definitively unused) on
// Daily/Weekly/Monthly charts, matching the reference frame resolved above.
// lookahead_on for live-read accuracy (the panel only renders at barstate.islast → no
// historical-bar bias).
ema20_daily = _isIntradayTF ? request.security(syminfo.tickerid, "D", ta.ema(close, 20), lookahead=barmerge.lookahead_on) : na
atr14_daily = _isIntradayTF ? request.security(syminfo.tickerid, "D", ta.atr(14),         lookahead=barmerge.lookahead_on) : na
ema20_val = _useDailyRef ? ema20_daily : ema20_chart
atr14_val = _useDailyRef ? atr14_daily : atr14_chart

// --- STATE VARIABLES ---
var line  currentLine  = na
var label currentLabel = na
var line  projLine     = na

var int    trendState      = 0
var float  activePivotPrice = na
var string activePivotType  = na
var int    activePivotIndex = na

// History
var float  lockedHigh    = na
var float  lockedLow     = na
var string lastHighClass = na
var string lastLowClass  = na

// Previous structural reference — saved just BEFORE lockedHigh/lockedLow are overwritten at
// each direction change. The extending path must classify against these, NOT against lockedHigh/
// lockedLow (which at extension time hold the CURRENT direction's initial price, not the
// prior structural pivot that defines HH/LH/EH or HL/LL/EL context).
var float  prevLockedHigh = na
var float  prevLockedLow  = na

// Swing Counter
var int swingCount     = 0
// Rolling choppiness counter — stores bar_index of every confirmed direction flip (H→L or L→H)
// Queried against a rolling lookback window (default 52 weeks) to measure choppiness
var array<int> flipBars = array.new_int(0)
// Confirmed trend — only updated by confirmed pivots (Sections 1/2), NOT by projection (Section 3).
var int confirmedTrend = 0

// --- Momentum state captured at the moment of each confirmed direction flip ---
// prevSwingPctFinal — % range of the most recently completed (finalised) leg
//                     → denominator for the Impulse:Correction ratio shown on STRUCTURE row
// prevLegVel        — velocity (%/bar) of the most recently completed leg
//                     → baseline for the accel/decel arrow on BAR AGE row
// legLeadInVolRatio — avg(vol[1..3]) / avg(vol[4..6]) sampled at the last BoS bar
//                     → ⤴/⤵ glyph on BOS LEVEL row
var float prevSwingPctFinal = na
var float prevLegVel        = na
var float legLeadInVolRatio = na

// BoS Detection State
var bool bosUp = false
var bool bosDn = false
bosUp := false
bosDn := false

// Developing structure — written by Section 3 (projection BoS), read by the panel.
// These track what the NEXT confirmed high/low classification WOULD be if the
// developing pivot were confirmed. They never contaminate line colours.
var string devStructHigh = na
var string devStructLow  = na
var int    devSwingCount = na
// Reset each bar — only set when Section 3 detects a developing BoS or broadening
devStructHigh := na
devStructLow  := na
devSwingCount := na

// EH/EL Proximity Threshold — driven by user input (default 0.5%)
float eq_threshold = eq_pct / 100.0

// Enhancement state — Volume Confirmation on most recent BoS
var float lastBosVolRatio = na
var bool  lastBosVolPass  = false
var int   lastBosBar      = na
var int   lastBosDir      = 0   // +1 = bullish BoS, -1 = bearish BoS, 0 = none yet

// Enhancement — Invalidation Level + BoS Level horizontal line handles
var line  invalidLine = na
var line  bosLine     = na

// Volume SMA — must be computed at top level (ta.sma cannot live inside conditionals)
float volSma50 = ta.sma(volume, 50)

// Choppiness lookback (bars) — single source of truth, reused by the flipBars trim below
// and by the CHOPPINESS panel row. Constant per run (timeframe + pivotCountWeeks are fixed).
int chopBarsBack = timeframe.ismonthly ? math.max(1, pivotCountWeeks / 4) :
                   timeframe.isweekly  ? pivotCountWeeks :
                   timeframe.isdaily   ? pivotCountWeeks * 5 :
                   pivotCountWeeks * 5
// Trim flipBars to the choppiness window each bar so it can't grow unbounded over the chart's
// life. Entries older than the cutoff are never counted by the CHOPPINESS row, so dropping
// them is output-neutral. Flips are stored in ascending bar order → remove from the front.
int _chopCutoff = bar_index - chopBarsBack
while array.size(flipBars) > 0 and array.get(flipBars, 0) < _chopCutoff
    array.shift(flipBars)

// Fibonacci line/label handles — persistent, managed on barstate.islast
var line  fib50Line   = na
var line  fib618Line  = na
var label fib50Lbl    = na
var label fib618Lbl   = na
// Extension handles — 1.272 / 1.618 upward targets
var line  fib1272Line = na
var line  fib1618Line = na
var label fib1272Lbl  = na
var label fib1618Lbl  = na
// Bar index of the most recently locked swing low — used as fib anchor
var int   lockedLowBar = na
// Bar index of the most recently locked swing high — used to compute completed-down-leg duration
var int   lockedHighBar = na

// --- HELPERS ---

// Major pivot: swing magnitude from refPrice to pivotPrice exceeds thresh
f_isMajor(float pivotPrice, float refPrice, float thresh) =>
    not na(refPrice) and refPrice > 0 and math.abs(pivotPrice - refPrice) / refPrice * 100 >= thresh

// Label color: Green for uptrend pivots, Red for downtrend, Orange for equal pivots (EH/EL)
C_EQ    = color.new(#FF8C00, 0)   // orange — dedicated EH/EL colour
C_AMBER = color.new(#FFBF00, 0)   // amber — sideways / neutral trend colour
C_PANEL_HDR = color.new(#1A237E, 0)   // indigo — panel row label (left column) background
C_PANEL_BG  = color.new(#131722, 0)   // chart-dark — panel value (right column) default background

f_highLabelColor(string hClass) =>
    hClass == "HH" ? color.green : hClass == "LH" ? color.red : hClass == "EH" ? C_EQ : color.gray

f_lowLabelColor(string lClass) =>
    lClass == "HL" ? color.green : lClass == "LL" ? color.red : lClass == "EL" ? C_EQ : color.gray

f_getLabelText(string pType, string pClass, float startPrice, bool showPct) =>
    if showPct
        float chg = 0.0
        if not na(startPrice)
            chg := ((pType == "H" ? high[pivotRight] : low[pivotRight]) - startPrice) / startPrice * 100
        pClass + "\n(" + str.tostring(chg, "0.0") + "%)"
    else
        pClass

// Classify a high pivot relative to the previous locked high
f_classifyHigh(float newHigh, float prevHigh) =>
    string result = "HH"
    if not na(prevHigh) and prevHigh > 0
        float diff = math.abs(newHigh - prevHigh) / prevHigh
        if diff < eq_threshold
            result := "EH"
        else if newHigh < prevHigh
            result := "LH"
    result

// Classify a low pivot relative to the previous locked low
f_classifyLow(float newLow, float prevLow) =>
    string result = "LL"
    if not na(prevLow) and prevLow > 0
        float diff = math.abs(newLow - prevLow) / prevLow
        if diff < eq_threshold
            result := "EL"
        else if newLow > prevLow
            result := "HL"
    result

// Trend State Logic:
// UPTREND (+1):   Requires HH with prior HL, OR HL with prior HH (confirmed continuation)
// DOWNTREND (-1): Requires LL with prior LH, OR LH with prior LL (confirmed continuation)
// SIDEWAYS (0):   EH, EL, broadening, or mixed structure
//
// EH / EL rationale:
//   EH = price failed to exceed the prior high   → uptrend NOT confirmed → SIDEWAYS
//   EL = price failed to hold above the prior low → downtrend NOT confirmed → SIDEWAYS
//   Equal pivots are structurally significant: they signal indecision and prevent a false
//   trend confirmation. Swing count resets; the next confirmed HH/HL or LL/LH starts fresh.
f_updateTrend(string pivotSide, string pivotClass) =>
    int newTrend = 0
    int newSwing = 0
    // Sideways swing count helper: continue counting if prior state was also sideways,
    // otherwise start fresh at 1 (this pivot is the first of the new sideways phase).
    int sidewaysSwing = confirmedTrend == 0 ? swingCount + 1 : 1
    if pivotSide == "H"
        if pivotClass == "HH"
            if lastLowClass == "HL"
                newTrend := 1    // Classic uptrend: HH after HL
                newSwing := confirmedTrend == 1 ? swingCount + 1 : 1
            else
                newTrend := 0    // Broadening (HH after LL) or EL prior — not confirmed
                newSwing := sidewaysSwing
        else if pivotClass == "LH"
            if lastLowClass == "LL"
                newTrend := -1   // Classic downtrend: LH after LL
                newSwing := confirmedTrend == -1 ? swingCount + 1 : 1
            else
                newTrend := 0    // Mixed structure — not confirmed
                newSwing := sidewaysSwing
        else // EH — equal high: uptrend NOT confirmed → SIDEWAYS
            newTrend := 0
            newSwing := sidewaysSwing
    else // "L"
        if pivotClass == "LL"
            if lastHighClass == "LH"
                newTrend := -1   // Classic downtrend: LL after LH
                newSwing := confirmedTrend == -1 ? swingCount + 1 : 1
            else
                newTrend := 0    // Broadening (LL after HH) or EH prior — not confirmed
                newSwing := sidewaysSwing
        else if pivotClass == "HL"
            if lastHighClass == "HH"
                newTrend := 1    // Classic uptrend: HL after HH
                newSwing := confirmedTrend == 1 ? swingCount + 1 : 1
            else
                newTrend := 0    // Mixed structure — not confirmed
                newSwing := sidewaysSwing
        else // EL — equal low: downtrend NOT confirmed → SIDEWAYS
            newTrend := 0
            newSwing := sidewaysSwing
    [newTrend, newSwing]


// ============================================================
// --- MAIN LOOP ---
// ============================================================

// 1. New Pivot High Found
if not na(ph)
    if activePivotType == "H" and ph > activePivotPrice
        // EXTENDING existing high — move endpoint; re-classify against PREVIOUS structural high
        // (prevLockedHigh), NOT lockedHigh — lockedHigh at this point equals the initial price of
        // THIS direction, not the structural previous high that defines HH/LH/EH context.
        line.set_xy2(currentLine, bar_index[pivotRight], ph)
        activePivotPrice := ph
        activePivotIndex := bar_index[pivotRight]

        string hClass = f_classifyHigh(ph, prevLockedHigh)
        lastHighClass := hClass

        // Major/minor: re-evaluate as pivot extends (magnitude can cross threshold)
        bool isMajorExtH = f_isMajor(ph, lockedLow, majorThresh)
        line.set_width(currentLine, isMajorExtH ? 3 : 1)
        if show_pivot_labels and not na(currentLabel)
            string labelTxt = f_getLabelText("H", hClass, lockedLow, show_pivot_pct)
            label.set_xy(currentLabel, bar_index[pivotRight], ph)
            label.set_text(currentLabel, labelTxt)
            label.set_textcolor(currentLabel, f_highLabelColor(hClass))
            label.set_size(currentLabel, isMajorExtH ? size.normal : size.small)

    else if activePivotType == "L" or na(activePivotType)
        // NEW direction change: Low → High. Lock the previous low.
        if activePivotType == "L"
            lockedLow    := activePivotPrice
            lockedLowBar := activePivotIndex
            array.push(flipBars, bar_index[pivotRight])  // record bar of this flip for choppiness window

            // Capture just-completed DOWN leg metrics (prior high → this low) BEFORE lockedHigh is overwritten below.
            if not na(lockedHigh) and not na(lockedHighBar) and activePivotPrice > 0
                float _legPct  = (lockedHigh - activePivotPrice) / activePivotPrice * 100
                int   _legBars = math.max(1, activePivotIndex - lockedHighBar)
                prevSwingPctFinal := _legPct
                prevLegVel        := _legPct / _legBars

        string hClass = f_classifyHigh(ph, lockedHigh)

        [newTrend, newSwing] = f_updateTrend("H", hClass)
        trendState     := newTrend
        confirmedTrend := newTrend
        swingCount     := newSwing

        prevLockedHigh   := lockedHigh   // save structural previous high for extending-path use
        lockedHigh       := ph
        lockedHighBar    := bar_index[pivotRight]
        lastHighClass    := hClass
        activePivotPrice := ph
        activePivotIndex := bar_index[pivotRight]
        activePivotType  := "H"

        // lockedLow was just set above — use it as the swing reference
        bool isMajorH = f_isMajor(ph, lockedLow, majorThresh)
        // Line colour: green = confirmed uptrend pair (HH after HL), red = confirmed downtrend pair (LH after LL),
        // orange = EH (equal high → SIDEWAYS), white = all other mixed/broadening cases
        color lineColor = (hClass == "HH" and lastLowClass == "HL") ? color.green :
                          (hClass == "LH" and lastLowClass == "LL") ? color.red :
                          hClass == "EH"                             ? C_EQ :
                          color.new(color.white, 30)
        line.new(bar_index[pivotRight], ph, bar_index, ph, color=hClass == "EH" ? C_EQ : color.gray, style=line.style_dotted)
        currentLine := line.new(line.get_x2(currentLine), line.get_y2(currentLine), bar_index[pivotRight], ph, color=lineColor, width=isMajorH ? 3 : 1)

        if show_pivot_labels
            string labelTxt = f_getLabelText("H", hClass, lockedLow, show_pivot_pct)
            currentLabel := label.new(bar_index[pivotRight], ph, labelTxt, style=label.style_label_down, color=color.new(color.black, 100), textcolor=f_highLabelColor(hClass), size=isMajorH ? size.normal : size.small)
        else
            currentLabel := na



// 2. New Pivot Low Found
if not na(pl)
    if activePivotType == "L" and pl < activePivotPrice
        // EXTENDING existing low — move endpoint; re-classify against PREVIOUS structural low
        // (prevLockedLow), NOT lockedLow — lockedLow at this point equals the initial price of
        // THIS direction, not the structural previous low that defines HL/LL/EL context.
        line.set_xy2(currentLine, bar_index[pivotRight], pl)
        activePivotPrice := pl
        activePivotIndex := bar_index[pivotRight]

        string lClass = f_classifyLow(pl, prevLockedLow)
        lastLowClass := lClass

        // Major/minor: re-evaluate as pivot extends
        bool isMajorExtL = f_isMajor(pl, lockedHigh, majorThresh)
        line.set_width(currentLine, isMajorExtL ? 3 : 1)
        if show_pivot_labels and not na(currentLabel)
            string labelTxt = f_getLabelText("L", lClass, lockedHigh, show_pivot_pct)
            label.set_xy(currentLabel, bar_index[pivotRight], pl)
            label.set_text(currentLabel, labelTxt)
            label.set_textcolor(currentLabel, f_lowLabelColor(lClass))
            label.set_size(currentLabel, isMajorExtL ? size.normal : size.small)

    else if activePivotType == "H" or na(activePivotType)
        // NEW direction change High → Low, OR the very first pivot (seed) when nothing is active
        // yet. The "lock the previous high" work only applies when a real prior high exists
        // (activePivotType=="H"); on the seed (na) we just establish the first low — mirroring
        // how Section 1 seeds the first high (its lock-low block is guarded by activePivotType=="L").
        // Same-bar ph+pl is unambiguous: Section 1 runs first and seeds "H", so this branch then
        // takes the normal H→L path rather than the seed path — no zero-length leg.
        if activePivotType == "H"
            // Capture just-completed UP leg metrics (prior low → this high) BEFORE lockedLow is overwritten below.
            if not na(lockedLow) and not na(lockedLowBar) and lockedLow > 0
                float _legPct  = (activePivotPrice - lockedLow) / lockedLow * 100
                int   _legBars = math.max(1, activePivotIndex - lockedLowBar)
                prevSwingPctFinal := _legPct
                prevLegVel        := _legPct / _legBars

            lockedHigh    := activePivotPrice
            lockedHighBar := activePivotIndex
            array.push(flipBars, bar_index[pivotRight])  // record bar of this flip for choppiness window

        string lClass = f_classifyLow(pl, lockedLow)

        [newTrend, newSwing] = f_updateTrend("L", lClass)
        trendState     := newTrend
        confirmedTrend := newTrend
        swingCount     := newSwing

        prevLockedLow    := lockedLow    // save structural previous low for extending-path use
        lockedLow        := pl
        lockedLowBar     := bar_index[pivotRight]
        lastLowClass     := lClass
        activePivotPrice := pl
        activePivotIndex := bar_index[pivotRight]
        activePivotType  := "L"

        // lockedHigh was just set above — use it as the swing reference
        bool isMajorL = f_isMajor(pl, lockedHigh, majorThresh)
        // Line colour: green = confirmed uptrend pair (HL after HH), red = confirmed downtrend pair (LL after LH),
        // orange = EL (equal low → SIDEWAYS), white = all other mixed/broadening cases
        color lineColor = (lClass == "HL" and lastHighClass == "HH") ? color.green :
                          (lClass == "LL" and lastHighClass == "LH") ? color.red :
                          lClass == "EL"                             ? C_EQ :
                          color.new(color.white, 30)
        line.new(bar_index[pivotRight], pl, bar_index, pl, color=lClass == "EL" ? C_EQ : color.gray, style=line.style_dotted)
        currentLine := line.new(line.get_x2(currentLine), line.get_y2(currentLine), bar_index[pivotRight], pl, color=lineColor, width=isMajorL ? 3 : 1)

        if show_pivot_labels
            string labelTxt = f_getLabelText("L", lClass, lockedHigh, show_pivot_pct)
            currentLabel := label.new(bar_index[pivotRight], pl, labelTxt, style=label.style_label_up, color=color.new(color.black, 100), textcolor=f_lowLabelColor(lClass), size=isMajorL ? size.normal : size.small)
        else
            currentLabel := na



// ============================================================
// --- 3. LIVE TREND SYNC (Projection BoS) ---
// ============================================================
// syncBars includes the pivot bar itself (+1) so projSync extremes capture the pivot.
int _syncBars = na(activePivotIndex) ? 1 : (bar_index - activePivotIndex + 1)
int syncBars  = math.max(1, _syncBars)
float projSyncLow  = ta.lowest(low,  syncBars)
float projSyncHigh = ta.highest(high, syncBars)

// --- Developing BoS detection ---
// GATED by activePivotType: only evaluate the DEVELOPING side (opposite to active pivot).
//
// activePivotType == "L" → developing upward → check projSyncHigh vs lockedHigh for HH BoS.
//   The opposite side (low) uses the CONFIRMED lastLowClass from Section 2.
//
// activePivotType == "H" → developing downward → check projSyncLow vs lockedLow for LL BoS.
//   The opposite side (high) uses the CONFIRMED lastHighClass from Section 1.
//
// This gating prevents false triggers when an extending high pushes activePivotPrice
// above lockedHigh (Section 1 extends but doesn't update lockedHigh).

// Pre-compute classifications unconditionally — f_classifyHigh/f_classifyLow handle na inputs.
string _projHighClass = f_classifyHigh(projSyncHigh, lockedHigh)
string _projLowClass  = f_classifyLow(projSyncLow,  lockedLow)

// Confirmed-bar projection (ENH 7): when ON, only let the developing-BoS detection run on
// CLOSED bars so the panel/devStruct/bosUp/bosDn don't flip-and-unflip within the live bar.
// barstate.isconfirmed is always true on historical bars, so this only gates the live bar.
bool _projActive = not confirmedProjOnly or barstate.isconfirmed

if _projActive and activePivotType == "L" and _projHighClass == "HH"
    // Developing HH detected — the low side classification is already confirmed by
    // Section 2 (lastLowClass was set during the H→L direction change that created
    // this active low). Use it directly instead of re-classifying.
    string _devLowClass = na(lastLowClass) ? "HL" : lastLowClass
    // Write developing structure for the panel
    devStructHigh := "HH"
    devStructLow  := _devLowClass
    if _devLowClass == "HL"
        if trendState != 1
            bosUp := true
        trendState := 1
        // Developing swing count: if confirmed trend was already up, this developing HH
        // would extend the count by 1; otherwise it's the first swing of a new uptrend (CHoCH).
        devSwingCount := confirmedTrend == 1 ? swingCount + 1 : 1
    else
        // Developing HH but low is LL or EL (not HL) → broadening/mixed structure.
        trendState := 0

else if _projActive and activePivotType == "H" and _projLowClass == "LL"
    // Developing LL detected — the high side classification is already confirmed by
    // Section 1 (lastHighClass was set during the L→H direction change that created
    // this active high). Use it directly.
    string _devHighClass = na(lastHighClass) ? "LH" : lastHighClass
    // Write developing structure for the panel
    devStructHigh := _devHighClass
    devStructLow  := "LL"
    if _devHighClass == "LH"
        if trendState != -1
            bosDn := true
        trendState := -1
        // Developing swing count: extend if already downtrending, else first swing (CHoCH).
        devSwingCount := confirmedTrend == -1 ? swingCount + 1 : 1
    else
        // Developing LL but high is HH or EH (not LH) → broadening/mixed structure.
        trendState := 0

// ============================================================
// --- 3b. VOLUME CONFIRMATION CAPTURE ---
// ============================================================
// Fires only on the bar where bosUp/bosDn transitions to true (Section 3 sets these
// false at top of bar and true only on the BoS trigger bar). Captures the bar's
// volume ratio vs 50-SMA so the panel can flag whether the breakout had Weinstein-style
// volume confirmation. Logic in Sections 1/2/3 is untouched.
// Longs-Only Mode: only bullish BoS (bosUp) is captured — bearish breakdowns are noise
// for a longs-only trader and shouldn't shadow the last meaningful entry trigger.
bool captureBos = longsOnlyMode ? bosUp : (bosUp or bosDn)
if captureBos and not na(volSma50) and volSma50 > 0
    lastBosVolRatio := volume / volSma50
    lastBosVolPass  := lastBosVolRatio >= volConfirmMult
    lastBosBar      := bar_index
    lastBosDir      := bosUp ? 1 : -1
    // B4: 3-bar lead-in volume thrust — was institutional buying ramping INTO the BoS bar,
    // or did the BoS appear as an isolated spike? Ratio > 1.0 = rising lead-in (mark-up
    // characteristic). < 1.0 = declining lead-in (spike-and-fade risk).
    float _vLead = math.avg(volume[1], volume[2], volume[3])
    float _vBase = math.avg(volume[4], volume[5], volume[6])
    legLeadInVolRatio := (na(_vBase) or _vBase <= 0) ? na : _vLead / _vBase

// ============================================================
// --- 3c. MTF TREND CONFLUENCE ---
// ============================================================
// Fetches this same indicator's trendState evaluated on a higher timeframe.
// Auto resolution: intraday→D, D→W, W→M, M→3M. Manual override available.
// MTF1 = next upper TF; MTF2 = next-to-next upper TF (chain: intraday<D<W<M<3M).
string mtfTF = mtfTfChoice == "Auto" ? (timeframe.ismonthly ? "3M" : timeframe.isweekly ? "M" : timeframe.isdaily ? "W" : "D") : mtfTfChoice
string mtfTF2 = mtfTF == "D" ? "W" : mtfTF == "W" ? "M" : mtfTF == "M" ? "3M" : ""
// Lookahead choice — see input tooltip. Default "Live" matches what the HTF chart
// itself would show right now (includes the developing HTF bar). Safe here because
// the panel only renders at barstate.islast (no historical-bar bias).
_mtfLook = mtfReadMode == "Live (match HTF chart)" ? barmerge.lookahead_on : barmerge.lookahead_off
int    mtfTrendState  = request.security(syminfo.tickerid, mtfTF, trendState, lookahead=_mtfLook)
// No second HTF (e.g. Monthly chart → mtfTF2==""): reuse mtfTrendState instead of issuing a
// duplicate request for the same TF (the value is discarded anyway when hasMtf2 is false).
int    mtfTrendState2 = mtfTF2 == "" ? mtfTrendState : request.security(syminfo.tickerid, mtfTF2, trendState, lookahead=_mtfLook)

// ============================================================
// --- 4. PROJECTION LINE ---
// ============================================================
if show_proj
    int _barsSince = na(activePivotIndex) ? 1 : (bar_index - activePivotIndex + 1)
    int globalBarsSince = math.max(1, _barsSince)
    float globalLowest  = ta.lowest(low,  globalBarsSince)
    float globalHighest = ta.highest(high, globalBarsSince)

    if not na(activePivotPrice)
        line.delete(projLine)
        color projColor = trendState == 1 ? color.new(color.green, 60) : (trendState == -1 ? color.new(color.red, 60) : color.new(color.white, 55))
        if activePivotType == "H"
            projLine := line.new(activePivotIndex, activePivotPrice, bar_index, globalLowest,  color=projColor, style=line.style_dashed)
        else if activePivotType == "L"
            projLine := line.new(activePivotIndex, activePivotPrice, bar_index, globalHighest, color=projColor, style=line.style_dashed)

// ============================================================
// --- 5. TREND STATE INFO PANEL ---
// ============================================================
if show_panel and barstate.islast
    var table panel = table.new(panelPos, 2, 19, border_width=1, border_color=color.gray)

    // Displayed structure pair (developing classes when live, else last confirmed).
    string dispHigh = not na(devStructHigh) ? devStructHigh : lastHighClass
    string dispLow  = not na(devStructLow)  ? devStructLow  : lastLowClass
    string structStr = ""
    if not na(dispHigh) and not na(dispLow)
        structStr := dispHigh + " / " + dispLow

    // TREND derived from the SAME structure pair the panel prints, so the TREND and
    // STRUCTURE rows can never contradict (mirrors f_updateTrend's confirmation rules:
    // UPTREND only on HH+HL, DOWNTREND only on LH+LL, everything else SIDEWAYS).
    // `trendState` (a persisted var) can be stale relative to the displayed structure —
    // e.g. structure HH/LL is broadening → SIDEWAYS, but a leftover trendState=-1 would
    // otherwise render DOWNTREND over it. Fall back to trendState only when the structure
    // pair is incomplete (na).
    int dispTrend = trendState
    if not na(dispHigh) and not na(dispLow)
        dispTrend := (dispHigh == "HH" and dispLow == "HL") ? 1 : (dispHigh == "LH" and dispLow == "LL") ? -1 : 0

    string trendStr = dispTrend == 1 ? "UPTREND ↑" : (dispTrend == -1 ? "DOWNTREND ↓" : "SIDEWAYS →")
    color  trendBg  = dispTrend == 1 ? color.new(color.green, 60) : (dispTrend == -1 ? color.new(color.red, 60) : color.new(C_AMBER, 60))
    color  trendCol = color.white

    color structCol = dispTrend == 1 ? color.green  : (dispTrend == -1 ? color.red       : C_AMBER)

    int    dispSwing = not na(devSwingCount) ? devSwingCount : swingCount
    string swingStr  = str.tostring(dispSwing) + " swing(s)"
    color  swingBg   = C_PANEL_BG
    if dispSwing <= 2
        swingBg := color.new(color.green, 60)
    else if dispSwing == 3
        swingBg := color.new(C_AMBER, 60)
    else
        swingBg := color.new(color.red, 60)

    string rangeStr = "N/A"
    color  rangeBg  = C_PANEL_BG
    float  rngLow  = na(activePivotType) ? lockedLow  : projSyncLow
    float  rngHigh = na(activePivotType) ? lockedHigh : projSyncHigh
    float  swingPct = na
    if not na(rngHigh) and not na(rngLow) and rngLow > 0
        swingPct := ((rngHigh - rngLow) / rngLow) * 100
        rangeStr := str.tostring(swingPct, "0.0") + "%"
        if swingPct < majorThresh
            rangeBg := color.new(color.gray, 60)
        else if swingPct < (majorThresh * 2.0)
            rangeBg := color.new(color.green, 60)
        else
            rangeBg := color.new(C_AMBER, 60)

    string tfStr = timeframe.ismonthly ? "Monthly" :
                   timeframe.isweekly  ? "Weekly"  :
                   timeframe.isdaily   ? "Daily"   :
                   timeframe.period + " min"
    table.cell(panel, 0, 0, "TIMEFRAME",   bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 0, tfStr,         bgcolor=C_PANEL_BG, text_color=color.white, text_size=size.small)

    table.cell(panel, 0, 1, "TREND",       bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 1, trendStr,      bgcolor=trendBg,               text_color=trendCol,    text_size=size.small)

    string emaDistStr = "N/A"
    color  emaDistBg  = C_PANEL_BG
    if not na(ema20_val) and not na(atr14_val) and atr14_val > 0
        float _ema20DistAtr = (close - ema20_val) / atr14_val
        float _absDist      = math.abs(_ema20DistAtr)
        string _sign        = _ema20DistAtr >= 0 ? "+" : "−"
        string _refTag      = _useDailyRef ? " ATR(D)" : " ATR"
        emaDistStr := _sign + str.tostring(_absDist, "0.00") + _refTag
        if _absDist <= 1.5
            emaDistBg := color.new(color.green, 60)
        else if _absDist <= 3.0
            emaDistBg := color.new(color.gray, 60)
        else if _absDist <= 5.0
            emaDistBg := color.new(C_AMBER, 60)
        else
            emaDistBg := color.new(color.red, 60)
    table.cell(panel, 0, 2, "EMA20 DIST",  bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 2, emaDistStr,    bgcolor=emaDistBg,             text_color=color.white,  text_size=size.small)

    string mtfTrendStr = mtfTrendState == 1 ? "UPTREND ↑" : mtfTrendState == -1 ? "DOWNTREND ↓" : "SIDEWAYS →"
    color  mtfTrendBg  = mtfTrendState == 1 ? color.new(color.green, 60)  : mtfTrendState == -1 ? color.new(color.red, 60) : color.new(C_AMBER, 60)
    string mtfLabel    = "MTF (" + mtfTF + ")"
    table.cell(panel, 0, 3, mtfLabel,      bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 3, mtfTrendStr,   bgcolor=mtfTrendBg,            text_color=color.white, text_size=size.small)

    bool   hasMtf2     = mtfTF2 != ""
    string mtf2TrendStr = not hasMtf2 ? "—" : mtfTrendState2 == 1 ? "UPTREND ↑" : mtfTrendState2 == -1 ? "DOWNTREND ↓" : "SIDEWAYS →"
    color  mtf2TrendBg  = not hasMtf2 ? C_PANEL_BG : mtfTrendState2 == 1 ? color.new(color.green, 60) : mtfTrendState2 == -1 ? color.new(color.red, 60) : color.new(C_AMBER, 60)
    color  mtf2TrendCol = not hasMtf2 ? color.gray : color.white
    string mtf2Label    = "MTF (" + (hasMtf2 ? mtfTF2 : "—") + ")"
    table.cell(panel, 0, 4, mtf2Label,     bgcolor=C_PANEL_HDR, text_color=color.white,   text_size=size.small)
    table.cell(panel, 1, 4, mtf2TrendStr,  bgcolor=mtf2TrendBg,           text_color=mtf2TrendCol,  text_size=size.small)

    int _t0 = dispTrend   // chart leg: use the structure-consistent trend shown in the TREND row
    int _t1 = mtfTrendState
    int _t2 = hasMtf2 ? mtfTrendState2 : _t1
    bool   _anyUp    = _t0 == 1  or _t1 == 1  or _t2 == 1
    bool   _anyDown  = _t0 == -1 or _t1 == -1 or _t2 == -1
    bool   _allUp    = _t0 == 1  and _t1 == 1  and _t2 == 1
    bool   _allDown  = _t0 == -1 and _t1 == -1 and _t2 == -1
    string _alignTag = not hasMtf2 ? "—" : _allUp ? "ALIGNED ↑" : _allDown ? "ALIGNED ↓" : (_anyUp and _anyDown) ? "CONFLICT" : "MIXED"
    color  _alignBg  = not hasMtf2 ? C_PANEL_BG :
                       _allUp                  ? color.new(color.green, 60) :
                       _allDown                ? color.new(color.red,   60) :
                       (_anyUp and _anyDown)   ? color.new(color.red,   45) :
                                                  color.new(C_AMBER,     60)
    color _alignCol = not hasMtf2 ? color.gray : color.white
    table.cell(panel, 0, 5, "ALIGNMENT",   bgcolor=C_PANEL_HDR, text_color=color.white,   text_size=size.small)
    table.cell(panel, 1, 5, _alignTag,     bgcolor=_alignBg,              text_color=_alignCol,     text_size=size.small)

    table.cell(panel, 0, 6, "STRUCTURE",   bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 6, structStr,     bgcolor=C_PANEL_BG, text_color=structCol,   text_size=size.small)

    string icStr = "N/A"
    color  icBg  = C_PANEL_BG
    color  icCol = color.gray
    if not na(swingPct) and not na(prevSwingPctFinal) and prevSwingPctFinal > 0
        float _icRatio = swingPct / prevSwingPctFinal
        icStr := str.tostring(_icRatio, "0.0") + "×"
        icCol := color.white
        
        bool isUpLeg   = (activePivotType == "L")
        bool isDownLeg = (activePivotType == "H")
        bool isImpulse = (trendState == 1 and isUpLeg) or (trendState == -1 and isDownLeg)
        bool isCorrect = (trendState == 1 and isDownLeg) or (trendState == -1 and isUpLeg)
        
        if isImpulse
            if _icRatio >= 1.5
                icBg := color.new(color.green, 50)
            else if _icRatio >= 1.0
                icBg := color.new(color.green, 70)
            else
                icBg := color.new(color.red, 60)
        else if isCorrect
            if _icRatio < 1.0
                icBg := color.new(color.green, 60)
            else if _icRatio < 1.5
                icBg := color.new(C_AMBER, 60)
            else
                icBg := color.new(color.red, 60)
        else
            if _icRatio >= 1.0
                icBg := color.new(color.green, 60)
            else
                icBg := color.new(C_AMBER, 60)

    table.cell(panel, 0, 7, "MOMENTUM EXP.", bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 7, icStr,         bgcolor=icBg,                  text_color=icCol,       text_size=size.small)

    table.cell(panel, 0, 8, "SWING COUNT", bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 8, swingStr,      bgcolor=swingBg,               text_color=color.white, text_size=size.small)

    table.cell(panel, 0, 9, "SWING RANGE", bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 9, rangeStr,      bgcolor=rangeBg,               text_color=color.white, text_size=size.small)

    int barsBack = chopBarsBack
    int cutoff = bar_index - barsBack
    int chopCount = 0
    if array.size(flipBars) > 0
        for i = 0 to array.size(flipBars) - 1
            if array.get(flipBars, i) >= cutoff
                chopCount += 1
    bool devFlipPending = not na(devStructHigh) or not na(devStructLow)
    if devFlipPending
        chopCount += 1
    int effBars = math.min(barsBack, bar_index + 1)
    float barsPerFlip = chopCount > 0 ? effBars / chopCount : na
    float _atrPct = (not na(atr14_val) and not na(close) and close > 0) ? atr14_val / close * 100 : na
    float _volCut = timeframe.ismonthly ? 15.0 : timeframe.isweekly ? 8.0 : 3.0
    bool   _isEtf       = syminfo.type == "fund"
    bool   _isHighVol   = not _isEtf and not na(_atrPct) and _atrPct > _volCut
    int    cleanThresh  = not adaptiveChop ? 20 : _isEtf ? 25 : _isHighVol ? 15 : 20
    int    modThresh    = not adaptiveChop ? 10 : _isEtf ? 12 : _isHighVol ? 8  : 10
    string regimeLbl    = not adaptiveChop ? "STD (fixed)" : _isEtf ? "ETF" : _isHighVol ? "HIGH-VOL" : "STD"
    color  regimeBg     = _isEtf ? color.new(color.aqua, 60) : _isHighVol ? color.new(C_AMBER, 60) : color.new(color.green, 60)
    color chopBg = na(barsPerFlip) ? color.new(color.green, 60) : barsPerFlip >= cleanThresh ? color.new(color.green, 60) : barsPerFlip >= modThresh ? color.new(C_AMBER, 60) : color.new(color.red, 60)
    string chopStr = na(barsPerFlip) ? "∞ b/flip (0 in " + str.tostring(pivotCountWeeks) + "W)" : str.tostring(barsPerFlip, "#.0") + " b/flip (" + str.tostring(chopCount) + " in " + str.tostring(pivotCountWeeks) + "W)"

    table.cell(panel, 0, 10, "CHOPPINESS",  bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 10, chopStr,       bgcolor=chopBg,                text_color=color.white, text_size=size.small)

    string invStr = "N/A"
    color  invCol = color.gray
    string bosStr = "N/A"
    color  bosCol = color.gray
    string bosThrustStr = "N/A"
    color  bosThrustCol = color.gray
    color  bosBg  = C_PANEL_BG
    float  longInvalidPrice = na
    float  longBosPrice     = na
    if longsOnlyMode
        if not na(activePivotType)
            longInvalidPrice := activePivotType == "L" ? activePivotPrice : lockedLow
            // BoS level = the MOST RECENT swing high price must break to (re)confirm up.
            // When activePivotType=="H" a fresh high just formed and is pulling back, so the
            // breakout level is that fresh peak (activePivotPrice), NOT the older locked high.
            // When activePivotType=="L" (developing up from a low) the relevant high is lockedHigh.
            longBosPrice     := activePivotType == "H" ? activePivotPrice : lockedHigh
        if not na(longInvalidPrice)
            string lowLbl = na(lastLowClass) ? "L" : lastLowClass
            invStr := str.tostring(longInvalidPrice, format.mintick) + " (" + lowLbl + ")"
            invCol := trendState == 1 ? color.green : (trendState == -1 ? color.red : C_AMBER)
        if not na(longBosPrice)
            string highLbl = na(lastHighClass) ? "H" : lastHighClass
            bosStr := str.tostring(longBosPrice, format.mintick) + " (" + highLbl + ")"
            bosCol := trendState == 1 ? color.green : (trendState == -1 ? color.red : C_AMBER)
            if not na(lastBosVolRatio)
                string _passG = lastBosVolPass ? "✅" : "❌"
                string _leadG = na(legLeadInVolRatio) ? "" :
                                 legLeadInVolRatio >= 1.10 ? " ↑" :
                                 legLeadInVolRatio <= 0.90 ? " ↓" : " →"
                bosThrustStr := _passG + _leadG
                bosThrustCol := color.white
                if lastBosVolPass and not na(legLeadInVolRatio) and legLeadInVolRatio >= 1.10
                    bosBg := color.new(color.green, 60)
                else if not lastBosVolPass or (not na(legLeadInVolRatio) and legLeadInVolRatio <= 0.90)
                    bosBg := color.new(C_AMBER, 60)
    else
        if not na(activePivotPrice) and not na(activePivotType)
            string sideLbl = activePivotType == "L" ? (na(lastLowClass) ? "L" : lastLowClass) : (na(lastHighClass) ? "H" : lastHighClass)
            invStr := str.tostring(activePivotPrice, format.mintick) + " (" + sideLbl + ")"
            invCol := trendState == 1 ? color.green : (trendState == -1 ? color.red : C_AMBER)
        bosStr := "—"
        bosThrustStr := "—"

    table.cell(panel, 0, 11, "INVALIDATION", bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 11, invStr,         bgcolor=C_PANEL_BG, text_color=invCol,      text_size=size.small)

    table.cell(panel, 0, 12, "BOS LEVEL",    bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 12, bosStr,         bgcolor=C_PANEL_BG, text_color=bosCol,      text_size=size.small)

    table.cell(panel, 0, 13, "BOS VOL THRUST",bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 13, bosThrustStr,   bgcolor=bosBg,                 text_color=bosThrustCol,text_size=size.small)

    string volStr = "N/A"
    color  volCol = color.gray
    color  volBg  = C_PANEL_BG
    if not na(lastBosVolRatio)
        string dirArrow = lastBosDir == 1 ? " ↑" : " ↓"
        volStr := (lastBosVolPass ? "✅" : "❌") + dirArrow + " " + str.tostring(lastBosVolRatio, "0.00") + "×"
        volCol := color.white
        volBg  := lastBosVolPass ? color.new(color.green, 60) : color.new(color.red, 60)
    table.cell(panel, 0, 14, "VOL CONFIRM",  bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 14, volStr,         bgcolor=volBg,                 text_color=volCol,      text_size=size.small)

    string ageStr = "N/A"
    color  ageBg  = C_PANEL_BG
    string velStr = "N/A"
    color  velCol = color.gray
    color  velBg  = C_PANEL_BG
    if not na(activePivotIndex)
        int   barAge  = bar_index - activePivotIndex
        ageStr := str.tostring(barAge) + " bars"
        if barAge <= 5
            ageBg := color.new(color.green, 60)
        else if barAge <= 15
            ageBg := color.new(C_AMBER, 60)
        else
            ageBg := color.new(color.gray, 60)
            
        if not na(swingPct) and barAge > 0
            float _legVel = swingPct / barAge
            string _arrow = " →"
            velCol := color.white
            velBg  := color.new(color.gray, 60)
            if not na(prevLegVel) and prevLegVel > 0
                if _legVel > prevLegVel * 1.10
                    _arrow := " ↑"
                    velBg := color.new(color.green, 60)
                else if _legVel < prevLegVel * 0.90
                    _arrow := " ↓"
                    velBg := color.new(C_AMBER, 60)
            velStr := str.tostring(_legVel, "0.00") + "%/bar" + _arrow
    table.cell(panel, 0, 15, "BAR AGE",     bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 15, ageStr,        bgcolor=ageBg,                 text_color=color.white, text_size=size.small)
    table.cell(panel, 0, 16, "VELOCITY",    bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 16, velStr,        bgcolor=velBg,                 text_color=color.white, text_size=size.small)

    string regimeStr = regimeLbl + " · " + str.tostring(cleanThresh) + "/" + str.tostring(modThresh) + " b/flip"
    string atrStr = "N/A"
    color  atrBg  = C_PANEL_BG
    if not na(_atrPct)
        atrStr := str.tostring(_atrPct, "0.0") + "% (" + str.tostring(atr14_val, format.mintick) + ")"
        if _atrPct <= _volCut
            atrBg := color.new(color.green, 60)
        else if _atrPct <= _volCut * 1.5
            atrBg := color.new(C_AMBER, 60)
        else
            atrBg := color.new(color.red, 60)
    table.cell(panel, 0, 17, "REGIME",      bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 17, regimeStr,     bgcolor=regimeBg,              text_color=color.white, text_size=size.small)
    table.cell(panel, 0, 18, "ATR %",       bgcolor=C_PANEL_HDR, text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 18, atrStr,        bgcolor=atrBg,                 text_color=color.white, text_size=size.small)

// ============================================================
// --- 6. FIBONACCI RETRACEMENT (50% & 61.8%) — LONGS ONLY ---
// ============================================================
// Drawn only on barstate.islast so they always reflect the CURRENT confirmed swing.
// Swing: lockedLow (base) → lockedHigh (top).
//
// Both levels measure pullback support FROM the high downward:
//   50%   = lockedHigh − 0.500 × range  → purple
//   61.8% = lockedHigh − 0.618 × range  → orange
//
// Lines always anchor at lockedLowBar (the swing low pivot bar) so the visual
// span clearly reads as "retracement of the move from that low to the high".
//
// Style:
//   Solid   — trendState is uptrend/sideways, OR price has already broken above
//             lockedHigh (developing HH BoS) → actionable long re-entry zones
//   Dotted  — confirmed downtrend with no break above lockedHigh yet → reference only
// ============================================================
if barstate.islast
    // Always clean up stale fib objects first
    line.delete(fib50Line)
    line.delete(fib618Line)
    label.delete(fib50Lbl)
    label.delete(fib618Lbl)
    line.delete(fib1272Line)
    line.delete(fib1618Line)
    label.delete(fib1272Lbl)
    label.delete(fib1618Lbl)
    fib50Line   := na
    fib618Line  := na
    fib50Lbl    := na
    fib618Lbl   := na
    fib1272Line := na
    fib1618Line := na
    fib1272Lbl  := na
    fib1618Lbl  := na

    if (show_fib or show_fib_ext) and not na(lockedHigh) and not na(lockedLow) and lockedHigh > lockedLow
        float swingRange = lockedHigh - lockedLow

        // Anchor lines at the swing LOW bar so the span reads: low → right edge
        int fibStart = na(lockedLowBar) ? 0 : lockedLowBar
        int fibEnd   = bar_index + fib_ext

        // Dotted only when downtrend confirmed AND price hasn't yet broken above lockedHigh.
        // Once price crosses lockedHigh (developing HH), switch to solid — levels are now live.
        bool isDimmed = trendState == -1 and projSyncHigh <= lockedHigh
        int    fibAlpha    = isDimmed ? 40 : 0
        string fibStyle    = isDimmed ? line.style_dotted : line.style_solid

        // --- Retracements: pullback support levels (purple / orange) ---
        if show_fib
            float fib50  = lockedHigh - 0.500 * swingRange
            float fib618 = lockedHigh - 0.618 * swingRange

            color c50  = color.new(#A020F0, fibAlpha)        // purple → 50%
            color c618 = color.new(color.orange, fibAlpha)   // orange → 61.8%

            fib50Line  := line.new(fibStart, fib50,  fibEnd, fib50,  color=c50,  style=fibStyle, width=1)
            fib618Line := line.new(fibStart, fib618, fibEnd, fib618, color=c618, style=fibStyle, width=1)

            string lbl50  = " 50%  " + str.tostring(fib50,  format.mintick)
            string lbl618 = " 61.8% " + str.tostring(fib618, format.mintick)

            fib50Lbl  := label.new(fibEnd, fib50,  lbl50,  style=label.style_label_left, color=color.new(color.black, 100), textcolor=c50,  size=size.small)
            fib618Lbl := label.new(fibEnd, fib618, lbl618, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c618, size=size.small)

        // --- Extensions: upward profit targets above lockedHigh (teal / lime) ---
        // 1.272 = lockedLow + 1.272 × swingRange (classic Fibonacci T1)
        // 1.618 = lockedLow + 1.618 × swingRange (golden ratio T2)
        if show_fib_ext
            float fib1272 = lockedLow + 1.272 * swingRange
            float fib1618 = lockedLow + 1.618 * swingRange

            color c1272 = color.new(#00BFA5, fibAlpha)       // teal → 1.272
            color c1618 = color.new(#76FF03, fibAlpha)       // lime → 1.618

            fib1272Line := line.new(fibStart, fib1272, fibEnd, fib1272, color=c1272, style=fibStyle, width=1)
            fib1618Line := line.new(fibStart, fib1618, fibEnd, fib1618, color=c1618, style=fibStyle, width=1)

            string lbl1272 = " 1.272 " + str.tostring(fib1272, format.mintick)
            string lbl1618 = " 1.618 " + str.tostring(fib1618, format.mintick)

            fib1272Lbl := label.new(fibEnd, fib1272, lbl1272, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c1272, size=size.small)
            fib1618Lbl := label.new(fibEnd, fib1618, lbl1618, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c1618, size=size.small)

// ============================================================
// --- 6b. INVALIDATION + BOS LEVEL LINES ---
// ============================================================
// Longs-Only Mode: TWO dotted lines.
//   • Invalidation (latest swing low) — red-ish, structural stop for a long.
//   • BoS Level    (latest swing high) — green-ish, bullish entry trigger.
// Both extended right by fib_ext bars so they're clearly readable past current price.
// Original Mode: single line at the active pivot price (legacy).
if barstate.islast
    line.delete(invalidLine)
    line.delete(bosLine)
    invalidLine := na
    bosLine     := na
    if show_invalidation
        if longsOnlyMode
            // Invalidation line — latest swing low
            float invPx = na(activePivotType) ? na : (activePivotType == "L" ? activePivotPrice : lockedLow)
            if not na(invPx)
                invalidLine := line.new(bar_index - 1, invPx, bar_index + fib_ext, invPx, color=color.new(color.red, 30), style=line.style_dotted, width=1)
            // BoS Level line — the MOST RECENT swing high (the level a long must break).
            // Price: fresh peak (activePivotPrice) while pulling back from a just-made high
            // (activePivotType=="H"); otherwise the locked high. Anchor the line at that
            // pivot's BAR so it visually ties to the marked pivot instead of floating onto
            // whatever candle sits at the level near the right edge.
            float bosPx  = activePivotType == "H" ? activePivotPrice : lockedHigh
            int   bosBar = activePivotType == "H" ? activePivotIndex  : lockedHighBar
            if not na(bosPx)
                int _bosStart = na(bosBar) ? bar_index - 1 : bosBar
                bosLine := line.new(_bosStart, bosPx, bar_index + fib_ext, bosPx, color=color.new(color.green, 30), style=line.style_dotted, width=1)
        else
            // Legacy single-line behaviour
            if not na(activePivotPrice) and not na(activePivotIndex)
                color invLineCol = trendState == 1 ? color.new(color.green, 30) : trendState == -1 ? color.new(color.red, 30) : color.new(#FFBF00, 30)
                invalidLine := line.new(activePivotIndex, activePivotPrice, bar_index + fib_ext, activePivotPrice, color=invLineCol, style=line.style_dotted, width=1)

// --- 7. ALERT CONDITIONS ---
// NOTE (repaint): bosUp/bosDn come from the LIVE developing projection (Section 3). With the
// "Confirmed-bar projection" input OFF (default), these can flip and un-flip intrabar — set
// your TradingView alert to trigger "Once Per Bar Close" for stable signals, or turn that input
// ON for a non-repainting (one-bar-lagged) path.
alertcondition(bosUp, title="Bullish BoS (Break of Structure)", message="Weinstein Zigzag: Bullish Break of Structure on {{ticker}}! Price broke above locked high. (Live projection — confirm on bar close.)")
alertcondition(bosDn, title="Bearish BoS (Break of Structure)", message="Weinstein Zigzag: Bearish Breakdown on {{ticker}}! Price broke below locked low. (Live projection — confirm on bar close.)")
alertcondition(trendState == 1  and trendState[1] != 1,  title="Uptrend Confirmed",   message="Weinstein Zigzag: UPTREND confirmed on {{ticker}} (HH+HL).")
alertcondition(trendState == -1 and trendState[1] != -1, title="Downtrend Confirmed", message="Weinstein Zigzag: DOWNTREND confirmed on {{ticker}} (LH+LL).")

// ============================================================
// --- 8. MACHINE-READABLE OUTPUTS (ENH 6) ---
// ============================================================
// Hidden plots (no visual change) so a screener or another script can consume this engine via
// request.security(...) instead of scraping the panel. trendState is the LIVE (projection-aware)
// trend; confirmedTrend is the pivot-confirmed-only trend; bosUp/bosDn are the BoS triggers.
plot(trendState,     title="trendState",     display=display.none)
plot(confirmedTrend, title="confirmedTrend", display=display.none)
plot(bosUp ? 1 : 0,  title="bosUp",          display=display.none)
plot(bosDn ? 1 : 0,  title="bosDn",          display=display.none)
