//@version=6
// ============================================================================
// Commander Chart Markup v1.0 — Auto Stage-Pattern Annotator
// ----------------------------------------------------------------------------
// Automates the manual chart-reading workflow (HONAUT / RELIANCE / NAVINFLUOR /
// ACUTAAS markups) into a single, timeframe-agnostic indicator you can drop on
// ANY symbol or use in the TV screener.
//
// PIPELINE (per the 4-stage method):
//   1. DETECT   — swing pivots (ta.pivothigh/low), breakaway gaps, 52W levels.
//   2. CLASSIFY — Weinstein Stage (weekly 30-WMA), Mansfield RS vs Nifty 500.
//   3. ANNOTATE — best-fit trendlines through pivots WITH touch-count validation
//                 (>=3 = VALID solid; 2 = PROVISIONAL dashed) + geometry
//                 (rising/falling channel · falling wedge · sym. triangle) + apex.
//   4. VERDICT  — Stage + RS + setup (Stage 2 / SWG-PB / Stage 4 EXIT / reversal)
//                 + suggested entry / stop / target in a panel.
//
// DESIGN: touch-count validation encodes the "no 2-touch lines" discipline.
// Heavy pivot-pair fitting runs only on the last bar. RS/Stage reuse the same
// math as the Mansfield RS pane and the Unified Ecosystem (zero drift intent).
// ----------------------------------------------------------------------------
// v1.1 (Batch 1) — CLASSICAL PATTERNS added (reliable/geometric tier):
//   • Horizontal Support/Resistance ZONES (pivot clustering, touch-counted).
//   • FLAGS (impulse leg + tight consolidation box) — bull & bear.
//   • DOUBLE / TRIPLE TOP & BOTTOM (equal pivots + neckline, break-confirmed).
//   Detected patterns are listed in the panel.
// v1.2 (Batch 2) — HEURISTIC tier added (labelled "candidate", eyeball-only):
//   • HEAD & SHOULDERS + inverse (3-pivot, neckline, ✓break when neckline gives).
//   • CUP & HANDLE (two rims ~level + rounded low + shallow handle near rim).
//   These are false-positive-prone by nature — confirm visually before acting.
//   Recent-pivot trendlines + conservative geometry (channel only when parallel).
// v1.3 — KEY-LEVEL layers folded in (self-contained, no MCP needed):
//   • ANCHORED VWAP — ported from Dashboard v67.4.12 (anchor = Stage-2 start,
//     hlc3×vol cumulative). The true evolving curve, + manual-date override.
//   • FIBONACCI — ported from Zigzag v6.2 (retrace 50%/61.8% = high−r×range;
//     ext 1.272/1.618 = low+r×range), on the dominant lookback swing.
//   • S/R now has a tunable min-touch; AVWAP added to the verdict panel.
//   Trendlines stay auto (non-draggable) — snapshot & hand-redraw to stress-test.
// v1.4 — ANNOTATIONS optimized into a decision brief (the headline value):
//   • CONVICTION score 0–7 (Stage2 + RS>0 + RS-rising + >50MA + >AVWAP + >200MA
//     + vol-rising) → STRONG / MODERATE / WEAK at a glance.
//   • RS now shows trend arrow (↑/↓) + leads/lags; Stage shows bars-in-stage.
//   • Auto NEAREST support & resistance (from AVWAP/MA/Fib/52W) with % distance.
//   • Computed PLAN: Entry / Stop (risk%) / Target (R:R) for bullish setups.
//   • Panel reorganised into STATE · LEVELS · PLAN · VERDICT sections.
// v1.5 — DESCRIPTIVE annotations (MCP-style full-sentence notes at key levels):
//   • Sentence notes at Resistance / Support / AVWAP (what each level MEANS,
//     not just its price). Toggle: "Descriptive annotations".
//   • Headline summary OMITTED on purpose — that read lives in the panel.
// v1.6 — usability: SELECTABLE COLORS (new "Colors" input group for every
//   drawn element — trend up/down, AVWAP, Fib 50/61.8/ext, 52W H/L, apex, MAs,
//   pattern text); auto TRENDLINES no longer extend rightwards (drawn only up
//   to the current bar — no future projection).
// v1.7 — TIMEFRAME-ADAPTIVE pivot length, ported from Zigzag [Strict v6.2]
//   (Monthly 1 · Weekly 5 · Daily 2 · Intraday 2). Fixes the old flat "8"
//   that barely formed pivots on M/W and drifted from the canonical swing
//   engine. Four tunable inputs; raise Daily for cleaner markup trendlines.
// v1.8 — TRENDLINE CLOSE-RESPECT rule: a line is only accepted if no candle in
//   its span CLOSED beyond it (above resistance / below support) within the
//   touch tolerance. The classical valid-trendline test, on by default
//   ("reject if a candle closes through it"); turn off to revert to pivots-only.
// ============================================================================
indicator("Commander Chart Markup v1.8", overlay=true, max_lines_count=80, max_labels_count=100, max_boxes_count=30)
max_bars_back(close, 600)  // history buffer for the "no candle closes through the trendline" check

// ============================================================================
// 1. INPUTS
// ============================================================================
grpD = "Detection"
// Timeframe-adaptive pivot length — matches Wesinstein Swing Zigzag [Strict v6.2]
// (Monthly 1 · Weekly 5 · Daily 2 · Intraday 2) so pivots/trendlines stay in sync
// with the canonical swing engine across every timeframe.
piv_m     = input.int(1, "Monthly pivot length",  minval=1, group=grpD)
piv_w     = input.int(5, "Weekly pivot length",   minval=1, group=grpD)
piv_d     = input.int(2, "Daily pivot length",    minval=1, group=grpD, tooltip="Zigzag uses 2 for fine swing structure. For cleaner *markup* trendlines you may prefer a larger value (e.g. 4–6) — your call.")
piv_intra = input.int(2, "Intraday pivot length", minval=1, group=grpD)
int piv_lb = timeframe.ismonthly ? piv_m : timeframe.isweekly ? piv_w : timeframe.isdaily ? piv_d : piv_intra
maxPiv    = input.int(12, "Pivots tracked per side", minval=4, maxval=20, group=grpD)
trend_piv = input.int(5, "Trendline: fit only last N pivots", minval=3, maxval=12, group=grpD, tooltip="Keeps the trendline anchored near current price. Lower = hugs CMP tighter; higher = longer base.")
min_touch = input.int(3, "Min touches for a VALID trendline", minval=2, group=grpD)
tol_atr   = input.float(0.7, "Touch tolerance (× ATR14)", minval=0.1, step=0.1, group=grpD)
tl_nobreak = input.bool(true, "Trendline: reject if a candle CLOSES through it", group=grpD, tooltip="Classical valid-trendline rule — the line is only accepted if no candle in its span closed beyond it (above resistance / below support), within the touch tolerance.")
gap_pct   = input.float(4.0, "Breakaway gap % min", minval=0.5, step=0.5, group=grpD)
gap_volx  = input.float(2.0, "Gap volume × avg min", minval=1.0, step=0.5, group=grpD)

grpC = "Context"
benchSym = input.symbol("NSE:CNX500", "RS Benchmark (Nifty 500)", group=grpC)
rsLen    = input.int(52, "Mansfield RS MA length (bars)", minval=10, group=grpC)
nearHi_pct = input.float(3.0, "‘At highs’ threshold (% from 52WH)", step=0.5, group=grpC)
pb_atr   = input.float(1.5, "‘Pullback to MA’ band (× ATR)", step=0.5, group=grpC)

grpV = "Visuals"
show_tl     = input.bool(true, "Auto trendlines + geometry", group=grpV)
show_apex   = input.bool(true, "Apex marker (converging lines)", group=grpV)
show_levels = input.bool(true, "52W High / Low levels", group=grpV)
show_gaps   = input.bool(true, "Breakaway-gap markers", group=grpV)
show_ma     = input.bool(true, "Stage MAs (50/150/200)", group=grpV)
show_panel  = input.bool(true, "Verdict panel", group=grpV)
show_notes  = input.bool(true, "Descriptive annotations (MCP-style notes)", group=grpV, tooltip="Full-sentence labels: a headline read + narrative notes at Resistance / Support / AVWAP. Turn off if the chart feels busy.")
panel_posS  = input.string("Top Right", "Panel position", options=["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right"], group=grpV)

panel_pos = panel_posS == "Top Right" ? position.top_right : panel_posS == "Top Left" ? position.top_left : panel_posS == "Bottom Right" ? position.bottom_right : panel_posS == "Bottom Left" ? position.bottom_left : position.middle_right

grpP = "Classical Patterns (v1.1)"
show_sr     = input.bool(true,  "Support/Resistance zones", group=grpP)
sr_tol_atr  = input.float(0.6, "S/R cluster tolerance (× ATR)", minval=0.1, step=0.1, group=grpP)
sr_min_t    = input.int(2, "S/R min touches", minval=2, group=grpP, tooltip="A zone must be touched by at least this many pivots to be drawn.")
show_flags  = input.bool(true,  "Flags (impulse + tight consolidation)", group=grpP)
flag_cons   = input.int(6, "Flag consolidation bars", minval=3, group=grpP)
flag_imp    = input.int(10, "Flag impulse lookback bars", minval=4, group=grpP)
flag_impA   = input.float(4.0, "Flag impulse size (× ATR)", minval=1.0, step=0.5, group=grpP)
flag_rngA   = input.float(2.5, "Flag consolidation max (× ATR)", minval=0.5, step=0.5, group=grpP)
show_dt     = input.bool(true,  "Double / Triple Top & Bottom", group=grpP)
dt_tol_atr  = input.float(0.5, "Equal-pivot tolerance (× ATR)", minval=0.1, step=0.1, group=grpP)
// Batch 2 — heuristic / false-positive-prone tier (labelled "candidate")
show_hs     = input.bool(true,  "Head & Shoulders (+ inverse) — CANDIDATE", group=grpP, tooltip="Heuristic — eyeball candidate, not a confirmed signal.")
hs_tol_atr  = input.float(0.9, "H&S shoulder symmetry tol (× ATR)", minval=0.1, step=0.1, group=grpP)
show_cup    = input.bool(true,  "Cup & Handle — CANDIDATE", group=grpP, tooltip="Heuristic — loose detection; verify by eye.")
cup_dmin    = input.float(12.0, "Cup depth min %", minval=3, step=1, group=grpP)
cup_dmax    = input.float(50.0, "Cup depth max %", minval=10, step=1, group=grpP)

grpAV = "Anchored VWAP (ported from Dashboard v67.4.12)"
show_avwap   = input.bool(true,  "Anchored VWAP (curve)", group=grpAV, tooltip="Auto-anchored at the current Stage-2 start (hlc3×vol cumulative), exactly like the Dashboard. Toggle manual anchor below to override.")
avwap_manual = input.bool(false, "Use manual anchor date instead", group=grpAV)
avwap_date   = input.time(timestamp("01 Jan 2026 00:00 +0530"), "Manual anchor", group=grpAV)

grpF = "Fibonacci (ported from Zigzag v6.2)"
show_fib     = input.bool(true,  "Fib retrace 50% & 61.8%", group=grpF)
show_fib_ext = input.bool(true,  "Fib ext 1.272 & 1.618 (targets)", group=grpF)
fibLook      = input.int(120, "Fib swing lookback (bars)", minval=20, group=grpF, tooltip="Dominant swing = highest-high & lowest-low over this lookback. Retrace = high − r×range; ext = low + r×range (Zigzag v6.2 formulas).")
fib_ext_bars = input.int(15, "Fib line extend (bars right)", minval=2, maxval=100, group=grpF)

grpClr = "Colors"
c_up     = input.color(#26a69a, "Up / support / bullish", group=grpClr)
c_dn     = input.color(#ef5350, "Down / resistance / bearish", group=grpClr)
c_avwap  = input.color(#ffa726, "Anchored VWAP", group=grpClr)
c_fibR   = input.color(#A020F0, "Fib 50% retrace", group=grpClr)
c_fib618 = input.color(color.orange, "Fib 61.8% retrace", group=grpClr)
c_fibE   = input.color(#00BFA5, "Fib extensions", group=grpClr)
c_52h    = input.color(#ce93d8, "52W High", group=grpClr)
c_52l    = input.color(#90a4ae, "52W Low", group=grpClr)
c_apex   = input.color(#b0bec5, "Apex", group=grpClr)
c_pat    = input.color(#4dd0e1, "Pattern text (panel)", group=grpClr)
c_ma50   = input.color(color.orange, "MA 50", group=grpClr)
c_ma150  = input.color(color.blue, "MA 150", group=grpClr)
c_ma200  = input.color(color.gray, "MA 200", group=grpClr)

// ============================================================================
// 2. CONTEXT — ATR, MAs, Weinstein Stage, Mansfield RS
// ============================================================================
float atr14 = ta.atr(14)
float sma50  = ta.sma(close, 50)
float sma150 = ta.sma(close, 150)
float sma200 = ta.sma(close, 200)
bool minervini_up = not na(sma200) and close > sma50 and sma50 > sma150 and sma150 > sma200

// Weekly 30-WMA Weinstein anchor (works on any chart TF)
[wma30, wma30p] = request.security(syminfo.tickerid, "W", [ta.sma(close, 30), ta.sma(close, 30)[1]], lookahead=barmerge.lookahead_off)
int stage = na(wma30) ? 0 : (close > wma30 and wma30 >= wma30p ? 2 : close > wma30 ? 3 : wma30 < wma30p ? 4 : 1)
// reversal flag: was below the 30-WMA within the last 25 bars, now reclaimed
float lowest25 = ta.lowest(close, 25)
bool reclaim_30w = close > wma30 and lowest25 < wma30

// Mansfield RS vs benchmark (TF-aware; same formula as the RS pane)
float benchClose = request.security(benchSym, timeframe.period, close, lookahead=barmerge.lookahead_off)
float rsRatio = benchClose > 0 ? close / benchClose : na
float rsMa = ta.sma(rsRatio, rsLen)
float mansfield = na(rsMa) or rsMa == 0 ? na : (rsRatio / rsMa - 1.0) * 100.0
bool rs_pos = not na(mansfield) and mansfield > 0

// 52-week extremes (rolling)
int look52 = 252
float hh52 = ta.highest(high, look52)
float ll52 = ta.lowest(low, look52)

// Hoisted ta.* (must evaluate every bar — used inside conditional blocks below)
float volSma50  = ta.sma(volume, 50)
float flagConsHi = ta.highest(high, flag_cons)
float flagConsLo = ta.lowest(low, flag_cons)

// --- Anchored VWAP (port of Dashboard v67.4.12: anchor = Stage-2 start; hlc3×vol) ---
var float av_cumV  = 0.0
var float av_cumPV = 0.0
var int   av_last  = 1
int av_anchor = avwap_manual ? avwap_date : ((stage == 2 and (na(stage[1]) or stage[1] != 2)) ? time : na)
var int av_hold = 1
if not na(av_anchor)
    av_hold := av_anchor
if av_hold > 1 and av_hold != av_last
    av_cumV  := 0.0
    av_cumPV := 0.0
    av_last  := av_hold
if av_last > 1 and time >= av_last
    av_cumV  += volume
    av_cumPV += hlc3 * volume
float avwap = av_cumV > 0 ? av_cumPV / av_cumV : na

// --- Fib dominant swing (Zigzag v6.2 formulas on a lookback-range swing) ---
float fibHi = ta.highest(high, fibLook)
float fibLo = ta.lowest(low, fibLook)
float fibRange = fibHi - fibLo
float fib_50  = fibHi - 0.500 * fibRange
float fib_618 = fibHi - 0.618 * fibRange
float fib_e1  = fibLo + 1.272 * fibRange
float fib_e2  = fibLo + 1.618 * fibRange

// --- annotation metrics (every-bar) ---
var int stageStartBar = 0
if ta.change(stage) != 0
    stageStartBar := bar_index
bool rsRising  = not na(mansfield) and not na(mansfield[5]) and mansfield > mansfield[5]
bool volRising = ta.sma(volume, 10) > volSma50
float volRel   = volSma50 > 0 ? volume / volSma50 : na

// pick nearest support (highest level below price) / resistance (lowest above)
f_maxBelow(float acc, float cur, float px) => (not na(px) and px < cur) ? (na(acc) ? px : math.max(acc, px)) : acc
f_minAbove(float acc, float cur, float px) => (not na(px) and px > cur) ? (na(acc) ? px : math.min(acc, px)) : acc

// ============================================================================
// 3. PIVOT COLLECTION
// ============================================================================
var array<int>   phx = array.new<int>()
var array<float> phy = array.new<float>()
var array<int>   plx = array.new<int>()
var array<float> ply = array.new<float>()

float ph = ta.pivothigh(piv_lb, piv_lb)
float pl = ta.pivotlow(piv_lb, piv_lb)
if not na(ph)
    array.push(phx, bar_index - piv_lb)
    array.push(phy, ph)
    if array.size(phx) > maxPiv
        array.shift(phx)
        array.shift(phy)
if not na(pl)
    array.push(plx, bar_index - piv_lb)
    array.push(ply, pl)
    if array.size(plx) > maxPiv
        array.shift(plx)
        array.shift(ply)

// ============================================================================
// 4. BEST-FIT TRENDLINE (max touches within tolerance through pivot pairs)
//    Returns [x1,y1,x2,y2,touches]. Direction-agnostic so it naturally yields
//    rising channels (Stage 2) or descending resistance (Stage 4).
// ============================================================================
// upper=true → line must be a true RESISTANCE (no pivot pierces meaningfully ABOVE);
// upper=false → true SUPPORT (no pivot pierces BELOW). Among valid (non-pierced)
// lines, pick the one with the most touches. This keeps geometry trend-consistent.
f_fit(array<int> xs, array<float> ys, float tol, bool upper, int recentK, bool noBreak) =>
    int n = array.size(xs)
    int s = math.max(0, n - recentK)   // consider only the last recentK pivots → anchors near CMP
    float bx1 = na
    float by1 = na
    float bx2 = na
    float by2 = na
    int best = 0
    if n - s >= 2
        for i = s to n - 2
            for j = i + 1 to n - 1
                int xi = array.get(xs, i)
                float yi = array.get(ys, i)
                int xj = array.get(xs, j)
                float yj = array.get(ys, j)
                if xj != xi
                    float slope = (yj - yi) / (xj - xi)
                    int t = 0
                    int pierce = 0
                    for k = s to n - 1
                        float diff = array.get(ys, k) - (yi + slope * (array.get(xs, k) - xi))
                        if math.abs(diff) <= tol
                            t := t + 1
                        else if upper and diff > tol
                            pierce := pierce + 1
                        else if not upper and diff < -tol
                            pierce := pierce + 1
                    // CLOSE-respect rule: no candle may CLOSE beyond the line in its span
                    bool brk = false
                    if noBreak and pierce == 0
                        int bStart = int(math.max(xi, bar_index - 500))
                        for b = bStart to bar_index
                            float lineYb = yi + slope * (b - xi)
                            float cb = close[bar_index - b]
                            if (upper and cb > lineYb + tol) or (not upper and cb < lineYb - tol)
                                brk := true
                    if pierce == 0 and not brk and t > best
                        best := t
                        bx1 := xi
                        by1 := yi
                        bx2 := xj
                        by2 := yj
    [bx1, by1, bx2, by2, best]

// Strongest horizontal cluster in a pivot array, within price band [lo,hi]
// (band filters out stale pivots off the current 52W range) → [level, count]
f_cluster(array<float> ys, float tol, float lo, float hi) =>
    int n = array.size(ys)
    float bestLvl = na
    int bestCnt = 0
    if n >= 2
        for i = 0 to n - 1
            float yi = array.get(ys, i)
            if yi >= lo and yi <= hi
                int c = 0
                float sum = 0.0
                for k = 0 to n - 1
                    float yk = array.get(ys, k)
                    if yk >= lo and yk <= hi and math.abs(yk - yi) <= tol
                        c := c + 1
                        sum := sum + yk
                if c > bestCnt
                    bestCnt := c
                    bestLvl := sum / c
    [bestLvl, bestCnt]

// Lowest pivot-low strictly between bar indices a and b (na if none) — neckline for tops
f_troughBetween(array<int> lxs, array<float> lys, int a, int b) =>
    float lo = na
    if array.size(lxs) > 0
        for m = 0 to array.size(lxs) - 1
            int lx = array.get(lxs, m)
            if lx > a and lx < b
                float ly = array.get(lys, m)
                lo := na(lo) ? ly : math.min(lo, ly)
    lo

// Highest pivot-high strictly between bar indices a and b (na if none) — neckline for bottoms
f_peakBetween(array<int> hxs, array<float> hys, int a, int b) =>
    float hi = na
    if array.size(hxs) > 0
        for m = 0 to array.size(hxs) - 1
            int hx = array.get(hxs, m)
            if hx > a and hx < b
                float hy = array.get(hys, m)
                hi := na(hi) ? hy : math.max(hi, hy)
    hi

// ============================================================================
// 5. RENDER (last bar only) — trendlines, geometry, apex, levels, panel
// ============================================================================
var line  lnUp   = na
var line  lnLo   = na
var line  lnHH   = na
var line  lnLL   = na
var line  lnApex = na
var label lbUp   = na
var label lbLo   = na
var label lbApex = na
var table panel  = na
// v1.1 classical-pattern handles
var line  lnR    = na
var line  lnS    = na
var label lbR    = na
var label lbS    = na
var box   bxFlag = na
var label lbFlag = na
var line  lnNeck = na
var label lbDT   = na
// Batch 2 handles
var line  lnHS   = na
var label lbHS   = na
var label lbCup  = na
// v1.3 Fib handles
var line  fib50L  = na
var line  fib618L = na
var line  fibE1L  = na
var line  fibE2L  = na
var label fib50Lb = na
var label fib618Lb = na
var label fibE1Lb = na
var label fibE2Lb = na
// v1.4 descriptive-note handles
var label lbSupN = na
var label lbResN = na
var label lbAvwN = na

// gap markers (per-bar, self-managing)
bool gapUp = show_gaps and not na(close[1]) and open > close[1] * (1.0 + gap_pct / 100.0) and volume > volSma50 * gap_volx and close > open
bool gapDn = show_gaps and not na(close[1]) and open < close[1] * (1.0 - gap_pct / 100.0) and volume > volSma50 * gap_volx and close < open
plotshape(gapUp, "Breakaway gap up", style=shape.triangleup, location=location.belowbar, color=color.new(c_up, 0), size=size.small)
plotshape(gapDn, "Breakaway gap dn", style=shape.triangledown, location=location.abovebar, color=color.new(c_dn, 0), size=size.small)

// MAs for stage context
plot(show_ma ? sma50 : na, "SMA50", color=color.new(c_ma50, 0), linewidth=1)
plot(show_ma ? sma150 : na, "SMA150", color=color.new(c_ma150, 40), linewidth=1)
plot(show_ma ? sma200 : na, "SMA200", color=color.new(c_ma200, 0), linewidth=1)

// geometry holders (string for panel)
var string geom = "—"
var string apexTxt = "—"
var string setup = "—"
var string verdict = "—"
var string pats = "none"

if barstate.islast
    float tol = tol_atr * atr14

    // --- fit upper resistance (highs) & lower support (lows), recent pivots only ---
    [ux1, uy1, ux2, uy2, ut] = f_fit(phx, phy, tol, true, trend_piv, tl_nobreak)
    [vx1, vy1, vx2, vy2, vt] = f_fit(plx, ply, tol, false, trend_piv, tl_nobreak)

    float slopeU = na
    float slopeL = na
    if show_tl and not na(ux1) and ux2 != ux1
        slopeU := (uy2 - uy1) / (ux2 - ux1)
        line.delete(lnUp)
        label.delete(lbUp)
        bool validU = ut >= min_touch
        color cU = slopeU < 0 ? color.new(c_dn, 0) : color.new(c_up, 0)
        float uy_now = uy1 + slopeU * (bar_index - ux1)
        lnUp := line.new(int(ux1), uy1, bar_index, uy_now, xloc=xloc.bar_index, extend=extend.none, color=cU, width=2, style=(validU ? line.style_solid : line.style_dashed))
        lbUp := label.new(bar_index, uy_now, (slopeU < 0 ? "Resistance" : "Upper") + " " + (validU ? "VALID " : "prov. ") + str.tostring(ut) + "×", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(cU, 80), textcolor=cU, size=size.small)

    if show_tl and not na(vx1) and vx2 != vx1
        slopeL := (vy2 - vy1) / (vx2 - vx1)
        line.delete(lnLo)
        label.delete(lbLo)
        bool validL = vt >= min_touch
        color cL = slopeL > 0 ? color.new(c_up, 0) : color.new(c_dn, 0)
        float vy_now = vy1 + slopeL * (bar_index - vx1)
        lnLo := line.new(int(vx1), vy1, bar_index, vy_now, xloc=xloc.bar_index, extend=extend.none, color=cL, width=2, style=(validL ? line.style_solid : line.style_dashed))
        lbLo := label.new(bar_index, vy_now, (slopeL > 0 ? "Support" : "Lower") + " " + (validL ? "VALID " : "prov. ") + str.tostring(vt) + "×", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(cL, 80), textcolor=cL, size=size.small)

    // --- geometry classification ---
    if not na(slopeU) and not na(slopeL)
        float avgMag = (math.abs(slopeU) + math.abs(slopeL)) / 2.0
        float conv = slopeU - slopeL          // <0 converging, >0 diverging
        bool sameDir = (slopeU > 0) == (slopeL > 0)
        bool parallelish = avgMag > 0 and math.abs(conv) <= 0.25 * avgMag and sameDir
        if parallelish
            geom := slopeU > 0 ? "Rising channel" : "Falling channel"
        else if conv < 0   // narrowing
            geom := (slopeU < 0 and slopeL < 0) ? "Falling wedge" : (slopeU > 0 and slopeL > 0) ? "Rising wedge" : "Triangle (converging)"
        else               // widening
            geom := (slopeU > 0 and slopeL > 0) ? "Uptrend (rising support/resist, not parallel)" : (slopeU < 0 and slopeL < 0) ? "Downtrend (falling, not parallel)" : "Broadening"

        // --- apex (where upper & lower cross) ---
        float denom = slopeU - slopeL
        apexTxt := "—"
        line.delete(lnApex)
        label.delete(lbApex)
        if math.abs(denom) > 1e-9
            // uy1 + slopeU*(x-ux1) = vy1 + slopeL*(x-vx1)
            float xApex = (vy1 - uy1 - slopeL * vx1 + slopeU * ux1) / denom
            float yApex = uy1 + slopeU * (xApex - ux1)
            int barsAhead = int(xApex) - bar_index
            if show_apex and barsAhead > 0 and barsAhead < 300
                lnApex := line.new(int(xApex), yApex, int(xApex), yApex + atr14, xloc=xloc.bar_index, extend=extend.both, color=color.new(c_apex, 30), width=1, style=line.style_dotted)
                lbApex := label.new(int(xApex), yApex, "◆ apex ~" + str.tostring(yApex, format.mintick) + " · " + str.tostring(barsAhead) + " bars", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(c_apex, 70), textcolor=c_apex, size=size.small)
                apexTxt := str.tostring(yApex, format.mintick) + " in " + str.tostring(barsAhead) + " bars"

    // --- 52W high / low levels ---
    if show_levels
        line.delete(lnHH)
        line.delete(lnLL)
        lnHH := line.new(bar_index - look52, hh52, bar_index + 10, hh52, xloc=xloc.bar_index, color=color.new(c_52h, 0), width=1, style=line.style_dotted)
        lnLL := line.new(bar_index - look52, ll52, bar_index + 10, ll52, xloc=xloc.bar_index, color=color.new(c_52l, 0), width=1, style=line.style_dotted)

    // --- setup + verdict ---
    float distHi = hh52 > 0 ? (hh52 - close) / hh52 * 100.0 : na
    bool nearMA = not na(sma50) and math.abs(close - sma50) <= pb_atr * atr14
    if stage == 4 and not rs_pos
        setup := "STAGE 4 decline"
        verdict := "EXIT / avoid — no new longs"
    else if reclaim_30w and (stage == 1 or stage == 2) and rs_pos
        setup := "Stage 4→2 reversal (30-WMA reclaim)"
        verdict := "Emerging long — confirm RS rising"
    else if stage == 2 and minervini_up and rs_pos
        if nearMA
            setup := "SWG-PB (pullback to rising MA)"
            verdict := "Buy-the-dip — entry on MA reclaim, stop < MA"
        else if not na(distHi) and distHi <= nearHi_pct
            setup := "Stage 2 at highs"
            verdict := "Breakout/continuation — buy strength, watch extension"
        else
            setup := "Stage 2 uptrend"
            verdict := "Hold / add on pullback to MA"
    else if stage == 1
        setup := "Stage 1 base"
        verdict := "Watch — needs breakout + RS > 0"
    else
        setup := "Neutral / mixed"
        verdict := "No edge — wait"

    // ========================================================================
    // 5b. CLASSICAL PATTERNS (v1.1 Batch 1)
    // ========================================================================
    pats := ""

    // --- horizontal Support / Resistance zones (pivot clustering) ---
    if show_sr
        float srTol = sr_tol_atr * atr14
        [rLvl, rCnt] = f_cluster(phy, srTol, ll52, hh52)
        [sLvl, sCnt] = f_cluster(ply, srTol, ll52, hh52)
        line.delete(lnR)
        label.delete(lbR)
        line.delete(lnS)
        label.delete(lbS)
        if not na(rLvl) and rCnt >= sr_min_t
            lnR := line.new(bar_index - 200, rLvl, bar_index + 10, rLvl, xloc=xloc.bar_index, color=color.new(c_dn, 20), width=1)
            lbR := label.new(bar_index + 10, rLvl, "R " + str.tostring(rCnt) + "×", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(c_dn, 80), textcolor=c_dn, size=size.small)
        if not na(sLvl) and sCnt >= sr_min_t
            lnS := line.new(bar_index - 200, sLvl, bar_index + 10, sLvl, xloc=xloc.bar_index, color=color.new(c_up, 20), width=1)
            lbS := label.new(bar_index + 10, sLvl, "S " + str.tostring(sCnt) + "×", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(c_up, 80), textcolor=c_up, size=size.small)

    // --- flags (impulse leg + tight consolidation) ---
    if show_flags
        float consHi = flagConsHi
        float consLo = flagConsLo
        float consRange = consHi - consLo
        float priorMove = close[flag_cons] - close[flag_cons + flag_imp]
        bool tight = consRange < flag_rngA * atr14
        bool bullFlag = tight and priorMove > flag_impA * atr14
        bool bearFlag = tight and priorMove < -flag_impA * atr14
        box.delete(bxFlag)
        label.delete(lbFlag)
        if bullFlag or bearFlag
            color fc = bullFlag ? c_up : c_dn
            bxFlag := box.new(bar_index - flag_cons + 1, consHi, bar_index, consLo, border_color=fc, bgcolor=color.new(fc, 88), border_width=1)
            lbFlag := label.new(bar_index - flag_cons + 1, consHi, (bullFlag ? "Bull" : "Bear") + " flag", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(fc, 70), textcolor=fc, size=size.small)
            pats := (bullFlag ? "Bull flag" : "Bear flag")

    // --- double / triple top & bottom (equal pivots + neckline) ---
    if show_dt
        float dtTol = dt_tol_atr * atr14
        line.delete(lnNeck)
        label.delete(lbDT)
        bool drewDT = false
        // TOPS (pivot highs)
        int nH = array.size(phy)
        if nH >= 2 and not drewDT
            float h1 = array.get(phy, nH - 1)
            float h2 = array.get(phy, nH - 2)
            int hx1 = array.get(phx, nH - 1)
            int hx2 = array.get(phx, nH - 2)
            bool trip = false
            if nH >= 3
                float h3 = array.get(phy, nH - 3)
                trip := math.abs(h3 - h1) <= dtTol and math.abs(h3 - h2) <= dtTol
            if math.abs(h1 - h2) <= dtTol
                float neck = f_troughBetween(plx, ply, hx2, hx1)
                if not na(neck)
                    string nm = (trip ? "Triple" : "Double") + " Top" + (close < neck ? " ✓break" : "")
                    lnNeck := line.new(hx2, neck, bar_index + 10, neck, xloc=xloc.bar_index, color=color.new(c_dn, 0), width=1, style=line.style_dashed)
                    lbDT := label.new(hx1, math.max(h1, h2), nm, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(c_dn, 70), textcolor=c_dn, size=size.small)
                    pats := str.length(pats) == 0 ? nm : pats + " · " + nm
                    drewDT := true
        // BOTTOMS (pivot lows)
        int nL = array.size(ply)
        if nL >= 2 and not drewDT
            float l1 = array.get(ply, nL - 1)
            float l2 = array.get(ply, nL - 2)
            int lx1 = array.get(plx, nL - 1)
            int lx2 = array.get(plx, nL - 2)
            bool trip2 = false
            if nL >= 3
                float l3 = array.get(ply, nL - 3)
                trip2 := math.abs(l3 - l1) <= dtTol and math.abs(l3 - l2) <= dtTol
            if math.abs(l1 - l2) <= dtTol
                float neck2 = f_peakBetween(phx, phy, lx2, lx1)
                if not na(neck2)
                    string nm2 = (trip2 ? "Triple" : "Double") + " Bottom" + (close > neck2 ? " ✓break" : "")
                    lnNeck := line.new(lx2, neck2, bar_index + 10, neck2, xloc=xloc.bar_index, color=color.new(c_up, 0), width=1, style=line.style_dashed)
                    lbDT := label.new(lx1, math.min(l1, l2), nm2, xloc=xloc.bar_index, style=label.style_label_up, color=color.new(c_up, 70), textcolor=c_up, size=size.small)
                    pats := str.length(pats) == 0 ? nm2 : pats + " · " + nm2

    // --- Head & Shoulders (+ inverse) — CANDIDATE (heuristic, last 3 pivots) ---
    if show_hs
        float hsTol = hs_tol_atr * atr14
        line.delete(lnHS)
        label.delete(lbHS)
        bool drewHS = false
        // regular H&S — 3 pivot highs, head highest, shoulders ~equal
        int nHh = array.size(phy)
        if nHh >= 3
            float lsh = array.get(phy, nHh - 3)
            float hdh = array.get(phy, nHh - 2)
            float rsh = array.get(phy, nHh - 1)
            int xlsh = array.get(phx, nHh - 3)
            int xhdh = array.get(phx, nHh - 2)
            int xrsh = array.get(phx, nHh - 1)
            if hdh > lsh and hdh > rsh and math.abs(lsh - rsh) <= hsTol and (hdh - math.max(lsh, rsh)) > hsTol
                float t1h = f_troughBetween(plx, ply, xlsh, xhdh)
                float t2h = f_troughBetween(plx, ply, xhdh, xrsh)
                if not na(t1h) and not na(t2h)
                    float neckH = (t1h + t2h) / 2.0
                    string nmh = "H&S" + (close < neckH ? " ✓break" : " (cand)")
                    lnHS := line.new(xlsh, neckH, bar_index + 10, neckH, xloc=xloc.bar_index, color=color.new(c_dn, 0), width=1, style=line.style_dotted)
                    lbHS := label.new(xhdh, hdh, nmh, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(c_dn, 75), textcolor=c_dn, size=size.small)
                    pats := str.length(pats) == 0 ? nmh : pats + " · " + nmh
                    drewHS := true
        // inverse H&S — 3 pivot lows, head lowest
        int nLh = array.size(ply)
        if nLh >= 3 and not drewHS
            float lsl = array.get(ply, nLh - 3)
            float hdl = array.get(ply, nLh - 2)
            float rsl = array.get(ply, nLh - 1)
            int xlsl = array.get(plx, nLh - 3)
            int xhdl = array.get(plx, nLh - 2)
            int xrsl = array.get(plx, nLh - 1)
            if hdl < lsl and hdl < rsl and math.abs(lsl - rsl) <= hsTol and (math.min(lsl, rsl) - hdl) > hsTol
                float t1l = f_peakBetween(phx, phy, xlsl, xhdl)
                float t2l = f_peakBetween(phx, phy, xhdl, xrsl)
                if not na(t1l) and not na(t2l)
                    float neckL = (t1l + t2l) / 2.0
                    string nml = "Inv H&S" + (close > neckL ? " ✓break" : " (cand)")
                    lnHS := line.new(xlsl, neckL, bar_index + 10, neckL, xloc=xloc.bar_index, color=color.new(c_up, 0), width=1, style=line.style_dotted)
                    lbHS := label.new(xhdl, hdl, nml, xloc=xloc.bar_index, style=label.style_label_up, color=color.new(c_up, 75), textcolor=c_up, size=size.small)
                    pats := str.length(pats) == 0 ? nml : pats + " · " + nml

    // --- Cup & Handle — CANDIDATE (loose: two rims ~level, rounded low, handle) ---
    if show_cup
        label.delete(lbCup)
        int nHc = array.size(phy)
        if nHc >= 2
            float rightRim = array.get(phy, nHc - 1)
            int xRight = array.get(phx, nHc - 1)
            float leftRim = na
            int xLeft = na
            for m = nHc - 2 to 0
                float hm = array.get(phy, m)
                if na(leftRim) and math.abs(hm - rightRim) <= 0.05 * rightRim
                    leftRim := hm
                    xLeft := array.get(phx, m)
            if not na(leftRim) and not na(xLeft)
                float cupLow = f_troughBetween(plx, ply, xLeft, xRight)
                if not na(cupLow)
                    float depth = (rightRim - cupLow) / rightRim * 100.0
                    bool handle = close < rightRim and close > rightRim * 0.88
                    if depth >= cup_dmin and depth <= cup_dmax and handle
                        lbCup := label.new(xRight, rightRim, "Cup&Handle? (cand)", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(c_up, 75), textcolor=c_up, size=size.small)
                        pats := str.length(pats) == 0 ? "Cup&Handle? (cand)" : pats + " · Cup&Handle? (cand)"

    if str.length(pats) == 0
        pats := "none"

    // --- Fibonacci (Zigzag v6.2 port) — retrace high−r×range; ext low+r×range ---
    line.delete(fib50L)
    line.delete(fib618L)
    line.delete(fibE1L)
    line.delete(fibE2L)
    label.delete(fib50Lb)
    label.delete(fib618Lb)
    label.delete(fibE1Lb)
    label.delete(fibE2Lb)
    if (show_fib or show_fib_ext) and not na(fibHi) and not na(fibLo) and fibHi > fibLo
        int fS = bar_index - fibLook
        int fE = bar_index + fib_ext_bars
        if show_fib
            fib50L   := line.new(fS, fib_50,  fE, fib_50,  xloc=xloc.bar_index, color=color.new(c_fibR, 0), width=1)
            fib618L  := line.new(fS, fib_618, fE, fib_618, xloc=xloc.bar_index, color=color.new(c_fib618, 0), width=1)
            fib50Lb  := label.new(fE, fib_50,  "50% "   + str.tostring(fib_50,  format.mintick), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c_fibR, size=size.small)
            fib618Lb := label.new(fE, fib_618, "61.8% " + str.tostring(fib_618, format.mintick), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c_fib618, size=size.small)
        if show_fib_ext
            fibE1L   := line.new(fS, fib_e1, fE, fib_e1, xloc=xloc.bar_index, color=color.new(c_fibE, 0), width=1)
            fibE2L   := line.new(fS, fib_e2, fE, fib_e2, xloc=xloc.bar_index, color=color.new(c_fibE, 0), width=1)
            fibE1Lb  := label.new(fE, fib_e1, "1.272 " + str.tostring(fib_e1, format.mintick), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c_fibE, size=size.small)
            fibE2Lb  := label.new(fE, fib_e2, "1.618 " + str.tostring(fib_e2, format.mintick), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(color.black, 100), textcolor=c_fibE, size=size.small)

    // === shared metrics (used by both the descriptive notes and the panel) ===
    int barsInStage = bar_index - stageStartBar
    string rsArrow = na(mansfield) ? "" : (rsRising ? " ↑" : " ↓")
    int conv = (stage == 2 ? 1 : 0) + (rs_pos ? 1 : 0) + (rsRising ? 1 : 0) + ((not na(sma50) and close > sma50) ? 1 : 0) + ((not na(avwap) and close > avwap) ? 1 : 0) + ((not na(sma200) and close > sma200) ? 1 : 0) + (volRising ? 1 : 0)
    string convTxt = conv >= 6 ? "STRONG" : conv >= 4 ? "MODERATE" : "WEAK"
    color  convCol = conv >= 6 ? color.lime : conv >= 4 ? color.yellow : color.red
    float supN = na
    supN := f_maxBelow(supN, close, avwap)
    supN := f_maxBelow(supN, close, sma50)
    supN := f_maxBelow(supN, close, fib_50)
    supN := f_maxBelow(supN, close, fib_618)
    supN := f_maxBelow(supN, close, ll52)
    float resN = na
    resN := f_minAbove(resN, close, hh52)
    resN := f_minAbove(resN, close, fib_e1)
    resN := f_minAbove(resN, close, fib_e2)
    float supPct = (not na(supN) and close > 0) ? (close - supN) / close * 100 : na
    float resPct = (not na(resN) and close > 0) ? (resN - close) / close * 100 : na
    bool   bullish  = stage == 2 or str.contains(setup, "reversal")
    float  pEntry   = close
    float  pStop    = na(supN) ? close - 2.0 * atr14 : supN * 0.995
    float  pT1      = na(resN) ? hh52 : resN
    float  pRR      = (pEntry - pStop) > 0 and not na(pT1) ? (pT1 - pEntry) / (pEntry - pStop) : na
    float  pRiskPct = pEntry > 0 ? (pEntry - pStop) / pEntry * 100 : na
    string stg_txt = stage == 2 ? "Stage 2 ✓" : stage == 1 ? "Stage 1" : stage == 3 ? "Stage 3 ⚠" : stage == 4 ? "Stage 4 ✗" : "—"
    color  stg_col = stage == 2 ? color.lime : stage == 1 ? color.yellow : stage == 3 ? color.orange : stage == 4 ? color.red : color.gray
    color  rs_col  = rs_pos ? color.lime : color.red
    color  vd_col  = str.contains(verdict, "EXIT") ? color.red : (str.contains(verdict, "Buy") or str.contains(verdict, "long") or str.contains(verdict, "Breakout")) ? color.lime : color.silver

    // === descriptive annotations (MCP-style full-sentence notes at key levels) ===
    // (Headline summary intentionally omitted — that read lives in the panel.)
    if show_notes
        label.delete(lbResN)
        label.delete(lbSupN)
        label.delete(lbAvwN)
        if not na(resN)
            lbResN := label.new(bar_index + 2, resN, "Resistance " + str.tostring(resN, format.mintick) + " (+" + str.tostring(resPct, "0.0") + "%) — overhead supply / first target; a clean break = continuation", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(c_52h, 82), textcolor=c_52h, size=size.small)
        if not na(supN)
            lbSupN := label.new(bar_index + 2, supN, "Support " + str.tostring(supN, format.mintick) + " (−" + str.tostring(supPct, "0.0") + "%) — nearest floor (AVWAP/MA/Fib); stop reference / buy-the-dip", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(c_up, 82), textcolor=c_up, size=size.small)
        if not na(avwap)
            lbAvwN := label.new(bar_index + 2, avwap, "AVWAP " + str.tostring(avwap, format.mintick) + (close > avwap ? " — price ABOVE: Stage-2 cost basis holding as support" : " — price BELOW: cost basis flipped to resistance (caution)"), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(c_avwap, 82), textcolor=c_avwap, size=size.small)

    // --- compact panel ---
    if show_panel
        if na(panel)
            panel := table.new(panel_pos, 2, 17, bgcolor=color.new(color.black, 18), border_width=1, border_color=color.new(color.gray, 50))
        color  hdrbg   = color.new(color.blue, 0)
        color  sepbg   = color.new(color.gray, 65)

        table.cell(panel, 0, 0, "◧ MARKUP", text_color=color.white, text_size=size.small, bgcolor=hdrbg)
        table.cell(panel, 1, 0, syminfo.ticker + " · " + timeframe.period, text_color=color.white, text_size=size.small, bgcolor=hdrbg)
        table.cell(panel, 0, 1, "Stage", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 1, stg_txt + " · " + str.tostring(barsInStage) + "b", text_color=stg_col, text_size=size.small)
        table.cell(panel, 0, 2, "RS (Mansfield)", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 2, (na(mansfield) ? "n/a" : str.tostring(mansfield, "0.0")) + rsArrow + (rs_pos ? " leads" : " lags"), text_color=rs_col, text_size=size.small)
        table.cell(panel, 0, 3, "Setup", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 3, setup, text_color=color.white, text_size=size.small)
        table.cell(panel, 0, 4, "Trend", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 4, geom + (apexTxt == "—" ? "" : " · apex " + apexTxt), text_color=color.silver, text_size=size.small)
        table.cell(panel, 0, 5, "Conviction", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 5, convTxt + " (" + str.tostring(conv) + "/7)", text_color=convCol, text_size=size.small)
        table.cell(panel, 0, 6, "── LEVELS ──", text_color=color.silver, text_size=size.tiny, bgcolor=sepbg)
        table.cell(panel, 1, 6, "", bgcolor=sepbg)
        table.cell(panel, 0, 7, "Resistance", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 7, na(resN) ? "—" : str.tostring(resN, format.mintick) + (na(resPct) ? "" : "  +" + str.tostring(resPct, "0.0") + "%"), text_color=color.new(c_52h, 0), text_size=size.small)
        table.cell(panel, 0, 8, "Support", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 8, na(supN) ? "—" : str.tostring(supN, format.mintick) + (na(supPct) ? "" : "  −" + str.tostring(supPct, "0.0") + "%"), text_color=color.new(c_up, 0), text_size=size.small)
        table.cell(panel, 0, 9, "AVWAP", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 9, na(avwap) ? "n/a" : str.tostring(avwap, format.mintick) + (close > avwap ? " ✓" : " ✗"), text_color=color.new(c_avwap, 0), text_size=size.small)
        table.cell(panel, 0, 10, "Patterns", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 10, pats, text_color=color.new(c_pat, 0), text_size=size.small)
        table.cell(panel, 0, 11, "── PLAN ──", text_color=color.silver, text_size=size.tiny, bgcolor=sepbg)
        table.cell(panel, 1, 11, "", bgcolor=sepbg)
        table.cell(panel, 0, 12, "Entry", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 12, bullish ? str.tostring(pEntry, format.mintick) : "—", text_color=color.white, text_size=size.small)
        table.cell(panel, 0, 13, "Stop", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 13, bullish ? str.tostring(pStop, format.mintick) + (na(pRiskPct) ? "" : "  (−" + str.tostring(pRiskPct, "0.0") + "%)") : "—", text_color=color.new(c_dn, 0), text_size=size.small)
        table.cell(panel, 0, 14, "Target · R:R", text_color=color.gray, text_size=size.small)
        table.cell(panel, 1, 14, (bullish and not na(pT1)) ? str.tostring(pT1, format.mintick) + (na(pRR) ? "" : "  (" + str.tostring(pRR, "0.0") + "R)") : "—", text_color=color.new(c_up, 0), text_size=size.small)
        table.cell(panel, 0, 15, "VERDICT", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 55))
        table.cell(panel, 1, 15, verdict, text_color=vd_col, text_size=size.small, bgcolor=color.new(color.gray, 55))

// Anchored VWAP — the true evolving curve (overlay)
plot(show_avwap ? avwap : na, "Anchored VWAP", color=color.new(c_avwap, 0), linewidth=2)

// data-window plots for screener columns
plot(stage, "Stage", display=display.data_window)
plot(mansfield, "Mansfield RS", display=display.data_window)
plot(avwap, "AVWAP", display=display.data_window)
