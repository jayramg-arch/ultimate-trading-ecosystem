//@version=6
strategy("Weinstein PA Field Strategy [v1.0]",
     overlay=true,
     initial_capital=1000000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.10,
     pyramiding=0,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ==========================================
// PURPOSE
// ==========================================
// Companion to "Weinstein and Swing Pro Dashboard v67.4.8".
// Wraps the Price Action cascade as a Pine STRATEGY so we can use
// `batch_run get_strategy_results` to measure per-symbol effectiveness
// across the Nifty 500 universe (TV Premium server-side compute).
//
// DESIGN
// ------
// • Test ONE PA state at a time (input dropdown). One run per state.
// • Entry: when the selected detector fires (long only).
// • Exit: after `horizon_bars` (catalyst-aware default per state).
// • No SL/TP — measuring RAW signal alpha, not execution mechanics.
// • Commission 0.10% (matches replay.py v2.6 realistic sim).
// • One position at a time; new signal while in-trade is ignored.
//
// CALIBRATION TARGETS (from dashboard cascade — kept in sync)
// -----------------------------------------------------------
// State                | Tier | Default horizon | Source detector
// VCP BO               | +3   | 90d             | pa_vcp_bo (10d high + relVol + closeUpper)
// GAP-UP BO            | +3   | 90d             | pa_gap_up_bo (gap above prior high + vol)
// STAGE-2 LAUNCH       | +3   | 180d            | pa_s2_launch (weekly 30WMA cross + vol)
// 50SMA UNDERCUT       | +2   | 45d             | pa_50sma_undercut (intraday breach + reclaim)
// HAMMER (at 200SMA)   | +2   | 60d             | pa_hammer_at_200 (hammer + low near 200SMA)
// HAMMER (at 50SMA)    | +2   | 30d             | pa_hammer_at_50 (hammer + low near 50SMA)
// OUTSIDE BAR (Bull)   | +2   | 15d             | pa_outside_bull (engulf both extremes)
// IB-NR7 COIL          | +2   | 10d             | pa_ib_nr7 (inside + NR7 same bar)
//
// CALLOUTS / KNOWN SIMPLIFICATIONS vs Dashboard
// ---------------------------------------------
// 1. dLockH approximated as ta.highest(high, 20)[1]. The dashboard uses a
//    strict-trend locked high from f_daily_super_bundle_internal — close
//    enough for an initial validation. Affects Gap-Up BO only.
// 2. wMA30 / stageID via simple weekly SMA — no Weinstein stage filter.
//    Means Stage-2 Launch fires on ANY 30WMA cross, not Stage-2-confirmed.
//    Will slightly inflate sample size; trade-off accepted for v1.0.
// 3. vcp_ok approximated as 10d ATR < 0.75× 40d ATR (matches dashboard's
//    isContraction). No multi-base depth check.
// ==========================================

// ==========================================
// INPUTS
// ==========================================
grpTest = "═══ Test Selection ═══"

testState = input.string("VCP_BO",
     title="PA State to test",
     options=["VCP_BO", "GAP_UP_BO", "STAGE_2_LAUNCH", "UNDERCUT_50SMA",
              "HAMMER_200SMA", "HAMMER_50SMA", "OUTSIDE_BAR_BULL", "IB_NR7_COIL"],
     group=grpTest,
     tooltip="Run one state per batch_run pass. Default horizons match dashboard cascade.")

useDefaultHorizon = input.bool(true, "Use catalyst-aware default horizon", group=grpTest)
horizonOverride   = input.int(30, "Override horizon (bars)", minval=5, maxval=252, group=grpTest,
     tooltip="Only used if 'Use catalyst-aware default' is unchecked")

grpDates = "═══ Date Window ═══"
startYear  = input.int(2023, "Start year",  minval=2010, maxval=2030, group=grpDates)
startMonth = input.int(1,    "Start month", minval=1,    maxval=12,   group=grpDates)
endYear    = input.int(2026, "End year",    minval=2010, maxval=2030, group=grpDates)
endMonth   = input.int(5,    "End month",   minval=1,    maxval=12,   group=grpDates)

inTestWindow = time >= timestamp(startYear, startMonth, 1, 0, 0) and
               time <= timestamp(endYear,   endMonth,  28, 23, 59)

// ==========================================
// CATALYST-AWARE HORIZON MAPPING
// (canonical — mirror in pa_field_validator.py once ported)
// ==========================================
f_default_horizon(string st) =>
    switch st
        "VCP_BO"           => 90
        "GAP_UP_BO"        => 90
        "STAGE_2_LAUNCH"   => 180
        "UNDERCUT_50SMA"   => 45
        "HAMMER_200SMA"    => 60
        "HAMMER_50SMA"     => 30
        "OUTSIDE_BAR_BULL" => 15
        "IB_NR7_COIL"      => 10
        => 30

int horizon_bars = useDefaultHorizon ? f_default_horizon(testState) : horizonOverride

// ==========================================
// SHARED DEPENDENCIES (minimal — only what detectors need)
// ==========================================
float atrVal      = ta.atr(14)
float atr10       = ta.atr(10)
float atr40       = ta.atr(40)
float dMA50       = ta.sma(close, 50)
float dMA200      = ta.sma(close, 200)
float vavg        = ta.sma(volume, 50)
float curRelVol   = vavg != 0 ? volume / vavg : 0.0

float ema10_ctx   = ta.ema(close, 10)
float ema20_ctx   = ta.ema(close, 20)
bool  inDowntrendCtx = close < ema10_ctx and ema10_ctx < ema20_ctx
bool  inUptrendCtx   = close > ema10_ctx and ema10_ctx > ema20_ctx

float d_l20       = ta.lowest(low, 20)
float d_h52       = ta.highest(high, 252)

// dLockH approximation (callout #1 above)
float dLockH      = ta.highest(high, 20)[1]
bool  hasLockH    = not na(dLockH)

// vcp_ok approximation (callout #3)
bool  vcp_ok      = not na(atr10) and not na(atr40) and atr40 > 0 and atr10 < (atr40 * 0.75)

// Weekly 30WMA cross (callout #2 — no Stage-2 filter)
bool  w_s2_cross  = request.security(syminfo.tickerid, "W", ta.crossover(close, ta.sma(close, 30)), ignore_invalid_symbol=true)

// ==========================================
// DETECTORS (verbatim from Dashboard v67.4.8, lines 2734-2960)
// ==========================================

// VCP Breakout — vcp_ok + close > 10d high + relVol > 1.2 + intra-pos ≥ 0.60
float _pa_10d_high_1 = ta.highest(high, 10)[1]
bool pa_vcp_bo = vcp_ok and close > _pa_10d_high_1 and curRelVol > 1.2 and (close - low) > ((high - low) * 0.60)

// Gap-Up Breakout — open > prior high, close > dLockH with vol, hold gap
bool volConfirm    = curRelVol > 1.25
bool pa_gap_up_bo  = hasLockH and open > high[1] and close > dLockH and close > open and volConfirm

// Stage-2 Launch — weekly 30WMA cross + vol
bool pa_s2_launch = w_s2_cross and curRelVol > 1.25

// 50SMA Undercut & Rally
bool pa_50sma_undercut = not na(dMA50) and dMA50 > 0 and low < dMA50 and close > dMA50 and close > open and curRelVol > 1.25

// Hammer geometry
float _bodyHi = math.max(open, close)
float _bodyLo = math.min(open, close)
float _body   = _bodyHi - _bodyLo
float _lower  = _bodyLo - low
float _upper  = high - _bodyHi
float _rng    = high - low
bool pa_hammer = _rng > 0 and _lower > _body * 2 and _upper < _body and (_bodyHi >= low + _rng * 0.66)

// Hammer at MA
bool _near_dma50  = not na(dMA50)  and dMA50  > 0 and math.abs(low - dMA50)  / dMA50  <= 0.015
bool _near_dma200 = not na(dMA200) and dMA200 > 0 and math.abs(low - dMA200) / dMA200 <= 0.020
bool pa_hammer_at_50  = pa_hammer and _near_dma50  and close > dMA50  and curRelVol > 1.0
bool pa_hammer_at_200 = pa_hammer and _near_dma200 and close > dMA200 and curRelVol > 1.0

// Outside Bar (Bullish)
bool pa_outside_bull = high > high[1] and low < low[1] and close > high[1] and close > open

// Inside Bar / NR7 / IB-NR7
bool pa_inside = high < high[1] and low > low[1]
bool _r0 = true
float _curRange = high - low
for _i = 1 to 6
    if (high[_i] - low[_i]) < _curRange
        _r0 := false
        break
bool pa_nr7    = _r0
bool pa_ib_nr7 = pa_inside and pa_nr7

// ==========================================
// ENTRY DISPATCH
// ==========================================
bool entrySignal = false
if testState == "VCP_BO"
    entrySignal := pa_vcp_bo
else if testState == "GAP_UP_BO"
    entrySignal := pa_gap_up_bo
else if testState == "STAGE_2_LAUNCH"
    entrySignal := pa_s2_launch
else if testState == "UNDERCUT_50SMA"
    entrySignal := pa_50sma_undercut
else if testState == "HAMMER_200SMA"
    entrySignal := pa_hammer_at_200
else if testState == "HAMMER_50SMA"
    entrySignal := pa_hammer_at_50
else if testState == "OUTSIDE_BAR_BULL"
    entrySignal := pa_outside_bull
else if testState == "IB_NR7_COIL"
    entrySignal := pa_ib_nr7

// ==========================================
// STRATEGY EXECUTION
// One position at a time. Time-based exit after `horizon_bars`.
// ==========================================
var int barsInTrade = 0

if strategy.position_size > 0
    barsInTrade := barsInTrade + 1
else
    barsInTrade := 0

bool canEnter = inTestWindow and strategy.position_size == 0 and entrySignal
if canEnter
    strategy.entry("PA_LONG", strategy.long, comment=testState)

if strategy.position_size > 0 and barsInTrade >= horizon_bars
    strategy.close("PA_LONG", comment="HORIZON_EXIT")

// ==========================================
// VISUALS (chart sanity check)
// ==========================================
plotshape(entrySignal and inTestWindow and strategy.position_size == 0,
     title="Entry",
     location=location.belowbar,
     style=shape.triangleup,
     color=color.new(#00c853, 0),
     size=size.small)

bgcolor(strategy.position_size > 0 ? color.new(color.green, 92) : na, title="In Trade")

// ==========================================
// DEBUG TABLE (top-right, visible on chart for sanity)
// ==========================================
var table dbg = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(dbg, 0, 0, "State:",       text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 1, 0, testState,      text_color=color.yellow, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 0, 1, "Horizon:",     text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 1, 1, str.tostring(horizon_bars) + " bars", text_color=color.aqua, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 0, 2, "Trades:",      text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 1, 2, str.tostring(strategy.closedtrades), text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 0, 3, "WinRate:",     text_color=color.white, bgcolor=color.new(color.gray, 70))
    float wr = strategy.closedtrades > 0 ? (strategy.wintrades / strategy.closedtrades) * 100 : 0.0
    table.cell(dbg, 1, 3, str.tostring(wr, "#.1") + "%", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 0, 4, "Net P&L%:",    text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 1, 4, str.tostring((strategy.netprofit / strategy.initial_capital) * 100, "#.2") + "%", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 0, 5, "ProfitFactor:",text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dbg, 1, 5, str.tostring(strategy.grossprofit / math.max(strategy.grossloss, 0.01), "#.2"), text_color=color.white, bgcolor=color.new(color.gray, 70))
