//@version=6
indicator("Weinstein Fundamental X-Ray v1.1", overlay=true, explicit_plot_zorder=true)

// ==========================================
// 1. INPUTS & APPEARANCE
// ==========================================
grp_ui = "UI Settings"
show_table  = input.bool(true, title="Show Data Table", group=grp_ui)
table_pos   = input.string("Bottom Right", title="Table Position", options=["Top Right", "Bottom Right", "Bottom Left", "Top Left", "Middle Right"], group=grp_ui)
text_size   = input.string("Small", title="Text Size", options=["Tiny", "Small", "Normal", "Large", "Auto"], group=grp_ui)
stack_pad   = input.int(26, title="Spacer Rows (For Stacking)", minval=0, maxval=50, group=grp_ui, tooltip="Increase this to push the table higher, allowing another dashboard (like Weinstein Suite) to sit underneath it.")

c_bg        = input.color(color.rgb(10, 20, 35, 10), title="Background Color", group=grp_ui)
c_text      = input.color(color.rgb(230, 237, 243, 0), title="Text Color", group=grp_ui)
c_good      = input.color(color.rgb(35, 134, 54, 0), title="Healthy Color", group=grp_ui)
c_warn      = input.color(color.rgb(227, 179, 65, 0), title="Warning Color", group=grp_ui)
c_bad       = input.color(color.rgb(248, 81, 73, 0), title="Danger Color", group=grp_ui)
c_border    = input.color(color.rgb(30, 58, 95, 0), title="Border Color", group=grp_ui)

// Helpers for Alignment
t_pos = table_pos == "Top Right" ? position.top_right : 
         table_pos == "Bottom Right" ? position.bottom_right : 
         table_pos == "Bottom Left" ? position.bottom_left : 
         table_pos == "Top Left" ? position.top_left : position.middle_right

t_size = text_size == "Tiny" ? size.tiny : 
          text_size == "Small" ? size.small : 
          text_size == "Normal" ? size.normal : 
          text_size == "Large" ? size.large : size.auto

// ==========================================
// 2. DATA EXTRACTION (request.financial)
// ==========================================
// Note: We use barmerge.lookahead_off to prevent data leakage and guarantee execution on current bar.
var string f_opts = "" // N/A

// SECTION A: EARNINGS & REVENUE (Quarterly Comparisons)
// Revenue (Total)
rev_fq = request.financial(syminfo.tickerid, "TOTAL_REVENUE", "FQ", ignore_invalid_symbol=true)
ni_fq  = request.financial(syminfo.tickerid, "NET_INCOME", "FQ", ignore_invalid_symbol=true)

// TradingView Native TTM Metrics (Usually stable)
eps_ttm         = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE", "TTM", ignore_invalid_symbol=true)
eps_diluted_fq  = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_DILUTED", "FQ", ignore_invalid_symbol=true)
rev_ttm         = request.financial(syminfo.tickerid, "TOTAL_REVENUE", "TTM", ignore_invalid_symbol=true)

// Growth Metrics (Manually Calculated to Prevent TV NSE Crashes)
rev_fq_4 = rev_fq[252] // Approx 1 Year Ago (Standard TV Daily approximation for step-lines)
ni_fq_4  = ni_fq[252]

rev_yoy_fq = (not na(rev_fq) and not na(rev_fq_4) and rev_fq_4 != 0) ? ((rev_fq - rev_fq_4) / math.abs(rev_fq_4)) * 100 : na
ni_yoy_fq  = (not na(ni_fq) and not na(ni_fq_4) and ni_fq_4 != 0) ? ((ni_fq - ni_fq_4) / math.abs(ni_fq_4)) * 100 : na

// SECTION B: PROFITABILITY & EFFICIENCY
// Calculate generic QoQ momentum using Series History
bool is_accelerating = false
if not na(ni_fq) and not na(ni_fq[65]) and not na(ni_fq[130])
    float g1 = (ni_fq - ni_fq[65]) / math.abs(ni_fq[65])
    float g2 = (ni_fq[65] - ni_fq[130]) / math.abs(ni_fq[130])
    if g1 > g2 and g1 > 0
        is_accelerating := true

// Manual Ratios (Safer than TV Native for NSE)
op_inc_fq = request.financial(syminfo.tickerid, "OPERATING_INCOME", "FQ", ignore_invalid_symbol=true)
equity_fq = request.financial(syminfo.tickerid, "TOTAL_EQUITY", "FQ", ignore_invalid_symbol=true)
assets_fq = request.financial(syminfo.tickerid, "TOTAL_ASSETS", "FQ", ignore_invalid_symbol=true)

op_margin_calc = (not na(op_inc_fq) and not na(rev_fq) and rev_fq != 0) ? (op_inc_fq / rev_fq) * 100 : na
roe_calc       = (not na(ni_fq) and not na(equity_fq) and equity_fq != 0) ? (ni_fq / equity_fq) * 100 : na
roa_calc       = (not na(ni_fq) and not na(assets_fq) and assets_fq != 0) ? (ni_fq / assets_fq) * 100 : na

// SECTION C: DEBT & VALUATION
debt_fq   = request.financial(syminfo.tickerid, "TOTAL_DEBT", "FQ", ignore_invalid_symbol=true)
shares_fq = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FQ", ignore_invalid_symbol=true)

debt_calc = (not na(debt_fq) and not na(equity_fq) and equity_fq != 0) ? (debt_fq / equity_fq) : na
pe_calc   = (not na(eps_ttm) and eps_ttm != 0) ? (close / eps_ttm) : na
pb_calc   = (not na(shares_fq) and not na(equity_fq) and equity_fq != 0) ? ((close * shares_fq) / equity_fq) : na

// ==========================================
// 3. MACRO & MARKET CONTEXT (request.security)
// ==========================================
// A. Macro Level (India 10Y Yield & USDINR)
in10y     = request.security("TVC:IN10Y", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
in10y_1m  = request.security("TVC:IN10Y", "D", close[21], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off) // 1 Month Ago

usdinr    = request.security("FX_IDC:USDINR", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
usdinr_1m = request.security("FX_IDC:USDINR", "D", close[21], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// B. Market Level (Nifty 500)
cnx500_close  = request.security("NSE:CNX500", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
cnx500_sma50  = request.security("NSE:CNX500", "D", ta.sma(close, 50), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
cnx500_sma200 = request.security("NSE:CNX500", "D", ta.sma(close, 200), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// Determine Macro/Market Health Strings
string yield_trend = na(in10y) ? "N/A" : (in10y > in10y_1m ? "RISING 🔴" : "FALLING 🟢") // Falling yields are generally good for equities
string fx_trend    = na(usdinr) ? "N/A" : (usdinr > usdinr_1m ? "WEAKENING 🔴" : "STRENGTHENING 🟢") // Weakening INR reduces FII buying

string mkt_health = "N/A"
if not na(cnx500_close) and not na(cnx500_sma200)
    if cnx500_close > cnx500_sma50 and cnx500_sma50 > cnx500_sma200
        mkt_health := "STRONG UPTREND 🟢"
    else if cnx500_close < cnx500_sma50 and cnx500_close < cnx500_sma200
        mkt_health := "DOWNTREND 🔴"
    else
        mkt_health := "SIDEWAYS / CHOP 🟡"

// C. Sector Definition
string asset_sector = syminfo.sector


// ==========================================
// 4. FORMATTING & LOGIC
// ==========================================
f_format_money(val) =>
    if na(val)
        "N/A"
    else if val >= 10000000000 // 10k Cr
        str.tostring(val / 10000000000, "#.1") + "K Cr"
    else if val >= 10000000 // 1 Cr
        str.tostring(val / 10000000, "#.1") + " Cr"
    else
        str.tostring(val, "#.#")

f_format_pct(val, is_ratio=false) =>
    if na(val)
        "N/A"
    else
        float pct_val = is_ratio ? val * 100 : val
        str.tostring(pct_val, "#.1") + "%"

f_format_float(val) =>
    if na(val)
        "N/A"
    else
        str.tostring(val, "#.2")

// Logic Determinations
color c_ni_grow  = na(ni_yoy_fq) ? c_text : (ni_yoy_fq > 0 ? c_good : c_bad)
color c_rev_grow = na(rev_yoy_fq) ? c_text : (rev_yoy_fq > 0 ? c_good : c_bad)

color c_margin = na(op_margin_calc) ? c_text : (op_margin_calc > 15 ? c_good : (op_margin_calc > 0 ? c_text : c_bad))
color c_roe    = na(roe_calc) ? c_text : (roe_calc > 15 ? c_good : (roe_calc > 0 ? c_text : c_bad))

// Debt to Equity in TV Native was originally treated like a percentage by default or scaling. Since we calculate it raw, 1.0 = 1x
color c_debt   = na(debt_calc) ? c_text : (debt_calc < 1.0 ? c_good : (debt_calc < 2.0 ? c_warn : c_bad))
color c_pe     = na(pe_calc) ? c_text : (pe_calc < 0 ? c_bad : (pe_calc < 40 ? c_good : c_warn))

// ==========================================
// 5. DRAWING THE DASHBOARD
// ==========================================
var table panel = table.new(t_pos, 3, 30 + stack_pad, border_width=1, border_color=c_border, frame_color=c_border, frame_width=2)

if barstate.islast and show_table
    // Header
    table.cell(panel, 0, 0, "FUNDAMENTAL X-RAY", bgcolor=c_bg, text_color=color.rgb(88, 166, 255), text_size=t_size, text_halign=text.align_center)
    table.merge_cells(panel, 0, 0, 1, 0)
    
    int r = 1
    
    // --- SECTION MACRO & MARKET ---
    table.cell(panel, 0, r, ">> MACRO & CLIMATE", bgcolor=color.new(c_border, 80), text_color=color.rgb(139, 148, 158), text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(panel, 0, r, 1, r)
    r += 1

    table.cell(panel, 0, r, "India 10Y Yield", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_float(in10y) + "% (" + yield_trend + ")", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1

    table.cell(panel, 0, r, "USD/INR", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_float(usdinr) + " (" + fx_trend + ")", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1

    table.cell(panel, 0, r, "CNX500 Market Trend", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, mkt_health, bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1

    table.cell(panel, 0, r, "Asset Sector", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, asset_sector, bgcolor=c_bg, text_color=color.rgb(227, 179, 65), text_size=t_size, text_halign=text.align_right)
    r += 1
    
    // --- SECTION A: EARNINGS & REVENUE ---
    table.cell(panel, 0, r, ">> MOMENTUM", bgcolor=color.new(c_border, 80), text_color=color.rgb(139, 148, 158), text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(panel, 0, r, 1, r)
    r += 1
    
    table.cell(panel, 0, r, "Revenue (TTM)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_money(rev_ttm), bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "EPS (TTM)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_float(eps_ttm), bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "Net Income Growth (QoQ YoY)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_pct(ni_yoy_fq), bgcolor=c_bg, text_color=c_ni_grow, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "Earnings Acceleration", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    string accel_str = is_accelerating ? "🟢 YES" : "🔴 NO"
    table.cell(panel, 1, r, accel_str, bgcolor=c_bg, text_color=is_accelerating ? c_good : c_bad, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "Revenue Growth (QoQ YoY)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_pct(rev_yoy_fq), bgcolor=c_bg, text_color=c_rev_grow, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    // --- SECTION B: PROFITABILITY & EFFICIENCY ---
    table.cell(panel, 0, r, ">> EFFICIENCY", bgcolor=color.new(c_border, 80), text_color=color.rgb(139, 148, 158), text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(panel, 0, r, 1, r)
    r += 1
    
    table.cell(panel, 0, r, "Operating Margin (FQ)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_pct(op_margin_calc), bgcolor=c_bg, text_color=c_margin, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "Return on Equity (FQ)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_pct(roe_calc), bgcolor=c_bg, text_color=c_roe, text_size=t_size, text_halign=text.align_right)
    r += 1

    table.cell(panel, 0, r, "Return on Assets (FQ)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_pct(roa_calc), bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    // --- SECTION C: HEALTH & VALUATION ---
    table.cell(panel, 0, r, ">> HEALTH & VALUE", bgcolor=color.new(c_border, 80), text_color=color.rgb(139, 148, 158), text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(panel, 0, r, 1, r)
    r += 1
    
    table.cell(panel, 0, r, "Debt to Equity (FQ)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    string debt_str = na(debt_calc) ? "N/A" : str.tostring(debt_calc, "#.2") + "x"
    table.cell(panel, 1, r, debt_str, bgcolor=c_bg, text_color=c_debt, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "P/E Ratio (Current)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    string pe_str = na(pe_calc) ? "N/A" : (pe_calc < 0 ? "Loss" : str.tostring(pe_calc, "#.1"))
    table.cell(panel, 1, r, pe_str, bgcolor=c_bg, text_color=c_pe, text_size=t_size, text_halign=text.align_right)
    r += 1
    
    table.cell(panel, 0, r, "Price to Book (Current)", bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_left)
    table.cell(panel, 1, r, f_format_float(pb_calc), bgcolor=c_bg, text_color=c_text, text_size=t_size, text_halign=text.align_right)
    r += 1
    // Clean Footer Spacer
    table.cell(panel, 0, r, " ", bgcolor=c_bg, text_color=c_bg)
    table.merge_cells(panel, 0, r, 1, r)
    r += 1

    // -------------------------------------
    // OPTION 2: SPACER ROWS FOR STACKING (BOTTOM RIGHT OVERLAP FIX)
    // -------------------------------------
    if table_pos == "Bottom Right" and stack_pad > 0
        for i = 1 to stack_pad
            table.cell(panel, 0, r, " ", bgcolor=color.new(color.black, 100), text_color=color.new(color.black, 100), height=1.3)
            table.merge_cells(panel, 0, r, 1, r)
            r += 1
