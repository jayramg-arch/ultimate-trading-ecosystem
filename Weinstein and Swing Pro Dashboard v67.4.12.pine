alertcondition(newStrongBuy, title="★ Strong Buy Signal", message="Weinstein Pro: STRONG BUY Signal Detected on {{ticker}}!")
alertcondition(hitPullback, title="📉 PULLBACK ZONE", message="Weinstein Pro: Valid Pullback Zone Detected on {{ticker}}!")
alertcondition(close > use_ema20 and close[1] < use_ema20, title="EMA 20 Crossover", message="Weinstein Pro: Price Crossed Above EMA 20 on {{ticker}}.")
alertcondition(mktState == "BEARISH", title="Market Health Alert", message="Weinstein Pro: Nifty 500 has flipped to BEARISH.")

// ==========================================
// COMPRESSED VIEW — composite row strings (v67.3.0)
// ==========================================
// Each string packs the same information that the detailed view shows across
// multiple rows. No data is lost — only the row count compresses. Renders
// only when show_detailed_view = false (Decision Mode).
// ==========================================

// v67.3.0 FIX: hoist roomStr / roomCol out of the detailed-render `if` block
// so the compressed view can reference them in compLvlStr. In Pine v6, locals
// declared inside `if barstate.islast` are scoped to that block only.
string roomStr = "CLEAR"
color  roomCol = color.new(#26a69a, 0)
if resistCount == 0 or na(ovhPrice)
    roomStr := "BLUE SKY 🚀"
    roomCol := color.new(#26a69a, 0)
else if ovhPrice <= close
    roomStr := "CLEAR (BO)"
    roomCol := color.new(#26a69a, 0)
else
    float distToOvh = ((ovhPrice - close) / close) * 100
    if finalEntry > 0 and finalSL > 0
        float computedRisk = math.abs(finalEntry - finalSL)
        float t1_val_check = finalEntry + (computedRisk * dyn_T1_R)
        if t1_val_check > ovhPrice and close < ovhPrice
            roomStr := "⚠️ NO ROOM (vs " + str.tostring(math.round_to_mintick(ovhPrice)) + ")"
            roomCol := color.orange
        else
            roomStr := "CLEAR (" + str.tostring(distToOvh, "#.1") + "%)"
    else
        roomStr := str.tostring(distToOvh, "#.1") + "% (vs " + str.tostring(math.round_to_mintick(ovhPrice)) + ")"
        roomCol := distToOvh < 5.0 ? color.new(#ff9800, 0) : color.new(#26a69a, 0)

// v67.4.13: prospective Gate-3 R:R preview for setups with NO entry profile set
// (finalEntry == 0, so the active-trade "Current R:R" row never fires). Estimates
// entry = close, SL = close − 2.5 × ATR(14) (consistent with the 14-day ATR stop
// methodology), reward = distance to nearest overhead level (ovhPrice). It is an
// ESTIMATE only ("~" prefix) and is appended to the LEVELS / ROOM compact row —
// it does NOT create/modify any entry/SL profile and does NOT touch RRG logic.
string setupRRStr = ""
if finalEntry == 0 and atrVal > 0 and close > 0
    float _estEntry = close
    float _estRisk  = atrVal * 2.5
    if _estRisk > 0
        if resistCount == 0 or na(ovhPrice)
            setupRRStr := " · ~R:R open ▲"
        else if ovhPrice > _estEntry
            float _estRR = (ovhPrice - _estEntry) / _estRisk
            setupRRStr := " · ~R:R " + str.tostring(_estRR, "#.1") + "R"

// --- RRG helpers (v67.4.1: compressed — JdK centered, RRG plane projection).
// Inputs centered on 0 (RS_Ratio-100 / RS_Momentum-100). Same >0 semantics
// as legacy Mansfield. See changelog for backtest rationale (n=5,460).
f_rrg_quad(float v, float m) =>
    v >= 0 and m >= 0 ? "Leading" : v >= 0 ? "Weakening" : m >= 0 ? "Improving" : "Lagging"
f_rrg_quad_letter(float v, float m) =>
    v >= 0 and m >= 0 ? "L" : v >= 0 ? "W" : m >= 0 ? "I" : "G"

// Combined trajectory + score + tradeable in ONE function (tokens).
// Returns [arrow, traj, cur, nxt, score, tradeable].
f_rrg_info(float v, float m, float vt, float mt) =>
    float dv = v - vt
    float dm = m - mt
    string cur = v >= 0 and m >= 0 ? "LEADING" : v >= 0 ? "WEAKENING" : v < 0 and m < 0 ? "LAGGING" : "IMPROVING"
    string nxt = cur
    if cur == "LEADING"
        nxt := dm < -0.3 ? "WEAKENING" : (dv < -0.3 and dm < 0.3 ? "IMPROVING" : cur)
    else if cur == "WEAKENING"
        nxt := dv < -0.3 ? "LAGGING"   : (dm >  0.3 and dv > -0.3 ? "LEADING"   : cur)
    else if cur == "LAGGING"
        nxt := dm >  0.3 ? "IMPROVING" : (dv >  0.3 and dm > -0.3 ? "WEAKENING" : cur)
    else
        nxt := dv >  0.3 ? "LEADING"   : (dm < -0.3 and dv <  0.3 ? "LAGGING"   : cur)
    string arrow = dv > 0.3 ? (dm > 0.3 ? "↗️" : dm < -0.3 ? "↘️" : "➡️") : dv < -0.3 ? (dm > 0.3 ? "↖️" : dm < -0.3 ? "↙️" : "⬅️") : dm > 0.3 ? "⬆️" : dm < -0.3 ? "⬇️" : "•"
    string traj = nxt == cur ? cur + " (stable)" : cur + " → " + nxt
    // v67.4.3: recalibrated on n=5,020 new-formula backtest.
    // Score: only LEADING earns bonus (+2). Other quadrants flat in new data.
    // Tradeable: cell-level — positive-alpha cells only.
    int sc = cur == "LEADING" ? 2 : 0
    bool tr = (cur == "LEADING"   and (nxt == "LEADING"   or nxt == "IMPROVING")) or
              (cur == "IMPROVING" and  nxt == "LEADING")  or
              (cur == "LAGGING"   and  nxt == "IMPROVING") or
              (cur == "WEAKENING" and  nxt == "LEADING")
    [arrow, traj, cur, nxt, sc, tr]

// --- Market regime short code ---
string _mkt_short = str.contains(mktState, "BULLISH")  ? "BULL"
                  : str.contains(mktState, "CORRECTION") ? "CORR"
                  : str.contains(mktState, "RECOVERY") ? "RCVR"
                  : str.contains(mktState, "BEARISH") ? "BEAR" : "N/A"

// --- Sector stage short emoji ---
string _sec_emoji = secStageNum == 2 ? "S2" : secStageNum == 1 ? "S1" : secStageNum == 3 ? "S3⚠" : secStageNum == 4 ? "S4🔻" : "n/a"

// --- Sector velocity short code (3-4 letter) ---
string _sec_vel_short = str.contains(secVelStr, "ACCELERATING") ? "Acc"
                     : str.contains(secVelStr, "EXHAUSTED")    ? "Exh"
                     : str.contains(secVelStr, "HIDDEN")       ? "Hid"
                     : str.contains(secVelStr, "DEAD")         ? "Dead"
                     : "Static"

// --- Earnings suffix (red flag when <5 days) ---
string _er_suffix = earnStr == "N/A" ? "" : (" · ER: " + earnStr)

// 1. MACRO / SECTOR (one row, was 4-5)
string compMacroStr = _mkt_short + " · Sec: " + str.replace_all(str.replace_all(syminfo.sector, " ", ""), "/", "/") + " " + _sec_emoji + " " + _sec_vel_short + _er_suffix
color  compMacroCol = _mkt_short == "BULL" ? color.new(#26a69a, 0) : _mkt_short == "BEAR" ? color.new(#ef5350, 0) : _mkt_short == "CORR" ? color.new(#ff9800, 30) : _mkt_short == "RCVR" ? color.new(#3b82f6, 0) : color.gray

// 2. RS (JdK) (one row, was 3) — Dashboard's canonical engine
// v67.4: Migrated to JdK 2-pass RS-Ratio/RS-Momentum (StockCharts default,
// parity with Bull Screener). Added rotation trajectory (e.g. "LEADING → WEAKENING")
// so a glance shows where the stock is heading on the RRG plane, not just where it sits.
string _rrg500_letter = f_rrg_quad_letter(val500, _rsMom500)
string _rrg500_full   = f_rrg_quad(val500, _rsMom500)
string _rrgSec_full   = f_rrg_quad(valSec, _rsMomSec)
[_rrg500_arrow, _rrg500_traj, _rrg500_cur, _rrg500_nxt, _rrg500_score, _rrg500_tradeable] = f_rrg_info(val500, _rsMom500, _valTrail500, _momTrail500)
string _tr_tag = _rrg500_tradeable ? "✓ BUY OK" : "✗ WAIT"
// v67.4.1: split RS and RRG into TWO distinct compressed rows.
// compRsStr = per-benchmark direction/level only (Mansfield-style state).
// compRrgStr = RRG quadrant + arrow + trajectory + score + tradeable.
// RS row uses the legacy f_rsStateStr direction/level labels (Rising/Declining/Flat
// + Positive/Negative/Neutral) — same wording as the detailed-view RS rows.
string compRsStr  = "N500: " + f_rrg_icon(rs500State) + " " + rs500State + "  ·  Sec: " + f_rrg_icon(rsSecState) + " " + rsSecState
color  compRsCol  = f_rrg_color(rsSecState)
string compRrgStr = _rrg500_cur + " " + _rrg500_arrow + "  " + (_rrg500_score > 0 ? "+" : "") + str.tostring(_rrg500_score) + "  ·  " + _rrg500_traj + "  ·  " + _tr_tag + "  (RS-Ratio " + str.tostring(val500 + 100, "#.#") + ")"
// Color: tradeable=false (cliff-edge LEADING etc.) → RED. Else quadrant color.
color  compRrgCol = not _rrg500_tradeable ? color.new(#ef5350, 0) : _rrg500_cur == "LEADING" ? color.new(#26a69a, 0) : _rrg500_cur == "WEAKENING" ? color.new(#ff9800, 0) : _rrg500_cur == "IMPROVING" ? color.new(#3b82f6, 0) : color.new(#ef5350, 0)

// 3. CATALYST + GATES (one row, was 2)
string _failing_gates = ""
_failing_gates := (g1_stage    ? "" : " G1") + (g2_above200 ? "" : " G2") + (g3_secRS    ? "" : " G3") + (g4_secStage ? "" : " G4") + (g5_trendTpl ? "" : " G5") + (g6_volAcc   ? "" : " G6") + (g7_fresh    ? "" : " G7") + (g8_maSqz    ? "" : " G8") + (g9_bbSqz    ? "" : " G9")
string _gates_bracket = (g1_stage ? "1" : "·") + (g2_above200 ? "2" : "·") + (g3_secRS ? "3" : "·") + (g4_secStage ? "4" : "·") + (g5_trendTpl ? "5" : "·") + (g6_volAcc ? "6" : "·") + (g7_fresh ? "7" : "·") + (g8_maSqz ? "8" : "·") + (g9_bbSqz ? "9" : "·")
string compCatStr = chartCat + " · POS-BO: " + str.tostring(bs_gates_passing) + "/9 [" + _gates_bracket + "]" + (bs_gates_passing < 9 and str.length(_failing_gates) > 0 ? "  ⚠" + _failing_gates : "")
color  compCatCol = catalyst_id > 0 and bs_gates_passing == 9 ? color.new(#26a69a, 0) : catalyst_id > 0 ? chartCatCol : (bs_gates_passing >= 6 ? color.new(#ff9800, 0) : color.gray)

// 4. WEEKLY STRUCTURE (one row, was 5-6)
string _w_arrow = wTrendDir == 1 ? "↗️" : wTrendDir == -1 ? "↘️" : "↔️"
string _pb_suffix = wHealthStr == "N/A" or wHealthStr == "" ? "" : (" · PB " + (wHealthStr == "HEALTHY (Low Vol)" ? "Healthy" : str.contains(wHealthStr, "NORMAL") ? "Normal" : "Weak"))
string compWeeklyStr = stageDisplay + (isStage2Family ? " · " + str.tostring(stageWeeks) + "w leg/" + str.tostring(macroStageWeeks) + "w macro · " + stage2FreshTag : "") + " · W" + _w_arrow + _pb_suffix
color  compWeeklyCol = stageCol

// 5. DAILY STRUCTURE (one row, was 5)
string _d_arrow = dTrendDir == 1 ? "↗️" : dTrendDir == -1 ? "↘️" : "↔️"
string _50dma_arrow = d50SlopeState == "RISING" ? "↗️" : d50SlopeState == "FALLING" ? "↘️" : "↔️"
string _engine_short = trend_engine_canonical ? "Engine v6.2 L" + str.tostring(pivotLeft) + "/R" + str.tostring(pivotRight) + " ✓" : "Engine ⚠ Sync Zigzag"
string compDailyStr = "D" + _d_arrow + " · 50DMA" + _50dma_arrow + " " + (dSmaAligned ? "Aligned" : "Misaligned") + " · " + _engine_short
color  compDailyCol = dTrendDir == 1 and dSmaAligned ? color.new(#26a69a, 0) : dTrendDir == -1 ? color.new(#ef5350, 0) : color.new(#ff9800, 30)

// 6. PRICE ACTION (one row, unchanged content, denser format)
string compPaStr = paState + " [paTier " + (paTier >= 0 ? "+" : "") + str.tostring(paTier) + "]"
color  compPaCol = paColor

// 7. MOMENTUM (one row, was 4-5)
string _div_suffix = currRsiDiv == "BULLISH DIV" ? " ⚠Bull" : currRsiDiv == "BEARISH DIV" ? " ⚠Bear" : ""
string _vol_short  = str.contains(volState, "ACCUMULATION") ? "Accum " + str.tostring(curRelVol, "#.1") + "x"
                   : str.contains(volState, "DISTRIBUTION") ? "Distr " + str.tostring(curRelVol, "#.1") + "x"
                   : str.contains(volState, "DRY UP")      ? "DryUp " + str.tostring(curRelVol, "#.1") + "x"
                   : str.contains(volState, "SQUEEZE")     ? "Squeeze"
                   : "Vol " + str.tostring(curRelVol, "#.1") + "x"
string _adr_short  = str.contains(patStr, "True Dry Up") ? "VCP True" : str.contains(patStr, "Actionable") ? "VCP Act" : str.contains(patStr, "Expansion") ? "Expansion" : "ADR Norm"
string _pb_zone_suffix = hitPullback ? " · PB:Zone" : ""
string compMomStr = "RSI " + str.tostring(currRsi, "#.#") + _div_suffix + " · " + _vol_short + " · " + _adr_short + " · EMA20 " + (emaDist >= 0 ? "+" : "") + str.tostring(emaDist, "#.#") + "%" + _pb_zone_suffix
color  compMomCol = currRsiDiv == "BEARISH DIV" ? color.new(#ef5350, 0) : currRsiDiv == "BULLISH DIV" ? color.new(#26a69a, 0) : str.contains(volState, "ACCUMULATION") ? color.new(#26a69a, 30) : color.new(#f5f5f5, 0)

// 8. LEVELS / ROOM (one row, was 4-5)
string _ath_short = devATH < 0 or na(devATH) ? "ATH " + str.tostring(math.abs(devATH), "#.#") + "%" : "ATH⬆️"
string compLvlStr = str.tostring(resistCount) + " Resist · " + roomStr + " · 52W: " + s_dev52 + " · " + _ath_short + (keyLvlState == "MID-RANGE (No Near Level)" ? "" : " · " + keyLvlState) + setupRRStr
color  compLvlCol = str.contains(roomStr, "NO ROOM") ? color.new(#ff9800, 0) : str.contains(roomStr, "BLUE SKY") ? color.new(#26a69a, 0) : color.new(#f5f5f5, 0)

// 9. STYLE / PERSONA (one row, was 2)
string compStyleStr = style_txt + " · " + persona_txt
color  compStyleCol = style_txt == "🚀 BOTH" ? color.new(#FFD700, 0) : str.contains(style_txt, "POSITIONAL") ? color.new(color.blue, 0) : str.contains(style_txt, "SWING") ? color.new(color.fuchsia, 0) : color.gray

// 10. MY TRADE (one row, was 2-3) — only when position open
string compMyTradeStr = tradeStatus + " · " + rrText + " · " + mktProfile
color  compMyTradeCol = tradeColor

// 11. POSITION STATUS (one row, was 3) — only when position open
string compPosStatusStr = "Entry " + entryDateStr + " · " + str.tostring(daysHeld) + "d · " + timeWarnStr
color  compPosStatusCol = timeWarnCol

// ==========================================
// DRAWING
// ==========================================
var table panel = table.new(tablePos, 4, 60, border_width=1, border_color=color.gray)  // v65.0: bumped 50→60 to accommodate recovery panel rows


drawRowL(tbl, r, title, valText, valColor, cellBg, titleColor, valTextColor) =>
    table.cell(tbl, 0, r, title, bgcolor=cellBg, text_color=titleColor, text_size=textSize, text_halign=text.align_left)
    table.cell(tbl, 1, r, valText, bgcolor=valColor, text_color=valTextColor, text_size=textSize, text_halign=text.align_center)

drawRowR(tbl, r, title, valText, valColor, cellBg, titleColor, valTextColor) =>
    table.cell(tbl, 2, r, title, bgcolor=cellBg, text_color=titleColor, text_size=textSize, text_halign=text.align_left)
    table.cell(tbl, 3, r, valText, bgcolor=valColor, text_color=valTextColor, text_size=textSize, text_halign=text.align_center)

// v67.3.0: full-width row for Decision-Mode (compressed view).
// Merges columns 1-3 so the composite string can render across the whole cell.
drawRowC(tbl, r, title, valText, valColor, cellBg, titleColor, valTextColor) =>
    table.cell(tbl, 0, r, title, bgcolor=cellBg, text_color=titleColor, text_size=textSize, text_halign=text.align_left)
    table.merge_cells(tbl, 1, r, 3, r)
    table.cell(tbl, 1, r, valText, bgcolor=valColor, text_color=valTextColor, text_size=textSize, text_halign=text.align_left)

// v67.3.0: DETAILED VIEW — preserved verbatim, gated by show_detailed_view toggle.
//   When OFF (default), control flows to the compressed render block below.
if barstate.islast and show_detailed_view
    int rowL = 0
    int rowR = 0

    // ── V1.3 Unified Palette ──────────────────────────────────────────────────
    color C_HDR     = color.new(#1e222d, 0)   // dark header
    color C_LBL     = color.new(#ffffff, 0)   // white label bg
    color C_LBL_TXT = color.new(#000000, 0)   // black label text
    color C_VAL_TXT = color.new(#000000, 0)   // black value text
    color C_BULL    = color.new(#26a69a, 0)   // teal  — bullish / pass
    color C_WARN    = color.new(#ff9800, 0)   // orange — caution / hold
    color C_BEAR    = color.new(#ef5350, 0)   // red   — bearish / fail
    color C_NEUT    = color.new(#f5f5f5, 0)   // light grey — neutral / n/a
    color C_LIME    = color.new(#00c853, 0)   // bright green — strong bull

    // Header Left
    table.cell(panel, 0, rowL, "WEINSTEIN DASHBOARD", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, syminfo.ticker, bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    // Header Right
    table.cell(panel, 2, rowR, "DATE", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, str.tostring(year(timenow)) + "-" + str.tostring(month(timenow)) + "-" + str.tostring(dayofmonth(timenow)), bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    rowL += 1
    rowR += 1

    if panicExit
        drawRowL(panel, rowL, "⚠️ CRITICAL ALERT", "PRICE < 40WMA", C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
        rowL += 1

    // --- LEFT COLUMN ---
    // 1. BREADTH & SECTOR
    table.cell(panel, 0, rowL, "── BREADTH & SECTOR ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, "", bgcolor=C_HDR)
    rowL += 1

    drawRowL(panel, rowL, "Mkt Health (N500)", mktState, mktColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    string secStr = syminfo.sector + " / " + syminfo.industry
    drawRowL(panel, rowL, "Sector Info", secStr, C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    color _secStageDispCol = str.contains(secStageStr, "STAGE 2") ? color.new(#26a69a, 0) : str.contains(secStageStr, "STAGE 1") ? color.new(#ff9800, 0) : color.new(#ef5350, 0)
    drawRowL(panel, rowL, "Sector Stage (W)", secStageStr, _secStageDispCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Sector Velocity (ROC)", secVelStr, secVelCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "RS (vs Nifty 50)", f_rrg_icon(rs50State) + " " + rs50State, f_rrg_color(rs50State), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "RS (vs N500)", f_rrg_icon(rs500State) + " " + rs500State, f_rrg_color(rs500State), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "RS (" + autoSectorName + ")", f_rrg_icon(rsSecState) + " " + rsSecState, f_rrg_color(rsSecState), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    // v67.4.1: dedicated RRG row — quadrant + arrow + trajectory + score + tradeable.
    // Distinct from RS rows above (which show direction/level only). Color reflects
    // tradeable gate: red if cliff-edge LEADING or LAGGING, green otherwise.
    string _rrgL_txt = _rrg500_cur + " " + _rrg500_arrow + "  " + (_rrg500_score > 0 ? "+" : "") + str.tostring(_rrg500_score) + "  ·  " + _rrg500_traj + "  ·  " + (_rrg500_tradeable ? "✓ BUY OK" : "✗ WAIT") + "  (RS-Ratio " + str.tostring(val500 + 100, "#.#") + ")"
    color  _rrgL_col = _rrg500_tradeable ? color.new(#26a69a, 0) : color.new(#ef5350, 0)
    drawRowL(panel, rowL, "RRG (vs N500)", _rrgL_txt, _rrgL_col, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Next Earnings", earnStr, earnColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1

    // 2. ASSET QUALITY & CONFIRMATION
    table.cell(panel, 0, rowL, "── ASSET QUALITY & CONFIRM ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, "", bgcolor=C_HDR)
    rowL += 1

    drawRowL(panel, rowL, "ASSET QUALITY", assetQuality, gradeCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Vol Accum (Setup)", vol_acc_ok ? "PASS" : "WAIT", vol_acc_ok ? C_BULL : C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "VCP Tightness", vcp_ok ? "PASS" : "WAIT", vcp_ok ? C_BULL : C_WARN, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Vol Shelf (VWMA)", vol_shelf_ok ? "YES" : "NO", vol_shelf_ok ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Price > M-VWAP", mvwap_ok ? "YES" : "NO", mvwap_ok ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Daily Close > CPR", cpr_ok ? "YES" : "NO", cpr_ok ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "Anti-Algo BO Gate", anti_algo_ok ? "PASS" : "FAIL", anti_algo_ok ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1

    // 3. THE VERDICT & SETUP
    table.cell(panel, 0, rowL, "── THE VERDICT & SETUP ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, "", bgcolor=C_HDR)
    rowL += 1

    drawRowL(panel, rowL, "RECOMMENDATION", displayRec, recColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "CATALYST (Edge)", chartCat, chartCatCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    // v67.2.5: POS-BO gate transparency row. Mirrors the Bull Screener's 9-gate stack.
    //   GREEN  9/9 = all gates pass (POS-BO catalyst is eligible to fire)
    //   ORANGE 6-8 = close but blocked — note which gates are red below
    //   RED    <6 = setup not ready
    string _gates_str = str.tostring(bs_gates_passing) + "/9 [" + (g1_stage ? "1" : "·") + (g2_above200 ? "2" : "·") + (g3_secRS ? "3" : "·") + (g4_secStage ? "4" : "·") + (g5_trendTpl ? "5" : "·") + (g6_volAcc ? "6" : "·") + (g7_fresh ? "7" : "·") + (g8_maSqz ? "8" : "·") + (g9_bbSqz ? "9" : "·") + "]"
    color _gates_col = bs_gates_passing == 9 ? C_BULL : (bs_gates_passing >= 6 ? C_WARN : C_BEAR)
    drawRowL(panel, rowL, "POS-BO Gates", _gates_str, _gates_col, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "ACTION SIGNAL", actionSignal, conf_col, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "TRADE STYLE", style_txt, style_col, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1
    drawRowL(panel, rowL, "PERSONA", persona_txt, persona_col, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowL += 1

    // 4. TRADE & PORTFOLIO STATUS
    table.cell(panel, 0, rowL, "── TRADE & PORTFOLIO ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, "", bgcolor=C_HDR)
    rowL += 1

    if tradeActive
        drawRowL(panel, rowL, "MY TRADE", tradeStatus, tradeColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
        rowL += 1
        drawRowL(panel, rowL, "ENTRY DATE", entryDateStr, C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
        rowL += 1
        drawRowL(panel, rowL, "DAYS HELD", str.tostring(daysHeld) + " Day(s)", daysHeld > 30 ? C_BULL : C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
        rowL += 1
        drawRowL(panel, rowL, "Time Stop (P/S)", timeWarnStr, timeWarnCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
        rowL += 1
        if finalSL > 0
            drawRowL(panel, rowL, "Dynamic Profile", mktProfile, isBullMarket ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
            rowL += 1
            drawRowL(panel, rowL, "Current R:R", rrText, currentR >= 1.0 ? C_BULL : C_WARN, C_LBL, C_LBL_TXT, C_VAL_TXT)
            rowL += 1

    // --- RIGHT COLUMN ---
    // 1. POSITIONAL: THE HUNTER
    table.cell(panel, 2, rowR, "── 🦁 POSITIONAL: THE HUNTER ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, "(Weinstein/Weekly)", bgcolor=C_HDR, text_color=color.white, text_size=size.small, text_halign=text.align_center)
    rowR += 1

    drawRowR(panel, rowR, "Market Structure", stageDisplay, stageCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    // v67.2.2: split the week count out of Market Structure into its own row.
    //   leg   = sub-stage age (resets on UP↔PULLBACK) — same anchor the Dashboard always used
    //   macro = full Stage-2 lifespan (matches Commander Bull Screener)
    //   tag   = Fresh / Maturing / Extended — keys off stage2_fresh_weeks input
    drawRowR(panel, rowR, "Stage 2 Age", stage2AgeStr, stage2FreshCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Master Trend (W)", f_trendText(wTrendDir), f_trendColor(wTrendDir), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    bool pAbove30 = wClose > wMA30
    drawRowR(panel, rowR, "Price > 30W MA", pAbove30 ? "YES" : "NO", pAbove30 ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "30-Week MA Slope", wMASlopeState, wMASlopeState == "RISING" ? C_BULL : (wMASlopeState == "FALLING" ? C_BEAR : C_NEUT), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Weekly PB Health", wkHealthStr, wkHealthCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Overhead Resist", str.tostring(resistCount) + " Level(s)", resistCount == 0 ? C_BULL : C_WARN, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    
    // --- Room for Trade Metric (computed at global scope in v67.3.0, see above) ---
    drawRowR(panel, rowR, "Room for Trade", roomStr, roomCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1

    drawRowR(panel, rowR, "52W High Space", s_dev52, dev52 > -15 ? C_BULL : C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "ATH Space", s_devATH, (not na(devATH) and devATH > -15) ? C_BULL : C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1

    // 2. SWING: THE SNIPER
    table.cell(panel, 2, rowR, "── 🎯 SWING: THE SNIPER ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, "(Minervini/Daily)", bgcolor=C_HDR, text_color=color.white, text_size=size.small, text_halign=text.align_center)
    rowR += 1

    drawRowR(panel, rowR, "Daily Trend (D)", f_trendText(dTrendDir), f_trendColor(dTrendDir), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    // v67.2.4: Trend Engine config. Mirrors the on-chart Zigzag [Strict v6.2].
    // GREEN = canonical defaults (matches Zigzag out-of-the-box).
    // ORANGE = user overrode pivot or eq_threshold — must apply same override
    // to Zigzag panel or Daily Trend rows will disagree across tools.
    drawRowR(panel, rowR, "Trend Engine", trend_engine_str, trend_engine_col, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Trend Template (>200d)", dSmaAligned ? "ALIGNED" : "MISALIGNED", dSmaAligned ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    bool pAbove50 = dClose > dMA50
    drawRowR(panel, rowR, "Price > 50 DMA", pAbove50 ? "YES" : "NO", pAbove50 ? C_BULL : C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "50 DMA Slope", d50SlopeState, d50SlopeState == "RISING" ? C_BULL : (d50SlopeState == "FALLING" ? C_BEAR : C_NEUT), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Price Action Structure", paState, paColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Volume Trend", volState, volColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Volatility State (ADR)", patStr, C_NEUT, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, ema_lbl + " Proximity", emaState, emaColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Key-Level/Zone Proximity", keyLvlState, keyLvlColor, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    string rsiStr = str.tostring(currRsi, "#.##") + " / " + currRsiDiv
    drawRowR(panel, rowR, "RSI & Divergence", rsiStr, currRsiDiv == "BULLISH DIV" ? C_BULL : (currRsiDiv == "BEARISH DIV" ? C_BEAR : C_NEUT), C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1
    drawRowR(panel, rowR, "Daily Pullback Health", dayHealthStr, dayHealthCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
    rowR += 1

// ==========================================
// v67.3.0: COMPRESSED VIEW (Decision Mode) — default rendering
// ==========================================
// 13-18 rows depending on whether a position is open. All information from the
// detailed view is preserved through composite cells (see compMacroStr,
// compRsStr, etc. computed above). Toggle "Show Detailed View" to expand back.
// ==========================================
if barstate.islast and not show_detailed_view
    int row = 0

    color C_HDR     = color.new(#1e222d, 0)
    color C_LBL     = color.new(#ffffff, 0)
    color C_LBL_TXT = color.new(#000000, 0)
    color C_VAL_TXT = color.new(#000000, 0)
    color C_BULL    = color.new(#26a69a, 0)
    color C_WARN    = color.new(#ff9800, 0)
    color C_BEAR    = color.new(#ef5350, 0)
    color C_NEUT    = color.new(#f5f5f5, 0)
    color C_LIME    = color.new(#00c853, 0)

    // Header (full width)
    table.cell(panel, 0, row, "WEINSTEIN DASHBOARD · " + syminfo.ticker, bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.merge_cells(panel, 0, row, 2, row)
    table.cell(panel, 3, row, str.tostring(year(timenow)) + "-" + str.tostring(month(timenow)) + "-" + str.tostring(dayofmonth(timenow)), bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    row += 1

    // CRITICAL ALERT (only when active)
    if panicExit
        drawRowC(panel, row, "⚠️ CRITICAL ALERT", "PRICE < 40WMA — EXIT NOW", C_BEAR, C_LBL, C_LBL_TXT, C_VAL_TXT)
        row += 1

    // === 🎯 ACT NOW (4 rows) ===
    table.cell(panel, 0, row, "── 🎯 ACT NOW ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.merge_cells(panel, 0, row, 3, row)
    row += 1

    drawRowC(panel, row, "RECOMMENDATION",    displayRec,        recColor,         C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "ACTION SIGNAL",     actionSignal,      conf_col,         C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "CATALYST + GATES",  compCatStr,        compCatCol,       C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "ASSET QUALITY",     scoreStr,          gradeCol,         C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1

    // === 📊 STRUCTURE (5 rows) ===
    table.cell(panel, 0, row, "── 📊 STRUCTURE ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.merge_cells(panel, 0, row, 3, row)
    row += 1

    drawRowC(panel, row, "WEEKLY STRUCTURE",  compWeeklyStr,     compWeeklyCol,    C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "DAILY STRUCTURE",   compDailyStr,      compDailyCol,     C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "PRICE ACTION",      compPaStr,         compPaCol,        C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "MOMENTUM",          compMomStr,        compMomCol,       C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "LEVELS / ROOM",     compLvlStr,        compLvlCol,       C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1

    // === 🌐 CONTEXT (3 rows) ===
    table.cell(panel, 0, row, "── 🌐 CONTEXT ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.merge_cells(panel, 0, row, 3, row)
    row += 1

    drawRowC(panel, row, "MACRO / SECTOR",    compMacroStr,      compMacroCol,     C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "RS (vs N500/Sec)",  compRsStr,         compRsCol,        C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "RRG (vs N500)",     compRrgStr,        compRrgCol,       C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1
    drawRowC(panel, row, "STYLE / PERSONA",   compStyleStr,      compStyleCol,     C_LBL, C_LBL_TXT, C_VAL_TXT)
    row += 1

    // === 📦 PORTFOLIO ===
    table.cell(panel, 0, row, "── 📦 PORTFOLIO ──", bgcolor=C_HDR, text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.merge_cells(panel, 0, row, 3, row)
    row += 1

    if tradeActive
        drawRowC(panel, row, "MY TRADE",          compMyTradeStr,    compMyTradeCol,   C_LBL, C_LBL_TXT, C_VAL_TXT)
        row += 1
        drawRowC(panel, row, "POSITION STATUS",   compPosStatusStr,  compPosStatusCol, C_LBL, C_LBL_TXT, C_VAL_TXT)
        row += 1



plot(wMA30, "30W MA", color=wMASlopeState == "RISING" ? color.green : color.red, linewidth=2)
plot(wMA40, "40W MA", color=color.black, linewidth=1)

// ==========================================
// AUTO-ANCHORED VWAP (Stage 2 Focus)
// ==========================================
// v67.2 FIX #8: Removed duplicate `request.security` for f_getStageAndTime —
//   we now reuse the `stageStart` already returned by the weekly super-bundle
//   at the top of section 5 (saves 1 of the 40 request.security budget).
// v67.2 FIX #9: `last_anchor_time` previously initialised to 0, so on bar 0
//   `time >= 0` was true and the AVWAP accumulator soaked in epoch-to-now
//   history before any anchor was set. Sentinel changed to 1 with a guard.
var float cumVol = 0.0
var float cumVolPrice = 0.0
var int   last_anchor_time = 1  // sentinel: 1 = "no real anchor yet"

// Reset AVWAP when the weekly stage start time changes (new stage began)
if not na(stageStart) and stageStart != last_anchor_time
    cumVol := 0.0
    cumVolPrice := 0.0
    last_anchor_time := stageStart

// Only accumulate AFTER a real anchor has been set (sentinel > 1)
if last_anchor_time > 1 and time >= last_anchor_time
    cumVol += volume
    cumVolPrice += (hlc3 * volume)

float avwap = cumVol > 0 ? cumVolPrice / cumVol : na

plot(showAVWAP and stageID == "STAGE 2 (UP)" ? avwap : na, title="Auto AVWAP (Stage 2)", color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_line)

// ==========================================
// TRADE LINES & LABELS (v20.0 Logic Ported)
// ==========================================

// Helper for Distance %
f_dist(float lvl) =>
    float d = ((lvl - close) / close) * 100
    string s = (d > 0 ? "+" : "") + str.tostring(d, "#.1") + "%"
    s

// Target Logic (2R and 3R as per v20.0)
visualSL := finalTSL > 0 ? finalTSL : finalSL
float risk_per_share = math.abs(finalEntry - finalSL)
float t1_val = finalEntry + (risk_per_share * dyn_T1_R)
float t2_val = finalEntry + (risk_per_share * dyn_T2_R)
float t3_val = finalEntry + (risk_per_share * dyn_T3_R)

// PLOTS (Continuous Lines for History)
// Fix: Simplified condition to 'tradeActive' to restore draggability (TV requires plot series to be linked to inputs consistently)
color entryColor = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.blue, 0) : color.new(color.blue, 100)
color slColor    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.red, 0) : color.new(color.red, 100)
color t1Color    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.green, 30) : color.new(color.green, 100)
color t2Color    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.green, 50) : color.new(color.green, 100)
color t3Color    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.green, 70) : color.new(color.green, 100)

plot(showTrade and finalEntry > 0 ? finalEntry : na, "Entry Price", color=entryColor, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive ? visualSL : na, "Hard SL (Trail)", color=slColor, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 and visualSL < finalEntry ? t1_val : na, "Target 1 (Dynamic)", color=t1Color, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 and visualSL < t2_val ? t2_val : na, "Target 2 (Dynamic)", color=t2Color, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 and visualSL >= finalEntry ? t3_val : na, "Target 3 (Dynamic)", color=t3Color, style=plot.style_linebr, linewidth=1)

// Trailing SL Logic Removed in favor of Native Chandelier Exit

// LABELS (Last Bar Only - v20.0 Style)
if barstate.islast and showTrade and tradeActive
    // Entry Label
    label.new(bar_index + 3, finalEntry, "Avg. Entry: " + str.tostring(math.round_to_mintick(finalEntry)), color=color.blue, style=label.style_none, textcolor=color.blue, size=size.small)
    
    // SL & Targets Labels with Distance
    if finalSL > 0
        if finalTSL > 0
            // Trail SL is active — show both Hard SL (dim) and Trail SL (bright)
            string hslDist = showDist ? ", " + f_dist(finalSL) : ""
            label.new(bar_index + 3, finalSL, "Hard SL: " + str.tostring(math.round_to_mintick(finalSL)) + hslDist, color=color.red, style=label.style_none, textcolor=color.new(color.red, 60), size=size.small)
            string tslDist = showDist ? ", " + f_dist(finalTSL) : ""
            label.new(bar_index + 3, finalTSL, "Trail SL: " + str.tostring(math.round_to_mintick(finalTSL)) + tslDist, color=color.orange, style=label.style_none, textcolor=color.orange, size=size.small)
        else
            // No trail SL — show Hard SL normally
            string slDist = showDist ? ", " + f_dist(finalSL) : ""
            label.new(bar_index + 3, finalSL, "Hard SL: " + str.tostring(math.round_to_mintick(finalSL)) + slDist, color=color.red, style=label.style_none, textcolor=color.red, size=size.small)
        
    if finalSL > 0 and visualSL < finalEntry
        string t1Dist = showDist ? ", " + f_dist(t1_val) : ""
        label.new(bar_index + 3, t1_val, "Target 1: " + str.tostring(math.round_to_mintick(t1_val)) + t1Dist, color=color.green, style=label.style_none, textcolor=color.green, size=size.small)
        
    if finalSL > 0 and visualSL < t2_val
        string t2Dist = showDist ? ", " + f_dist(t2_val) : ""
        label.new(bar_index + 3, t2_val, "Target 2: " + str.tostring(math.round_to_mintick(t2_val)) + t2Dist, color=color.green, style=label.style_none, textcolor=color.lime, size=size.small)
    if finalSL > 0 and visualSL >= finalEntry
        string t3Dist = showDist ? ", " + f_dist(t3_val) : ""
        label.new(bar_index + 3, t3_val, "Target 3: " + str.tostring(math.round_to_mintick(t3_val)) + t3Dist, color=color.green, style=label.style_none, textcolor=color.lime, size=size.small)
    


// ==========================================
// ALGO SIGNAL MODE: Algorithmic SL/T1/T2 on Chart
// Activates ONLY when the current chart stock has NO portfolio slot matched,
// but a live Catalyst signal (chartCat) exists. Shows computed levels.
// ==========================================
bool algoSignalMode = not tradeActive and persistCat != "NONE" and showTrade

// --- Algorithmic Level Math ---
// Uses persistCat (not chartCat) so lines remain visible even when the signal
// fired on a previous bar and today's bar conditions don't exactly re-trigger.
bool is_pos_cat   = persistCat == "POS-ACCUM" or persistCat == "POS-BO"
bool is_swing_cat = persistCat == "SWG-BO" or persistCat == "SWG-PB" or persistCat == "SWG-GAP" or persistCat == "SWG-REV"

float alg_rec_entry = close

// SL: Positional = d_l20 - 0.2*ATR10 (structural pivot minus breathing room)
//     Swing      = d_l20 * 0.998 (tighter, respects the 5-day pivot range)
float alg_rec_sl = na
if is_pos_cat
    float pos_sl_base = d_l20 - (d_atr10 * 0.2)
    alg_rec_sl := pos_sl_base < close ? pos_sl_base : close - (d_atr10 * 1.5)
else if is_swing_cat
    float swg_sl_base = d_l20 * 0.998
    alg_rec_sl := swg_sl_base < close ? swg_sl_base : close * 0.98

float alg_risk = alg_rec_sl > 0 ? math.max(0.01, alg_rec_entry - alg_rec_sl) : close * 0.05

// Targets at 2R and 3R from computed entry
float alg_t1 = alg_rec_entry + (alg_risk * 2.0) // Minimum 1:2 R:R
float alg_t2 = alg_rec_entry + (alg_risk * 3.5) // Extended runner target

// Overhead Resistance Check: Is there a supply zone between entry and T1?
// Checks 52-week high & 200DMA (whichever is closer overhead)
float alg_overhead = math.min(d_h52, close < d_sma200 ? d_sma200 : d_h52)
bool alg_t1_blocked = alg_overhead > alg_rec_entry and alg_t1 > alg_overhead

// Color coding: Green = clean room to T1 | Orange = T1 hits resistance (warn)
color alg_sl_col  = color.new(color.red,    0)
color alg_t1_col  = alg_t1_blocked ? color.new(color.orange, 0) : color.new(color.lime, 0)
color alg_t2_col  = alg_t1_blocked ? color.new(color.orange, 50) : color.new(color.lime, 30)
color alg_ent_col = color.new(#00BCD4, 0)  // Cyan/Teal - distinct from manual entry blue

// --- Lines + Labels (last bar only — NO historical rendering) ---
if barstate.islast and algoSignalMode
    float rr_dist = alg_rec_sl > 0 ? ((alg_rec_entry - alg_rec_sl) / alg_rec_entry) * 100 : 0.0
    string warn_tag = alg_t1_blocked ? " ⚠️ vs " + str.tostring(math.round_to_mintick(alg_overhead)) : ""
    
    // Horizontal lines extending right from current bar
    line.new(bar_index, alg_rec_entry, bar_index + 10, alg_rec_entry, extend=extend.right, color=alg_ent_col, style=line.style_dashed, width=1)
    line.new(bar_index, alg_rec_sl,    bar_index + 10, alg_rec_sl,    extend=extend.right, color=alg_sl_col,  style=line.style_solid,  width=1)
    line.new(bar_index, alg_t1,        bar_index + 10, alg_t1,        extend=extend.right, color=alg_t1_col,  style=line.style_solid,  width=1)
    line.new(bar_index, alg_t2,        bar_index + 10, alg_t2,        extend=extend.right, color=alg_t2_col,  style=line.style_dashed, width=1)
    
    // Entry label
    label.new(bar_index + 3, alg_rec_entry,
              "📌 Rec Entry: " + str.tostring(math.round_to_mintick(alg_rec_entry)) + " [" + persistCat + "]",
              color=color.new(#00BCD4, 0), style=label.style_none, textcolor=#00BCD4, size=size.small)
    
    // SL label
    string sl_dist_str = showDist ? " (" + str.tostring(rr_dist, "#.1") + "% risk)" : ""
    label.new(bar_index + 3, alg_rec_sl,
              "🛑 Algo SL: " + str.tostring(math.round_to_mintick(alg_rec_sl)) + sl_dist_str,
              color=color.new(color.red, 0), style=label.style_none, textcolor=color.red, size=size.small)
    
    // T1 label (color-coded for resistance)
    string t1_dist_str = showDist ? " " + f_dist(alg_t1) : ""
    label.new(bar_index + 3, alg_t1,
              "🎯 T1 (2R): " + str.tostring(math.round_to_mintick(alg_t1)) + t1_dist_str + warn_tag,
              color=alg_t1_col, style=label.style_none, textcolor=alg_t1_col, size=size.small)
    
    // T2 label
    string t2_dist_str = showDist ? " " + f_dist(alg_t2) : ""
    label.new(bar_index + 3, alg_t2,
              "🚀 T2 (3.5R): " + str.tostring(math.round_to_mintick(alg_t2)) + t2_dist_str,
              color=alg_t2_col, style=label.style_none, textcolor=alg_t2_col, size=size.small)


// ==========================================
// 10. GEMINI PROMPT GENERATION (User Request)
// ==========================================
show_prompt = input.bool(false, title="Generate Gemini Context Prompt (Check Logs)", group="AI Analysis Tools", tooltip="Enable this, then check 'Pine Logs' tab to copy the text prompt for Gemini.")

// Debounce logic to prevent log flooding on live bars
varip int last_log_time = 0
int current_time = timenow
bool time_ok = (current_time - last_log_time) > 5000 // 5 seconds

if show_prompt and barstate.islast and time_ok
    last_log_time := current_time
    
    // Fix: Unpack Tuple first
    [secTicker, secName] = f_get_hybrid_sector()

    // Construct the Prompt String
    string p_str = "Role: Senior Quantitative Analyst (Weinstein & Minervini Expert).\n" +
                 "Task: Analyze the following asset based on Stan Weinstein's Stage Analysis and Mark Minervini's VCP/SEPA principles.\n\n" +
                 "ASSET: " + syminfo.ticker + " (" + secName + ")\n" +
                 "Current Market Price: " + str.tostring(close) + "\n\n" +
                 
                 "--- 1. MARKET & SECTOR CONTEXT ---\n" +
                 "Broad Market Health (Nifty 500): " + mktState + "\n" +
                 "Sector RS State: " + rsSecState + "\n" +
                 "Asset RS State (vs Nifty 500): " + rs500State + "\n\n" +
                 
                 "--- 2. TREND & MOMENTUM ---\n" +
                 "Stage Structure: " + stageDisplay + "\n" +
                 "Weekly Trend: " + (wTrendDir == 1 ? "UP" : (wTrendDir == -1 ? "DOWN" : "SIDEWAYS")) + "\n" +
                 "Daily Trend: " + (dTrendDir == 1 ? "UP" : (dTrendDir == -1 ? "DOWN" : "SIDEWAYS")) + "\n" +
                 "30-Week SMA: " + str.tostring(wMA30) + " (Slope: " + wMASlopeState + ")\n" +
                 "Price > 30WMA: " + (close > wMA30 ? "YES" : "NO") + "\n" +
                 "50-Day SMA Slope: " + d50SlopeState + "\n" +
                 "Price > 50DMA: " + (close > dMA50 ? "YES" : "NO") + "\n" +
                 "Trend Template (50>150>200): " + (dSmaAligned ? "ALIGNED (Bullish)" : "MISALIGNED") + "\n\n" +
                 
                 "--- 3. PRICE ACTION & KEY LEVELS ---\n" +
                 "Current ATR (10 / 40): " + str.tostring(d_atr10_val) + " / " + str.tostring(d_atr40_val) + "\n" +
                 "Volume State vs 50SMA: " + volState + "\n" +
                 "Trigger State: " + chartCat + " (" + rsSecState + ")\n\n" +

                 "--- INSTRUCTIONS FOR ANALYSIS ---\n" +
                 "1. First, analyze the Broad Market and Sector context (Is the tide rising?).\n" +
                 "2. Perform a brief Fundamental Check (Earnings growth, Valuation, etc.) and Sentiment Analysis (Recent News/Hype).\n" +
                 "3. Evaluate the Asset's Stage (Weinstein) and Volatility Contraction (Minervini).\n" +
                 "4. Check for specific overhead supply (Resistance) vs immediate support.\n" +
                 "5. Conclude with a clear Buy/Sell/Hold decision and potential trade setup (Entry/Stop/Target)."
                 
    log.info("\n⬇️ COPY GEMINI PROMPT BELOW ⬇️\n\n" + p_str + "\n\n⬆️ COPY GEMINI PROMPT ABOVE ⬆️")
    alert("Gemini Prompt Generated for " + syminfo.ticker + ". Check Pine Logs.", alert.freq_once_per_bar_close)

// ==========================================
// 11. EXPORT PORTFOLIO TO CSV (User Request)
// ==========================================
show_csv = input.bool(false, title="Export Portfolio to CSV Log", group="Data Tools", tooltip="Enable this, then check 'Pine Logs' tab to copy your portfolio data (Ticker, Entry, SL, Sector) in CSV format.")

// Helper to format row
f_row(t, e, s, d, sec) =>
    if t != ""
        t + "," + str.tostring(e) + "," + str.tostring(s) + "," + str.format("{0,date,yyyy-MM-dd}", d) + "," + str.tostring(sec) + "\\n"
    else
        ""

if show_csv and barstate.islast and time_ok
    string csv_out = "Ticker,Entry,SL,Date,Sector\\n"

    csv_out := csv_out + f_row(p1_tick, p1_ent, p1_sl, p1_date, p1_sec)
    csv_out := csv_out + f_row(p2_tick, p2_ent, p2_sl, p2_date, p2_sec)
    csv_out := csv_out + f_row(p3_tick, p3_ent, p3_sl, p3_date, p3_sec)
    csv_out := csv_out + f_row(p4_tick, p4_ent, p4_sl, p4_date, p4_sec)
    csv_out := csv_out + f_row(p5_tick, p5_ent, p5_sl, p5_date, p5_sec)
    csv_out := csv_out + f_row(p6_tick, p6_ent, p6_sl, p6_date, p6_sec)
    csv_out := csv_out + f_row(p7_tick, p7_ent, p7_sl, p7_date, p7_sec)
    csv_out := csv_out + f_row(p8_tick, p8_ent, p8_sl, p8_date, p8_sec)
    csv_out := csv_out + f_row(p9_tick, p9_ent, p9_sl, p9_date, p9_sec)
    csv_out := csv_out + f_row(p10_tick, p10_ent, p10_sl, p10_date, p10_sec)
    csv_out := csv_out + f_row(p11_tick, p11_ent, p11_sl, p11_date, p11_sec)
    csv_out := csv_out + f_row(p12_tick, p12_ent, p12_sl, p12_date, p12_sec)
    csv_out := csv_out + f_row(p13_tick, p13_ent, p13_sl, p13_date, p13_sec)
    csv_out := csv_out + f_row(p14_tick, p14_ent, p14_sl, p14_date, p14_sec)
    csv_out := csv_out + f_row(p15_tick, p15_ent, p15_sl, p15_date, p15_sec)
    csv_out := csv_out + f_row(p16_tick, p16_ent, p16_sl, p16_date, p16_sec)
    csv_out := csv_out + f_row(p17_tick, p17_ent, p17_sl, p17_date, p17_sec)
    csv_out := csv_out + f_row(p18_tick, p18_ent, p18_sl, p18_date, p18_sec)
    csv_out := csv_out + f_row(p19_tick, p19_ent, p19_sl, p19_date, p19_sec)
    csv_out := csv_out + f_row(p20_tick, p20_ent, p20_sl, p20_date, p20_sec)
    csv_out := csv_out + f_row(p21_tick, p21_ent, p21_sl, p21_date, p21_sec)
    csv_out := csv_out + f_row(p22_tick, p22_ent, p22_sl, p22_date, p22_sec)
    csv_out := csv_out + f_row(p23_tick, p23_ent, p23_sl, p23_date, p23_sec)
    csv_out := csv_out + f_row(p24_tick, p24_ent, p24_sl, p24_date, p24_sec)
    csv_out := csv_out + f_row(p25_tick, p25_ent, p25_sl, p25_date, p25_sec)
    csv_out := csv_out + f_row(p26_tick, p26_ent, p26_sl, p26_date, p26_sec)
    csv_out := csv_out + f_row(p27_tick, p27_ent, p27_sl, p27_date, p27_sec)
