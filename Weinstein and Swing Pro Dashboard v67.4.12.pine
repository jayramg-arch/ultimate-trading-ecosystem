// HYBRID SECTOR LOOKUP
f_get_hybrid_sector() =>
    string t = ""
    string n = ""

    // 1. DB Lookup first (highest accuracy — full Nifty 500 coverage)
    string __clean_t = str.replace_all(str.upper(str.trim(syminfo.ticker)), "NSE:", "")
    __clean_t := str.replace_all(__clean_t, "BSE:", "")
    string dbSec = f_db_sector_lookup(__clean_t)
    if dbSec != ""
        t := dbSec
        n := str.replace_all(dbSec, "NSE:", "")

    // 2. Fall back to Manual Portfolio Slots (for stocks not in DB)
    if t == ""
        if f_match(p1_tick)
            t := p1_sec
            n := str.replace_all(p1_sec, "NSE:", "")
        else if f_match(p2_tick)
            t := p2_sec
            n := str.replace_all(p2_sec, "NSE:", "")
        else if f_match(p3_tick)
            t := p3_sec
            n := str.replace_all(p3_sec, "NSE:", "")
        else if f_match(p4_tick)
            t := p4_sec
            n := str.replace_all(p4_sec, "NSE:", "")
        else if f_match(p5_tick)
            t := p5_sec
            n := str.replace_all(p5_sec, "NSE:", "")
        else if f_match(p6_tick)
            t := p6_sec
            n := str.replace_all(p6_sec, "NSE:", "")
        else if f_match(p7_tick)
            t := p7_sec
            n := str.replace_all(p7_sec, "NSE:", "")
        else if f_match(p8_tick)
            t := p8_sec
            n := str.replace_all(p8_sec, "NSE:", "")
        else if f_match(p9_tick)
            t := p9_sec
            n := str.replace_all(p9_sec, "NSE:", "")
        else if f_match(p10_tick)
            t := p10_sec
            n := str.replace_all(p10_sec, "NSE:", "")
        else if f_match(p11_tick)
            t := p11_sec
            n := str.replace_all(p11_sec, "NSE:", "")
        else if f_match(p12_tick)
            t := p12_sec
            n := str.replace_all(p12_sec, "NSE:", "")
        else if f_match(p13_tick)
            t := p13_sec
            n := str.replace_all(p13_sec, "NSE:", "")
        else if f_match(p14_tick)
            t := p14_sec
            n := str.replace_all(p14_sec, "NSE:", "")
        else if f_match(p15_tick)
            t := p15_sec
            n := str.replace_all(p15_sec, "NSE:", "")
        else if f_match(p16_tick)
            t := p16_sec
            n := str.replace_all(p16_sec, "NSE:", "")
        else if f_match(p17_tick)
            t := p17_sec
            n := str.replace_all(p17_sec, "NSE:", "")
        else if f_match(p18_tick)
            t := p18_sec
            n := str.replace_all(p18_sec, "NSE:", "")
        else if f_match(p19_tick)
            t := p19_sec
            n := str.replace_all(p19_sec, "NSE:", "")
        else if f_match(p20_tick)
            t := p20_sec
            n := str.replace_all(p20_sec, "NSE:", "")
        else if f_match(p21_tick)
            t := p21_sec
            n := str.replace_all(p21_sec, "NSE:", "")
        else if f_match(p22_tick)
            t := p22_sec
            n := str.replace_all(p22_sec, "NSE:", "")
        else if f_match(p23_tick)
            t := p23_sec
            n := str.replace_all(p23_sec, "NSE:", "")
        else if f_match(p24_tick)
            t := p24_sec
            n := str.replace_all(p24_sec, "NSE:", "")
        else if f_match(p25_tick)
            t := p25_sec
            n := str.replace_all(p25_sec, "NSE:", "")
        else if f_match(p26_tick)
            t := p26_sec
            n := str.replace_all(p26_sec, "NSE:", "")
        else if f_match(p27_tick)
            t := p27_sec
            n := str.replace_all(p27_sec, "NSE:", "")
        else if f_match(p28_tick)
            t := p28_sec
            n := str.replace_all(p28_sec, "NSE:", "")
        else if f_match(p29_tick)
            t := p29_sec
            n := str.replace_all(p29_sec, "NSE:", "")
        else if f_match(p30_tick)
            t := p30_sec
            n := str.replace_all(p30_sec, "NSE:", "")

    // 3. Fall back to Auto-Mapper (keyword-based, for off-list tickers)
    if t == ""
        [at, an] = f_get_sector_ticker()
        t := at
        n := an

    [t, n]
// RS State = combines SLOPE direction with LEVEL (Positive/Neutral/Negative)
// Format: "Rising (Positive)", "Flat (Negative)", etc.
// v63.4: True RRG quadrant = (mansfield level, RS-momentum 4-bar ROC).
// Returned string includes the quadrant token AND legacy (Positive)/(Negative)/Rising/Declining
// markers so existing str.contains consumers keep working.
f_rsStateStr(float s, float v, float thresh) => 
    string level = v > 0 ? "(Positive)" : (v < 0 ? "(Negative)" : "(Neutral)")
    string dir   = s > thresh ? "Rising" : (s < -thresh ? "Declining" : "Flat")
    dir + " " + level

f_rsVelocityStr(float currentSlope, float pastSlope) =>
    float roc = currentSlope - pastSlope
    string vState = "⚪ Static"
    color vCol = color.gray
    
    // Using 0.0005 as a baseline velocity threshold
    if currentSlope > 0 and roc > 0.0005
        vState := "🔥 ACCELERATING LEADER"
        vCol := color.new(#00e676, 0)
    else if currentSlope > 0 and roc < -0.0005
        vState := "⚠️ EXHAUSTED LEADER"
        vCol := color.orange
    else if currentSlope < 0 and roc > 0.001
        vState := "👀 HIDDEN ACCUMULATION"
        vCol := color.aqua
    else if currentSlope < 0 and roc <= 0
        vState := "🩸 DEAD MONEY"
        vCol := color.red
    
    [vState, vCol]


// v67.4.2: Strike.Money-matched JdK formula (replaces 2-pass StockCharts default).
// Calibration against 15 symbols vs Strike's published values showed:
//   2-pass (old): ratio error 8.86, quadrant agreement 66.7%
//   1-pass + 5-bar smooth (new): ratio error 5.52, quadrant agreement 93.8%
// Strike uses single-pass normalization with final 5-bar smoothing — NOT
// the textbook double-pass. Default length raised 10 → 12.
// Returns CENTERED values (RS_Ratio - 100, RS_Momentum - 100) so legacy
// downstream code continues to work unchanged.
//
// Extra returns (val_trail, mom_trail) hold the (RS-Ratio, RS-Momentum) values
// from `trailLen` bars ago — used by f_rrg_trajectory to project rotation
// direction on the RRG plane.
//
// Parameters:
//   slopeLen  — bars for the legacy slope arrow (Δ RS_Ratio over slopeLen)
//   jdkLen    — JdK normalization length (Strike-matched default = 12)
//   trailLen  — RRG trajectory tail length (standard = 4 weeks)
f_calc_rs_logic(int rsl, int rslLevel, int slopeLen, int jdkLen, int trailLen) =>
    // Called via request.security("STOCK / BENCH", ...) → close IS the ratio.
    rs           = close
    rs_sma       = ta.sma(rs, jdkLen)
    rs_ratio_raw = 100.0 + ((rs - rs_sma) / rs_sma) * 100.0
    rs_ratio     = ta.sma(rs_ratio_raw, 5)                 // 5-bar smooth — Strike-match
    // RS-Momentum = SMA(length) of ROC of smoothed RS-Ratio
    rm1          = 100.0 * (rs_ratio / rs_ratio[1])
    rs_mom       = ta.sma(rm1, jdkLen)

    // Centered (-100) so legacy >0 thresholds keep their meaning
    float val      = rs_ratio - 100.0
    float mom_c    = rs_mom   - 100.0

    // Legacy slope arrow: change in RS_Ratio over slopeLen bars
    float slope = val - nz(val[slopeLen], val)
    float pastSlope = slope[5]

    // RRG trajectory tail: where were we trailLen bars ago?
    float val_trail = nz(val[trailLen],   val)
    float mom_trail = nz(mom_c[trailLen], mom_c)

    // Warm-up: JdK needs ~3×length + buffer for stable values
    int warmup = math.max(jdkLen * 3 + 10, 60)
    bool _warmed = bar_index >= warmup and not na(rs) and rs > 0
    float val_g       = _warmed ? val       : na
    float slope_g     = _warmed ? slope     : na
    float mom_g       = _warmed ? mom_c     : na
    float val_trail_g = _warmed ? val_trail : na
    float mom_trail_g = _warmed ? mom_trail : na

    [slope_g, val_g, pastSlope, mom_g, val_trail_g, mom_trail_g]

f_weeklyHealth(float riseThresh) =>
    float volAvgW = ta.sma(volume, 50)
    float atrW = ta.atr(14)
    int phIndex = -1
    float highestP = 0.0
    for i = 1 to 10
        if high[i] > highestP
            highestP := high[i]
            phIndex := i
    string hStr = "N/A"
    color hCol = color.gray
    if phIndex > 0
        int badBars = 0
        for j = 0 to phIndex - 1
            bool isDown = close[j] < open[j]
            bool highVol = volume[j] > volAvgW[j] * 1.2
            bool wideRange = (high[j]-low[j]) > (atrW[j] * 1.5)
            if isDown and (highVol or (wideRange and close[j] < low[j] + (high[j]-low[j])*0.25))
                badBars += 1
        if badBars == 0
            hStr := "HEALTHY (Low Vol)"
            hCol := color.green
        else if badBars <= 1
            hStr := "NORMAL"
            hCol := color.blue
        else
            hStr := "WEAK (Selling)"
            hCol := color.orange
    [hStr, hCol]

// --- ZIGZAG TREND SYNCHRONIZATION (v6.2 synced) ---
// v67.2 FIX #14: EH/EL threshold now sourced from `eq_threshold_dash` input
// (group "Advanced Thresholds"). Default 0.005 (0.5%) matches Zigzag v6.2.

f_classifyHigh(float newHigh, float prevHigh) =>
    string result = "HH"
    if not na(prevHigh) and prevHigh > 0
        float diff = math.abs(newHigh - prevHigh) / prevHigh
        if diff < eq_threshold_dash
            result := "EH"
        else if newHigh < prevHigh
            result := "LH"
    result

f_classifyLow(float newLow, float prevLow) =>
    string result = "LL"
    if not na(prevLow) and prevLow > 0
        float diff = math.abs(newLow - prevLow) / prevLow
        if diff < eq_threshold_dash
            result := "EL"
        else if newLow > prevLow
            result := "HL"
    result

f_getStrictTrend(float h, float l, int left, int right) =>
    var int trendState     = 0
    var int confirmedTrend = 0
    var float lockedHigh   = na
    var float lockedLow    = na
    var string lastHighClass   = na
    var string lastLowClass    = na
    var string activePivotType = na
    var float activePivotPrice = na
    var int activePivotIndex   = na
    // v6.2: previous structural references for correct extension-path classification
    var float prevLockedHigh   = na
    var float prevLockedLow    = na

    ph = ta.pivothigh(h, left, right)
    pl = ta.pivotlow(l, left, right)

    // 1. New Pivot High Found
    if not na(ph)
        if activePivotType == "H" and ph > activePivotPrice
            // EXTENDING existing high — re-classify against PREVIOUS structural high
            // (prevLockedHigh), NOT lockedHigh (which equals THIS direction's initial price).
            activePivotPrice := ph
            activePivotIndex := bar_index[right]
            string hClass = f_classifyHigh(ph, prevLockedHigh)  // v6.2: was lockedHigh
            lastHighClass := hClass
        else if activePivotType == "L" or na(activePivotType)
            // NEW direction change: Low → High. Lock the previous low.
            if activePivotType == "L"
                lockedLow := activePivotPrice

            string hClass = f_classifyHigh(ph, lockedHigh)

            // v6.2 strict f_updateTrend: EL on the low side does NOT confirm uptrend.
            // Only strict HL (after HH) or LL (after LH) confirms.
            int newTrend = 0
            if hClass == "HH"
                if lastLowClass == "HL"     // v6.2: removed EL from gate
                    newTrend := 1
                else
                    newTrend := 0
            else if hClass == "LH"
                if lastLowClass == "LL"     // v6.2: removed EL from gate
                    newTrend := -1
                else
                    newTrend := 0
            else  // EH → SIDEWAYS
                newTrend := 0

            trendState     := newTrend
            confirmedTrend := newTrend
            prevLockedHigh := lockedHigh   // v6.2: save structural previous high
            lockedHigh     := ph
            lastHighClass  := hClass
            activePivotPrice := ph
            activePivotIndex := bar_index[right]
            activePivotType  := "H"

    // 2. New Pivot Low Found
    if not na(pl)
        if activePivotType == "L" and pl < activePivotPrice
            // EXTENDING existing low — re-classify against PREVIOUS structural low
            // (prevLockedLow), NOT lockedLow (which equals THIS direction's initial price).
            activePivotPrice := pl
            activePivotIndex := bar_index[right]
            string lClass = f_classifyLow(pl, prevLockedLow)  // v6.2: was lockedLow
            lastLowClass := lClass
        else if activePivotType == "H"
            // NEW direction change: High → Low. Lock the previous high.
            lockedHigh := activePivotPrice

            string lClass = f_classifyLow(pl, lockedLow)

            // v6.2 strict f_updateTrend: EH on the high side does NOT confirm downtrend.
            int newTrend = 0
            if lClass == "LL"
                if lastHighClass == "LH"   // v6.2: removed EH from gate
                    newTrend := -1
                else
                    newTrend := 0
            else if lClass == "HL"
                if lastHighClass == "HH"   // v6.2: removed EH from gate
                    newTrend := 1
                else
                    newTrend := 0
            else  // EL → SIDEWAYS
                newTrend := 0

            trendState     := newTrend
            confirmedTrend := newTrend
            prevLockedLow  := lockedLow    // v6.2: save structural previous low
            lockedLow      := pl
            lastLowClass   := lClass
            activePivotPrice := pl
            activePivotIndex := bar_index[right]
            activePivotType  := "L"

    // 3. LIVE TREND SYNC (Projection BoS) — v6.2 fully synced
    // syncBars includes the pivot bar itself (+1) so projSync extremes capture the pivot.
    int _syncBars = na(activePivotIndex) ? 1 : (bar_index - activePivotIndex + 1)
    int syncBars  = math.max(1, _syncBars)
    float projSyncLow  = ta.lowest(l, syncBars)
    float projSyncHigh = ta.highest(h, syncBars)

    // Pre-compute classifications unconditionally
    string _projHighClass = f_classifyHigh(projSyncHigh, lockedHigh)
    string _projLowClass  = f_classifyLow(projSyncLow,  lockedLow)

    // GATED by activePivotType: only evaluate the DEVELOPING side.
    // activePivotType == "L" → developing upward → check HH BoS only.
    //   Opposite-side class uses CONFIRMED lastLowClass (v6.2 fix: no re-classification).
    // activePivotType == "H" → developing downward → check LL BoS only.
    //   Opposite-side class uses CONFIRMED lastHighClass (v6.2 fix).
    if activePivotType == "L" and _projHighClass == "HH"
        string _devLowClass = na(lastLowClass) ? "HL" : lastLowClass  // confirmed, not re-classified
        if _devLowClass == "HL"
            trendState := 1
        else
            trendState := 0
    else if activePivotType == "H" and _projLowClass == "LL"
        string _devHighClass = na(lastHighClass) ? "LH" : lastHighClass  // confirmed, not re-classified
        if _devHighClass == "LH"
            trendState := -1
        else
            trendState := 0

    [trendState, lockedHigh, lockedLow]

f_getStageAndTime(int maLen, int slopeLen, float thresh) =>
    float wCl = close
    float wMA = ta.sma(close, maLen)
    // Force array allocation with a trailing fallback to prevent nested <na> drops
    float wMA_old = wMA[slopeLen]
    float slopeVal = (wMA - nz(wMA_old, wMA)) / math.max(1, slopeLen)
    float dynThresh = wMA * thresh
    
    // Fetch Structural Trend for anchoring
    [tDir, _, _] = f_getStrictTrend(high, low, 5, 5)
    
    // Logic Matrix matching your Document:
    bool isRising = slopeVal > dynThresh
    bool isFalling = slopeVal < -dynThresh
    bool isAbove = wCl > wMA
    
    var string s = "STAGE 4 (DOWN)"
    
    // STATE MACHINE LOGIC
    if s == "STAGE 1 (BASE)"
        if isRising and isAbove
            s := "STAGE 2 (UP)"
        else if isFalling and not isAbove and tDir != 1
            s := "STAGE 4 (DOWN)"
            
    else if s == "STAGE 2 (UP)" or s == "STAGE 2 (PULLBACK)"
        if isFalling and not isAbove and tDir != 1
            s := "STAGE 4 (DOWN)"
        else if (not isRising and not isAbove) or (tDir == -1 and not isAbove)
            s := "STAGE 3 (TOP)"
        else if not isAbove
            s := "STAGE 2 (PULLBACK)"
        else
            s := "STAGE 2 (UP)"
            
    else if s == "STAGE 3 (TOP)"
        if isFalling and not isAbove and tDir != 1
            s := "STAGE 4 (DOWN)"
        else if isRising and isAbove
            s := "STAGE 2 (UP)"
            
    else if s == "STAGE 4 (DOWN)"
        if isRising and isAbove
            s := "STAGE 2 (UP)"
        else if not isFalling and isAbove
            s := "STAGE 1 (BASE)"
            
    // Structural Overrides for safety
    if tDir == 1 and s == "STAGE 4 (DOWN)"
        s := "STAGE 1 (BASE)"
    if tDir == -1 and (s == "STAGE 2 (UP)" or s == "STAGE 2 (PULLBACK)")
        s := "STAGE 3 (TOP)"
        
    var string lastS = ""
    var int startTime = 0
    if bar_index == 0
        lastS := s
        startTime := time
    if s != lastS
        startTime := time
        lastS := s

    // v67.2.2: Macro Stage-2 anchor — separate from the sub-stage anchor above.
    // Only resets when the stage family EXITS Stage 2 (not on UP↔PULLBACK).
    // Resolves the disconnect between Dashboard "leg age" (resets on pullback)
    // and Screener "macro age" (true Stage-2 lifespan).
    var int macroStart = 0
    var bool wasInStage2 = false
    bool inStage2_now = s == "STAGE 2 (UP)" or s == "STAGE 2 (PULLBACK)"
    if bar_index == 0
        macroStart := time
        wasInStage2 := inStage2_now
    if inStage2_now and not wasInStage2
        macroStart := time   // fresh entry into Stage 2 family
    wasInStage2 := inStage2_now

    [s, startTime, macroStart, slopeVal, wMA]



f_trackATH() =>
    var float h = high
    h := math.max(h, high)
    h



f_trendText(int t) => t == 1 ? "UP" : (t == -1 ? "DOWN" : "SIDEWAYS")
f_trendColor(int t) => t == 1 ? color.new(#26a69a, 0) : (t == -1 ? color.new(#ef5350, 0) : color.new(#ff9800, 0))

// --- Overhead Resistance (Fixed v63.4) ---
// Pine Script compliant: ta.pivothigh called ONCE per bar (top of function, not in a loop).
// Uses var arrays to accumulate confirmed weekly pivot highs bar-by-bar.
// FIX: Replaced ta.highestbars ATH-epoch gate with a fixed 104-bar (2-year) lookback.
//   Root cause of 0% bug: ta.highestbars returns 0 for stocks near recent highs,
//   making athBarIdx = bar_index (future), so no stored pivot could ever qualify.
//   Also: ATH fewer than 5 bars ago has no confirmed pivots in that window
//   (ta.pivothigh needs 5 bars right-side confirmation lag).
// Version: v63.4 — Fixed 2-year window, dedup within 1.5% clusters.
// Returns [count, closestPrice] as a tuple — used by f_weekly_super_bundle_internal.

f_getOverheadResist(float currentPrice) =>
    var float[] pivotVals = array.new_float(0)   // Confirmed weekly pivot high prices
    var int[]   pivotBars = array.new_int(0)     // bar_index when each pivot was confirmed

    // Called ONCE per bar at top scope — satisfies Pine Script consistency rule
    float wPh = ta.pivothigh(high, 5, 5)

    // Accumulate historical pivots (newest first)
    if not na(wPh)
        array.unshift(pivotVals, wPh)
        array.unshift(pivotBars, bar_index)
        if array.size(pivotVals) > 800          // Increased cap for longer historical lookback
            array.pop(pivotVals)
            array.pop(pivotBars)

    // Query: count all pivot highs above CMP till ATH.
    // FIX: Using dynamic ATH lookback (up to 1000 weeks / ~20 years).
    int   athLookback = bar_index > 0 ? math.min(1000, bar_index) : 1
    int   athBarIdx   = math.abs(ta.highestbars(high, athLookback)) 
    int   epochStart  = bar_index - athBarIdx

    int   count       = 0
    float closest     = na
    float min_dist    = 9999999.0
    float lastAccepted = na                     // Dedup: last accepted price level

    int sz = array.size(pivotVals)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(pivotBars, i) >= epochStart
                float pVal = array.get(pivotVals, i)
                // Use a tiny buffer (0.1%) to avoid status flickering at exact levels
                if pVal > (currentPrice * 1.001)
                    // Deduplication: skip if within 1.5% of last accepted zone
                    bool isDupe = not na(lastAccepted) and math.abs(pVal - lastAccepted) / lastAccepted < 0.015
                    if not isDupe
                        count       += 1
                        lastAccepted := pVal
                        float dist   = pVal - currentPrice
                        if dist < min_dist
                            min_dist := dist
                            closest  := pVal

    // Ensure ATH is ALWAYS counted if price is below it and it hasn't been captured as a pivot zone
    float athVal = ta.highest(high, athLookback)
    if not na(athVal) and athVal > (currentPrice * 1.001)
        bool hasAthZone = false
        if sz > 0
            for i = 0 to sz - 1
                if array.get(pivotBars, i) >= epochStart
                    float pVal = array.get(pivotVals, i)
                    if pVal > (currentPrice * 1.001) and math.abs(athVal - pVal) / pVal < 0.015
                        hasAthZone := true
                        break
        if not hasAthZone
            count += 1
            float dist = athVal - currentPrice
            if dist < min_dist
                min_dist := dist
                closest  := athVal

    [count, closest]


f_calc_adx_bool() =>
    [dp, dm, adx] = ta.dmi(14, 14)
    adx > 20 and dp > dm // Synced with Strategy v4.0 (20 instead of 25 for Indian mid-caps)

f_get_screener_data_internal() =>
    // Internal Catalyst Logic
    float _c = close
    float _o = open
    float _v = volume
    float _e20 = ta.ema(_c, 20)
    float _e20_1 = _e20[1]
    float _rsi14 = ta.rsi(_c, 14)
    float _v50 = ta.sma(_v, 50)
    bool  _adx_ok = f_calc_adx_bool()
    
    float _s50 = ta.sma(_c, 50)
    float _s150 = ta.sma(_c, 150)
    float _s200 = ta.sma(_c, 200)
    float _obv = ta.cum(math.sign(ta.change(_c)) * _v)
    float _obv_h50_1 = ta.highest(_obv, 50)[1]
    float _p_h50 = ta.highest(high, 50)
    float _rsi70 = ta.rsi(_c, 70)
    float _h10_1 = ta.highest(high, 10)[1]
    float _rsi3 = ta.rsi(_c, 3)
    float _h1 = high[1]
    float _h250 = ta.highest(high, 250)
    
    float _atr10 = ta.atr(10)
    float _atr40 = ta.atr(40)
    
    int _catId = 0
    // Catalyst Logic (Stage Detection)
    // Note: Using 150-SMA as a fast daily proxy for True Weekly Stage 2 logic (Aligned with ULTIMATE Screener)
    bool is_stage2 = (_c > _s150) 
    bool is_stage1 = not is_stage2 and (_c > _s200)
    bool vol_dry = _v < _v50
    bool vcp_tight = _atr10 < (_atr40 * 0.75)
    bool d_flat = ((_p_h50 - _c) / _c) > 0.08
    float _obv_roc5  = ta.roc(_obv, 5)
    float _obv_roc10 = ta.roc(_obv, 10)
    float _obv_sma20 = ta.sma(_obv, 20)
    bool  _obv_trending_up = _obv_roc5 > 0 and _obv > _obv_sma20 and _obv_roc5 > _obv_roc10

    if (is_stage1 or is_stage2) and (_obv > _obv_h50_1) and _obv_trending_up and d_flat and vcp_tight
        _catId := 1 // POS-ACCUM
    else if is_stage2 and (_c > _h250 * 0.95) and (_v > _v50 * 1.5)
        _catId := 2 // POS-BO
    else if is_stage2 and (_o > _h1 * 1.02) and (_c > _o)
        _catId := 6 // SWG-GAP
    else if is_stage2 and vcp_tight and (_c > _h10_1) and (_v > _v50 * 1.2)
        _catId := 4 // SWG-BO
    else if is_stage2 and (_c > _e20) and (((_c - _e20) / _e20) < 0.05) and vol_dry and (_rsi14 > 40) and (_rsi70 > 55)
        _catId := 3 // SWG-PB
    else if is_stage2 and (_rsi3 < 20) and (((_e20 - _c) / _e20) > 0.05)
        _catId := 5 // SWG-REV

    [_c, _o, low, close[1], _e20, _e20_1, _rsi14, _v, _v50, _adx_ok, _catId, _s50, _s200]

f_get_screener_data(string t) =>
    string cln = str.trim(t)
    bool good = str.length(cln) > 1
    string targetSym = good ? cln : syminfo.tickerid
    [c_raw, o_raw, l_raw, c1_raw, e_raw, e1_raw, r_raw, v_raw, va_raw, adx_raw, cat_raw, s50_raw, s200_raw] = request.security(targetSym, "D", f_get_screener_data_internal(), ignore_invalid_symbol=true)
    
    // Guard: Only return valid data if ticker input was non-empty
    [c, o, l, c1, e, e1, r, v, va, adx_ok, catId, s50, s200] = if good
        [c_raw, o_raw, l_raw, c1_raw, e_raw, e1_raw, r_raw, v_raw, va_raw, adx_raw, cat_raw, s50_raw, s200_raw]
    else
        [float(na), float(na), float(na), float(na), float(na), float(na), float(na), float(na), float(na), bool(na), int(na), float(na), float(na)]
    [c, o, l, c1, e, e1, r, v, va, adx_ok, catId, s50, s200]


f_rsi_div(float src, int len, int left, int right) =>
    float rsiVal = ta.rsi(src, len)
    ph = ta.pivothigh(high, left, right)
    pl = ta.pivotlow(low, left, right)
    rsiPh = ta.pivothigh(rsiVal, left, right)
    rsiPl = ta.pivotlow(rsiVal, left, right)
    string div = "None"
    var float lastPP_H = na 
    var float lastRP_H = na 
    var float lastPP_L = na 
    var float lastRP_L = na 
    if not na(ph)
        if not na(lastPP_H) and ph > lastPP_H and not na(rsiPh) and rsiPh < lastRP_H
            div := "BEARISH DIV"
        lastPP_H := ph
        lastRP_H := not na(rsiPh) ? rsiPh : lastRP_H
    if not na(pl)
        if not na(lastPP_L) and pl < lastPP_L and not na(rsiPl) and rsiPl > lastRP_L
            div := "BULLISH DIV"
        lastPP_L := pl
        lastRP_L := not na(rsiPl) ? rsiPl : lastRP_L
    [rsiVal, div]

// ==========================================
// 5. MAIN CALCULATIONS (OPTIMIZED)
// ==========================================

// Global Indicators
var float g_atr5 = 0.0
var float g_atr20 = 0.0
g_atr5 := ta.atr(5)
g_atr20 := ta.atr(20)

// Lightweight sector stage read for Gap 1 — returns readable stage string on weekly timeframe
f_sec_stage_lite() =>
    float ma30 = ta.sma(close, 30)
    float slope = ma30 - ma30[4]
    close > ma30 and slope > 0 ? "✅ STAGE 2 (Bull)" : close > ma30 and slope <= 0 ? "⚠️ STAGE 3 (Top)" : close < ma30 and slope < 0 ? "🔻 STAGE 4 (Bear)" : "😴 STAGE 1 (Base)"

// Internal function to return a flat tuple for weekly data (avoids nested tuple error in request.security)
f_weekly_super_bundle_internal(float dCl, int maLen, int slopeLen, float thresh) =>
    [sID, sTime, sMacroTime, sSlope, sMA] = f_getStageAndTime(maLen, slopeLen, thresh)
    ma40 = ta.sma(close, 40)
    cl = close
    [hStr, hCol] = f_weeklyHealth(0.0)
    [tDir, tH, tL] = f_getStrictTrend(high, low, 5, 5)
    [ovh_val, ovh_price] = f_getOverheadResist(dCl)
    w_rsi = ta.rsi(close, 14)
    // Pre-Stage 2 early warning: Stage 1 stock with 10W MA turning up, price above 10W MA and 30W MA
    float wMA10 = ta.sma(close, 10)
    bool early_stage2 = sID == "STAGE 1 (BASE)" and wMA10 > wMA10[1] and close > wMA10 and close > sMA
    [sID, sTime, sMacroTime, sSlope, sMA, ma40, cl, hStr, hCol, tDir, tH, tL, ovh_val, w_rsi, ovh_price, early_stage2]

// Consolidated Weekly Security Call (Optimized to stay under 40-call request.security limit)
// v67.2.2: added stageMacroStart (macro Stage-2 anchor, doesn't reset on UP↔PULLBACK).
[stageID, stageStart, stageMacroStart, wSlopeVal, wMA30, wMA40, wClose, wHealthStr, wHealthCol, wTrendDir, wLockH, wLockL, ovh, wRsiVal, ovhPrice, wEarlyStage2] = request.security(syminfo.tickerid, "W", f_weekly_super_bundle_internal(close, maLengthW, wmaSlopeLen, slopeThresh), ignore_invalid_symbol=true)

resistCount := ovh

bool panicExit = close < wMA40

// Set Weekly Slope State Text
wMASlopeState := "FLAT"
if wSlopeVal > (wMA30 * slopeThresh)
    wMASlopeState := "RISING"
else if wSlopeVal < -(wMA30 * slopeThresh)
    wMASlopeState := "FALLING"

int msPerWeek = 604800000
int timeDiff = timenow - stageStart
if timeDiff < 0
    timeDiff := 0
int stageWeeks = math.ceil(timeDiff / msPerWeek)  // LEG age (resets on UP↔PULLBACK)
if stageWeeks < 1
    stageWeeks := 1

// v67.2.2: MACRO Stage-2 age (only resets on full Stage-2 exit)
int macroDiff = timenow - stageMacroStart
if macroDiff < 0
    macroDiff := 0
int macroStageWeeks = math.ceil(macroDiff / msPerWeek)
if macroStageWeeks < 1
    macroStageWeeks := 1

bool isStage2Family = (stageID == "STAGE 2 (UP)") or (stageID == "STAGE 2 (PULLBACK)")
string stage2FreshTag = "—"
color  stage2FreshCol = color.gray
if isStage2Family
    if stageWeeks <= stage2_fresh_weeks
        stage2FreshTag := "Fresh"
        stage2FreshCol := color.new(#26a69a, 0)
    else if macroStageWeeks <= 26
        stage2FreshTag := "Maturing"
        stage2FreshCol := color.new(#ff9800, 0)
    else
        stage2FreshTag := "Extended"
        stage2FreshCol := color.orange

string stage2AgeStr = isStage2Family ? str.tostring(stageWeeks) + "w leg / " + str.tostring(macroStageWeeks) + "w macro · " + stage2FreshTag : "n/a (not in Stage 2)"

// v67.2.4: Trend Engine config display — shows the three knobs that must match
// the on-chart Zigzag [Strict]. Green when ALL three match the canonical
// defaults (engine v6.2, pivot 2/2, eq_threshold 0.5%); orange on any drift.
string trend_engine_str = "v6.2 · L" + str.tostring(pivotLeft) + "/R" + str.tostring(pivotRight) + " · " + str.tostring(eq_threshold_dash * 100, "#.##") + "%"
bool trend_engine_canonical = (pivotLeft == 2) and (pivotRight == 2) and (math.abs(eq_threshold_dash - 0.005) < 1e-9)
color trend_engine_col = trend_engine_canonical ? color.new(#26a69a, 0) : color.new(#ff9800, 0)
if not trend_engine_canonical
    trend_engine_str := trend_engine_str + " ⚠ Sync Zigzag"

f_get_mvwap() =>
    var float pv_sum = 0.0
    var float v_sum  = 0.0
    if timeframe.change("M")
        pv_sum := 0.0
        v_sum  := 0.0
    pv_sum := pv_sum + (close * volume)
    v_sum  := v_sum + volume
    pv_sum / v_sum

// Internal function to return a flat tuple for daily data (avoids nested tuple error in request.security)
f_daily_super_bundle_internal(int dma50_len, int dma150_len, int dma200_len, int dmaSlopeLen, int fibLookback, int pLeft, int pRight) =>
    [tDir, tH, tL] = f_getStrictTrend(high, low, pLeft, pRight)
    [close, high, low, open, volume, ta.sma(volume, 50),
      ta.sma(close, dma50_len), ta.sma(close, dma150_len), ta.sma(close, dma200_len),
      f_calc_slope_val(ta.sma(close, dma50_len), dmaSlopeLen),
      ta.ema(close, 20),
      ta.atr(14), ta.atr(10), ta.atr(40),
      ta.highest(high, 20), ta.lowest(low, 20),
      ta.highest(high, 252), ta.highest(high, 1250), ta.lowest(low, 252),  // v67.2.5: d_l52 for Bull Screener trend-template gate
      ta.rsi(close, 14),
      ta.highest(high, fibLookback), ta.lowest(low, fibLookback), f_calc_adx_bool(), close[65], close[130], tDir, tH, tL,
      (high[1] + low[1] + close[1]) / 3, (high[1] + low[1]) / 2, ((high[1] + low[1] + close[1]) / 3 - (high[1] + low[1]) / 2) + (high[1] + low[1] + close[1]) / 3,
      f_get_mvwap()]

// 4. DAILY SUPER BUNDLE
[d_c, d_h, d_l, d_o, d_v, d_vavg, d_sma50, d_sma150, d_sma200, d_slope50, d_ema20val, d_atr14, d_atr10, d_atr40, d_h20, d_l20, d_h52, d_hATH, d_l52, d_rsiVal, d_h_fib, d_l_fib, d_adx_ok, c_65_ago, c_130_ago, dTrendDir, dLockH, dLockL, d_pivot, d_bc, d_tc, m_vwap] = request.security(syminfo.tickerid, "D", f_daily_super_bundle_internal(dma50_len, dma150_len, dma200_len, dmaSlopeLen, fibLookback, pivotLeft, pivotRight), ignore_invalid_symbol=true)


dClose := d_c
dHigh := d_h
dLow := d_l
dMA50 := d_sma50
dMA200 := d_sma200
dailyRsi := d_rsiVal 
d_atr10_val := d_atr10
d_atr40_val := d_atr40
d_ema20_val := d_ema20val
d_vol := d_v
d_vol_avg := d_vavg
atrVal := d_atr14

// 5. RS BUNDLES (3 Calls) - CALCULATING RS STATE EARLY FOR USE IN STAGE LOGIC
// Auto-detect Sector (Overrides manual input if needed, or we can use manual as fallback)
// We will use the AUTO scanner as primary
[global_sec_t, global_sec_n] = f_get_hybrid_sector()
string autoSectorTick = useManual ? benchSector : global_sec_t
string autoSectorName = useManual ? str.replace_all(benchSector, "NSE:", "") : global_sec_n

// Fallback to Nifty 500 if no sector found
if autoSectorTick == ""
    autoSectorTick := bench500
    autoSectorName := "Nifty 500 (Default)"

// Safety Checks for Spreads
bool valid_b50 = str.length(bench50) > 1
bool valid_b500 = str.length(bench500) > 1
bool valid_sec = str.length(autoSectorTick) > 1

// Gap 1: Sector Stage Gate — lightweight weekly stage read for the auto-detected sector
string _secStageTick = valid_sec ? autoSectorTick : ""
secStageStr := request.security(_secStageTick, "W", f_sec_stage_lite(), ignore_invalid_symbol=true)

// Unconditional Security Calls (Compiler Warning Fix)
// v63.4: lookahead_off (was lookahead_on) — removes forward-bar bias in weekly RS reads
string req50 = valid_b50 ? (cleanTicker + " / " + bench50) : ""
[_slope50, _val50, _pastSlope50, _rsMom50, _valTrail50, _momTrail50] = request.security(req50, "W", f_calc_rs_logic(rsLength, rsLevelLen, rsSlopeLen, jdkLength, rrgTrailLen), barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)

string req500 = valid_b500 ? (cleanTicker + " / " + bench500) : ""
[_slope500, _val500, _pastSlope500, _rsMom500, _valTrail500, _momTrail500] = request.security(req500, "W", f_calc_rs_logic(rsLength, rsLevelLen, rsSlopeLen, jdkLength, rrgTrailLen), barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)

string reqSec = valid_sec ? (cleanTicker + " / " + autoSectorTick) : ""
[_slopeSec, _valSec, _pastSlopeSec, _rsMomSec, _valTrailSec, _momTrailSec] = request.security(reqSec, "W", f_calc_rs_logic(rsLength, rsLevelLen, rsSlopeLen, jdkLength, rrgTrailLen), barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)


slope50 := _slope50
val50 := _val50
slope500 := _slope500
val500 := _val500
slopeSec := _slopeSec
valSec := _valSec


// v63.4: True RRG quadrant from (mansfield level, RS-momentum=ROC(mansfield,4)).
// Quadrants: LEADING / WEAKENING / LAGGING / IMPROVING.
rs50State  := f_rsStateStr(slope50,  val50,  rsSlopeThresh)
rs500State := f_rsStateStr(slope500, val500, rsSlopeThresh)
rsSecState := f_rsStateStr(slopeSec, valSec, rsSlopeThresh)

// Sector Velocity States
string secVelStr = "N/A"
color secVelCol = color.gray
if not na(slopeSec) and not na(_pastSlopeSec)
    [vStr, vCol] = f_rsVelocityStr(slopeSec, _pastSlopeSec)
    secVelStr := vStr
    secVelCol := vCol

// ==========================================
// 5.5 REFINED MARKET STRUCTURE (ACTIONABLE CONTEXT)
// ==========================================
// Focus: Describes the "Character" of the trend, not just the Definition.

bool d_bullish_200 = dClose > dMA200
bool rs_is_leading = str.contains(rs50State, "(Positive)")

// Base Logic from Weekly Stage Calc
if stageID == "STAGE 2 (UP)"
    if d_bullish_200
        if rs_is_leading
            stageDisplay := "🚀 STAGE 2 (Full Confluence)" // Price, MA, and RS all Green
            stageCol := color.new(#26a69a, 0)
        else
            stageDisplay := "⚠️ STAGE 2 (Weak Leadership)" // Price Up, but RS Negative
            stageCol := color.orange
    else
        stageDisplay := "⚓ STAGE 2 (Value Zone)" // Weekly Up, Daily Cheap (Below 200)
        stageCol := color.new(#26a69a, 30) 
else if stageID == "STAGE 2 (PULLBACK)"
    stageDisplay := "⚓ STAGE 2 (Dip Opportunity)" // Rising MA, price dipped slightly
    stageCol := color.new(#26a69a, 30)
else if stageID == "STAGE 1 (BASE)"
    if d_bullish_200
        stageDisplay := "👀 STAGE 1 (Constructive)" // Base is maturing, reclaimed 200SMA
        stageCol := color.new(#ff9800, 0)
    else
        stageDisplay := "😴 STAGE 1 (Dormant)" // Below 200SMA, snoozing
        stageCol := color.gray
else if stageID == "STAGE 3 (TOP)"
    stageDisplay := "🛑 STAGE 3 (Volatile Churn)" // High Volatility, No Progress
    stageCol := color.orange
else if stageID == "STAGE 4 (DOWN)"
    stageDisplay := "🔻 STAGE 4 (Liquidate)" // Clear Downtrend
    stageCol := color.red
else
    stageDisplay := stageID // Fallback
    stageCol := color.gray

// v67.2.2: Week count moved to the new "Stage 2 Age" row (leg + macro + freshness).
// stageDisplay now carries only the structural label so a glance at Market Structure
// gives regime; a glance at Stage 2 Age gives timing.
if wEarlyStage2
    stageDisplay := stageDisplay + " ⬆️PRE-S2"


// Trend variables provided by Daily Super Bundle v60.4
// CPR/MVWAP provided by Daily Super Bundle v60.4

// 7. BENCHMARK BUNDLE (1 Call)
// Fetch Base Index + Historical 65/130d Prices for RS Proxy
// v64.0: extended tuple to also expose CNX500 SMA50/SMA200/52W high as globals.
//        Used by the Recovery 3-way regime gate — NO new security call added.
var float b_c_65_ago = 0.0
var float b_c_130_ago = 0.0
var float b_c_val = 0.0
var float b_sma50_v  = na
var float b_sma200_v = na
var float b_h52_v    = na

if str.length(bench500) > 1
    [_b_c, _b_50, _b_200, _b_c_65, _b_c_130, _b_h52] = request.security(bench500, "D", [close, ta.sma(close, 50), ta.sma(close, 200), close[65], close[130], ta.highest(high, 250)], ignore_invalid_symbol=true)

    b_c_65_ago := na(_b_c_65) ? 0.0 : _b_c_65
    b_c_130_ago := na(_b_c_130) ? 0.0 : _b_c_130
    b_c_val := na(_b_c) ? 0.0 : _b_c
    b_sma50_v  := _b_50
    b_sma200_v := _b_200
    b_h52_v    := _b_h52
    bool bench_data_valid = not na(_b_c_65) and _b_c_65 > 0
    if _b_c > _b_50 and _b_50 > _b_200
        mktState := "BULLISH (Confirmed)"
        mktColor := color.new(#26a69a, 0)
    else if _b_c < _b_50 and _b_50 > _b_200 and _b_c > _b_200
        mktState := "CORRECTION (In Uptrend)"
        mktColor := color.new(#ff9800, 30) 
    else if _b_c > _b_50 and _b_50 < _b_200
        mktState := "RECOVERY (Weak)"
        mktColor := color.blue
    else
        mktState := "BEARISH"
        mktColor := color.red
else
    mktState := "N/A (No Bench)"
    mktColor := color.gray

// v67.0: Recovery Edges and RFF Lite calculation block removed.
// All recovery detection logic migrated to Weinstein Unified Ecosystem.


// --- LOCAL LOGIC (ZERO CALLS) ---

d50SlopeState := "FLAT"
if d_slope50 > (d_sma50 * flatThresh)
    d50SlopeState := "RISING"
else if d_slope50 < -(d_sma50 * flatThresh)
    d50SlopeState := "FALLING"

bool dSmaAligned = (d_sma50 > d_sma150) and (d_sma150 > d_sma200)

cpr_ok = not use_micro_edge or (close > d_tc)

mvwap_ok = not use_micro_edge or (close > m_vwap)

// Vol Shelf: VWMA(20) > VWMA(50) with 3-bar confirmation — faster detection of institutional accumulation.
d_vwma_20 = ta.vwma(volume, 20)
d_vwma_50 = ta.vwma(volume, 50)
vol_shelf_ok = not use_macro_edge or (d_vwma_20 > d_vwma_50 and d_vwma_20[1] > d_vwma_50[1] and d_vwma_20[2] > d_vwma_50[2])

f_get_vol_accum(lookback, min_days, avg_len) =>
    vol_sma = ta.sma(volume, avg_len)
    daily_range = high - low
    closing_range = daily_range == 0 ? 0 : (close - low) / daily_range
    is_accum = (close > close[1]) and (volume > vol_sma) and (closing_range > 0.6)
    accum_density = math.sum(is_accum ? 1 : 0, lookback)
    accum_density >= min_days 

vol_accum_res = f_get_vol_accum(vol_acc_days, vol_acc_min, vol_avg_len)
vol_acc_ok    = not use_macro_edge or vol_accum_res

f_is_vcp(mult) =>
    atr_10 = ta.atr(10)
    avg_atr_50 = ta.sma(atr_10, 50)
    is_tight = atr_10 < (avg_atr_50 * mult)
    is_dry = ta.vwma(volume, 5) < ta.sma(volume, 50)
    is_tight and is_dry

vcp_res = f_is_vcp(vcp_thresh)
vcp_ok  = vcp_res // Always require VCP parameters for ideal setup filtering
vcp_ok_bo  = f_is_vcp(vcp_mult_bo)
vcp_ok_swg = f_is_vcp(vcp_mult_swg)

// --- KEY-LEVEL / ZONE PROXIMITY LOGIC ---
// 1. Demand & Supply Zones (FVG Proxy)
var float last_dz = na // Bullish FVG (Demand)
var float last_sz = na // Bearish FVG (Supply)

// Bullish FVG: Current low > High of 2 bars ago
if low > high[2] and close[1] > open[1]
    last_dz := high[2] // The top of the gap acts as Demand

// Bearish FVG: Current high < Low of 2 bars ago
if high < low[2] and close[1] < open[1]
    last_sz := low[2] // The bottom of the gap acts as Supply

// v67.2 FIX #10: Invalidate FVG zones when price closes through them.
// A demand zone is "broken" once close prints below it; a supply zone is broken
// once close prints above it. Without this, stale gaps remained active forever
// and polluted the Key-Level Proximity row.
if not na(last_dz) and close < last_dz
    last_dz := na
if not na(last_sz) and close > last_sz
    last_sz := na

// 2. Trendlines & Multiple Pivots (Strictly Pivot Connections)
var float pl1 = na, var int pl1_bar = na
var float pl2 = na, var int pl2_bar = na
var float[] last_pls = array.new_float(5, na)

float curr_pl = ta.pivotlow(low, 5, 5)
if not na(curr_pl)
    pl2 := pl1, pl2_bar := pl1_bar
    pl1 := curr_pl, pl1_bar := bar_index - 5
    array.unshift(last_pls, curr_pl)
    array.pop(last_pls)

var float ph1 = na, var int ph1_bar = na
var float ph2 = na, var int ph2_bar = na
var float[] last_phs = array.new_float(5, na)

float curr_ph = ta.pivothigh(high, 5, 5)
if not na(curr_ph)
    ph2 := ph1, ph2_bar := ph1_bar
    ph1 := curr_ph, ph1_bar := bar_index - 5
    array.unshift(last_phs, curr_ph)
    array.pop(last_phs)

float tl_bull = na
if not na(pl1) and not na(pl2) and pl1_bar != pl2_bar
    float slope_l = (pl1 - pl2) / (pl1_bar - pl2_bar)
    tl_bull := pl1 + slope_l * (bar_index - pl1_bar)

float tl_bear = na
if not na(ph1) and not na(ph2) and ph1_bar != ph2_bar
    float slope_h = (ph1 - ph2) / (ph1_bar - ph2_bar)
    tl_bear := ph1 + slope_h * (bar_index - ph1_bar)

// 3. Dynamic 20EMA & ATH
float dyn_sr = d_ema20val
float cur_ath = f_trackATH()

// Calculate distances (%)
f_dist_pct(float val) => val != 0 and not na(val) ? math.abs(close - val) / close * 100 : 999.0

float dist_dz = f_dist_pct(last_dz)
float dist_sz = f_dist_pct(last_sz)
float dist_tl_bull = f_dist_pct(tl_bull)
float dist_tl_bear = f_dist_pct(tl_bear)
float dist_dyn_sr = f_dist_pct(dyn_sr)
float dist_ath = f_dist_pct(cur_ath)

// v67.2 FIX #14: prox_thresh now sourced from input (group "Advanced Thresholds").
string[] active_lbls = array.new_string(0)
float min_dist = 999.0
string closest_pos = "near"

if dist_dz <= prox_thresh
    array.push(active_lbls, "DZ")
    if dist_dz < min_dist
        min_dist := dist_dz
        closest_pos := close > last_dz ? "above" : "below"

if dist_sz <= prox_thresh
    array.push(active_lbls, "SZ")
    if dist_sz < min_dist
        min_dist := dist_sz
        closest_pos := close > last_sz ? "above" : "below"

if dist_tl_bull <= prox_thresh
    array.push(active_lbls, "TL (Bullish)")
    if dist_tl_bull < min_dist
        min_dist := dist_tl_bull
        closest_pos := close > tl_bull ? "above" : "below"

if dist_tl_bear <= prox_thresh
    array.push(active_lbls, "TL (Bearish)")
    if dist_tl_bear < min_dist
        min_dist := dist_tl_bear
        closest_pos := close > tl_bear ? "above" : "below"

// Iterate recent 5 pivot highs and lows to find closest S/R
float min_piv_dist = 999.0
float best_piv_val = na

for i = 0 to 4
    float ph = array.get(last_phs, i)
    if not na(ph)
        float d = f_dist_pct(ph)
        if d < min_piv_dist
            min_piv_dist := d
            best_piv_val := ph

    float pl = array.get(last_pls, i)
    if not na(pl)
        float d = f_dist_pct(pl)
        if d < min_piv_dist
            min_piv_dist := d
            best_piv_val := pl

if min_piv_dist <= prox_thresh
    string p_lbl = close > best_piv_val ? "S" : "R"
    if array.indexof(active_lbls, p_lbl) == -1
        array.push(active_lbls, p_lbl)
    if min_piv_dist < min_dist
        min_dist := min_piv_dist
        closest_pos := close > best_piv_val ? "above" : "below"

if dist_dyn_sr <= prox_thresh
    string dyn_qualifier = close > dyn_sr ? "S" : "R"
    array.push(active_lbls, "Dynamic " + dyn_qualifier)
    if dist_dyn_sr < min_dist
        min_dist := dist_dyn_sr
        closest_pos := close > dyn_sr ? "above" : "below"

if dist_ath <= prox_thresh
    array.push(active_lbls, "ATH")
    if dist_ath < min_dist
        min_dist := dist_ath
        closest_pos := close > cur_ath ? "above" : "below"

if array.size(active_lbls) > 0
    string joined_lbls = array.join(active_lbls, ", ")
    keyLvlState := str.tostring(min_dist, "#.1") + "% " + closest_pos + " " + joined_lbls
    keyLvlColor := color.orange
else
    keyLvlState := "MID-RANGE (No Near Level)"
    keyLvlColor := color.gray

// Volume calc locally first because Price Action breakout check needs it now (v56.0)
float curRelVol = d_vavg != 0 ? d_v / d_vavg : 0.0

// ==========================================
// v67.2: PRICE-ACTION SETUP DETECTORS
// Each detector is a boolean; the cascade below maps detections to
// (paState, paColor, paTier). paTier is consumed by the Action Signal score.
// ==========================================

// v67.4.5: Shared trend-context helper for reversal-pattern preconditions.
// A "reversal" only makes sense after a decline — without this gate, hammer
// and bullish engulfing fire as continuation noise inside uptrends.
float _ema10_ctx = ta.ema(close, 10)
float _ema20_ctx = ta.ema(close, 20)
bool  _inDowntrendCtx = close < _ema10_ctx and _ema10_ctx < _ema20_ctx

// True NR7 — current bar range strictly smallest of last 7 bars.
// v67.4.5 FIX #9: use strict < so a tie on a prior bar's range doesn't kill NR7.
bool _r0 = true
float _curRange = high - low
for _i = 1 to 6
    if (high[_i] - low[_i]) < _curRange
        _r0 := false
        break
bool pa_nr7 = _r0

// Inside Bar / Inside-3
bool pa_inside  = high < high[1] and low > low[1]
bool pa_inside3 = pa_inside and (high[1] < high[2] and low[1] > low[2]) and (high[2] < high[3] and low[2] > low[3])

// Pocket Pivot (Bonde / Minervini) — up close, vol > max DOWN-bar volume in last 10.
// v67.4.5 FIX #4: added "above 50-SMA" gate + close in upper half of bar.
// Stops Tier +2 prints inside Stage 4 relief rallies.
float _maxDownVol = 0.0
for _j = 1 to 10
    if close[_j] < close[_j+1] and volume[_j] > _maxDownVol
        _maxDownVol := volume[_j]
bool _pp_closeUpperHalf = (close - low) >= ((high - low) * 0.5)
bool pa_pocket = close > close[1] and close > open and _maxDownVol > 0 and volume > _maxDownVol and not na(dMA50) and close > dMA50 and _pp_closeUpperHalf

// Bullish / Bearish Engulfing (body engulfs prior body).
// v67.4.5 FIX #7: bullish engulfing required downtrend context + relVol > 1.2.
// v67.4.11 B6 GATE: tighten to relVol > 2.0 AND prior-bar oversold (RSI(14)[1] < 40).
// N500 verified: lifts bull-regime alpha from -0.21% to +1.35% (P=91%),
// bear-regime alpha from +2.93% to +6.92% (P=100%). Captures only the
// classic-TA "engulf at oversold with institutional volume" setup.
float _bullengulf_rsi = ta.rsi(close, 14)
bool _raw_bull_engulf = close[1] < open[1] and close > open and open <= close[1] and close >= open[1]
bool pa_bull_engulf = _raw_bull_engulf and _inDowntrendCtx and curRelVol > 2.0 and not na(_bullengulf_rsi[1]) and _bullengulf_rsi[1] < 40
bool pa_bear_engulf = close[1] > open[1] and close < open and open >= close[1] and close <= open[1]

// Hammer — small body in upper third, lower wick > 2× body
float _bodyHi = math.max(open, close)
float _bodyLo = math.min(open, close)
float _body   = _bodyHi - _bodyLo
float _lower  = _bodyLo - low
float _upper  = high - _bodyHi
float _rng    = high - low
bool pa_hammer = _rng > 0 and _lower > _body * 2 and _upper < _body and (_bodyHi >= low + _rng * 0.66)

// Wyckoff Spring — dipped below the n-day low intraday, closed back above.
// v67.4.5 FIX #5: lookback widened 20d → 50d (proper Wyckoff TR length) and
// requires light-volume undercut (volume < 50-SMA of volume). Removes most
// false +3 prints from any random dip-recover.
float _l50_spring = ta.lowest(low, 50)
float _vol_sma50_spring = ta.sma(volume, 50)
bool pa_spring = not na(_l50_spring) and low < _l50_spring[1] and close > _l50_spring[1] and close > open and volume < _vol_sma50_spring

// Failed Breakout — yesterday closed above dLockH (with meaningful overshoot),
// today closes back below. v67.4.5 FIX #1: added 0.5×ATR overshoot threshold +
// relVol gate. Previously fired on any 0.01% wick above dLockH.
// v67.4.9 FIX #2: use dLockH[1] (yesterday's locked-high) as the breakout
// reference. dLockH today INCLUDES today's high in its rolling max, so
// close[1] > dLockH was structurally impossible (close[1] can only EQUAL
// the max it contributed to, never strictly exceed it).
float _bo_buf = atrVal * 0.5
float _dLockH_ref = dLockH[1]
bool pa_failed_bo = not na(_dLockH_ref) and close < _dLockH_ref and close[1] > (_dLockH_ref + _bo_buf) and high[1] > (_dLockH_ref + _bo_buf) and curRelVol > 1.0

// 3-Bar Bullish Reversal — 3 lower lows then close > max of last 3 highs
bool pa_3bar_rev = low[1] < low[2] and low[2] < low[3] and close > math.max(high[1], math.max(high[2], high[3]))

// Distribution Day — IBD definition: close < prior close by ≥0.2% AND
// volume > prior bar's volume. v67.4.5 FIX #2: was close < open (could fire
// on an up-day with a red body) — now uses the proper prior-close reference.
bool pa_distrib = close < close[1] * 0.998 and volume > volume[1] and (high - low) > atrVal

// Flat Base — 25-day H–L range < 12% of low
float _h25 = ta.highest(high, 25)
float _l25 = ta.lowest(low, 25)
bool pa_flat_base = _l25 > 0 and ((_h25 - _l25) / _l25) < 0.12

// Stage-2 Launch — TRUE weekly crossover of close over 30-WMA with volume.
// v67.4.5 FIX #3: now uses request.security("W", ta.crossover(...)) so
// close[1] genuinely means previous weekly bar. Daily-TF zig-zags around
// wMA30 no longer repeatedly fire this +3 catalyst.
bool _w_s2_cross = request.security(syminfo.tickerid, "W", ta.crossover(close, ta.sma(close, maLengthW)), ignore_invalid_symbol=true)
bool pa_s2_launch = stageID == "STAGE 2 (UP)" and _w_s2_cross and curRelVol > 1.25

// SMC Liquidity Sweep — moved up from Action Signal block so PA cascade can consume it.
// v67.2 FIX #7: 10-bar dedup guard. Old logic re-fired every bar where conditions
// held — e.g. a stock bouncing repeatedly around its 50SMA with above-avg volume
// would print "LIQ SWEEP RECLAIM" 5 days in a row. Now fires once, then locks
// out for 10 bars (configurable via liq_sweep_lockout input).
float c_s50        = ta.sma(close, 50)
float c_vol_sma50  = ta.sma(volume, 50)
float c_low5       = ta.lowest(low, 5)
bool  _raw_liq_sweep = c_low5 < c_s50 and close > c_s50 and volume > (c_vol_sma50 * 1.5)
var int barsSinceLiqSweep = 9999
bool c_liq_sweep = _raw_liq_sweep and barsSinceLiqSweep > liq_sweep_lockout
barsSinceLiqSweep := c_liq_sweep ? 0 : (barsSinceLiqSweep + 1)

// Tight VCP Breakout — vcp_ok + close > 10d high + relVol > 1.2 + intra-pos ≥ 0.60
// v67.4.9 FIX #1: vcp_ok is checked on PRIOR bar (vcp_ok[1]). The breakout bar
// itself is by definition an expansion — wide range, vol spike — so atr_10
// and vwma(vol,5) both spike on it, making vcp_ok false on the very bar
// pa_vcp_bo wants to fire. The fix: require contraction in the bar BEFORE
// the breakout. This is the Minervini sequence (tight → break) the detector
// was always trying to express.
float _pa_10d_high_1 = ta.highest(high, 10)[1]
bool pa_vcp_bo = vcp_ok[1] and close > _pa_10d_high_1 and curRelVol > 1.2 and (close - low) > ((high - low) * 0.60)

// v56.0 Anti-Algo Breakout Filter
bool closeNearHigh  = (close - low) > ((high - low) * 0.75)
bool volConfirm     = curRelVol > 1.25
bool hasLockH       = not na(dLockH)
bool isTrueBreakout = hasLockH and close > dLockH and closeNearHigh and volConfirm

// ==========================================
// v67.4.6: NEW PA DETECTORS
// ==========================================

// Shared uptrend-context helper (mirror of _inDowntrendCtx from v67.4.5).
// Used to gate shooting-star reversal precondition.
bool _inUptrendCtx = close > _ema10_ctx and _ema10_ctx > _ema20_ctx

// Shooting Star — body in lower third of bar, upper wick > 2× body,
// lower wick < body. Bearish only when there's an uptrend to reverse AND
// price is extended (near 52w high OR >15% above dMA50).
bool _ss_shape = _rng > 0 and _upper > _body * 2 and _lower < _body and (_bodyLo <= low + _rng * 0.33)
bool _ss_extended = (not na(d_h52) and d_h52 > 0 and (close / d_h52) > 0.95) or (not na(dMA50) and dMA50 > 0 and ((close - dMA50) / dMA50) > 0.15)
bool pa_shooting_star = _ss_shape and _inUptrendCtx and _ss_extended

// Outside Bar (Bullish) — fully engulfs prior bar's range AND closes above
// prior high. Stronger than plain bullish engulfing; sweeps both extremes.
bool pa_outside_bull = high > high[1] and low < low[1] and close > high[1] and close > open

// Gap-Up Breakout — opens above prior high, closes above dLockH with vol.
// Minervini's institutional gap. Must hold the gap into the close.
bool pa_gap_up_bo = hasLockH and open > high[1] and close > dLockH and close > open and volConfirm

// IB-NR7 Coil — inside bar AND NR7 on the same bar. Institutional-grade
// volatility compression (Crabel). Promoted to Tier +2.
bool pa_ib_nr7 = pa_inside and pa_nr7

// v67.4.8: Hammer at 50/200 SMA — institutional defense of major MA.
// pa_hammer already validates the wick geometry; here we add MA proximity.
bool _near_dma50  = not na(dMA50)  and dMA50  > 0 and math.abs(low - dMA50)  / dMA50  <= 0.015
bool _near_dma200 = not na(dMA200) and dMA200 > 0 and math.abs(low - dMA200) / dMA200 <= 0.020
bool pa_hammer_at_50  = pa_hammer and _near_dma50  and close > dMA50  and curRelVol > 1.0
bool pa_hammer_at_200 = pa_hammer and _near_dma200 and close > dMA200 and curRelVol > 1.0

// v67.4.8: 50SMA Undercut & Rally — keys off the SMA itself (not the 50-bar
// low like Wyckoff Spring). Institutional reference defense.
bool pa_50sma_undercut = not na(dMA50) and dMA50 > 0 and low < dMA50 and close > dMA50 and close > open and curRelVol > 1.25

// ==========================================
// v67.4.6: BASE COUNT TRACKER
// Tracks completed bases since the last fresh Stage 1→2 transition.
// A base completes when price reclaims the prior base-high after pulling
// back ≥7% from it. baseCount is appended as "[B<n>]" to VCP BO and
// Stage-2 Launch state strings.
// ==========================================
var int   baseCount       = 0
var float baseTrackHigh   = na
var bool  basePullbackOcc = false
bool _freshStage2 = stageID == "STAGE 2 (UP)" and stageID[1] != "STAGE 2 (UP)"
if _freshStage2
    baseCount       := 1
    baseTrackHigh   := high
    basePullbackOcc := false
else if not na(baseTrackHigh)
    if low < baseTrackHigh * 0.93
        basePullbackOcc := true
    if basePullbackOcc and close > baseTrackHigh
        baseCount       := baseCount + 1
        baseTrackHigh   := high
        basePullbackOcc := false
    else if high > baseTrackHigh and not basePullbackOcc
        baseTrackHigh := high
string _baseTag = baseCount > 0 ? " [B" + str.tostring(baseCount) + "]" : ""

// ==========================================
// PRICE-ACTION CASCADE (priority: A+ > A > B > Tier 0 watch > C)
// Sets paState, paColor, paTier.
// v67.4.12: 4 bearish detectors moved to Tier 0 watch states near bottom
// of cascade (no longer override bullish states). See header changelog.
// ==========================================
if pa_spring
    paState := "★ SPRING (Failed Breakdown)"
    paColor := color.new(#00c853, 0)
    paTier  := 3
// v67.4.6: GAP-UP BREAKOUT — institutional gap above pivot with vol. Tier +3.
else if pa_gap_up_bo
    isBreakout := true
    paState := "★ GAP-UP BREAKOUT" + _baseTag
    paColor := color.new(#00c853, 0)
    paTier  := 3
else if pa_vcp_bo
    paState := "★ VCP BREAKOUT" + _baseTag
    paColor := color.new(#00c853, 0)
    paTier  := 3
else if pa_s2_launch
    paState := "★ STAGE-2 LAUNCH" + _baseTag
    paColor := color.new(#26a69a, 0)
    paTier  := 3
else if isTrueBreakout
    isBreakout := true
    paState := "BREAKOUT (Confirmed)" + _baseTag
    paColor := color.new(#26a69a, 0)
    paTier  := 2
// v67.4.8: 50SMA Undercut & Rally — institutional reference defense.
// More specific than Pocket Pivot when both fire (undercut + reclaim of the
// 50SMA itself is the cleaner signal).
else if pa_50sma_undercut
    paState := "★ 50SMA UNDERCUT & RALLY"
    paColor := color.new(#00c853, 0)
    paTier  := 2
else if pa_pocket
    paState := "★ POCKET PIVOT"
    paColor := color.new(#26a69a, 0)
    paTier  := 2
// v67.4.10: OUTSIDE BAR moved to Tier +1 — see changelog. (Was here at Tier +2.)
else if c_liq_sweep
    paState := "★ LIQ SWEEP RECLAIM"
    paColor := color.aqua
    paTier  := 2
else if pa_bull_engulf
    paState := "BULLISH ENGULFING"
    paColor := color.new(#26a69a, 30)
    paTier  := 2
else if pa_3bar_rev
    paState := "3-BAR REVERSAL (Bull)"
    paColor := color.new(#26a69a, 30)
    paTier  := 2
// v67.2 FIX #4: POWER PLAY (Strong Close) promoted from B (+1) to A (+2) and
// moved above breakout/consolidation branches. Old position meant a long
// bullish lower-wick bar was suppressed by any passive close-near-pivot match.
// v67.4.5 FIX #8: now requires curRelVol > 1.0 — a no-volume marubozu in a
// downtrend should not earn Tier +2.
else if close > open and (close - low) > (high - close) * 3 and curRelVol > 1.0
    paState := "POWER PLAY (Strong Close)"
    paColor := color.new(#26a69a, 30)
    paTier  := 2
else if hasLockH and close > dLockH
    paState := "BREAKOUT (Unconfirmed)"
    paColor := color.orange
    paTier  := 1
else if hasLockH and close < dLockH and close > (dLockH * 0.95)
    paState := "CONSOLIDATION (Tight)"
    paColor := color.blue
    paTier  := 1
else if pa_flat_base
    paState := "FLAT BASE (Tight)"
    paColor := color.blue
    paTier  := 1
// v67.4.6: IB-NR7 Coil — promoted to Tier +2. Inside bar AND NR7 together
// is institutional-grade volatility compression (Crabel). Sits above plain
// inside-3 / NR7 because it's strictly stronger than either alone.
else if pa_ib_nr7
    paState := "★ IB-NR7 COIL"
    paColor := color.new(#26a69a, 0)
    paTier  := 2
else if pa_inside3
    paState := "INSIDE-3 (Coil)"
    paColor := color.new(#ff9800, 0)
    paTier  := 1
else if pa_nr7
    paState := "★ TRUE NR7"
    paColor := color.new(#ff9800, 0)
    paTier  := 1
else if pa_inside
    paState := "INSIDE BAR"
    paColor := color.new(#ff9800, 30)
    paTier  := 1
// v67.4.10: OUTSIDE BAR (Bull) demoted from Tier +2 to Tier +1 per N500 data.
// Still flagged with ★ as a notable engulf pattern; just no longer earns
// the higher Action Signal weight.
else if pa_outside_bull
    paState := "★ OUTSIDE BAR (Bull)"
    paColor := color.new(#26a69a, 30)
    paTier  := 1
// v67.4.5 FIX #6: replaced inverted "close > dMA50" filter with proper
// downtrend-context gate. Hammers earn their keep AFTER a decline — the old
// filter was suppressing hammers exactly where they were most actionable
// (bouncing off the 50/200 SMA from below).
// v67.4.8: 200SMA defense first (longer-cycle reference); 50SMA second.
// Both promoted to Tier +2. Plain hammer (Tier +1) catches the rest.
else if pa_hammer_at_200
    paState := "★ HAMMER (at 200SMA)"
    paColor := color.new(#00c853, 0)
    paTier  := 2
else if pa_hammer_at_50
    paState := "★ HAMMER (at 50SMA)"
    paColor := color.new(#26a69a, 0)
    paTier  := 2
else if pa_hammer and _inDowntrendCtx
    paState := "HAMMER (Reversal)"
    paColor := color.new(#26a69a, 30)
    paTier  := 1
else if close < open and (high - close) > (close - low) * 3
    paState := "SELLING TAIL (Rejection)"
    paColor := color.orange
    paTier  := -1
// v67.4.12: Bearish "(Watch)" detectors — neutralized to Tier 0 per N500 data.
// Still visible as labels for human pattern recognition; no score penalty.
// Co-firing bullish states above this point win the cascade.
else if pa_failed_bo
    paState := "FAILED BREAKOUT (Watch)"
    paColor := color.new(color.orange, 30)
    paTier  := 0
else if pa_distrib
    paState := "DISTRIBUTION DAY (Watch)"
    paColor := color.new(color.orange, 30)
    paTier  := 0
else if pa_bear_engulf and close < dMA50
    paState := "BEARISH ENGULFING (Watch)"
    paColor := color.new(color.orange, 30)
    paTier  := 0
else if pa_shooting_star
    paState := "SHOOTING STAR (Watch)"
    paColor := color.new(color.orange, 30)
    paTier  := 0
else
    paState := "NORMAL"
    paColor := color.gray
    paTier  := 0

// HTF (High-Tight Flag) — strongest override (+4): 100% move in 8w + tight 15-bar consolidation
float low8w = ta.lowest(low, 40)
bool bigMove = (close - low8w) / low8w > 1.0
bool consolidation = (ta.highest(high, 15) - ta.lowest(low, 15)) / ta.lowest(low, 15) < 0.20
bool htf = bigMove and consolidation and dClose > dMA50
if htf
    paState := "★★ POWER PLAY (HTF)"
    paColor := color.fuchsia
    paTier  := 4

// ==========================================
// v67.4.7 DECORATOR #1 — BASE-COUNT TIER ADJUSTMENT
// Demote late-stage breakouts. HTF (Tier 4) is the launch leg, not late
// continuation, so exempt it. Only bullish breakout/launch class affected.
// ==========================================
bool _isBreakoutClass = paTier >= 2 and paTier < 4 and (str.contains(paState, "BREAKOUT") or str.contains(paState, "LAUNCH"))
if _isBreakoutClass and baseCount == 3
    paState := paState + " ⚠ Late Stage"
    paColor := color.new(#ff9800, 0)
    paTier  := paTier - 1
else if _isBreakoutClass and baseCount >= 4
    paState := paState + " ⚠ V.Late (B" + str.tostring(baseCount) + ")"
    paColor := color.orange
    paTier  := paTier - 2

// ==========================================
// v67.4.7 DECORATOR #2 — VOLUME-CONFIRMATION TAG
// Only tag actionable patterns. Avoid double-tagging if a "(Vol" substring
// is already present (defensive against future cascade changes).
// ==========================================
if math.abs(paTier) >= 1 and not str.contains(paState, "(Vol")
    if curRelVol >= 2.0
        paState := paState + " (Vol++)"
    else if curRelVol >= 1.5
        paState := paState + " (Vol+)"
    else if curRelVol < 0.7
        paState := paState + " (Low Vol)"

// Volume state (Uses curRelVol from earlier)
string curVolStr = str.tostring(curRelVol, "#.1") + "x"
volState := "NORMAL (" + curVolStr + ")"
if curRelVol > 1.5
    if d_c > d_c[1]
        volState := "ACCUMULATION (" + curVolStr + ")"
        volColor := color.new(#26a69a, 0)
    else
        volState := "DISTRIBUTION (" + curVolStr + ")"
        volColor := color.red
else if curRelVol < 0.7
    volState := "DRY UP (" + curVolStr + ")"
    volColor := color.new(#ff9800, 0)

// Volatility (VCP v56.0 Upgrade)
bool isContraction = d_atr10_val < (d_atr40_val * 0.75) 
bool volumeDryUp = curRelVol < 0.8 // Requires Volume to die down to be a true VCP
bool isExpansion = d_atr10_val > (d_atr40_val * 1.25)

patStr := "Normal Volatility"
if isContraction and volumeDryUp
    patStr := "VCP (True Dry Up)"
else if isContraction
    patStr := "VCP (Actionable)" // Contracting, but lacking that perfect volume signature
else if isExpansion
    patStr := "Vol Expansion"

// Highs
// Highs (Space to Run)
float distTo52 = ((close - d_h52) / d_h52) * 100
float distToATH = ((close - d_hATH) / d_hATH) * 100
// If below high, show distance TO it (Positive Space). If above, show deviation FROM it.
dev52 := distTo52 < 0 ? math.abs(distTo52) : distTo52
devATH := distToATH < 0 ? math.abs(distToATH) : distToATH
// Format strings for display
string s_dev52 = (distTo52 < 0 ? "Run: " : "Abv: ") + str.tostring(math.abs(distTo52), "#.1") + "%"
string s_devATH = (distToATH < 0 ? "Run: " : "Abv: ") + str.tostring(math.abs(distToATH), "#.1") + "%"

// EMA Logic
d_ema20 := d_ema20val
isIntra := timeframe.isintraday
use_ema20 := isIntra ? d_ema20 : ta.ema(close, 20)
ema_lbl := isIntra ? "Price vs EMA20 (Daily)" : "Price vs EMA20 (Chart)"

if not na(use_ema20)
    emaDist := close != 0 ? (close - use_ema20) / close * 100 : 0.0
    absDist := math.abs(emaDist)
    string extState = absDist > 15.0 ? "OverExtended" : "Normal"
    if high > use_ema20 and close < use_ema20
        emaState := "RESISTANCE (Hit Head)"
        emaColor := color.red
    else if low < use_ema20 and close > use_ema20
        emaState := "SUPPORT (Bounced)"
        emaColor := color.new(#26a69a, 0)
    else if absDist < 1.0
        emaState := "NEAR (" + str.tostring(emaDist, "#.1") + "%)"
        emaColor := color.blue
    else if close > use_ema20
        emaState := "PRICE ABOVE (" + extState + ")" 
        emaColor := color.new(#26a69a, 30)
    else
        emaState := "PRICE BELOW (" + extState + ")"
        emaColor := color.red

// Earnings
earningsNext = earnings.future_time 
if not na(earningsNext)
    earnStr := str.format_time(earningsNext, "dd-MMM")
    float msPerDay = 1000 * 60 * 60 * 24
    float daysToEarn = (earningsNext - timenow) / msPerDay
    if daysToEarn > 0 and daysToEarn <= 5
        earnStr := "⚠️ " + earnStr + " (<5 Days!)"
        earnColor := color.red
    else
        earnColor := color.gray

[_currRsi, _currRsiDiv] = f_rsi_div(close, 14, 5, 5)
currRsi := _currRsi
currRsiDiv := _currRsiDiv

bool isSqueeze = g_atr5 < (g_atr20 * 0.60)
if isSqueeze
    volState := "VOLATILITY SQUEEZE (Ready)"
    volColor := color.blue

// Score Base
score := 0
if stageID == "STAGE 2 (UP)"
    score += 25
else if stageID == "STAGE 1 (BASE)"
    score += 10
if str.contains(rs50State, "(Positive)")  // FIX v62.0: using str.contains to match Positive RS level
    score += 15
if d50SlopeState == "RISING" and dSmaAligned
    score += 15
else if d50SlopeState == "RISING"
    score += 5
if str.contains(volState, "ACCUM") or isSqueeze
    score += 10
if dailyRsi > 50 and dailyRsi < 70
    score += 5
float distToDailyEma = close != 0 ? math.abs((close - d_ema20_val) / close * 100) : 0.0
if distToDailyEma < 2.0 
    score += 10 

// ==========================================
// v56.0 IBD RS PERCENTILE PROXY (Performance Score)
// ==========================================
float p_q3 = na(c_65_ago) or c_65_ago == 0 ? 0.0 : ((dClose - c_65_ago) / c_65_ago) * 100
float p_h1 = na(c_130_ago) or c_130_ago == 0 ? 0.0 : ((dClose - c_130_ago) / c_130_ago) * 100

// Compare against Benchmark (Nifty 500 equivalent raw growth)
float safe_b_c = na(b_c_val) ? 0.0 : b_c_val
bool bench_data_valid = not na(safe_b_c) and safe_b_c > 0 and not na(b_c_65_ago) and b_c_65_ago > 0 and not na(b_c_130_ago) and b_c_130_ago > 0
float b_q3 = not bench_data_valid ? 0.0 : ((safe_b_c - b_c_65_ago) / b_c_65_ago) * 100
float b_h1 = not bench_data_valid ? 0.0 : ((safe_b_c - b_c_130_ago) / b_c_130_ago) * 100

// We want stock outperformance
float alpha_q3 = p_q3 - b_q3
float alpha_h1 = p_h1 - b_h1

if alpha_q3 > 20.0 and alpha_h1 > 30.0
    score += 20 // Huge outperformance
else if alpha_q3 > 10.0 and alpha_h1 > 15.0
    score += 10 // Solid outperformance
else if alpha_q3 < 0.0 or alpha_h1 < 0.0
    score -= 10 // Underperformer

// v67.2 FIX #15: Floor at 0 — under-performance branch can subtract 10 and the
// pre-cap value could go negative, displaying as "-X/100" in the dashboard.
if score < 0
    score := 0
// Cap Score
if score > 100
    score := 100

if score >= 80
    grade := "A+ (Excellent)"
    gradeCol := color.new(#26a69a, 0)
else if score >= 60
    grade := "B (Good)"
    gradeCol := color.new(#ff9800, 0)
else
    grade := "C (Weak)"
    gradeCol := color.orange
scoreStr := str.tostring(score) + "/100 [" + grade + "]"

// Use New Naming
string assetQuality = scoreStr

// RECOMMENDATION
recText := "WAIT / NEUTRAL"
recColor := color.gray

bool isStage2 = (stageID == "STAGE 2 (UP)")
bool isUptrend = (dTrendDir == 1)
bool isRsStrong = str.contains(rs50State, "(Positive)") // Only true Positive level states count

if isStage2 and isUptrend and isRsStrong
    if str.contains(mktState, "BEARISH")
        recText := "WAIT (Mkt Bearish)"
        recColor := color.orange
    else
        recText := "STRONG BUY (Momentum)"
        recColor := color.new(#26a69a, 0)
else if isStage2 and isUptrend
    if str.contains(mktState, "BEARISH")
        recText := "WAIT (Mkt Bearish)"
        recColor := color.orange
    else
        recText := "BUY (Check RS)"
        recColor := color.new(#26a69a, 0)
else if isStage2 and dTrendDir == 0
    recText := "HOLD (Consolidation)"
    recColor := color.blue
else if stageID == "STAGE 1 (BASE)"
    recText := "WATCHLIST (Base Building)"
    recColor := color.new(#ff9800, 0)
else if stageID == "STAGE 4 (DOWN)"
    recText := "AVOID (Stage 4)"
    recColor := color.red
else if currRsiDiv == "BEARISH DIV"
    recText := "CAUTION (Divergence)"
    recColor := color.orange
else if dTrendDir == -1
    recText := "NO TRADE (Downtrend)"
    recColor := color.red


// Logic for New Signal Detection
bool signalStrongBuy = (stageID == "STAGE 2 (UP)" and dTrendDir == 1 and str.contains(rs50State, "(Positive)"))
bool signalBuy       = (stageID == "STAGE 2 (UP)" and dTrendDir == 1)

newStrongBuy := signalStrongBuy and not signalStrongBuy[1]
newBuy       := signalBuy and not signalBuy[1] and not signalStrongBuy // Avoid double labeling
bool newBreakout  = isBreakout and not isBreakout[1]

// Pullback Logic (Restored)
// Extracting highest/lowest to global scope for consistency
float h20 = ta.highest(high, 20)
float l20 = ta.lowest(low, 20)
float hFib = ta.highest(high, fibLookback)
float lFib = ta.lowest(low, fibLookback)

// Pullback Logic (Restored via VDU / Momentum below)

if markFresh and (newStrongBuy or newBuy)
    displayRec := "★ " + recText
else
    displayRec := recText

// ==========================================
// 8. CATALYST ENGINE — BULL SCREENER MIRROR (v67.2.5)
// ==========================================
// CANONICAL SOURCE OF TRUTH: Commander Bull Screener v2.9.
// The gate stack and catalyst resolution below are a verbatim port of the
// Screener's engine (Commander_Bull_Screener_v2.9.pine lines 942–1096),
// NOT an independent implementation. If the Screener's catalyst logic
// changes, this block MUST be updated to match — no independent evolution.
// Same architectural principle as the Zigzag-trend mirror (§14 in guide).
// ==========================================

string chartCat = "NONE"
color chartCatCol = color.gray

// --- Anti-algo intraday position (still needed by the 'Anti-Algo BO Gate' dashboard row) ---
float _intraday_range = d_h - d_l
float _intraday_pos   = _intraday_range > 0 ? (close - d_l) / _intraday_range : 0.5
bool  anti_algo_ok    = _intraday_pos >= 0.60 and close > d_o

// --- Sector stage as integer (parsed from secStageStr already computed) ---
int secStageNum = str.contains(secStageStr, "STAGE 2") ? 2 : str.contains(secStageStr, "STAGE 1") ? 1 : str.contains(secStageStr, "STAGE 3") ? 3 : str.contains(secStageStr, "STAGE 4") ? 4 : 0
bool sector_stage_ok = (secStageNum == 2 or secStageNum == 1)

// --- Daily ADX numeric (Bull Screener uses both ok-bool and numeric value) ---
[_bs_dp, _bs_dm, d_adx_val] = ta.dmi(14, 14)
bool hunter_adx_ok = d_adx_val >= hunter_daily_adx_min

// --- Alpha gate — Asset Quality score ≥ 60 (was named alpha_ok in Screener) ---
bool alpha_ok = score >= 60

// --- Bull-Screener-aligned isBreakout (DIFFERENT from PA-cascade isBreakout above) ---
// PA cascade's isBreakout uses dLockH (strict-trend locked high) and drives chart shapes.
// Bull Screener's catalyst uses recentHigh21 (21-day high). Both kept; separate names.
float bs_recentHigh21  = ta.highest(high[1], 21)
bool  bs_closeNearHigh = (d_c - d_l) > ((d_h - d_l) * 0.75)
bool  bs_volConfirm    = curRelVol > 1.25
bool  bs_isBreakout    = d_c > bs_recentHigh21 and bs_closeNearHigh and bs_volConfirm

// --- 9-Gate weinstein_setup (Bull Screener mirror; same booleans the Screener panel exposes) ---
bool g1_stage     = (stageID == "STAGE 2 (UP)") or (stageID == "STAGE 1 (BASE)")                          // G1
bool g2_above200  = d_c > d_sma200                                                                          // G2
bool g3_secRS     = not str.contains(rsSecState, "Lagging")                                                 // G3
bool g4_secStage  = sector_stage_ok                                                                         // G4
bool g5_trendTpl  = d_h52 > 0 and d_l52 > 0 and ((d_h52 - d_c) / d_h52 <= 0.25) and ((d_c - d_l52) / d_l52 >= 0.30)  // G5
// G6: vol_acc — ≥ vol_acc_min_bs of last 20 bars green-close in upper 60% with above-avg volume
float _v5_dr   = d_h - d_l
float _v5_cr   = _v5_dr == 0 ? 0 : (d_c - d_l) / _v5_dr
bool  _v5_one  = (d_c > d_c[1]) and (d_v > d_vavg) and (_v5_cr > 0.6)
float _v5_sum  = math.sum(_v5_one ? 1 : 0, 20)
bool g6_volAcc    = _v5_sum >= vol_acc_min_bs                                                               // G6
bool g7_fresh     = nz(macroStageWeeks, 999) <= 26                                                          // G7 (uses macro Stage-2 anchor from v67.2.2)
// R6: Price coil replaces MA squeeze — 20-bar range < 10% of close
float _bs_coil_range = ta.highest(d_h, 20) - ta.lowest(d_l, 20)
bool g8_maSqz     = (_bs_coil_range / d_c) <= 0.10                                                          // G8
// R5: NR7 range contraction replaces BB squeeze
float _bs_cur_range = d_h - d_l
float _bs_min_range_7 = ta.lowest(d_h - d_l, 7)
bool g9_bbSqz     = _bs_cur_range <= _bs_min_range_7 * 1.1                                                  // G9

bool weinstein_setup = g1_stage and g2_above200 and g3_secRS and g4_secStage and g5_trendTpl and g6_volAcc and g7_fresh and g8_maSqz and g9_bbSqz
int  bs_gates_passing = (g1_stage ? 1:0) + (g2_above200 ? 1:0) + (g3_secRS ? 1:0) + (g4_secStage ? 1:0) + (g5_trendTpl ? 1:0) + (g6_volAcc ? 1:0) + (g7_fresh ? 1:0) + (g8_maSqz ? 1:0) + (g9_bbSqz ? 1:0)

// --- Minervini Trend Template (50 > 150 > 200) ---
bool minervini_trend = d_c > d_sma50 and d_sma50 > d_sma150 and d_sma150 > d_sma200

// --- POS-ACCUM detector ---
float bs_obv = ta.cum(math.sign(ta.change(d_c)) * d_v)
float bs_obv_h50_1 = ta.highest(bs_obv, 50)[1]
float bs_price_h50 = ta.highest(d_h, 50)[1]
bool  bs_is_obv_bo = bs_obv > bs_obv_h50_1
// H2: Volume-price accumulation bars replace OBV trending-up filter.
int _bs_acc_bars = 0
for i = 0 to 19
    if not na(d_c[i]) and not na(d_o[i]) and not na(d_v[i]) and not na(d_v[i+1])
        if d_c[i] > d_o[i] and d_v[i] > d_v[i+1]
            _bs_acc_bars += 1
bool  bs_is_obv_trending_up = _bs_acc_bars >= 8
bool  bs_is_price_lagging = d_c < (bs_price_h50 * 0.90)
bool  bs_is_flat_base = ta.stdev(d_c, 50) < (ta.sma(d_c, 50) * 0.10)

// ── PRICE-ACTION catalyst gates (v67.5 2026-06-03 — replace lagging indicators,
//    synced to bull_screener.py). ──────────────────────────────────────────
int bs_pa_dir_cnt = 0
for _kk = 0 to 13
    if not na(d_c[_kk]) and not na(d_o[_kk]) and not na(d_h[_kk + 1])
        if d_c[_kk] > d_o[_kk] and d_h[_kk] > d_h[_kk + 1]
            bs_pa_dir_cnt += 1
bool bs_pa_dir_ok = bs_pa_dir_cnt >= 7                       // replaces hunter_adx_ok
bool bs_pa_wk_mom = not na(wClose[5]) and wClose > wClose[5] // replaces wRsiVal >= min
bool bs_pa_not_extended = na(d_c[5]) or d_c <= d_c[5] * 1.05 // replaces dailyRsi <= max

bool  is_pos_accum = bs_is_obv_bo and bs_is_obv_trending_up and bs_is_price_lagging and bs_is_flat_base and weinstein_setup and vcp_ok_bo and bs_pa_not_extended

// --- Daily CPR (Central Pivot Range) — close > Top Central Pivot ---
// Ported from Commander Bull Screener v3.1 lines 998-1002
float bs_pivot = (d_h + d_l + d_c) / 3.0
float bs_bc    = (d_h + d_l) / 2.0
float bs_tc    = bs_pivot + math.abs(bs_pivot - bs_bc)
bool  bs_cpr_ok   = d_c > bs_tc

// --- Monthly VWAP — close > anchored VWAP since month start ---
// Ported from Commander Bull Screener v3.1 lines 1005-1014
var float bs_sumPV = na
var float bs_sumV  = na
if ta.change(time("M")) != 0
    bs_sumPV := d_v * d_c
    bs_sumV  := d_v
else
    bs_sumPV := nz(bs_sumPV) + d_v * d_c
    bs_sumV  := nz(bs_sumV)  + d_v
float bs_mvwap = bs_sumV > 0 ? bs_sumPV / bs_sumV : d_c
bool  bs_mvwap_ok = d_c > bs_mvwap

// --- SWG-PB detector (TIGHT — Screener uses ±1.5%, not Dashboard's old 5%) ---
float bs_pb_dist_ema20 = ((d_c - d_ema20_val) / d_ema20_val) * 100
bool  bs_is_ema_pb_zone = bs_pb_dist_ema20 <= 1.5 and bs_pb_dist_ema20 >= -1.5
// R2: Pullback depth replaces RSI(14) pocket
float _bs_sw_hi_20 = ta.highest(d_h, 20)
float _bs_sw_lo_20 = ta.lowest(d_l, 20)
float _bs_sw_range = _bs_sw_hi_20 - _bs_sw_lo_20
float _bs_retrace_pct = _bs_sw_range > 0 ? (_bs_sw_hi_20 - d_c) / _bs_sw_range : 0.0
bool  bs_rsi_pb_pocket  = _bs_retrace_pct >= 0.38 and _bs_retrace_pct <= 0.62
bool  bs_rsi_w_strong   = wRsiVal > 60
bool  bs_vol_vdu_ok     = d_v < (d_vavg * 0.7) and d_c < d_c[1]
bool  bs_hitPullback    = bs_is_ema_pb_zone and bs_rsi_pb_pocket and bs_rsi_w_strong and bs_vol_vdu_ok and minervini_trend and alpha_ok and bs_cpr_ok and bs_mvwap_ok

// --- SWG-BO detector ---
float bs_pivot_15h = ta.highest(d_h, 15)[1]
bool  bs_is_pivot_break = d_c > bs_pivot_15h
bool  is_swing_bo = minervini_trend and vcp_ok_swg and bs_is_pivot_break and bs_volConfirm and anti_algo_ok

// --- SWG-GAP detector ---
float bs_dPrevHigh = d_h[1]
float bs_gap_pct = bs_dPrevHigh > 0 ? (d_o - bs_dPrevHigh) / bs_dPrevHigh * 100 : 0.0
bool  is_gap_go = bs_gap_pct >= 4.0 and curRelVol >= 3.0 and d_c > d_o and _intraday_pos >= 0.60 and weinstein_setup

// --- SWG-REV detector ---
// R3: 3-bar down structure + lower 20% of 10-bar range replaces RSI(3) < 20.
bool _bs_3bar_down = not na(d_c[3]) and d_c < d_c[1] and d_c[1] < d_c[2] and d_c[2] < d_c[3]
float _bs_lo_10 = ta.lowest(d_l, 10)
float _bs_range_10 = ta.highest(d_h, 10) - _bs_lo_10
float _bs_pos_10 = _bs_range_10 > 0 ? (d_c - _bs_lo_10) / _bs_range_10 : 0.5
bool  _bs_pa_oversold = _bs_3bar_down and _bs_pos_10 < 0.20
bool  bs_stage1_or_2 = (stageID == "STAGE 1 (BASE)") or (stageID == "STAGE 2 (UP)")
// v67.5: dropped wRsiVal>40 (redundant with bs_stage1_or_2 — pure PA).
bool  is_mean_rev = _bs_pa_oversold and d_v > d_vavg * 1.5 and d_c < d_ema20_val and bs_stage1_or_2

// --- CATALYST RESOLUTION — Bull Screener priority order (verbatim mirror) ---
int catalyst_id = 0
if is_pos_accum
    catalyst_id := 1
    chartCat := "POS-ACCUM"
    chartCatCol := color.new(#26a69a, 0)
// v67.5: wRsiVal>=min + hunter_adx_ok -> bs_pa_wk_mom + bs_pa_dir_ok (pure PA).
else if weinstein_setup and bs_isBreakout and bs_pa_wk_mom and bs_pa_dir_ok
    catalyst_id := 2
    chartCat := "POS-BO"
    chartCatCol := color.blue
else if is_gap_go
    catalyst_id := 6
    chartCat := "SWG-GAP"
    chartCatCol := color.aqua
else if is_swing_bo
    catalyst_id := 4
    chartCat := "SWG-BO"
    chartCatCol := color.fuchsia
else if bs_hitPullback
    catalyst_id := 3
    chartCat := "SWG-PB"
    chartCatCol := color.orange
else if is_mean_rev
    catalyst_id := 5
    chartCat := "SWG-REV"
    chartCatCol := color.red

// --- PERSISTENT CATALYST: holds the most recent signal for up to 5 bars ---
// Prevents blank chart when signal fired on previous bar but not exactly today
var string persistCat    = "NONE"
var color  persistCatCol = color.gray
var int    persistAge    = 0  // Bars since last signal fired

bool _signalFiredThisBar = false

if chartCat != "NONE"
    persistCat       := chartCat
    persistCatCol    := chartCatCol
    persistAge       := 0
    _signalFiredThisBar := true
else if newStrongBuy or newBuy  // Fallback: shape signals can trigger algo mode too
    persistCat       := "POS-ACCUM"
    persistCatCol    := color.lime
    persistAge       := 0
    _signalFiredThisBar := true
else
    persistAge := persistAge + 1

// Only expire stale signals — do NOT reset on Stage 4, as transitional stocks
// (e.g. recovering Stage 4→1) can have valid buy signals before stage upgrades.
// The 5-bar staleness check is sufficient protection against lingering signals.
if not _signalFiredThisBar and persistAge > 5
    persistCat    := "NONE"
    persistCatCol := color.gray
    persistAge    := 0

// PLOTTING SIGNALS
plotshape(showSignals and newStrongBuy, title="Strong Buy Signal", style=shape.labelup, location=location.belowbar, color=color.lime, textcolor=color.black, text="★", size=size.tiny)
plotshape(showSignals and newBuy,       title="Buy Signal",        style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, text="B", size=size.tiny)
plotshape(showSignals and newBreakout,  title="Breakout Signal",   style=shape.triangleup, location=location.belowbar, color=color.blue, size=size.tiny)
// (hitPullback plotted below)

if panicExit
    displayRec := "EXIT NOW (40WMA Break)"
    recColor := color.red

// ==========================================
// PULLBACK & VOLATILITY (Strategy Aligned)
// ==========================================
// We use the Strategy's superior Pullback Logic: EMA Proximity + Momentum Divorce + VDU
float pb_dist_ema20 = d_ema20_val != 0 ? ((dClose - d_ema20_val) / d_ema20_val) * 100 : 0.0
bool is_ema_pb_zone = pb_dist_ema20 <= pb_dist_max and pb_dist_ema20 >= -pb_dist_max // v67.2 FIX #14: input-driven

// Momentum Divorce (Price drop, RSI holds)
bool rsi_divorce = dailyRsi > 40 and wRsiVal > 60 // rsi_d_th = 40, rsi_w_th = 60

// Institutional Footprint (Volume Drying Up - VDU)
bool vol_vdu_ok = d_vol < d_vol_avg

bool hitPullback = is_ema_pb_zone and rsi_divorce and vol_vdu_ok
if hitPullback
    dayHealthStr := "Inst. Pullback Zone"
    dayHealthCol := color.orange
else
    dayHealthStr := "No Setup"
    dayHealthCol := color.gray

// Plot Pullback Signal
plotshape(showSignals and hitPullback, title="Pullback Hit", style=shape.circle, location=location.belowbar, color=color.new(color.purple, 20), size=size.tiny)

// Define highest20 for Trade Manager
float highest20 = h20

// --- RESET STATE PER BAR (Fix for Symbol Switching) ---
finalEntry := 0.0
finalSL := 0.0
finalTSL := 0.0
finalDate := 0

// Trade Manager
if quick_ent > 0
    finalEntry := quick_ent
    finalSL    := quick_sl
    finalTSL   := 0.0
else if f_match(p1_tick)
    finalEntry := p1_ent
    finalSL := p1_sl
    finalTSL := p1_tsl
    finalDate := p1_date
else if f_match(p2_tick)
    finalEntry := p2_ent
    finalSL := p2_sl
    finalTSL := p2_tsl
    finalDate := p2_date
else if f_match(p3_tick)
    finalEntry := p3_ent
    finalSL := p3_sl
    finalTSL := p3_tsl
    finalDate := p3_date
else if f_match(p4_tick)
    finalEntry := p4_ent
    finalSL := p4_sl
    finalTSL := p4_tsl
    finalDate := p4_date
else if f_match(p5_tick)
    finalEntry := p5_ent
    finalSL := p5_sl
    finalTSL := p5_tsl
    finalDate := p5_date
else if f_match(p6_tick)
    finalEntry := p6_ent
    finalSL := p6_sl
    finalTSL := p6_tsl
    finalDate := p6_date
else if f_match(p7_tick)
    finalEntry := p7_ent
    finalSL := p7_sl
    finalTSL := p7_tsl
    finalDate := p7_date
else if f_match(p8_tick)
    finalEntry := p8_ent
    finalSL := p8_sl
    finalTSL := p8_tsl
    finalDate := p8_date
else if f_match(p9_tick)
    finalEntry := p9_ent
    finalSL := p9_sl
    finalTSL := p9_tsl
    finalDate := p9_date
else if f_match(p10_tick)
    finalEntry := p10_ent
    finalSL := p10_sl
    finalTSL := p10_tsl
    finalDate := p10_date
else if f_match(p11_tick)
    finalEntry := p11_ent
    finalSL := p11_sl
    finalTSL := p11_tsl
    finalDate := p11_date
else if f_match(p12_tick)
    finalEntry := p12_ent
    finalSL := p12_sl
    finalTSL := p12_tsl
    finalDate := p12_date
else if f_match(p13_tick)
    finalEntry := p13_ent
    finalSL := p13_sl
    finalTSL := p13_tsl
    finalDate := p13_date
else if f_match(p14_tick)
    finalEntry := p14_ent
    finalSL := p14_sl
    finalTSL := p14_tsl
    finalDate := p14_date
else if f_match(p15_tick)
    finalEntry := p15_ent
    finalSL := p15_sl
    finalTSL := p15_tsl
    finalDate := p15_date
else if f_match(p16_tick)
    finalEntry := p16_ent
    finalSL := p16_sl
    finalTSL := p16_tsl
    finalDate := p16_date
else if f_match(p17_tick)
    finalEntry := p17_ent
    finalSL := p17_sl
    finalTSL := p17_tsl
    finalDate := p17_date
else if f_match(p18_tick)
    finalEntry := p18_ent
    finalSL := p18_sl
    finalTSL := p18_tsl
    finalDate := p18_date
else if f_match(p19_tick)
    finalEntry := p19_ent
    finalSL := p19_sl
    finalTSL := p19_tsl
    finalDate := p19_date
else if f_match(p20_tick)
    finalEntry := p20_ent
    finalSL := p20_sl
    finalTSL := p20_tsl
    finalDate := p20_date
else if f_match(p21_tick)
    finalEntry := p21_ent
    finalSL := p21_sl
    finalTSL := p21_tsl
    finalDate := p21_date
else if f_match(p22_tick)
    finalEntry := p22_ent
    finalSL := p22_sl
    finalTSL := p22_tsl
    finalDate := p22_date
else if f_match(p23_tick)
    finalEntry := p23_ent
    finalSL := p23_sl
    finalTSL := p23_tsl
    finalDate := p23_date
else if f_match(p24_tick)
    finalEntry := p24_ent
    finalSL := p24_sl
    finalTSL := p24_tsl
    finalDate := p24_date
else if f_match(p25_tick)
    finalEntry := p25_ent
    finalSL := p25_sl
    finalTSL := p25_tsl
    finalDate := p25_date
else if f_match(p26_tick)
    finalEntry := p26_ent
    finalSL := p26_sl
    finalTSL := p26_tsl
    finalDate := p26_date
else if f_match(p27_tick)
    finalEntry := p27_ent
    finalSL := p27_sl
    finalTSL := p27_tsl
    finalDate := p27_date
else if f_match(p28_tick)
    finalEntry := p28_ent
    finalSL := p28_sl
    finalTSL := p28_tsl
    finalDate := p28_date
else if f_match(p29_tick)
    finalEntry := p29_ent
    finalSL := p29_sl
    finalTSL := p29_tsl
    finalDate := p29_date
else if f_match(p30_tick)
    finalEntry := p30_ent
    finalSL := p30_sl
    finalTSL := p30_tsl
    finalDate := p30_date

tradeActive = finalEntry > 0

if tradeActive
    // BUG FIX (Dragging Line Override): 
    // If the user drags finalSL to 0.0 directly on chart, it might trigger intermediate falses.
    float safe_hard_sl = na(finalSL) ? 0.0 : finalSL
    // --- RR DISPLAY & DYNAMIC TARGETING LOGIC ---
    float riskPerShare = finalEntry - finalSL
    float currentProfitPerShare = close - finalEntry
    
    // Dynamic Profiles Based on Market Health (N500)
    isBullMarket := str.contains(mktState, "BULLISH")
    dyn_T1_R := isBullMarket ? 2.5 : 2.0   // Bull: Let it run / Bear: Take early
    dyn_T2_R := isBullMarket ? 4.0 : 2.5
    dyn_T3_R := isBullMarket ? 6.0 : 4.0   // Bull: Hold runner / Bear: Cap at 2.5R
    
    mktProfile := isBullMarket ? "🟢 BULL (Aggressive)" : "🔴 BEAR (Hit & Run)"
    
    if riskPerShare > 0
        currentR := currentProfitPerShare / riskPerShare
        rrText := str.tostring(currentR, "#.1") + "R (Target: " + str.tostring(dyn_T1_R) + "R)" 
    
    // Effective SL (Hard SL vs Trailing SL)
    // TSL Logic removed in favor of Chandelier Exit script
    visualSL := safe_hard_sl
    // ---------------------------
    
    // Day calculation Logic
    entryDateStr := "N/A"
    daysHeld := 0
    if finalDate > 0
        daysHeld := math.floor((time - finalDate) / 86400000)
        entryDateStr := str.format("{0,date,yyyy-MM-dd}", finalDate)

    // Gap 5: Time Stop Proximity Warning (mirrors Strategy v4.42 inputs)
    int pos_stop_thresh = pos_time_stop_w * 5  // weeks → trading days
    int swg_stop_thresh = swg_time_stop_d
    int pos_days_left   = pos_stop_thresh - daysHeld
    int swg_days_left   = swg_stop_thresh - daysHeld
    if daysHeld > 0
        if daysHeld >= pos_stop_thresh
            timeWarnStr := "⏰ POS TIME STOP HIT"
            timeWarnCol := color.red
        else if pos_days_left <= 5
            timeWarnStr := "⚠️ POS: " + str.tostring(pos_days_left) + "d left"
            timeWarnCol := color.orange
        else if daysHeld >= swg_stop_thresh
            timeWarnStr := "⏰ SWG TIME STOP HIT"
            timeWarnCol := color.red
        else if swg_days_left <= 3
            timeWarnStr := "⚠️ SWG: " + str.tostring(swg_days_left) + "d left"
            timeWarnCol := color.orange
        else
            timeWarnStr := "OK (P:" + str.tostring(pos_days_left) + "d | S:" + str.tostring(swg_days_left) + "d)"
            timeWarnCol := color.gray

    float curPnL = ((close - finalEntry) / finalEntry) * 100
    string pnlStr = (curPnL > 0 ? "+" : "") + str.tostring(curPnL, "#.2") + "%"
    
    if close < visualSL
        tradeStatus := "⚠️ STOP HIT (" + pnlStr + ")"
        tradeColor := color.red
    else if curPnL > 0
        // SCALE IN / TRIM LOGIC
        bool cond_add = dTrendDir == 1 and dailyRsi < 70 and close > use_ema20 and not isSqueeze // Don't add inside a squeeze, wait for pop
        bool cond_trim = dailyRsi > 75 or absDist > 15.0 or (not na(earningsNext) and (earningsNext - timenow) / 86400000 < 3)
        
        if cond_trim
            tradeStatus := "TRIM (" + pnlStr + ")"
            tradeColor := color.fuchsia
        else if cond_add
            tradeStatus := "SCALE IN (" + pnlStr + ")"
            tradeColor := color.blue
        else
            tradeStatus := "HOLD (" + pnlStr + ")"
            tradeColor := color.new(#26a69a, 0)
    else
        tradeStatus := "HOLD (" + pnlStr + ")"
        tradeColor := color.orange
        
    // Room for Trade Warning Check
    if not na(ovhPrice) and finalEntry > 0 and riskPerShare > 0
        float t1_val_check = finalEntry + (riskPerShare * dyn_T1_R)
        if t1_val_check > ovhPrice and close < ovhPrice
            tradeStatus := tradeStatus + " | ⚠️ NO ROOM vs " + str.tostring(math.round_to_mintick(ovhPrice))
            tradeColor := color.orange
        
    // Old line.new logic removed in favor of plot() calls at the end of script for better persistence

// ==========================================
// Gemini Prompt Logic moved to end of script

// ==========================================
// NEW: PRICE ACTION CONFLUENCE (5-STAR)
// ==========================================
// 1. Trend: Above EMA 20
bool c_trend = close > d_ema20_val
// 2. Momentum: RSI > 50 (Bullish)
bool c_mom = dailyRsi > 50
// 3. Volume Action: 
// Breakout -> Needs Vol Expansion (Vol > Avg)
// Pullback -> Needs Vol Contraction (Vol < Avg)
bool c_vol = false
if close > open
    c_vol := d_vol > d_vol_avg // Demand coming in
else
    c_vol := d_vol < d_vol_avg // Supply drying up

// 4. ADX Check
bool c_adx = d_adx_ok

// 4. Max-Vol Bar (POC proxy)  — v67.2 FIX #6: relabelled from "Volume Profile".
// This is NOT a true POC (which is the price level with the most traded volume);
// it's "high of the highest-volume bar in the last `vpLookback` bars" — a fast
// proxy for the upper edge of recent institutional interest. Name updated so
// the logic and the label agree.
int poc_idx = 0
float max_v = 0.0
for i = 0 to vpLookback - 1
    if volume[i] > max_v
        max_v := volume[i]
        poc_idx := i
float poc_level = high[poc_idx] // high of the max-volume bar (NOT a true POC)
bool c_vp = close > poc_level

// v67.2: c_pa (close > open) factor dropped — paTier from the PA cascade now
// provides the PA evidence at proper resolution. c_s50 / c_vol_sma50 / c_low5 /
// c_liq_sweep have moved up to the PA detector block (used by both cascade and
// Action Signal); they are already in scope here.

// Raw confluence: 6 booleans (was 7; trivial close>open removed)
int conf_score_raw = 0
if c_trend
    conf_score_raw += 1
if c_mom
    conf_score_raw += 1
if c_vol
    conf_score_raw += 1
if c_vp
    conf_score_raw += 1
if c_adx
    conf_score_raw += 1
if c_liq_sweep
    conf_score_raw += 1

// Couple PA tier: action_score = clamp(raw_conf + paTier, 0, 10)
//   paTier range: -2 (Failed BO / Distribution / Bearish Engulf) … +4 (HTF)
//   raw_conf range: 0…6
//   action_score: 0…10
int conf_score = conf_score_raw + paTier
if conf_score < 0
    conf_score := 0
if conf_score > 10
    conf_score := 10

// Numerical display: "X/10 (Label)"
string _act_lbl = ""
if conf_score >= 9
    _act_lbl := "Excellent"
else if conf_score >= 7
    _act_lbl := "Strong"
else if conf_score >= 5
    _act_lbl := "Good"
else if conf_score >= 3
    _act_lbl := "Moderate"
else
    _act_lbl := "Weak"
string actionSignal = str.tostring(conf_score) + "/10 (" + _act_lbl + ")"

color conf_col = conf_score >= 7 ? color.new(#26a69a, 0) : (conf_score >= 4 ? color.new(#ff9800, 0) : color.gray)

// ==========================================
// WATCHLIST SCANNER (Top Picks + Alerts)
// ==========================================
string top_picks_msg = ""

// --- POSITION STYLE LOGIC (New v54.0) ---
// Criteria for Positional (Stage 2 Hunter)
// Must be in Stage 2 (Above 30WMA + WMA Rising) and Outperforming (RS > 0)
// Using val50 (RS vs Nifty 50) as proxy for "rsMansfield"
// --- SMART TRADE STYLE LOGIC (v54.1 Advanced) ---

// 1. POSITIONAL (The Hunter)
// Core: Structural Strength & Long-Term Trend
bool pos_stage_ok = (stageID == "STAGE 2 (UP)") or (stageID == "STAGE 1 (BASE)") // Early entry allowed
bool pos_trend_ok = close > dMA200 and wMASlopeState != "FALLING" // Must be above 200 SMA & Weekly MA not crashing
bool pos_rs_ok    = not str.contains(rsSecState, "(Negative)") // Sector shouldn't be dead
bool is_positional = pos_stage_ok and pos_trend_ok and pos_rs_ok

// 2. SWING (The Sniper)
// Core: Momentum, Pattern & Short-Term Thrust
bool sw_trend_ok  = close > d_ema20_val and d_ema20_val > dMA50 // Quick trend defined
bool sw_mom_ok    = dailyRsi > 55 or str.contains(volState, "ACCUM") // RSI or Volume support
bool sw_pat_ok    = str.contains(paState, "VCP") or str.contains(paState, "NR7") or str.contains(paState, "CONSOLIDATION") or str.contains(paState, "BREAKOUT")
float dist_ema20  = ((close - d_ema20_val) / d_ema20_val) * 100
bool sw_safe_ok   = dist_ema20 < 15 // Not extended
bool is_swing     = sw_trend_ok and (sw_mom_ok or sw_pat_ok) and sw_safe_ok

string style_txt = "WAIT"
color style_col = color.gray

if is_positional and is_swing
    style_txt := "🚀 BOTH"
    style_col := color.new(#FFD700, 0) // Gold
else if is_positional
    style_txt := "🦁 POSITIONAL"
    style_col := color.new(color.blue, 0)
else if is_swing
    style_txt := "⚡ SWING"
    style_col := color.new(color.fuchsia, 0)

// --- STOCK PERSONALITY LOGIC (v54.3 Enhanced) ---
string persona_txt = "⚠️ MIXED"
color persona_col = color.gray

// 1. Calculate Conditions
// Volatility Check (ADR%)
float adr_pct = (d_atr10_val / close) * 100
bool is_volatile = adr_pct > 5.0

// Extension Check
float dist_ema20_pct = ((close - d_ema20_val) / d_ema20_val) * 100
bool is_extended = (dist_ema20_pct > 20.0) or (dailyRsi > 75) // Price > 20% above EMA20 OR RSI Overbought

// Leader Criteria (Prime)
bool is_leader_cand = str.contains(rs50State, "(Positive)") and close > dMA200 and close > dMA50 and dev52 < 15

// Momentum Criteria (Swing)
bool is_momentum_cand = (dailyRsi > 60 or str.contains(rs50State, "(Positive)") or str.contains(rs50State, "Rising")) and close > d_ema20_val

// Turnaround Criteria (Value)
bool is_turnaround_cand = (str.contains(rs50State, "Rising") or str.contains(rs50State, "Declining")) and close > dMA50 and close < dMA200

// Laggard Criteria (Avoid)
bool is_laggard_cand = str.contains(rs50State, "(Negative)") or (close < dMA200 and not is_turnaround_cand)

// 2. Logic (Hierarchy: Danger > Quality > Median > Bad)
if is_volatile
    persona_txt := " VOLATILE"
    persona_col := color.new(color.red, 0) // Explicit Red
else if is_extended
    persona_txt := "⚠️ EXTENDED"
    persona_col := color.orange
else if is_leader_cand
    persona_txt := " LEADER"
    persona_col := color.new(#26a69a, 0)
else if is_momentum_cand
    persona_txt := "🐂 MOMENTUM"
    persona_col := color.fuchsia
else if is_turnaround_cand
    persona_txt := "⚓ TURNAROUND"
    persona_col := color.aqua
else if is_laggard_cand
    persona_txt := "💤 LAGGARD"
    persona_col := color.new(color.red, 30) // Darker Red



// ... (Existing Signal Logic) ...

// Helper to check Confluence (4 or 5 stars)
f_check_conf(float c, float o, float ema, float rsi, float v, float va, bool adx_ok) =>
    int _score = 0
    if not na(c)
        if c > ema 
            _score += 1
        if rsi > 50 
            _score += 1
        if (c > o and v > va) or (c < o and v < va)
            _score += 1
        // Simplified VP check for scanner (Price > EMA is strong proxy for value)
        if c > ema 
            _score += 1
        if c > o 
            _score += 1
        if adx_ok
            _score += 1
    _score >= 4 // Returns true if 4+ stars

// Helper to calc health (1=profit, 2=hold, 3=stop) from raw data
f_calc_h(float c, float e, float s) =>
    int r = 0
    if not na(c) and e > 0 // Only count if Entry Price is set
        // Fix: Implied 10% Stop if SL is 0.0
        float effective_stop = s > 0 ? s : (e * 0.90)
        
        if c < effective_stop
            r := 3
        else if c > e
            r := 1
        else
            r := 2
    r

// Helper to check cross from raw data
f_check_x(float c, float c1, float e, float e1) =>
    bool x = false
    if not na(c) and not na(e) and not na(c1) and not na(e1)
        x := c > e and c1 <= e1
    x

// --- ALPHA SCREENER ENGINE (v59.0) ---

// Alpha Score Calculator (0 to 100)
// Evaluates: Trend Structure (30), Momentum (30), Volume (20), Safety (20)
f_calc_alpha_score(float c, float o, float ema20, float sma50, float v, float va) =>
    float _score = 0.0
    if not na(c)
        // 1. Trend Structure (Max 30)
        if c > ema20
            _score += 15
        if c > sma50
            _score += 15

        // 2. Momentum (Max 30) — PRICE ACTION (v67.5 2026-06-03: replaces RSI/ADX)
        // PA momentum (replaces RSI>60/50): close above its 10- and 5-bar-ago values.
        bool _m10 = c > close[10]
        bool _m5  = c > close[5]
        if _m10 and _m5
            _score += 20
        else if _m10
            _score += 10
        // PA directional strength (replaces ADX): >=7 of last 14 bars up + higher high.
        int _dir = 0
        for _i = 1 to 14
            if close[_i] > open[_i] and high[_i] > high[_i + 1]
                _dir += 1
        if _dir >= 7
            _score += 10
            
        // 3. Volume Thrust (Max 20)
        if c > o and v > (va * 1.5) // Massive accumulation
            _score += 20
        else if c > o and v > va // Standard accumulation
            _score += 10
            
        // 4. Safety / Volatility (Max 20)
        // We prefer tight consolidations near averages
        float dist_ema = math.abs((c - ema20) / ema20) * 100
        if dist_ema < 5.0
            _score += 20
        else if dist_ema < 10.0
            _score += 10
            
        // --- 5. MACRO EDGE BACKTEST OVERLAY ---
        // Based on 5-Year Categorical Backtest: Vol Bias (Shelf + Accumulation) provides highest P-Factor edge
        if use_macro_edge
            // Implicit requirement: Vol > SMA50 AND VWMA > SMA (Simulated proxy via V > VA)
            if v > va 
                _score += 10 // Boost score if Macro Edge is met
            else
                _score -= 20 // Heavily penalize breakouts lacking institutional volume bias
                
    _score

// Helper to check for Minervini Pullback
f_check_pullback(float c, float o, float l, float ema20, float v, float va) =>
    bool is_pb = false
    if not na(c)
        // Price near or touching EMA20, volume is below average (VDU)
        float dist_ema = ((c - ema20) / ema20) * 100
        bool near_ema = (dist_ema > 0 and dist_ema < 4.0) or (l < ema20 and c > ema20)
        bool vol_dry = v < (va * (1.0 - vdu_pct))
        
        // --- MICRO EDGE BACKTEST OVERLAY ---
        // Based on 5-Year Backtest: Squeeze (MA/BB) + Price Levels (CPR/VWAP) provide massive edge on Swings
        bool micro_valid = true
        if use_micro_edge
            // Ensure distance between 20EMA and 50SMA is tight (Squeeze proxy)
            bool ema_tension_tight = ((ema20 - c) / c) * 100 < 6.0 
            // In a real environment we'd check CPR/VWAP natively, but using strict proximity as proxy
            micro_valid := ema_tension_tight
            
        is_pb := near_ema and vol_dry and micro_valid
    is_pb


