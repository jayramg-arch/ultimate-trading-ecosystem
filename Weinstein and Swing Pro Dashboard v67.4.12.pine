// Trailing Stop inputs removed. Using Chandelier Exit indicator natively.

// ==========================================
// 2. STRATEGY INPUTS
// ==========================================
groupStrat  = "Strategy Inputs"
maLengthW   = input.int(30, title="Weinstein SMA Length (Weekly)", group=groupStrat)
wmaSlopeLen = input.int(4, title="30 WMA Slope Lookback (Weeks)", group=groupStrat)
slopeThresh = input.float(0.0005, title="30WMA Slope Threshold (Flat)", group=groupStrat)

bench50     = input.symbol("NSE:NIFTY", title="Benchmark 1 (Nifty 50)", group=groupStrat)
bench500    = input.symbol("NSE:CNX500", title="Benchmark 2 (Nifty 500 - Breadth)", group=groupStrat)
benchSector = input.symbol("NSE:CNX500", title="Benchmark 3 (Manual Sector)", group=groupStrat, tooltip="Used ONLY if 'Enable Manual Override' is checked below.")
useManual   = input.bool(false, title="[Enable] Manual Sector Override", group=groupStrat, tooltip="If checked, Benchmark 3 is used. If unchecked, the Dashboard auto-detects the sector based on your portfolio and internal database.")


pos_time_stop_w = input.int(6,  title="Positional Time Stop (Weeks Stagnant)", group=groupStrat, tooltip="Mirror of Strategy: close positional if open ≥ N weeks with unrealised profit < 0.5R. Default 6W.")
swg_time_stop_d = input.int(10, title="Swing Time Stop (Days Stagnant)",        group=groupStrat, tooltip="Mirror of Strategy: close swing if open ≥ N days with unrealised profit < 0.5R. Default 10D.")

rsLength        = input.int(26,   title="RS Slope Length (Weeks)",               group=groupStrat, tooltip="Lookback for the RS slope (↑↓→ arrows). 26W = 6 months of momentum.")
rsSlopeLen      = input.int(8,    title="RS Slope Lookback (Weeks)",               group=groupStrat)
// v67.4: JdK RRG parameters (StockCharts default — matches Bull Screener Python)
jdkLength       = input.int(12,   title="JdK RRG Length",                          group=groupStrat, minval=2, tooltip="Normalization length for JdK RS-Ratio / RS-Momentum. v67.4.2: default raised to 12 (single-pass + 5-bar smooth) to match Strike.Money — was 10 (2-pass StockCharts). Drives both the normalization SMA and the momentum SMA.")
rrgTrailLen     = input.int(4,    title="RRG Trajectory Tail (Weeks)",             group=groupStrat, minval=1, tooltip="How many weeks back to measure the RRG rotation vector. 4W = standard tail length. Larger = smoother direction but slower to detect rotation.")
rsSlopeThresh   = input.float(0.2, title="RS Slope Sensitivity (Threshold)",      group=groupStrat, minval=0.05, maxval=1.5, step=0.05, tooltip="How steep the RS momentum (4-bar ROC of Mansfield ×100) must be to register as Rising/Declining. v63.4: rescaled ×10 for new Mansfield ×100 scale.")
rsLevelLen      = input.int(52,   title="RS Level Period (Positive/Negative)",        group=groupStrat, tooltip="Lookback for determining Positive vs Negative RS Level. Default 52W matches standard Mansfield RS indicators. Positive = stock outperforming over this window.")

groupMA     = "Daily MA Settings"
dma50_len   = input.int(50, title="50 DMA Length", group=groupMA)
dma150_len  = input.int(150, title="150 DMA Length", group=groupMA)
dma200_len  = input.int(200, title="200 DMA Length", group=groupMA)
dmaSlopeLen = input.int(21, title="50DMA Slope Lookback (Days)", group=groupMA)
flatThresh  = input.float(0.0005, title="Slope Flat Threshold (Daily)", group=groupMA)

groupTech   = "Technical Settings"
// === Configurable Fib Lookback ===
fibLookback = input.int(21, title="Est. Pullback Lookback (Days)", group=groupTech)
// User Specific Pivot Settings
pivotLeft   = input.int(2, title="Pivot Lookback Left (Daily)", group=groupTech, tooltip="v67.2.3: reverted to 2/2 (was bumped 2→3 in v67.2.1, reverted in v67.2.3). MUST MATCH the on-chart Zigzag indicator's pivot setting — Dashboard 'Daily Trend' and Zigzag panel will disagree if these differ. Both tools share the same v6.2 strict-trend engine, but different pivot windows detect different swings. Weekly is still hard-coded 5/5.")
pivotRight  = input.int(2, title="Pivot Lookback Right (Daily)", group=groupTech, tooltip="Must match the on-chart Zigzag's right pivot setting.")
atrLen      = input.int(14, title="ATR Length", group=groupTech)

// Volume Profile Settings (Basic POC Logic)
vpLookback  = input.int(100, "VP Lookback Bars", group=groupTech)

// --- Mathematical Edges (Backtested) ---
grp_edge = "Mathematical Edges (Backtested)"
use_macro_edge = input.bool(true, title="[ENABLE] Macro Edge: Institutional Vol Bias", group=grp_edge, tooltip="Only fires STRONG BUY if Volume Shelf (VWMA>SMA) AND Volume Accumulation rules are met.")
use_micro_edge = input.bool(true, title="[ENABLE] Micro Edge: Price & Squeeze Validation", group=grp_edge, tooltip="Only fires PULLBACK 🎯 if Price > CPR & Monthly VWAP AND 20/50 Squeeze is active.")

// v67.2 FIX #14: Hard-coded thresholds promoted to proper inputs (group: "Advanced Thresholds").
// Defaults preserved — change only if you've validated against your backtest data.
grpAdv          = "Advanced Thresholds (v67.2)"
vol_acc_days    = input.int(10,    title="Vol Accum Lookback (Days)",       group=grpAdv, minval=3,  maxval=30, tooltip="Window over which to count accumulation days for f_get_vol_accum.")
vol_acc_min     = input.int(2,     title="Vol Accum Min Days",              group=grpAdv, minval=1,  maxval=10, tooltip="Minimum accumulation days within the lookback for vol_acc_ok to pass.")
vol_avg_len     = input.int(50,    title="Volume SMA Length (bars)",        group=grpAdv, minval=20, maxval=200)
vcp_thresh      = input.float(1.5, title="VCP Tightness Multiplier",        group=grpAdv, minval=0.5, maxval=3.0, step=0.1, tooltip="ATR10 < ATR50 × this multiplier to qualify as a VCP. Default 1.5; lower = stricter.")
vdu_pct         = input.float(0.30,title="VDU % Below Vol Avg",             group=grpAdv, minval=0.1, maxval=0.6, step=0.05, tooltip="Volume Dry-Up: vol < vol_avg × (1 - this). Default 0.30 = vol must be ≤ 70% of avg.")
eq_threshold_dash = input.float(0.005, title="Zigzag EH/EL Threshold (frac)", group=grpAdv, minval=0.001, maxval=0.02, step=0.001, tooltip="Equal-high / equal-low tolerance for the strict-trend pivot classifier. 0.005 = 0.5%, matches Zigzag v6.2 default.")
prox_thresh     = input.float(2.5, title="Key-Level Proximity % Threshold", group=grpAdv, minval=0.5, maxval=10.0, step=0.5, tooltip="A key level (DZ/SZ/TL/pivot/EMA/ATH) is flagged 'near' when distance is within this %.")
pb_dist_max     = input.float(5.0, title="Pullback EMA-Distance Max %",     group=grpAdv, minval=2.0, maxval=15.0, step=0.5, tooltip="Daily pullback zone: |close - EMA20| / EMA20 must be ≤ this %.")
liq_sweep_lockout = input.int(10,  title="Liquidity Sweep Lockout (bars)",  group=grpAdv, minval=3,  maxval=30, tooltip="v67.2 FIX #7: after a Liq Sweep Reclaim fires, suppress further detections for this many bars.")
stage2_fresh_weeks = input.int(13, title="Stage 2 'Fresh' Threshold (weeks)",group=grpAdv, minval=4,  maxval=52, tooltip="v67.2.2: leg-age cutoff for the 'Fresh' Stage-2 tag in the new 'Stage 2 Age' dashboard row. ≤ this → Fresh; otherwise Maturing (≤ 26w macro) or Extended.")

// v67.2.5: Bull Screener catalyst-mirror inputs (MUST match Commander Bull Screener v2.9 defaults)
grpBS                 = "Bull Screener Mirror (v67.2.5)"
hunter_weekly_rsi_min = input.int(60, title="Hunter Weekly RSI Min",   group=grpBS, minval=40, maxval=80, tooltip="Mirrors Commander Bull Screener v2.9 input of the same name. POS-BO catalyst requires wRsiVal ≥ this value.")
hunter_daily_adx_min  = input.int(25, title="Hunter Daily ADX Min",    group=grpBS, minval=10, maxval=50, tooltip="Mirrors Commander Bull Screener v2.9 input of the same name. POS-BO catalyst requires daily ADX ≥ this value.")
pos_accum_rsi_max     = input.int(50, title="POS-ACCUM Daily RSI Max", group=grpBS, minval=30, maxval=70, tooltip="Mirrors Commander Bull Screener v2.9 input of the same name. POS-ACCUM suppressed when dailyRsi > this value (late-stage chase-trap guard).")
vol_acc_min_bs        = input.int(3,  title="Vol Accum Density Min (Screener)", group=grpBS, minval=1, maxval=10, tooltip="Bull Screener-aligned threshold: ≥ this many of the last 20 daily bars must be green-close in upper-60% with above-avg volume. Default 3 matches Screener v2.9 / Strategy v2.5.")
vcp_mult_bo           = input.float(1.875, title="VCP ATR Mult (Breakout)", group=grpBS, minval=0.5, maxval=5.0, tooltip="VCP ATR multiplier for breakout setups.")
vcp_mult_swg          = input.float(1.50, title="VCP ATR Mult (Swing)", group=grpBS, minval=0.5, maxval=5.0, tooltip="VCP ATR multiplier for swing setups.")

groupAlert  = "Alerts & Visuals"
showSignals = input.bool(true, title="Show Buy/Breakout Labels", group=groupAlert)
showTrade   = input.bool(true, title="Show Trade Lines (Entry/Targets)", group=groupAlert)
showDist    = input.bool(true, title="Show % Distance on Trade Lines", group=groupAlert)
markFresh   = input.bool(true, title="Mark Fresh Signals (★)", group=groupAlert)
showAVWAP   = input.bool(true, title="Show Auto-Anchored VWAP (Stage 2 Start)", group=groupAlert)

// Styling
groupStyle  = "Dashboard Style"
