      // Fetch API errors
      if (error instanceof TypeError && error.message.includes('fetch')) {
        return new NetworkError('Network request failed', 'FETCH_ERROR', error);
      }
      
      // HTTP status errors
      if (error.message && error.message.includes('HTTP error')) {
        const statusMatch = error.message.match(/status: (\d+)/);
        const status = statusMatch ? parseInt(statusMatch[1]) : 0;
        
        if (status >= 500) {
          return new NetworkError(`Server error (${status})`, 'SERVER_ERROR', error);
        }
        if (status === 429) {
          return new NetworkError('Rate limited', 'RATE_LIMITED', error);
        }
        if (status >= 400) {
          return new NetworkError(`Client error (${status})`, 'CLIENT_ERROR', error);
        }
      }
      
      // Timeout errors
      if (error.name === 'AbortError' || error.message.includes('timeout')) {
        return new NetworkError('Request timeout', 'TIMEOUT', error);
      }
      
      // DNS/Connection errors
      if (error.message.includes('Failed to fetch') || 
          error.message.includes('ERR_NETWORK') ||
          error.message.includes('ERR_INTERNET_DISCONNECTED')) {
