// Trailing Stop inputs removed. Using Chandelier Exit indicator natively.

// ==========================================
// 2. STRATEGY INPUTS
// ==========================================
groupStrat  = "Strategy Inputs"
maLengthW   = input.int(30, title="Weinstein SMA Length (Weekly)", group=groupStrat)
wmaSlopeLen = input.int(4, title="30 WMA Slope Lookback (Weeks)", group=groupStrat)
slopeThresh = input.float(0.0005, title="30WMA Slope Threshold (Flat)", group=groupStrat)

bench50     = input.symbol("NSE:NIFTY", title="Benchmark 1 (Nifty 50)", group=groupStrat)
bench500    = input.symbol("NSE:CNX500", title="Benchmark 2 (Nifty 500 - Breadth)", group=groupStrat)
// benchSector removed (unused)

rsLength    = input.int(26, title="Mansfield RS Length", group=groupStrat)
rsSlopeLen  = input.int(8, title="RS Slope Lookback (Weeks)", group=groupStrat)

groupMA     = "Daily MA Settings"
dma50_len   = input.int(50, title="50 DMA Length", group=groupMA)
dma150_len  = input.int(150, title="150 DMA Length", group=groupMA)
dma200_len  = input.int(200, title="200 DMA Length", group=groupMA)
dmaSlopeLen = input.int(21, title="50DMA Slope Lookback (Days)", group=groupMA)
flatThresh  = input.float(0.0005, title="Slope Flat Threshold (Daily)", group=groupMA)

groupTech   = "Technical Settings"
// === Configurable Fib Lookback ===
fibLookback = input.int(21, title="Est. Pullback Lookback (Days)", group=groupTech)
// User Specific Pivot Settings
pivotLeft   = input.int(2, title="Pivot Lookback Left (Daily)", group=groupTech)
pivotRight  = input.int(2, title="Pivot Lookback Right (Daily)", group=groupTech)
atrLen      = input.int(14, title="ATR Length", group=groupTech)

// Volume Profile Settings (Basic POC Logic)
vpLookback  = input.int(100, "VP Lookback Bars", group=groupTech)

// --- Mathematical Edges (Backtested) ---
grp_edge = "Mathematical Edges (Backtested)"
use_macro_edge = input.bool(true, title="[ENABLE] Macro Edge: Institutional Vol Bias", group=grp_edge, tooltip="Only fires STRONG BUY if Volume Shelf (VWMA>SMA) AND Volume Accumulation rules are met.")
use_micro_edge = input.bool(true, title="[ENABLE] Micro Edge: Price & Squeeze Validation", group=grp_edge, tooltip="Only fires PULLBACK 🎯 if Price > CPR & Monthly VWAP AND 20/50 Squeeze is active.")

// Hidden inputs for calculation thresholds (kept out of UI to avoid clutter, set to mathematically optimal values)
vol_acc_days  = 10
vol_acc_min   = 2
vol_avg_len   = 50
vcp_thresh    = 1.5
vdu_pct       = 0.30

groupAlert  = "Alerts & Visuals"
showSignals = input.bool(true, title="Show Buy/Breakout Labels", group=groupAlert)
showTrade   = input.bool(true, title="Show Trade Lines (Entry/Targets)", group=groupAlert)
showDist    = input.bool(true, title="Show % Distance on Trade Lines", group=groupAlert)
markFresh   = input.bool(true, title="Mark Fresh Signals (★)", group=groupAlert)
showAVWAP   = input.bool(true, title="Show Auto-Anchored VWAP (Stage 2 Start)", group=groupAlert)

// Styling
groupStyle  = "Dashboard Style"
tablePos    = input.string(position.bottom_right, title="Position", options=[position.top_right, position.bottom_right, position.top_left, position.bottom_left], group=groupStyle)
textSize    = input.string(size.small, title="Data Size", options=[size.tiny, size.small, size.normal], group=groupStyle)
