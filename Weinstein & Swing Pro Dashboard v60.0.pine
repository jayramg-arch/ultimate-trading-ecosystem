if barstate.islast and array.size(alpha_scores) > 1
    int n = array.size(alpha_scores)
    for i = 0 to n - 2
        for j = 0 to n - i - 2
            if array.get(alpha_scores, j) < array.get(alpha_scores, j + 1)
                // Swap Scores
                float tempScore = array.get(alpha_scores, j)
                array.set(alpha_scores, j, array.get(alpha_scores, j + 1))
                array.set(alpha_scores, j + 1, tempScore)
                // Swap Tickers
                string tempTick = array.get(alpha_tickers, j)
                array.set(alpha_tickers, j, array.get(alpha_tickers, j + 1))
                array.set(alpha_tickers, j + 1, tempTick)
                // Swap Triggers
                string tempTrig = array.get(alpha_triggers, j)
                array.set(alpha_triggers, j, array.get(alpha_triggers, j + 1))
                array.set(alpha_triggers, j + 1, tempTrig)
                // Swap Colors
                color tempCol = array.get(alpha_colors, j)
                array.set(alpha_colors, j, array.get(alpha_colors, j + 1))
                array.set(alpha_colors, j + 1, tempCol)

