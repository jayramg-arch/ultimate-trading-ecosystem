// DRAWING
// ==========================================
var table panel = table.new(tablePos, 4, 50, border_width=1, border_color=color.gray)


drawRowL(tbl, r, title, valText, valColor, cellBg, titleColor, valTextColor) =>
    table.cell(tbl, 0, r, title, bgcolor=cellBg, text_color=titleColor, text_size=textSize, text_halign=text.align_left)
    table.cell(tbl, 1, r, valText, bgcolor=valColor, text_color=valTextColor, text_size=textSize, text_halign=text.align_center)

drawRowR(tbl, r, title, valText, valColor, cellBg, titleColor, valTextColor) =>
    table.cell(tbl, 2, r, title, bgcolor=cellBg, text_color=titleColor, text_size=textSize, text_halign=text.align_left)
    table.cell(tbl, 3, r, valText, bgcolor=valColor, text_color=valTextColor, text_size=textSize, text_halign=text.align_center)

if barstate.islast
    int rowL = 0
    int rowR = 0
    
    // Header Left
    table.cell(panel, 0, rowL, "WEINSTEIN DASHBOARD", bgcolor=color.new(color.blue, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, syminfo.ticker, bgcolor=color.new(color.blue, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    // Header Right
    table.cell(panel, 2, rowR, "DATE", bgcolor=color.new(color.blue, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, str.tostring(year(timenow)) + "-" + str.tostring(month(timenow)) + "-" + str.tostring(dayofmonth(timenow)), bgcolor=color.new(color.blue, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    rowL += 1
    rowR += 1

    if panicExit
        drawRowL(panel, rowL, "⚠️ CRITICAL ALERT", "PRICE < 40WMA", color.red, c_bg, c_text, color.white)
        rowL += 1

    // --- LEFT COLUMN ---
    // GROUP 1: MACRO & COMMON CONTEXT
    drawRowL(panel, rowL, "RECOMMENDATION", displayRec, recColor, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "CATALYST (Edge)", chartCat, chartCatCol, c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "ASSET QUALITY", assetQuality, gradeCol, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "ACTION SIGNAL", actionSignal, conf_col, c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "TRADE STYLE", style_txt, style_col, c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "PERSONA", persona_txt, persona_col, c_bg, c_text, color.black)
    rowL += 1
    
    // Trade & Portfolio Status
    drawRowL(panel, rowL, "PORTFOLIO HEALTH", pfStr, pfCol, c_bg, c_text, c_val_text)
    rowL += 1
    if tradeActive
        drawRowL(panel, rowL, "MY TRADE", tradeStatus, tradeColor, c_bg, c_text, c_val_text)
        rowL += 1
        drawRowL(panel, rowL, "ENTRY DATE", entryDateStr, color.gray, c_bg, c_text, c_val_text)
        rowL += 1
        drawRowL(panel, rowL, "DAYS HELD", str.tostring(daysHeld) + " Day(s)", daysHeld > 30 ? color.blue : color.gray, c_bg, c_text, c_val_text)
        rowL += 1
        if finalSL > 0
            drawRowL(panel, rowL, "Dynamic Profile", mktProfile, isBullMarket ? color.green : color.red, c_bg, c_text, c_val_text)
            rowL += 1
            drawRowL(panel, rowL, "Current R:R", rrText, currentR >= 1.0 ? color.green : color.orange, c_bg, c_text, c_val_text)
            rowL += 1

    // INST. ACTIVITY & FILTERS
    table.cell(panel, 0, rowL, "--- INST. ACTIVITY & FILTERS ---", bgcolor=color.new(color.yellow, 70), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, "", bgcolor=color.new(color.yellow, 70))
    rowL += 1

    drawRowL(panel, rowL, "Daily Close > CPR", cpr_ok ? "YES" : "NO", cpr_ok ? color.green : color.red, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "Price > M-VWAP", mvwap_ok ? "YES" : "NO", mvwap_ok ? color.green : color.red, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "Vol Shelf (VWMA)", vol_shelf_ok ? "YES" : "NO", vol_shelf_ok ? color.green : color.red, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "Vol Accum (Setup)", vol_acc_ok ? "PASS" : "WAIT", vol_acc_ok ? color.green : color.gray, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "VCP Tightness", vcp_ok ? "PASS" : "WAIT", vcp_ok ? color.green : color.orange, c_bg, c_text, c_val_text)
    rowL += 1

    // Breadth & Sector
    table.cell(panel, 0, rowL, "--- BREADTH & SECTOR ---", bgcolor=color.new(color.gray, 70), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, rowL, "", bgcolor=color.new(color.gray, 70))
    rowL += 1

    drawRowL(panel, rowL, "Mkt Health (N500)", mktState, mktColor, c_bg, c_text, c_val_text)
    rowL += 1
    string secStr = syminfo.sector + " / " + syminfo.industry
    drawRowL(panel, rowL, "Sector Info", secStr, color.gray, c_bg, c_text, c_val_text)
    rowL += 1
    drawRowL(panel, rowL, "Sector Velocity (ROC)", secVelStr, secVelCol, c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "RS (vs Nifty 50)", f_rrg_icon(rs50State) + " " + rs50State, f_rrg_color(rs50State), c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "RS (vs N500)", f_rrg_icon(rs500State) + " " + rs500State, f_rrg_color(rs500State), c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "RS (" + autoSectorName + ")", f_rrg_icon(rsSecState) + " " + rsSecState, f_rrg_color(rsSecState), c_bg, c_text, color.black)
    rowL += 1
    drawRowL(panel, rowL, "Next Earnings", earnStr, earnColor, c_bg, c_text, c_val_text)
    rowL += 1

    // --- RIGHT COLUMN ---
    // GROUP 2: POSITIONAL
    table.cell(panel, 2, rowR, "--- 🦁 POSITIONAL: THE HUNTER ---", bgcolor=color.new(color.blue, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, "(Weinstein/Weekly)", bgcolor=color.new(color.blue, 30), text_color=color.white, text_size=size.small, text_halign=text.align_center)
    rowR += 1

    drawRowR(panel, rowR, "Market Structure", stageDisplay, stageCol, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Master Trend (W)", f_trendText(wTrendDir), f_trendColor(wTrendDir), c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "30-Week MA Slope", wMASlopeState, wMASlopeState == "RISING" ? color.green : (wMASlopeState == "FALLING" ? color.red : color.blue), c_bg, c_text, c_val_text)
    rowR += 1
    bool pAbove30 = wClose > wMA30
    drawRowR(panel, rowR, "Price > 30W MA", pAbove30 ? "YES" : "NO", pAbove30 ? color.green : color.red, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Overhead Resist", str.tostring(resistCount) + " Level(s)", resistCount == 0 ? color.green : color.orange, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "52W High Space", s_dev52, dev52 > -15 ? color.green : color.gray, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "ATH Space", s_devATH, (not na(devATH) and devATH > -15) ? color.green : color.gray, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Weekly PB Health", wkHealthStr, wkHealthCol, c_bg, c_text, c_val_text)
    rowR += 1

    table.cell(panel, 2, rowR, "--- 🎯 SWING: THE SNIPER ---", bgcolor=color.new(color.purple, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, "(Minervini/Daily)", bgcolor=color.new(color.purple, 30), text_color=color.white, text_size=size.small, text_halign=text.align_center)
    rowR += 1

    drawRowR(panel, rowR, "Daily Trend (D)", f_trendText(dTrendDir), f_trendColor(dTrendDir), c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Trend Template (>200d)", dSmaAligned ? "ALIGNED" : "MISALIGNED", dSmaAligned ? color.green : color.red, c_bg, c_text, c_val_text)
    rowR += 1
    bool pAbove50 = dClose > dMA50
    drawRowR(panel, rowR, "Price > 50 DMA", pAbove50 ? "YES" : "NO", pAbove50 ? color.green : color.red, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "50 DMA Slope", d50SlopeState, d50SlopeState == "RISING" ? color.green : (d50SlopeState == "FALLING" ? color.red : color.gray), c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Price Action Structure", paState, paColor, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Volume Trend", volState, volColor, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Volatility State (ADR)", patStr, color.gray, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, ema_lbl + " Proximity", emaState, emaColor, c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "S/R Proximity", srState, srColor, c_bg, c_text, c_val_text)
    rowR += 1
    string rsiStr = str.tostring(currRsi, "#.##") + " / " + currRsiDiv
    drawRowR(panel, rowR, "RSI & Divergence", rsiStr, currRsiDiv == "BULLISH DIV" ? color.green : (currRsiDiv == "BEARISH DIV" ? color.red : color.gray), c_bg, c_text, c_val_text)
    rowR += 1
    drawRowR(panel, rowR, "Daily Pullback Health", dayHealthStr, dayHealthCol, c_bg, c_text, c_val_text)
    rowR += 1

    // --- ⚡ ALPHA SCREENER (v59.0 TOP 5 SETUPS) ---
    table.cell(panel, 2, rowR, "--- ⚡ ALPHA SCREENER ---", bgcolor=color.new(color.orange, 30), text_color=color.white, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 3, rowR, "(Top Watchlist Setups)", bgcolor=color.new(color.orange, 30), text_color=color.white, text_size=size.small, text_halign=text.align_center)
    rowR += 1
    
    if array.size(alpha_scores) > 0

        
        int drawCount = math.min(array.size(alpha_scores), 5) // Max 5 rows
        for i = 0 to drawCount - 1
            float s = array.get(alpha_scores, i)
            string t = array.get(alpha_tickers, i)
            string tr = array.get(alpha_triggers, i)
            color col = array.get(alpha_colors, i)
            string rowTitle = t + " [" + str.tostring(math.round(s)) + "]"
            drawRowR(panel, rowR, rowTitle, tr, col, c_bg, c_text, color.black)
            rowR += 1
    else
        drawRowR(panel, rowR, "Scanning Portfolio...", "No Quality Setups", color.gray, c_bg, c_text, color.white)
        rowR += 1


plot(wMA30, "30W MA", color=wMASlopeState == "RISING" ? color.green : color.red, linewidth=2)
plot(wMA40, "40W MA", color=color.black, linewidth=1)

// ==========================================
// AUTO-ANCHORED VWAP (Stage 2 Focus)
// ==========================================
// Use the 'startTime' generated by f_getStageAndTime for Anchoring
var float cumVol = 0.0
var float cumVolPrice = 0.0
var int last_anchor_time = 0

// Reset AVWAP if Stage changes to "STAGE 2 (UP)"
// We check if the stageStart_val changed (meaning a new stage began)
[_s, _st, _sl, _wma] = request.security(syminfo.tickerid, "W", f_getStageAndTime(maLengthW, wmaSlopeLen, slopeThresh), ignore_invalid_symbol=true)

if _st != last_anchor_time
    cumVol := 0.0
    cumVolPrice := 0.0
    last_anchor_time := _st

if time >= last_anchor_time
    cumVol += volume
    cumVolPrice += (hlc3 * volume)

float avwap = cumVol > 0 ? cumVolPrice / cumVol : na

plot(showAVWAP and stageID == "STAGE 2 (UP)" ? avwap : na, title="Auto AVWAP (Stage 2)", color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_line)

// ==========================================
// TRADE LINES & LABELS (v20.0 Logic Ported)
// ==========================================

// Helper for Distance %
f_dist(float lvl) =>
    float d = ((lvl - close) / close) * 100
    string s = (d > 0 ? "+" : "") + str.tostring(d, "#.1") + "%"
    s

// Target Logic (2R and 3R as per v20.0)
float risk_per_share = math.abs(finalEntry - finalSL)
float t1_val = finalEntry + (risk_per_share * dyn_T1_R)
float t2_val = finalEntry + (risk_per_share * dyn_T2_R)

// PLOTS (Continuous Lines for History)
// Fix: Simplified condition to 'tradeActive' to restore draggability (TV requires plot series to be linked to inputs consistently)
color entryColor = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.blue, 0) : color.new(color.blue, 100)
color slColor    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.red, 0) : color.new(color.red, 100)
color t1Color    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.green, 30) : color.new(color.green, 100)
color t2Color    = tradeActive and (finalDate == 0 or time >= finalDate) ? color.new(color.green, 50) : color.new(color.green, 100)

plot(showTrade and finalEntry > 0 ? finalEntry : na, "Entry Price", color=entryColor, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive ? finalSL : na, "Hard SL", color=slColor, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 ? t1_val : na, "Target 1 (Dynamic)", color=t1Color, style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 ? t2_val : na, "Target 2 (Dynamic)", color=t2Color, style=plot.style_linebr, linewidth=1)

// Trailing SL Logic Removed in favor of Native Chandelier Exit

// LABELS (Last Bar Only - v20.0 Style)
if barstate.islast and showTrade and tradeActive
    // Entry Label
    label.new(bar_index + 3, finalEntry, "Avg. Entry: " + str.tostring(math.round_to_mintick(finalEntry)), color=color.blue, style=label.style_none, textcolor=color.blue, size=size.small)
    
    // SL & Targets Labels with Distance
    if finalSL > 0
        // FIX for dragging: the line must exist un-bridged
        // Final fallback block updated below where plots live
        string slDist = showDist ? ", " + f_dist(finalSL) : ""
        label.new(bar_index + 3, finalSL, "Hard SL: " + str.tostring(math.round_to_mintick(finalSL)) + slDist, color=color.red, style=label.style_none, textcolor=color.red, size=size.small)
        
        string t1Dist = showDist ? ", " + f_dist(t1_val) : ""
        label.new(bar_index + 3, t1_val, "Target 1: " + str.tostring(math.round_to_mintick(t1_val)) + t1Dist, color=color.green, style=label.style_none, textcolor=color.green, size=size.small)
        
        string t2Dist = showDist ? ", " + f_dist(t2_val) : ""
        label.new(bar_index + 3, t2_val, "Target 2: " + str.tostring(math.round_to_mintick(t2_val)) + t2Dist, color=color.green, style=label.style_none, textcolor=color.lime, size=size.small)
    


// ==========================================
// 10. GEMINI PROMPT GENERATION (User Request)
// ==========================================
show_prompt = input.bool(false, title="Generate Gemini Context Prompt (Check Logs)", group="AI Analysis Tools", tooltip="Enable this, then check 'Pine Logs' tab to copy the text prompt for Gemini.")

// Debounce logic to prevent log flooding on live bars
varip int last_log_time = 0
int current_time = timenow
bool time_ok = (current_time - last_log_time) > 5000 // 5 seconds

if show_prompt and barstate.islast and time_ok
    last_log_time := current_time
    
    // Fix: Unpack Tuple first
    [secTicker, secName] = f_get_hybrid_sector()

    // Construct the Prompt String
    string p_str = "Role: Senior Quantitative Analyst (Weinstein & Minervini Expert).\n" +
                 "Task: Analyze the following asset based on Stan Weinstein's Stage Analysis and Mark Minervini's VCP/SEPA principles.\n\n" +
                 "ASSET: " + syminfo.ticker + " (" + secName + ")\n" +
                 "Current Market Price: " + str.tostring(close) + "\n\n" +
                 
                 "--- 1. MARKET & SECTOR CONTEXT ---\n" +
                 "Broad Market Health (Nifty 500): " + mktState + "\n" +
                 "Sector RS State: " + rsSecState + "\n" +
                 "Asset RS State (vs Nifty 500): " + rs500State + "\n\n" +
                 
                 "--- 2. TREND & MOMENTUM ---\n" +
                 "Stage Structure: " + stageDisplay + "\n" +
                 "Weekly Trend: " + (wTrendDir == 1 ? "UP" : (wTrendDir == -1 ? "DOWN" : "SIDEWAYS")) + "\n" +
                 "Daily Trend: " + (dTrendDir == 1 ? "UP" : (dTrendDir == -1 ? "DOWN" : "SIDEWAYS")) + "\n" +
                 "30-Week SMA: " + str.tostring(wMA30) + " (Slope: " + wMASlopeState + ")\n" +
                 "Price > 30WMA: " + (close > wMA30 ? "YES" : "NO") + "\n" +
                 "50-Day SMA Slope: " + d50SlopeState + "\n" +
                 "Price > 50DMA: " + (close > dMA50 ? "YES" : "NO") + "\n" +
                 "Trend Template (50>150>200): " + (dSmaAligned ? "ALIGNED (Bullish)" : "MISALIGNED") + "\n\n" +
                 
                 "--- 3. PRICE ACTION & KEY LEVELS ---\n" +
                 "1. First, analyze the Broad Market and Sector context (Is the tide rising?).\n" +
                 "2. Perform a brief Fundamental Check (Earnings growth, Valuation, etc.) and Sentiment Analysis (Recent News/Hype).\n" +
                 "3. Evaluate the Asset's Stage (Weinstein) and Volatility Contraction (Minervini).\n" +
                 "4. Check for specific overhead supply (Resistance) vs immediate support.\n" +
                 "5. Conclude with a clear Buy/Sell/Hold decision and potential trade setup (Entry/Stop/Target)."
                 
    log.info("\n⬇️ COPY GEMINI PROMPT BELOW ⬇️\n\n" + p_str + "\n\n⬆️ COPY GEMINI PROMPT ABOVE ⬆️")
    alert("Gemini Prompt Generated for " + syminfo.ticker + ". Check Pine Logs.", alert.freq_once_per_bar_close)

// ==========================================
// 11. EXPORT PORTFOLIO TO CSV (User Request)
// ==========================================
show_csv = input.bool(false, title="Export Portfolio to CSV Log", group="Data Tools", tooltip="Enable this, then check 'Pine Logs' tab to copy your portfolio data (Ticker, Entry, SL, Sector) in CSV format.")

// Helper to format row
f_row(t, e, s, d, sec) =>
    if t != ""
        t + "," + str.tostring(e) + "," + str.tostring(s) + "," + str.format("{0,date,yyyy-MM-dd}", d) + "," + str.tostring(sec) + "\\n"
    else
        ""

if show_csv and barstate.islast and time_ok
    string csv_out = "Ticker,Entry,SL,Date,Sector\\n"

    csv_out := csv_out + f_row(p1_tick, p1_ent, p1_sl, p1_date, p1_sec)
    csv_out := csv_out + f_row(p2_tick, p2_ent, p2_sl, p2_date, p2_sec)
    csv_out := csv_out + f_row(p3_tick, p3_ent, p3_sl, p3_date, p3_sec)
    csv_out := csv_out + f_row(p4_tick, p4_ent, p4_sl, p4_date, p4_sec)
    csv_out := csv_out + f_row(p5_tick, p5_ent, p5_sl, p5_date, p5_sec)
    csv_out := csv_out + f_row(p6_tick, p6_ent, p6_sl, p6_date, p6_sec)
    csv_out := csv_out + f_row(p7_tick, p7_ent, p7_sl, p7_date, p7_sec)
    csv_out := csv_out + f_row(p8_tick, p8_ent, p8_sl, p8_date, p8_sec)
    csv_out := csv_out + f_row(p9_tick, p9_ent, p9_sl, p9_date, p9_sec)
    csv_out := csv_out + f_row(p10_tick, p10_ent, p10_sl, p10_date, p10_sec)
    csv_out := csv_out + f_row(p11_tick, p11_ent, p11_sl, p11_date, p11_sec)
    csv_out := csv_out + f_row(p12_tick, p12_ent, p12_sl, p12_date, p12_sec)
    csv_out := csv_out + f_row(p13_tick, p13_ent, p13_sl, p13_date, p13_sec)
    csv_out := csv_out + f_row(p14_tick, p14_ent, p14_sl, p14_date, p14_sec)
    csv_out := csv_out + f_row(p15_tick, p15_ent, p15_sl, p15_date, p15_sec)
    csv_out := csv_out + f_row(p16_tick, p16_ent, p16_sl, p16_date, p16_sec)
    csv_out := csv_out + f_row(p17_tick, p17_ent, p17_sl, p17_date, p17_sec)
    csv_out := csv_out + f_row(p18_tick, p18_ent, p18_sl, p18_date, p18_sec)
    csv_out := csv_out + f_row(p19_tick, p19_ent, p19_sl, p19_date, p19_sec)
    csv_out := csv_out + f_row(p20_tick, p20_ent, p20_sl, p20_date, p20_sec)
    csv_out := csv_out + f_row(p21_tick, p21_ent, p21_sl, p21_date, p21_sec)
    csv_out := csv_out + f_row(p22_tick, p22_ent, p22_sl, p22_date, p22_sec)
    csv_out := csv_out + f_row(p23_tick, p23_ent, p23_sl, p23_date, p23_sec)
    csv_out := csv_out + f_row(p24_tick, p24_ent, p24_sl, p24_date, p24_sec)
    csv_out := csv_out + f_row(p25_tick, p25_ent, p25_sl, p25_date, p25_sec)
    csv_out := csv_out + f_row(p26_tick, p26_ent, p26_sl, p26_date, p26_sec)
    csv_out := csv_out + f_row(p27_tick, p27_ent, p27_sl, p27_date, p27_sec)
    csv_out := csv_out + f_row(p28_tick, p28_ent, p28_sl, p28_date, p28_sec)
