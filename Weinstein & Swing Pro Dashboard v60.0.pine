// Dynamic Risk Manager (Portfolio Heat)
if pf_total > 0
    if pf_stop >= 3 // Too many stops hit, flashing warning
        pfCol := color.red
        pfStr := "🔥 RISK OFF: " + pfStr
    else if pf_win > (pf_loss + pf_stop)
        pfCol := color.green
    else
        pfCol := color.orange

