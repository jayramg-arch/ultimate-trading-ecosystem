f_calc_slope_val(float src, int len) =>
    ta.linreg(src, len, 0) - ta.linreg(src, len, 1)

f_rrg_color(string s) =>
    str.contains(s, "Leading") ? #00e676 : (str.contains(s, "Weakening") ? #ffd600 : (str.contains(s, "Lagging") ? #ff5252 : #d500f9))

f_rrg_icon(string s) =>
    str.contains(s, "Leading") ? "↗" : (str.contains(s, "Weakening") ? "↘" : (str.contains(s, "Lagging") ? "↙" : "↖"))

f_match(string t) => 
    bool m = false
    if t != ""
        // robust matching: remove prefix from input if present
        string cleanInput = str.replace_all(str.upper(str.trim(t)), "NSE:", "")
        cleanInput := str.replace_all(cleanInput, "BSE:", "")
        string curT = str.upper(syminfo.ticker)
        if cleanInput == curT
            m := true
    m

f_prepTick(string t) =>
    string r = t
    if t != ""
        if not str.contains(t, ":")
            r := "NSE:" + t
    r

// AUTO SECTOR MAPPER
f_get_sector_ticker() =>
    string s = syminfo.sector
    string i = syminfo.industry
    string t = "NSE:CNX500" // Default fallback
    string n = "Nifty 500"
    
    // Prioritize by Industry keywords first (more specific)
    if str.contains(i, "Bank") or str.contains(s, "Finance")
        t := "NSE:BANKNIFTY"
        n := "Bank Nifty"
    else if str.contains(s, "Technology") or str.contains(i, "Software") or str.contains(i, "IT")
        t := "NSE:CNXIT"
        n := "Nifty IT"
    else if str.contains(s, "Health") or str.contains(i, "Pharma")
        t := "NSE:CNXPHARMA"
        n := "Pharma"
    else if str.contains(i, "Auto") or str.contains(s, "Consumer Durables")
        t := "NSE:CNXAUTO"
        n := "Nifty Auto"
    else if str.contains(s, "Consumer Non") or str.contains(i, "Food") or str.contains(i, "Beverage")
        t := "NSE:CNXFMCG"
        n := "FMCG"
    else if str.contains(s, "Minerals") or str.contains(i, "Steel") or str.contains(i, "Metal")
        t := "NSE:CNXMETAL"
        n := "Metal"
    else if str.contains(s, "Energy") or str.contains(i, "Oil") or str.contains(i, "Gas")
        t := "NSE:CNXENERGY"
        n := "Energy"
    else if str.contains(s, "Real Estate") or str.contains(i, "Construction")
        t := "NSE:CNXREALTY"
        n := "Realty"
    else if str.contains(s, "Infrastructure")
        t := "NSE:CNXINFRA"
        n := "Infra"
    
    // Return Tuple
    [t, n]

