alertcondition(close > use_ema20 and close[1] < use_ema20, title="EMA 20 Crossover", message="Weinstein Pro: Price Crossed Above EMA 20 on {{ticker}}.")
alertcondition(mktState == "BEARISH", title="Market Health Alert", message="Weinstein Pro: Nifty 500 has flipped to BEARISH.")

