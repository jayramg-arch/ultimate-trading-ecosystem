sortBy = input.string("Score/Grade", title="Rank/Sort By", options=["Score/Grade", "Volume Thrust", "Proximity to 52-Wk High", "Proximity to 20-EMA", "Relative Strength (Qtr)"], group=grpConfig)
sortDir = input.string("Descending (Best to Worst)", title="Sort Direction", options=["Descending (Best to Worst)", "Ascending (Worst to Best)"], group=grpConfig)
tbPos = input.string(position.top_right, title="Table Position", options=[position.top_right, position.bottom_right, position.middle_right, position.middle_center], group=grpConfig)


// ==========================================
// 2. DATA STRUCTURE & FETCH LOGIC
// ==========================================
type StockData
    string ticker
    float price
    string stageStr
    string gradeStr
    int score
    float distFromHigh
    float distFromEMA20
    float volThrust
    string vcpStr
    string rsStr
    color bgCol
    string recStr

// Grab benchmark performance once
b_qtr_roc = request.security(benchSym, timeframe.period, ta.roc(close, 65))

// A tuple function to grab all 13 core indicators concurrently
f_get_data() =>
    [close, open, ta.ema(close, 20), ta.sma(close, 50), ta.sma(close, 150), ta.sma(close, 200), ta.sma(close, 200)[10], ta.highest(high, 250), volume, ta.sma(volume, 50), ta.rsi(close, 14), ta.atr(10), ta.atr(40), ta.roc(close, 65)]

f_process_stock(string sym, float c, float o, float e20, float s50, float s150, float s200, float s200_10, float h250, float vol, float vSma, float rsi, float atr10, float atr40, float roc65, float benchRoc) =>
    if na(c) or c == 0
        StockData.new(sym, 0, "N/A", "N/A", 0, 0, 0, 0, "N/A", "N/A", color.gray, "WAIT")
    else
        // 1. Structural Grade & Stage
        score = 0
        grade = "F"
        stage = "STAGE 4"
        bg = color.new(#ff5252, 70) 
        
        if (c > s150) and (s150 > s200) and (s200 > s200_10)
            stage := "STAGE 2 (UP)"
            if (c > s50) and (s50 > s150)
                grade := "A"
                score := 5
                bg := color.new(#00e676, 50)
            else
                grade := "B"
                score := 4
                bg := color.new(#00e676, 70)
        else if (c > s200)
            stage := "STAGE 1 (BASE)"
            grade := "C"
            score := 3
            bg := color.new(#ffeb3b, 50)
        else if (s50 < s200)
            stage := "STAGE 4"
            grade := "D"
            score := 1
            bg := color.new(#ff9800, 50)

        // 2. Relative Strength Proxy (vs Nifty 50 over 65 days/1 Quarter)
        alpha = roc65 - benchRoc
        rs_str = "Lagging"
        if alpha > 15
            score += 2
            rs_str := "🔥 LEADING"
        else if alpha > 5
            score += 1
            rs_str := "Improving"
            
        // 3. Volatility Compression (VCP)
        vcp_str = "Normal"
        if atr10 < (atr40 * 0.70)
            vcp_str := "⚡ SQUEEZE"
            score += 1
        else if atr10 > (atr40 * 1.5)
            vcp_str := "Expanded"

        // 4. Volume Thrust
        vThrust = 0.0
        if vSma > 0 and (c > o)
            vThrust := (vol / vSma) * 100
            if vThrust > 150
                score += 1
                
        // 5. Distance Metrics
        d52High = h250 > 0 ? ((c - h250) / h250) * 100 : 0
        dEMA20 = e20 > 0 ? ((c - e20) / e20) * 100 : 0
        
        // 6. Final Recommendation String
        rec = "WAIT"
        if stage == "STAGE 2 (UP)" and c > e20 and rsi > 50
            if vcp_str == "⚡ SQUEEZE" and dEMA20 < 5.0
                rec := "🎯 SWING SETUP"
            else
                rec := "BUY (Trend)"
        else if stage == "STAGE 1 (BASE)" 
            rec := "WATCH (Basing)"
        else if stage == "STAGE 4"
            rec := "AVOID"

        StockData.new(sym, c, stage, grade, score, d52High, dEMA20, vThrust, vcp_str, rs_str, bg, rec)

