        array.push(a_stocks, f_process_stock(s29, c29, o29, e1_29, s50_29, s150_29, s200_29, s200_10_29, h250_29, v29, vSma_29, rsi29, atr10_29, atr40_29, roc29, b_qtr_roc))
    if s30 != "" and not na(c30)
        array.push(a_stocks, f_process_stock(s30, c30, o30, e1_30, s50_30, s150_30, s200_30, s200_10_30, h250_30, v30, vSma_30, rsi30, atr10_30, atr40_30, roc30, b_qtr_roc))
    
    // Sort Engine
    a_sortVals = array.new_float()
    for s in a_stocks
        float v = 0.0
        if sortBy == "Score/Grade"
            v := s.score + (s.volThrust / 1000) 
        else if sortBy == "Volume Thrust"
            v := s.volThrust
        else if sortBy == "Proximity to 52-Wk High"
            v := s.distFromHigh * -1 // Reverse
        else if sortBy == "Relative Strength (Qtr)"
            v := s.rsStr == "🔥 LEADING" ? 2 : (s.rsStr == "Improving" ? 1 : 0)
        else
            v := math.abs(s.distFromEMA20) * -1 // Tightest ema compression
        array.push(a_sortVals, v)
        
    int[] indices = array.sort_indices(a_sortVals)
    
    // Headers
    table.cell(ui, 0, 0, "RANK", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 1, 0, "TICKER", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 2, 0, "GRADE", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 3, 0, "STAGE", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 4, 0, "R. STRENGTH", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 5, 0, "VOLATILITY", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 6, 0, "VOL THRUST%", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 7, 0, "% FROM ATH", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 8, 0, "EMA DIST%", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    table.cell(ui, 9, 0, "REC", bgcolor=#1A237E, text_color=color.white, text_size=size.small)
    
    bool isDesc = sortDir == "Descending (Best to Worst)"
    
    if array.size(indices) > 0
        for i = 0 to array.size(indices) - 1
            idx = isDesc ? array.get(indices, (array.size(indices) - 1) - i) : array.get(indices, i)
            s = array.get(a_stocks, idx)
            
            cleanTick = str.replace_all(s.ticker, "NSE:", "")
            
            table.cell(ui, 0, i+1, str.tostring(i+1), bgcolor=s.bgCol, text_color=color.white, text_size=size.small)
            table.cell(ui, 1, i+1, cleanTick, bgcolor=s.bgCol, text_color=color.white, text_size=size.small)
            table.cell(ui, 2, i+1, s.gradeStr, bgcolor=s.bgCol, text_color=color.white, text_size=size.small)
            table.cell(ui, 3, i+1, s.stageStr, bgcolor=s.bgCol, text_color=color.white, text_size=size.small)
            
            // RS
            color rsCol = str.contains(s.rsStr, "LEADING") ? color.lime : color.white
            table.cell(ui, 4, i+1, s.rsStr, bgcolor=s.bgCol, text_color=rsCol, text_size=size.small)
            
            // VCP
            color vcpCol = str.contains(s.vcpStr, "SQUEEZE") ? color.yellow : color.white
            table.cell(ui, 5, i+1, s.vcpStr, bgcolor=s.bgCol, text_color=vcpCol, text_size=size.small)
            
            // Vol Thrust
            color vCol = color.white
            if s.volThrust > 150
                vCol := color.yellow // Accumulation!
            valStr = s.volThrust > 0 ? str.tostring(s.volThrust, "#.#") + "%" : "0%"
            table.cell(ui, 6, i+1, valStr, bgcolor=s.bgCol, text_color=vCol, text_size=size.small)
            
            // ATH Dist
            table.cell(ui, 7, i+1, str.tostring(s.distFromHigh, "#.#") + "%", bgcolor=s.bgCol, text_color=color.white, text_size=size.small)
            
            // EMA Dist
            color dCol = color.white
            if math.abs(s.distFromEMA20) < 3.0
                dCol := color.lime // Nice tight EMA compression
            table.cell(ui, 8, i+1, str.tostring(s.distFromEMA20, "#.#") + "%", bgcolor=s.bgCol, text_color=dCol, text_size=size.small)

            // Rec
            color rCol = str.contains(s.recStr, "BUY") or str.contains(s.recStr, "SETUP") ? color.lime : color.white
            table.cell(ui, 9, i+1, s.recStr, bgcolor=s.bgCol, text_color=rCol, text_size=size.small)
