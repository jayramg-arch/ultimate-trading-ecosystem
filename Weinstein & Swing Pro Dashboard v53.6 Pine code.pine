// HYBRID SECTOR LOOKUP
f_get_hybrid_sector() =>
    string t = ""
    string n = ""
    
    // Check against Manual Slots
    if f_match(p1_tick)
        t := p1_sec
        n := str.replace_all(p1_sec, "NSE:", "")
    else if f_match(p2_tick)
        t := p2_sec
        n := str.replace_all(p2_sec, "NSE:", "")
    else if f_match(p3_tick)
        t := p3_sec
        n := str.replace_all(p3_sec, "NSE:", "")
    else if f_match(p4_tick)
        t := p4_sec
        n := str.replace_all(p4_sec, "NSE:", "")
    else if f_match(p5_tick)
        t := p5_sec
        n := str.replace_all(p5_sec, "NSE:", "")
    else if f_match(p6_tick)
        t := p6_sec
        n := str.replace_all(p6_sec, "NSE:", "")
    else if f_match(p7_tick)
        t := p7_sec
        n := str.replace_all(p7_sec, "NSE:", "")
    else if f_match(p8_tick)
        t := p8_sec
        n := str.replace_all(p8_sec, "NSE:", "")
    else if f_match(p9_tick)
        t := p9_sec
        n := str.replace_all(p9_sec, "NSE:", "")
    else if f_match(p10_tick)
        t := p10_sec
        n := str.replace_all(p10_sec, "NSE:", "")
    else if f_match(p11_tick)
        t := p11_sec
        n := str.replace_all(p11_sec, "NSE:", "")
    else if f_match(p12_tick)
        t := p12_sec
        n := str.replace_all(p12_sec, "NSE:", "")
    else if f_match(p13_tick)
        t := p13_sec
        n := str.replace_all(p13_sec, "NSE:", "")
    else if f_match(p14_tick)
        t := p14_sec
        n := str.replace_all(p14_sec, "NSE:", "")
    else if f_match(p15_tick)
        t := p15_sec
        n := str.replace_all(p15_sec, "NSE:", "")
    else if f_match(p16_tick)
        t := p16_sec
        n := str.replace_all(p16_sec, "NSE:", "")
    else if f_match(p17_tick)
        t := p17_sec
        n := str.replace_all(p17_sec, "NSE:", "")
    else if f_match(p18_tick)
        t := p18_sec
        n := str.replace_all(p18_sec, "NSE:", "")
    else if f_match(p19_tick)
        t := p19_sec
        n := str.replace_all(p19_sec, "NSE:", "")
    else if f_match(p20_tick)
        t := p20_sec
        n := str.replace_all(p20_sec, "NSE:", "")
    else if f_match(p21_tick)
        t := p21_sec
        n := str.replace_all(p21_sec, "NSE:", "")
    else if f_match(p22_tick)
        t := p22_sec
        n := str.replace_all(p22_sec, "NSE:", "")
    else if f_match(p23_tick)
        t := p23_sec
        n := str.replace_all(p23_sec, "NSE:", "")
    else if f_match(p24_tick)
        t := p24_sec
        n := str.replace_all(p24_sec, "NSE:", "")
    else if f_match(p25_tick)
        t := p25_sec
        n := str.replace_all(p25_sec, "NSE:", "")
    
    // Fallback to Auto if no match
    if t == ""
        
        // 1. Try External DB Lookup first (Highest Accuracy)
        string dbSec = f_db_sector_lookup(str.replace_all(str.upper(syminfo.ticker), "NSE:", ""))
        if dbSec != ""
            t := dbSec
            n := str.replace_all(t, "NSE:", "")
        else 
            // 2. Try Generic Auto-Mapper (Keyword based)
            [at, an] = f_get_sector_ticker()
            t := at
            n := an
        
    [t, n]
// Slope > 0.02 = Leading (Stage 2)
// Slope < -0.02 = Lagging (Stage 4)
// Slope ~ 0 = Stabilizing (Stage 1) or Weakening (Stage 3) depending on context
f_rsStateStr(float s, float v, float thresh) => 
    string st = "Improving"
    if s > thresh
        st := "Leading"
    else if s < -thresh
        st := "Lagging"
    else
        // Flat Slope: Context needed, but default return:
        if v > 0
            st := "Weakening" // Flat but positive value usually Stage 3 top
        else
            st := "Improving" // Flat and negative usually Stage 1 base
    string slopeDir = "Flat"
    if s > 0.001
        slopeDir := "Rising"
    else if s < -0.001
        slopeDir := "Falling"
        
    st := st + " (" + slopeDir + ")"
    st

f_calc_rs_logic(int rsl, int slen) =>
    rp = close 
    rpSMA = ta.sma(rp, rsl)
    mrs = ((rp / rpSMA) - 1) * 10
    slope = ta.linreg(mrs, slen, 0) - ta.linreg(mrs, slen, 1)
    [slope, mrs]

f_weeklyHealth(float riseThresh) =>
    float volAvgW = ta.sma(volume, 20)
    float atrW = ta.atr(14)
    int phIndex = -1
    float highestP = 0.0
    for i = 1 to 10
        if high[i] > highestP
            highestP := high[i]
            phIndex := i
    string hStr = "N/A"
    color hCol = color.gray
    if phIndex > 0
        int badBars = 0
        for j = 0 to phIndex - 1
            bool isDown = close[j] < open[j]
            bool highVol = volume[j] > volAvgW[j] * 1.2
            bool wideRange = (high[j]-low[j]) > (atrW[j] * 1.5)
            if isDown and (highVol or (wideRange and close[j] < low[j] + (high[j]-low[j])*0.25))
                badBars += 1
        if badBars == 0
            hStr := "HEALTHY (Low Vol)"
            hCol := color.green
        else if badBars <= 1
            hStr := "NORMAL"
            hCol := color.blue
        else
            hStr := "WEAK (Selling)"
            hCol := color.orange
    [hStr, hCol]

f_getStageAndTime(int maLen, int slopeLen, float thresh) =>
    float wCl = close
    float wMA = ta.sma(close, maLen)
    float slopeVal = ta.linreg(wMA, slopeLen, 0) - ta.linreg(wMA, slopeLen, 1)
    float dynThresh = wMA * thresh
    
    // Default
    string s = "TRANSITION"
    
    // Logic Matrix matching your Document:
    bool isRising = slopeVal > dynThresh
    bool isFalling = slopeVal < -dynThresh
    bool isFlat = not isRising and not isFalling
    bool isAbove = wCl > wMA
    
    if isRising
        if isAbove
            s := "STAGE 2 (UP)"
        else
            s := "STAGE 2 (PULLBACK)"
    else if isFalling
        s := "STAGE 4 (DOWN)"
    else // Flat Slope
        if isAbove
            s := "STAGE 1 (BASE)" 
        else
            s := "STAGE 3 (TOP)"
            
    var string lastS = ""
    var int startTime = 0
    if bar_index == 0
        lastS := s
        startTime := time
    if s != lastS
        startTime := time
        lastS := s
    [s, startTime, slopeVal, wMA]



f_trackATH() =>
    var float h = high
    h := math.max(h, high)
    h

f_getStrictTrend(float h, float l, int left, int right) =>
    var int trend = 0
    ph = ta.pivothigh(h, left, right)
    pl = ta.pivotlow(l, left, right)
    var float lockedHigh = na
    var float lockedLow  = na
    if not na(ph)
        lockedHigh := ph
    if not na(pl)
        lockedLow := pl
    if not na(lockedHigh) and close > lockedHigh
        trend := 1
    else if not na(lockedLow) and close < lockedLow
        trend := -1
    [trend, lockedHigh, lockedLow]

f_trendText(int t) => t == 1 ? "UP" : (t == -1 ? "DOWN" : "SIDEWAYS")
f_trendColor(int t) => t == 1 ? color.green : (t == -1 ? color.red : color.orange)

f_countOverheadResist(float currentPrice) =>
    var float[] pivotStack = array.new_float(0)
    wPh = ta.pivothigh(high, 5, 5)
    if not na(wPh)
        array.unshift(pivotStack, wPh)
        if array.size(pivotStack) > 50
            array.pop(pivotStack)
    int count = 0
    if array.size(pivotStack) > 0
        for i = 0 to array.size(pivotStack) - 1
            if array.get(pivotStack, i) > currentPrice
                count += 1
    count



f_calc_adx_bool() =>
    [dp, dm, adx] = ta.dmi(14, 14)
    adx > 25 and dp > dm

f_get_screener_data(string t) =>
    // GUARD: Bulletproof Check
    // 1. Trim whitespace (handles " " inputs)
    // 2. Check for empty or too short strings
    string cln = str.trim(t)
    bool good = str.length(cln) > 1
    
    // Customize: Use empty string fallback to keep 'request.security' unconditional (Satisfies Compiler)
    // 'ignore_invalid_symbol=true' ensures this returns NAs instantly without error or heavy calc
    string reqT = good ? cln : ""
    [c, c1, e, e1, r, v, va, adx_ok] = request.security(reqT, "D", [close, close[1], ta.ema(close, 20), ta.ema(close, 20)[1], ta.rsi(close, 14), volume, ta.sma(volume, 20), f_calc_adx_bool()], ignore_invalid_symbol=true)
    
    [c, c1, e, e1, r, v, va, adx_ok]

f_rsi_div(float src, int len, int left, int right) =>
    float rsiVal = ta.rsi(src, len)
    ph = ta.pivothigh(high, left, right)
    pl = ta.pivotlow(low, left, right)
    rsiPh = ta.pivothigh(rsiVal, left, right)
    rsiPl = ta.pivotlow(rsiVal, left, right)
    string div = "None"
    var float lastPP_H = na 
    var float lastRP_H = na 
    var float lastPP_L = na 
    var float lastRP_L = na 
    if not na(ph)
        if not na(lastPP_H) and ph > lastPP_H and not na(rsiPh) and rsiPh < lastRP_H
            div := "BEARISH DIV"
        lastPP_H := ph
        lastRP_H := not na(rsiPh) ? rsiPh : lastRP_H
    if not na(pl)
        if not na(lastPP_L) and pl < lastPP_L and not na(rsiPl) and rsiPl > lastRP_L
            div := "BULLISH DIV"
        lastPP_L := pl
        lastRP_L := not na(rsiPl) ? rsiPl : lastRP_L
    [rsiVal, div]

// ==========================================
// 5. MAIN CALCULATIONS (OPTIMIZED)
// ==========================================

// Global Indicators
var float g_atr5 = 0.0
var float g_atr20 = 0.0
g_atr5 := ta.atr(5)
g_atr20 := ta.atr(20)

// 1. WEEKLY SUPER BUNDLE (Includes Stage Logic Check)
[_stageID_val, _stageStart_val, _wSlopeVal, _wMAVal] = request.security(syminfo.tickerid, "W", f_getStageAndTime(maLengthW, wmaSlopeLen, slopeThresh), ignore_invalid_symbol=true)

stageID := _stageID_val
wMA30 := _wMAVal
wMA40 := request.security(syminfo.tickerid, "W", ta.sma(close, 40), ignore_invalid_symbol=true)
wClose := request.security(syminfo.tickerid, "W", close, ignore_invalid_symbol=true)

bool panicExit = close < wMA40

// Set Weekly Slope State Text
wMASlopeState := "FLAT"
if _wSlopeVal > (wMA30 * slopeThresh)
    wMASlopeState := "RISING"
else if _wSlopeVal < -(wMA30 * slopeThresh)
    wMASlopeState := "FALLING"

int msPerWeek = 604800000
int timeDiff = timenow - _stageStart_val
if timeDiff < 0 
    timeDiff := 0
int stageWeeks = math.ceil(timeDiff / msPerWeek)
if stageWeeks < 1 
    stageWeeks := 1

// 3. WEEKLY HEALTH PIVOT (1 Call)
// Replaced simple pivot check with Advanced f_weeklyHealth
[wh_str, wh_col] = request.security(syminfo.tickerid, "W", f_weeklyHealth(0.0), ignore_invalid_symbol=true)
wkHealthStr := wh_str
wkHealthCol := wh_col

// 4. DAILY SUPER BUNDLE
[d_c, d_h, d_l, d_o, d_v, d_vavg, d_sma50, d_sma150, d_sma200, d_slope50, d_ema20val, d_atr14, d_atr10, d_atr40, d_h20, d_l20, d_h52, d_hATH, d_rsiVal, d_h_fib, d_l_fib, d_adx_ok] = request.security(syminfo.tickerid, "D", 
     [close, high, low, open, volume, ta.sma(volume, 20),
      ta.sma(close, dma50_len), ta.sma(close, dma150_len), ta.sma(close, dma200_len),
      f_calc_slope_val(ta.sma(close, dma50_len), dmaSlopeLen),
      ta.ema(close, 20),
      ta.atr(14), ta.atr(10), ta.atr(40),
      ta.highest(high, 20), ta.lowest(low, 20),
      ta.highest(high, 252), ta.highest(high, 1250),
      ta.rsi(close, 14),
      ta.highest(high, fibLookback), ta.lowest(low, fibLookback), f_calc_adx_bool()], ignore_invalid_symbol=true)

dClose := d_c
dHigh := d_h
dLow := d_l
dMA50 := d_sma50
dMA200 := d_sma200
dailyRsi := d_rsiVal 
d_atr10_val := d_atr10
d_atr40_val := d_atr40
d_ema20_val := d_ema20val
d_vol := d_v
d_vol_avg := d_vavg
atrVal := d_atr14

// 5. RS BUNDLES (3 Calls) - CALCULATING RS STATE EARLY FOR USE IN STAGE LOGIC
// Auto-detect Sector (Overrides manual input if needed, or we can use manual as fallback)
// We will use the AUTO scanner as primary
var string autoSectorTick = ""
var string autoSectorName = ""
if barstate.isfirst
    [t, n] = f_get_hybrid_sector()
    autoSectorTick := t
    autoSectorName := n

// string autoSectorTick = bench500
// string autoSectorName = "DEBUG (Hybrid Disabled)"

[_slope50, _val50] = request.security(syminfo.tickerid, "W", f_calc_rs_logic(rsLength, rsSlopeLen), ignore_invalid_symbol=true) 
[_slope500, _val500] = request.security(syminfo.tickerid, "W", f_calc_rs_logic(rsLength, rsSlopeLen), ignore_invalid_symbol=true)
[_slopeSec, _valSec] = request.security(syminfo.tickerid, "W", f_calc_rs_logic(rsLength, rsSlopeLen), ignore_invalid_symbol=true)

// Fallback to Nifty 500 if no sector found
if autoSectorTick == ""
    autoSectorTick := bench500
    autoSectorName := "Nifty 500 (Default)"

// Safety Checks for Spreads
bool valid_b50 = str.length(bench50) > 1
bool valid_b500 = str.length(bench500) > 1
bool valid_sec = str.length(autoSectorTick) > 1

// Unconditional Security Calls (Compiler Warning Fix)
string req50 = valid_b50 ? (cleanTicker + " / " + bench50) : ""
[_s50, _v50] = request.security(req50, "W", f_calc_rs_logic(rsLength, rsSlopeLen), ignore_invalid_symbol=true)
_slope50 := na(_s50) ? 0.0 : _s50
_val50   := na(_v50) ? 0.0 : _v50

string req500 = valid_b500 ? (cleanTicker + " / " + bench500) : ""
[_s500, _v500] = request.security(req500, "W", f_calc_rs_logic(rsLength, rsSlopeLen), ignore_invalid_symbol=true)
_slope500 := na(_s500) ? 0.0 : _s500
_val500   := na(_v500) ? 0.0 : _v500

string reqSec = valid_sec ? (cleanTicker + " / " + autoSectorTick) : ""
[_sSec, _vSec] = request.security(reqSec, "W", f_calc_rs_logic(rsLength, rsSlopeLen), ignore_invalid_symbol=true)
_slopeSec := na(_sSec) ? 0.0 : _sSec
_valSec   := na(_vSec) ? 0.0 : _vSec

slope50 := _slope50
val50 := _val50
slope500 := _slope500
val500 := _val500
slopeSec := _slopeSec
valSec := _valSec

// Use Revised Naming: Leading / Stabilizing / Weakening / Lagging
rs50State  := f_rsStateStr(slope50, val50, 0.02)
rs500State := f_rsStateStr(slope500, val500, 0.02)
rsSecState := f_rsStateStr(slopeSec, valSec, 0.02)

// ==========================================
// 5.5 REFINED MARKET STRUCTURE (ACTIONABLE CONTEXT)
// ==========================================
// Focus: Describes the "Character" of the trend, not just the Definition.

bool d_bullish_200 = dClose > dMA200
bool rs_is_leading = rs50State == "Leading"

// Base Logic from Weekly Stage Calc
if stageID == "STAGE 2 (UP)"
    if d_bullish_200
        if rs_is_leading
            stageDisplay := "🚀 STAGE 2 (Full Confluence)" // Price, MA, and RS all Green
            stageCol := color.lime
        else
            stageDisplay := "⚠️ STAGE 2 (Weak Leadership)" // Price Up, but RS Lagging
            stageCol := color.orange
    else
        stageDisplay := "⚓ STAGE 2 (Value Zone)" // Weekly Up, Daily Cheap (Below 200)
        stageCol := color.aqua 
else if stageID == "STAGE 2 (PULLBACK)"
    stageDisplay := "⚓ STAGE 2 (Dip Opportunity)" // Rising MA, price dipped slightly
    stageCol := color.aqua
else if stageID == "STAGE 1 (BASE)"
    if d_bullish_200
        stageDisplay := "👀 STAGE 1 (Constructive)" // Base is maturing, reclaimed 200SMA
        stageCol := color.yellow
    else
        stageDisplay := "😴 STAGE 1 (Dormant)" // Below 200SMA, snoozing
        stageCol := color.gray
else if stageID == "STAGE 3 (TOP)"
    stageDisplay := "🛑 STAGE 3 (Volatile Churn)" // High Volatility, No Progress
    stageCol := color.orange
else if stageID == "STAGE 4 (DOWN)"
    stageDisplay := "🔻 STAGE 4 (Liquidate)" // Clear Downtrend
    stageCol := color.red
else
    stageDisplay := stageID // Fallback
    stageCol := color.gray

stageDisplay := stageDisplay + " (" + str.tostring(stageWeeks) + "w)"


// 6. TREND BUNDLES (2 Calls)
[_t_dTrendDir, _t_dLockH, _t_dLockL] = request.security(syminfo.tickerid, "D", f_getStrictTrend(high, low, pivotLeft, pivotRight), ignore_invalid_symbol=true)
dTrendDir := _t_dTrendDir
dLockH := _t_dLockH
dLockL := _t_dLockL

[_t_wTrendDir, _t_wLockH, _t_wLockL] = request.security(syminfo.tickerid, "W", f_getStrictTrend(high, low, 5, 5), ignore_invalid_symbol=true)
wTrendDir := _t_wTrendDir

_resistCount = request.security(syminfo.tickerid, "W", f_countOverheadResist(close), ignore_invalid_symbol=true)
resistCount := _resistCount

// 7. BENCHMARK BUNDLE (1 Call)
// Guard against empty bench500
if str.length(bench500) > 1
    [_b_c, _b_50, _b_200] = request.security(bench500, "D", [close, ta.sma(close, 50), ta.sma(close, 200)], ignore_invalid_symbol=true)
    if _b_c > _b_50 and _b_50 > _b_200
        mktState := "BULLISH (Confirmed)"
        mktColor := color.lime
    else if _b_c < _b_50 and _b_50 > _b_200 and _b_c > _b_200
        mktState := "CORRECTION (In Uptrend)"
        mktColor := color.yellow 
    else if _b_c > _b_50 and _b_50 < _b_200
        mktState := "RECOVERY (Weak)"
        mktColor := color.blue
    else
        mktState := "BEARISH"
        mktColor := color.red
else
    mktState := "N/A (No Bench)"
    mktColor := color.gray

// --- LOCAL LOGIC (ZERO CALLS) ---

d50SlopeState := "FLAT"
if d_slope50 > (d_sma50 * flatThresh)
    d50SlopeState := "RISING"
else if d_slope50 < -(d_sma50 * flatThresh)
    d50SlopeState := "FALLING"

bool dSmaAligned = (d_sma50 > d_sma150) and (d_sma150 > d_sma200)

// S/R Proximity
float distToRes = math.abs(close - d_h20) / close * 100
float distToSup = math.abs(close - d_l20) / close * 100

if distToRes < 2.0
    srState := "⚠️ NEAR RESISTANCE"
    srColor := color.orange
else if distToSup < 2.0
    srState := "✅ NEAR SUPPORT"
    srColor := color.green
else
    srState := "MID-RANGE"
    srColor := color.gray

// Price Action
if not na(dLockH) 
    if close > dLockH
        isBreakout := true
        paState := "BREAKOUT (Impulsive)"
        paColor := color.lime
    else if close < dLockH and close > (dLockH * 0.95)
        paState := "CONSOLIDATION (Tight)"
        paColor := color.blue
    else if close > open and (close - low) > (high - close) * 3
        paState := "POWER PLAY (Strong Close)"
        paColor := color.green
    else if close < open and (high - close) > (close - low) * 3
        paState := "SELLING TAIL (Rejection)"
        paColor := color.orange
    else if (high - low) < (atrVal * 0.5)
        paState := "NR7 (Coiling)"
        paColor := color.yellow
    else
        paState := "NORMAL"
        paColor := color.gray

// Volume
float curRelVol = d_v / d_vavg
string curVolStr = str.tostring(curRelVol, "#.1") + "x"
volState := "NORMAL (" + curVolStr + ")"
if curRelVol > 1.5
    if d_c > d_c[1]
        volState := "ACCUMULATION (" + curVolStr + ")"
        volColor := color.green
    else
        volState := "DISTRIBUTION (" + curVolStr + ")"
        volColor := color.red
else if curRelVol < 0.7
    volState := "DRY UP (" + curVolStr + ")"
    volColor := color.yellow

// Volatility
bool isContraction = d_atr10_val < (d_atr40_val * 0.75) 
bool isExpansion = d_atr10_val > (d_atr40_val * 1.25)
patStr := "Normal Volatility"
if isContraction
    patStr := "VCP (Contraction)"
else if isExpansion
    patStr := "Vol Expansion"

// Highs
dev52 := ((close - d_h52) / d_h52) * 100
devATH := ((close - d_hATH) / d_hATH) * 100

// EMA Logic
d_ema20 := d_ema20val
isIntra := timeframe.isintraday
use_ema20 := isIntra ? d_ema20 : ta.ema(close, 20)
ema_lbl := isIntra ? "Price vs EMA20 (Daily)" : "Price vs EMA20 (Chart)"

if not na(use_ema20)
    emaDist := (close - use_ema20) / close * 100
    absDist := math.abs(emaDist)
    if high > use_ema20 and close < use_ema20
        emaState := "RESISTANCE (Hit Head)"
        emaColor := color.red
    else if low < use_ema20 and close > use_ema20
        emaState := "SUPPORT (Bounced)"
        emaColor := color.green
    else if absDist < 1.0
        emaState := "NEAR (" + str.tostring(emaDist, "#.1") + "%)"
        emaColor := color.blue
    else if close > use_ema20
        emaState := "PRICE ABOVE" 
        emaColor := color.green
    else
        emaState := "PRICE BELOW"
        emaColor := color.red

// Earnings
earningsNext = earnings.future_time 
if not na(earningsNext)
    earnStr := str.format_time(earningsNext, "dd-MMM")
    float msPerDay = 1000 * 60 * 60 * 24
    float daysToEarn = (earningsNext - timenow) / msPerDay
    if daysToEarn > 0 and daysToEarn <= 5
        earnStr := "⚠️ " + earnStr + " (<5 Days!)"
        earnColor := color.red
    else
        earnColor := color.gray

[_currRsi, _currRsiDiv] = f_rsi_div(close, 14, 5, 5)
currRsi := _currRsi
currRsiDiv := _currRsiDiv

bool isSqueeze = g_atr5 < (g_atr20 * 0.60)
if isSqueeze
    volState := "VOLATILITY SQUEEZE (Ready)"
    volColor := color.blue

// Score
score := 0
if stageID == "STAGE 2 (UP)"
    score += 30
else if stageID == "STAGE 1 (BASE)"
    score += 10
if rs50State == "Leading"
    score += 20
if d50SlopeState == "RISING" and dSmaAligned
    score += 20
else if d50SlopeState == "RISING"
    score += 10
if str.contains(volState, "ACCUM") or isSqueeze
    score += 15
if dailyRsi > 50 and dailyRsi < 70
    score += 5
float distToDailyEma = math.abs((close - d_ema20_val) / close * 100)
if distToDailyEma < 2.0 
    score += 15 

if score >= 80
    grade := "A+ (Excellent)"
    gradeCol := color.lime
else if score >= 60
    grade := "B (Good)"
    gradeCol := color.yellow
else
    grade := "C (Weak)"
    gradeCol := color.orange
scoreStr := str.tostring(score) + "/100 [" + grade + "]"

// RECOMMENDATION
recText := "WAIT / NEUTRAL"
recColor := color.gray

bool isStage2 = (stageID == "STAGE 2 (UP)")
bool isUptrend = (dTrendDir == 1)
bool isRsStrong = str.contains(rs50State, "Leading") or (str.contains(rs50State, "Rising") and not str.contains(rs50State, "Falling"))

if isStage2 and isUptrend and isRsStrong
    if str.contains(mktState, "BEARISH")
        recText := "WAIT (Mkt Bearish)"
        recColor := color.orange
    else
        recText := "STRONG BUY (Momentum)"
        recColor := color.lime
else if isStage2 and isUptrend
    if str.contains(mktState, "BEARISH")
        recText := "WAIT (Mkt Bearish)"
        recColor := color.orange
    else
        recText := "BUY (Check RS)"
        recColor := color.green
else if isStage2 and dTrendDir == 0
    recText := "HOLD (Consolidation)"
    recColor := color.blue
else if stageID == "STAGE 1 (BASE)"
    recText := "WATCHLIST (Base Building)"
    recColor := color.yellow
else if stageID == "STAGE 4 (DOWN)"
    recText := "AVOID (Stage 4)"
    recColor := color.red
else if currRsiDiv == "BEARISH DIV"
    recText := "CAUTION (Divergence)"
    recColor := color.orange
else if dTrendDir == -1
    recText := "NO TRADE (Downtrend)"
    recColor := color.red


// Logic for New Signal Detection
bool signalStrongBuy = (stageID == "STAGE 2 (UP)" and dTrendDir == 1 and str.contains(rs50State, "Leading"))
bool signalBuy       = (stageID == "STAGE 2 (UP)" and dTrendDir == 1)

newStrongBuy := signalStrongBuy and not signalStrongBuy[1]
newBuy       := signalBuy and not signalBuy[1] and not signalStrongBuy // Avoid double labeling
bool newBreakout  = isBreakout and not isBreakout[1]

// Pullback Logic (Restored)
// Extracting highest/lowest to global scope for consistency
float h20 = ta.highest(high, 20)
float l20 = ta.lowest(low, 20)
float hFib = ta.highest(high, fibLookback)
float lFib = ta.lowest(low, fibLookback)

bool hitPullback = false
if (d_l_fib > 0)
    // d_l_fib is serving as our generic 'level' holder in this scope, or we use Smart Fib
    // Let's use the 'smart_fib' calculated below if possible, but we need it here.
    // Re-calculating simple Pullback Trigger based on recent High:
    float _est_pb = h20 - ((h20 - l20) * 0.5)
    if low <= _est_pb and high >= _est_pb
        hitPullback := true

if markFresh and (newStrongBuy or newBuy)
    displayRec := "★ " + recText
else
    displayRec := recText

// PLOTTING SIGNALS
plotshape(showSignals and newStrongBuy, title="Strong Buy Signal", style=shape.labelup, location=location.belowbar, color=color.lime, textcolor=color.black, text="★", size=size.small)
plotshape(showSignals and newBuy,       title="Buy Signal",        style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, text="B", size=size.tiny)
plotshape(showSignals and newBreakout,  title="Breakout Signal",   style=shape.triangleup, location=location.belowbar, color=color.blue, size=size.tiny)
plotshape(showSignals and hitPullback,  title="Pullback Hit",      style=shape.circle, location=location.belowbar, color=color.new(color.purple, 20), size=size.small)


if panicExit
    displayRec := "EXIT NOW (40WMA Break)"
    recColor := color.red

// ==========================================
// FIX: DYNAMIC FIB LOOKBACK (21 Bars)
// ==========================================
float smart_fib = na
float smart_ema_pb = na

// Use user-defined 'fibLookback' (Default 21)
if timeframe.isintraday
    // Intraday: Daily High/Low (Fetched in Bundle)
    smart_fib := d_h_fib - ((d_h_fib - d_l_fib) * 0.5)
    smart_ema_pb := d_ema20val
else
    // Chart: High/Low of last 'fibLookback' bars
    smart_fib := hFib - ((hFib - lFib) * 0.5)
    smart_ema_pb := ta.ema(close, 20)

pbText := "EMA20: " + str.tostring(smart_ema_pb, "#.##")
if smart_fib > 0
    pbText := pbText + " | Fib: " + str.tostring(smart_fib, "#.##")
pbColor := color.blue

// Define highest20 for Trade Manager
float highest20 = h20

// Trade Manager
if quick_ent > 0
    finalEntry := quick_ent
    finalSL    := quick_sl
else if f_match(p1_tick)
    finalEntry := p1_ent
    finalSL := p1_sl
else if f_match(p2_tick)
    finalEntry := p2_ent
    finalSL := p2_sl
else if f_match(p3_tick)
    finalEntry := p3_ent
    finalSL := p3_sl
else if f_match(p4_tick)
    finalEntry := p4_ent
    finalSL := p4_sl
else if f_match(p5_tick)
    finalEntry := p5_ent
    finalSL := p5_sl
else if f_match(p6_tick)
    finalEntry := p6_ent
    finalSL := p6_sl
else if f_match(p7_tick)
    finalEntry := p7_ent
    finalSL := p7_sl
else if f_match(p8_tick)
    finalEntry := p8_ent
    finalSL := p8_sl
else if f_match(p9_tick)
    finalEntry := p9_ent
    finalSL := p9_sl
else if f_match(p10_tick)
    finalEntry := p10_ent
    finalSL := p10_sl
else if f_match(p11_tick)
    finalEntry := p11_ent
    finalSL := p11_sl
else if f_match(p12_tick)
    finalEntry := p12_ent
    finalSL := p12_sl
else if f_match(p13_tick)
    finalEntry := p13_ent
    finalSL := p13_sl
else if f_match(p14_tick)
    finalEntry := p14_ent
    finalSL := p14_sl
else if f_match(p15_tick)
    finalEntry := p15_ent
    finalSL := p15_sl
else if f_match(p16_tick)
    finalEntry := p16_ent
    finalSL := p16_sl
else if f_match(p17_tick)
    finalEntry := p17_ent
    finalSL := p17_sl
else if f_match(p18_tick)
    finalEntry := p18_ent
    finalSL := p18_sl
else if f_match(p19_tick)
    finalEntry := p19_ent
    finalSL := p19_sl
else if f_match(p20_tick)
    finalEntry := p20_ent
    finalSL := p20_sl
else if f_match(p21_tick)
    finalEntry := p21_ent
    finalSL := p21_sl
else if f_match(p22_tick)
    finalEntry := p22_ent
    finalSL := p22_sl
else if f_match(p23_tick)
    finalEntry := p23_ent
    finalSL := p23_sl
else if f_match(p24_tick)
    finalEntry := p24_ent
    finalSL := p24_sl
else if f_match(p25_tick)
    finalEntry := p25_ent
    finalSL := p25_sl

tradeActive = finalEntry > 0

if tradeActive
    // --- ADAPTIVE TSL LOGIC ---
    float riskPerShare = finalEntry - finalSL
    float currentProfitPerShare = close - finalEntry
    float currentR = 0.0
    
    // Calculate current R-Multiple
    if riskPerShare > 0
        currentR := currentProfitPerShare / riskPerShare
        rrText := "1 : " + str.tostring(math.abs(riskPerShare*2)/riskPerShare, "#.1") // Keep original RR display logic or simplfy
    
    // Determine Dynamic Multiplier
    float dynamicMult = tslMult
    
    // 2-Stage Ratchet
    if currentR >= tsl_r_trig2
        dynamicMult := tslMult * tsl_ratio2 // Stage 2: Super Tight
    else if currentR >= tsl_r_trig
        dynamicMult := tslMult * tsl_ratio // Stage 1: Tight
        
    // Calculate TSL with Dynamic Multiplier
    tm_tsl := highest20 - (atrVal * dynamicMult)
    
    effectiveSL := math.max(finalSL, tm_tsl)
    // ---------------------------
    
    float curPnL = ((close - finalEntry) / finalEntry) * 100
    string pnlStr = (curPnL > 0 ? "+" : "") + str.tostring(curPnL, "#.2") + "%"
    
    if close < effectiveSL
        tradeStatus := "⚠️ STOP HIT (" + pnlStr + ")"
        tradeColor := color.red
    else if curPnL > 0
        // SCALE IN / TRIM LOGIC
        bool cond_add = dTrendDir == 1 and dailyRsi < 70 and close > use_ema20 and not isSqueeze // Don't add inside a squeeze, wait for pop
        bool cond_trim = dailyRsi > 75 or absDist > 15.0 or (not na(earningsNext) and (earningsNext - timenow) / 86400000 < 3)
        
        if cond_trim
            tradeStatus := "TRIM (" + pnlStr + ")"
            tradeColor := color.fuchsia
        else if cond_add
            tradeStatus := "SCALE IN (" + pnlStr + ")"
            tradeColor := color.blue
        else
            tradeStatus := "HOLD (" + pnlStr + ")"
            tradeColor := color.green
    else
        tradeStatus := "HOLD (" + pnlStr + ")"
        tradeColor := color.orange
        
    // Old line.new logic removed in favor of plot() calls at the end of script for better persistence

// ==========================================
// Gemini Prompt Logic moved to end of script

// ==========================================
// NEW: PRICE ACTION CONFLUENCE (5-STAR)
// ==========================================
// 1. Trend: Above EMA 20
bool c_trend = close > d_ema20_val
// 2. Momentum: RSI > 50 (Bullish)
bool c_mom = dailyRsi > 50
// 3. Volume Action: 
// Breakout -> Needs Vol Expansion (Vol > Avg)
// Pullback -> Needs Vol Contraction (Vol < Avg)
bool c_vol = false
if close > open
    c_vol := d_vol > d_vol_avg // Demand coming in
else
    c_vol := d_vol < d_vol_avg // Supply drying up

// 4. ADX Check
bool c_adx = d_adx_ok

// 4. Volume Profile (Basic POC Estimate)
// Using highest volume bar in last 'vpLookback' as a proxy for POC
int poc_idx = 0
float max_v = 0.0
for i = 0 to vpLookback - 1
    if volume[i] > max_v
        max_v := volume[i]
        poc_idx := i
float poc_level = high[poc_idx] // Approximate Value Area High of that bar
bool c_vp = close > poc_level

// 5. Price Action: Bullish Candle
bool c_pa = close > open

int conf_score = 0
if c_trend 
    conf_score += 1
if c_mom 
    conf_score += 1
if c_vol 
    conf_score += 1
if c_vp 
    conf_score += 1
if c_pa 
    conf_score += 1
if c_adx
    conf_score += 1

string conf_stars = ""
if conf_score == 5
    conf_stars := "★★★★★ (Perfect)"
else if conf_score == 4
    conf_stars := "★★★★ (Strong)"
else if conf_score == 3
    conf_stars := "★★★ (Moderate)"
else
    conf_stars := "★ (Weak)"

color conf_col = conf_score >= 4 ? color.lime : (conf_score == 3 ? color.yellow : color.gray)

// ==========================================
// WATCHLIST SCANNER (Top Picks + Alerts)
// ==========================================
string alert_msg = ""
string top_picks_msg = ""

// Helper to check Confluence (4 or 5 stars)
f_check_conf(float c, float o, float ema, float rsi, float v, float va, bool adx_ok) =>
    int _score = 0
    if not na(c)
        if c > ema 
            _score += 1
        if rsi > 50 
            _score += 1
        if (c > o and v > va) or (c < o and v < va)
            _score += 1
        // Simplified VP check for scanner (Price > EMA is strong proxy for value)
        if c > ema 
            _score += 1
        if c > o 
            _score += 1
        if adx_ok
            _score += 1
    _score >= 4 // Returns true if 4+ stars

// Helper to calc health (1=profit, 2=hold, 3=stop) from raw data
f_calc_h(float c, float e, float s) =>
    int r = 0
    if not na(c) and e > 0 // Only count if Entry Price is set
        // Fix: Implied 10% Stop if SL is 0.0
        float effective_stop = s > 0 ? s : (e * 0.90)
        
        if c < effective_stop
            r := 3
        else if c > e
            r := 1
        else
            r := 2
    r

// Helper to check cross from raw data
f_check_x(float c, float c1, float e, float e1) =>
    bool x = false
    if not na(c) and not na(e)
        x := c > e and c1 <= e1
    x

f_process_slot(string t, float ent, float sl) =>
    string a_msg = ""
    string tp_msg = ""
    int h_val = 0
    
    // Get Data
    [c, cp, e, ep, r, v, va, adx_ok] = f_get_screener_data(t)
    
    // Health
    h_val := f_calc_h(c, ent, sl)
    
    // Alert Cross
    if f_check_x(c, cp, e, ep)
        a_msg := t + ", "
        
    // Top Pick Confluence
    if f_check_conf(c, cp, e, r, v, va, adx_ok)
        tp_msg := str.replace(t, "NSE:", "") + " "
        
    [h_val, a_msg, tp_msg]

