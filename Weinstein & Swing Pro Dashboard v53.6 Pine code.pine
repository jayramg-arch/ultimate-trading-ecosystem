// ==========================================
var table panel = table.new(tablePos, 2, 50, border_width=1, border_color=color.gray)

drawRow(tbl, r, title, valText, valColor, cellBg, titleColor, valTextColor) =>
    table.cell(tbl, 0, r, title, bgcolor=cellBg, text_color=titleColor, text_size=textSize, text_halign=text.align_left)
    table.cell(tbl, 1, r, valText, bgcolor=valColor, text_color=valTextColor, text_size=textSize, text_halign=text.align_center)

if barstate.islast
    table.cell(panel, 0, 0, "WEINSTEIN DASHBOARD", bgcolor=c_bg, text_color=c_text, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, 0, syminfo.ticker, bgcolor=c_bg, text_color=c_text, text_size=size.normal, text_halign=text.align_center)
    
    int startRow = 1
    
    if panicExit
        drawRow(panel, startRow, "⚠️ CRITICAL ALERT", "PRICE < 40WMA", color.red, c_bg, c_text, color.white)
        startRow += 1

    string secStr = syminfo.sector + " / " + syminfo.industry
    drawRow(panel, startRow, "Sector Info", secStr, color.gray, c_bg, c_text, c_val_text)
    startRow += 1
    
    drawRow(panel, startRow, "SETUP GRADE", scoreStr, gradeCol, c_bg, c_text, c_val_text)
    startRow += 1
    
    drawRow(panel, startRow, "CONFLUENCE RATING", conf_stars, conf_col, c_bg, c_text, color.black)
    startRow += 1
    
    drawRow(panel, startRow, "PORTFOLIO HEALTH", pfStr, pfCol, c_bg, c_text, c_val_text)
    startRow += 1
    
    if tradeActive
        drawRow(panel, startRow, "MY TRADE", tradeStatus, tradeColor, c_bg, c_text, c_val_text)
        startRow += 1
        if finalSL > 0
            drawRow(panel, startRow, "Planned R:R", rrText, color.gray, c_bg, c_text, c_val_text)
            startRow += 1
    
    drawRow(panel, startRow, "1. Market Health (Nifty 500)", mktState, mktColor, c_bg, c_text, c_val_text)
    startRow += 1

    // RRG Row Removed - Logic Integrated below

    drawRow(panel, startRow, "2. Market Structure", stageDisplay, stageCol, c_bg, c_text, c_val_text)
    startRow += 1
    
    // ENHANCED RS ROWS with RRG Visuals
    drawRow(panel, startRow, "3. RS State (Nifty 50)", f_rrg_icon(rs50State) + " " + rs50State, f_rrg_color(rs50State), c_bg, c_text, color.black)
    startRow += 1
    drawRow(panel, startRow, "4. RS State (Nifty 500)", f_rrg_icon(rs500State) + " " + rs500State, f_rrg_color(rs500State), c_bg, c_text, color.black)
    startRow += 1
    drawRow(panel, startRow, "5. RS State (" + autoSectorName + ")", f_rrg_icon(rsSecState) + " " + rsSecState, f_rrg_color(rsSecState), c_bg, c_text, color.black)
    startRow += 1

    drawRow(panel, startRow, "6. 30W MA Slope (3M)", wMASlopeState, wMASlopeState == "RISING" ? color.green : (wMASlopeState == "FALLING" ? color.red : color.blue), c_bg, c_text, c_val_text)
    startRow += 1
    
    bool pAbove30 = wClose > wMA30
    drawRow(panel, startRow, "7. Price > 30W MA", pAbove30 ? "YES" : "NO", pAbove30 ? color.green : color.red, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "8. 50D MA Slope (3M)", d50SlopeState, d50SlopeState == "RISING" ? color.green : (d50SlopeState == "FALLING" ? color.red : color.blue), c_bg, c_text, c_val_text)
    startRow += 1
    
    bool pAbove50 = dClose > dMA50
    drawRow(panel, startRow, "9. Price > 50D MA", pAbove50 ? "YES" : "NO", pAbove50 ? color.green : color.red, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "10. SMA 50 > 150 > 200", dSmaAligned ? "YES" : "NO", dSmaAligned ? color.green : color.red, c_bg, c_text, c_val_text)
    startRow += 1
    
    drawRow(panel, startRow, "11. Price Action Status", paState, paColor, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "12. O/H Resistance (>Price)", str.tostring(resistCount) + " Level(s)", resistCount == 0 ? color.green : color.orange, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "13. " + ema_lbl, emaState, emaColor, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "14. Volume Trend", volState, volColor, c_bg, c_text, c_val_text)
    startRow += 1
    
    drawRow(panel, startRow, "15. Next Earnings", earnStr, earnColor, c_bg, c_text, c_val_text)
    startRow += 1
    string rsiStr = str.tostring(currRsi, "#.##") + " / " + currRsiDiv
    drawRow(panel, startRow, "16. RSI (Chart) & Div", rsiStr, currRsiDiv == "BULLISH DIV" ? color.green : (currRsiDiv == "BEARISH DIV" ? color.red : color.gray), c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "17. ATR (Daily)", str.tostring(atrVal, "#.##"), color.gray, c_bg, c_text, c_val_text)
    startRow += 1
    string athStr = na(devATH) ? "N/A" : str.tostring(devATH, "#.1") + "%"
    drawRow(panel, startRow, "18. Near 52W High", str.tostring(dev52, "#.1") + "%", dev52 > -15 ? color.green : color.gray, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "19. Near ATH", athStr, (not na(devATH) and devATH > -15) ? color.green : color.gray, c_bg, c_text, c_val_text)
    startRow += 1
    
    table.cell(panel, 0, startRow, "--- TRENDS ---", bgcolor=c_bg, text_color=c_text, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, startRow, "", bgcolor=c_bg, text_color=c_text, text_size=size.normal)
    startRow += 1
    
    drawRow(panel, startRow, "Weekly Trend", f_trendText(wTrendDir), f_trendColor(wTrendDir), c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "Daily Trend", f_trendText(dTrendDir), f_trendColor(dTrendDir), c_bg, c_text, c_val_text)
    startRow += 1
    
    // NEW ROWS
    drawRow(panel, startRow, "S/R Proximity (20D)", srState, srColor, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "Volatility State", patStr, color.gray, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "Weekly Pullback Health", wkHealthStr, wkHealthCol, c_bg, c_text, c_val_text)
    startRow += 1

    table.cell(panel, 0, startRow, "--- SUMMARY ---", bgcolor=c_bg, text_color=c_text, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, startRow, "", bgcolor=c_bg, text_color=c_text, text_size=size.normal)
    startRow += 1

    drawRow(panel, startRow, "Est. Pullback Lvl", pbText, pbColor, c_bg, c_text, c_val_text)
    startRow += 1
    drawRow(panel, startRow, "RECOMMENDATION", displayRec, recColor, c_bg, c_text, c_val_text)
    startRow += 1
    
    // Portfolio Top Picks Removed as per user request

plot(wMA30, "30W MA", color=wMASlopeState == "RISING" ? color.green : color.red, linewidth=2)
plot(wMA40, "40W MA", color=color.black, linewidth=1)

// ==========================================
// TRADE LINES & LABELS (v20.0 Logic Ported)
// ==========================================

// Helper for Distance %
f_dist(float lvl) =>
    float d = ((lvl - close) / close) * 100
    string s = (d > 0 ? "+" : "") + str.tostring(d, "#.1") + "%"
    s

// Target Logic (2R and 3R as per v20.0)
float risk_per_share = finalEntry - finalSL
float t1_val = finalEntry + (risk_per_share * 2)
float t2_val = finalEntry + (risk_per_share * 3)

// PLOTS (Continuous Lines for History)
plot(showTrade and tradeActive ? finalEntry : na, "Entry Price", color=color.new(color.blue, 0), style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 ? finalSL : na, "Hard SL", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 ? t1_val : na, "Target 1 (2R)", color=color.new(color.green, 30), style=plot.style_linebr, linewidth=1)
plot(showTrade and tradeActive and finalSL > 0 ? t2_val : na, "Target 2 (3R)", color=color.new(color.green, 50), style=plot.style_linebr, linewidth=1)

// DOTS for Trailing SL
plot(showTrade and tradeActive and tm_tsl > finalSL ? tm_tsl : na, "Trailing SL", color=color.yellow, style=plot.style_circles, linewidth=2)

// LABELS (Last Bar Only - v20.0 Style)
if barstate.islast and showTrade and tradeActive
    // Entry Label
    label.new(bar_index + 12, finalEntry, "Avg. Entry: " + str.tostring(finalEntry), color=color.blue, style=label.style_none, textcolor=color.blue, size=size.small)
    
    // SL & Targets Labels with Distance
    // SL & Targets Labels with Distance
    if finalSL > 0
        string slDist = showDist ? ", " + f_dist(finalSL) : ""
        label.new(bar_index + 12, finalSL, "Hard SL: " + str.tostring(finalSL) + slDist, color=color.red, style=label.style_none, textcolor=color.red, size=size.small)
        
        string t1Dist = showDist ? ", " + f_dist(t1_val) : ""
        label.new(bar_index + 12, t1_val, "Target 1: " + str.tostring(t1_val) + t1Dist, color=color.green, style=label.style_none, textcolor=color.green, size=size.small)
        
        string t2Dist = showDist ? ", " + f_dist(t2_val) : ""
        label.new(bar_index + 12, t2_val, "Target 2: " + str.tostring(t2_val) + t2Dist, color=color.green, style=label.style_none, textcolor=color.lime, size=size.small)
    
    // Trailing SL Label
    if tm_tsl > finalSL
        string tslDist = showDist ? ", " + f_dist(tm_tsl) : ""
        label.new(bar_index + 12, tm_tsl, "TSL: " + str.tostring(tm_tsl) + tslDist, color=color.yellow, style=label.style_none, textcolor=color.yellow, size=size.small)

