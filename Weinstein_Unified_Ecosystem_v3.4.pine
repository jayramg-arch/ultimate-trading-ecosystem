// <DB_LOOKUP_END>

// HYBRID SECTOR LOOKUP (DB first, keyword auto-mapper fallback)
f_get_hybrid_sector() =>
    string __clean_t = str.replace_all(str.upper(str.trim(syminfo.ticker)), "NSE:", "")
    __clean_t := str.replace_all(__clean_t, "BSE:", "")
    string dbSec = f_db_sector_lookup(__clean_t)
    string t = ""
    if dbSec != ""
        t := dbSec
    else
        [_at, _] = f_get_sector_ticker()  // tuple [ticker, name] — only need ticker
        t := _at
    t


// ==========================================
// 7. DATA CALCULATIONS (SECURITY CALLS)
// ==========================================
// Market Health
[_mkt_close, _mkt_sma50, _mkt_sma200, _mkt_52w, _mkt_recent_low, _mkt_prior_low] = request.security("NSE:CNX500", "D", f_get_mkt_bundle(), lookahead=barmerge.lookahead_off)
bool mkt_bull = not na(_mkt_close) and not na(_mkt_sma200) and (_mkt_close > _mkt_sma50) and (_mkt_sma50 > _mkt_sma200)
float mkt_corr_depth = not na(_mkt_52w) and _mkt_52w > 0 ? (_mkt_52w - _mkt_close) / _mkt_52w : 0.0
bool  mkt_idx_corrected = mkt_corr_depth >= 0.07
bool  mkt_reclaim       = not na(_mkt_recent_low) and not na(_mkt_prior_low) and _mkt_recent_low > _mkt_prior_low
bool mkt_in_recovery = mkt_idx_corrected and mkt_reclaim

// Stock Weekly Stage
[wClose, wMA30, wSlope, wTrend, wRSI, current_stage, wEarlyStage2, wStageWks, wClose5wAgo] = request.security(syminfo.tickerid, "W", f_get_weekly_bundle(maLengthW, wSlopeLen, piv_w_left, piv_w_right, slopeThresh), lookahead=barmerge.lookahead_off)

// Sector Weekly Stage — resolved via full Nifty-500 DB + keyword fallback
var string sectorTicker = use_auto_sec ? f_get_hybrid_sector() : manualSector
[_sc, _sm, _ss, _st, _sr, _sec_stage_raw, _, _secStageWks, _] = request.security(sectorTicker, "W", f_get_weekly_bundle(maLengthW, wSlopeLen, piv_w_left, piv_w_right, slopeThresh), lookahead=barmerge.lookahead_off)
int _sec_stage = _sec_stage_raw
bool sector_stage_ok = not use_sector_filter or (_sec_stage == 1 or _sec_stage == 2)

// v2.9: JdK RS engine (parity with Dashboard + Bull Screener). 5-tuple now.
// B13: strip pre-existing "NSE:" prefix to avoid double-prefix on ratio symbol.
string _rs_ticker_clean = str.replace_all(str.upper(syminfo.ticker), "NSE:", "")
[rsVal500, rsSlope500, rs_momentum, _rsValTrail500, _rsMomTrail500] = request.security("NSE:" + _rs_ticker_clean + " / " + bench500, "W", f_rs_math(), barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)
[_rrg_arrow, _rrg_traj, rs_quadrant, _rrg_next, rs_rrg_score, rs_tradeable] = f_rrg_info(rsVal500, rs_momentum, _rsValTrail500, _rsMomTrail500)
// v3.4.1 (2026-06-08): align REV-RS / REV-EARLY RS gate to the Pine Screeners +
// Python canonical. Both gate on RS-Ratio LEVEL (Mansfield>0 / rs_val>0), NOT the
// legacy 4-week slope. rsVal500 = JdK RS-Ratio centered to 0 (right half of RRG =
// LEADING/WEAKENING). Was rsSlope500>0 (momentum, top half) — that drift made the
// chart block names the screeners fired (e.g. WEAKENING-quadrant leaders).
bool rs_positive = rsVal500 > 0

// Daily Indicators (MTF Safety)
[req_ema20, req_sma50, req_sma150, req_sma200, req_atr14] = request.security(syminfo.tickerid, "D", f_get_daily_indicators(ema20_len, atr_length), lookahead=barmerge.lookahead_off)

// CPR & VWAP
[d_pivot, d_bc, d_tc] = request.security(syminfo.tickerid, "D", f_get_cpr(), lookahead=barmerge.lookahead_off)
m_vwap = request.security(syminfo.tickerid, "D", f_get_mvwap(), lookahead=barmerge.lookahead_off)

// RFF Data — FY (annual) primary; E9 adds optional FQ fallback for sparse listings
float rff_ni_fy       = request.financial(syminfo.tickerid, "NET_INCOME",                    "FY", ignore_invalid_symbol=true)
float rff_ocf_fy      = request.financial(syminfo.tickerid, "CASH_F_OPERATING_ACTIVITIES",   "FY", ignore_invalid_symbol=true)
float rff_capex_fy    = request.financial(syminfo.tickerid, "CAPITAL_EXPENDITURES",           "FY", ignore_invalid_symbol=true)
float rff_ebitda_fy   = request.financial(syminfo.tickerid, "EBITDA",                         "FY", ignore_invalid_symbol=true)
float rff_interest_fy = request.financial(syminfo.tickerid, "INTEREST_EXPENSE",               "FY", ignore_invalid_symbol=true)
float rff_debt_fy     = request.financial(syminfo.tickerid, "TOTAL_DEBT",                     "FY", ignore_invalid_symbol=true)
float rff_equity_fy   = request.financial(syminfo.tickerid, "TOTAL_EQUITY",                   "FY", ignore_invalid_symbol=true)
float rff_ca_fy       = request.financial(syminfo.tickerid, "CURRENT_ASSETS",                 "FY", ignore_invalid_symbol=true)
float rff_cl_fy       = request.financial(syminfo.tickerid, "CURRENT_LIABILITIES",            "FY", ignore_invalid_symbol=true)
float rff_ta_fy       = request.financial(syminfo.tickerid, "TOTAL_ASSETS",                   "FY", ignore_invalid_symbol=true)

// E9: FQ fallback queries (only used when use_rff_fq_fallback is ON and the FY value is na)
float rff_ni_fq       = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "NET_INCOME",                    "FQ", ignore_invalid_symbol=true) : na
float rff_ocf_fq      = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "CASH_F_OPERATING_ACTIVITIES",   "FQ", ignore_invalid_symbol=true) : na
float rff_capex_fq    = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "CAPITAL_EXPENDITURES",           "FQ", ignore_invalid_symbol=true) : na
float rff_ebitda_fq   = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "EBITDA",                         "FQ", ignore_invalid_symbol=true) : na
float rff_interest_fq = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "INTEREST_EXPENSE",               "FQ", ignore_invalid_symbol=true) : na
float rff_debt_fq     = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "TOTAL_DEBT",                     "FQ", ignore_invalid_symbol=true) : na
float rff_equity_fq   = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "TOTAL_EQUITY",                   "FQ", ignore_invalid_symbol=true) : na
float rff_ca_fq       = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "CURRENT_ASSETS",                 "FQ", ignore_invalid_symbol=true) : na
float rff_cl_fq       = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "CURRENT_LIABILITIES",            "FQ", ignore_invalid_symbol=true) : na
float rff_ta_fq       = use_rff_fq_fallback ? request.financial(syminfo.tickerid, "TOTAL_ASSETS",                   "FQ", ignore_invalid_symbol=true) : na

float rff_ni       = na(rff_ni_fy)       ? rff_ni_fq       : rff_ni_fy
float rff_ocf      = na(rff_ocf_fy)      ? rff_ocf_fq      : rff_ocf_fy
float rff_capex    = na(rff_capex_fy)    ? rff_capex_fq    : rff_capex_fy
float rff_ebitda   = na(rff_ebitda_fy)   ? rff_ebitda_fq   : rff_ebitda_fy
float rff_interest = na(rff_interest_fy) ? rff_interest_fq : rff_interest_fy
float rff_debt     = na(rff_debt_fy)     ? rff_debt_fq     : rff_debt_fy
float rff_equity   = na(rff_equity_fy)   ? rff_equity_fq   : rff_equity_fy
float rff_ca       = na(rff_ca_fy)       ? rff_ca_fq       : rff_ca_fy
float rff_cl       = na(rff_cl_fy)       ? rff_cl_fq       : rff_cl_fy
float rff_ta       = na(rff_ta_fy)       ? rff_ta_fq       : rff_ta_fy
// Count how many raw fields have data (guard against all-na situation)
int rff_data_fields = (na(rff_ni) ? 0 : 1) + (na(rff_ocf) ? 0 : 1) + (na(rff_ebitda) ? 0 : 1) + (na(rff_debt) ? 0 : 1) + (na(rff_ca) ? 0 : 1) + (na(rff_ta) ? 0 : 1)
bool rff_has_data = rff_data_fields >= 3

int rff_score = 0
if not na(rff_ni) and rff_ni > 0
    rff_score += 1
float rff_fcf = nz(rff_ocf, 0.0) - math.abs(nz(rff_capex, 0.0))
if not na(rff_ocf) and rff_fcf > 0
    rff_score += 1
float rff_icr_val = (not na(rff_ebitda) and not na(rff_interest) and rff_interest > 0) ? (rff_ebitda / rff_interest) : na
if not na(rff_icr_val) and rff_icr_val > 3.5
    rff_score += 1
float rff_de_val = (not na(rff_debt) and not na(rff_equity) and rff_equity > 0) ? (rff_debt / rff_equity) : na
if not na(rff_de_val) and rff_de_val < 2.0
    rff_score += 1
float rff_cr_val = (not na(rff_ca) and not na(rff_cl) and rff_cl > 0) ? (rff_ca / rff_cl) : na
if not na(rff_cr_val) and rff_cr_val > 1.0
    rff_score += 1
float rff_roa_val = (not na(rff_ni) and not na(rff_ta) and rff_ta > 0) ? (rff_ni / rff_ta * 100.0) : na
if not na(rff_roa_val) and rff_roa_val > 5.0
    rff_score += 1

bool rff_ok = rff_min_score == 0 or rff_score >= rff_min_score
// ==========================================
// 8. INDICATORS & GLOBALS
// ==========================================
float d_ema20  = timeframe.isintraday ? req_ema20  : ta.ema(close, ema20_len)
float d_sma50  = timeframe.isintraday ? req_sma50  : ta.sma(close, 50)
float d_sma150 = timeframe.isintraday ? req_sma150 : ta.sma(close, 150)
float d_sma200 = timeframe.isintraday ? req_sma200 : ta.sma(close, 200)
float atr14    = timeframe.isintraday ? req_atr14  : ta.atr(atr_length)
float d_rsi    = ta.rsi(close, 14)
float vol_ma   = ta.sma(volume, vol_avg_len)
float vol_sma50_g = ta.sma(volume, 50)

float lowest_low_5  = ta.lowest(low, 5)
float lowest_low_10 = ta.lowest(low, 10)
float high52w       = ta.highest(high, 250)
float low52w        = ta.lowest(low, 250)
float bar_range     = high - low

bool stage1_base    = (current_stage == 1)
bool stage2_uptrend = (current_stage == 2)
bool stage3_top     = (current_stage == 3)
bool stage4_dntrend = (current_stage == 4)

[dTrend, _, _] = f_getStrictTrend(high, low, piv_d_left, piv_d_right)
bool trend_up  = dTrend == 1
bool in_date   = not use_date or (time >= start_date and time <= end_date)

// ==========================================
// 9. BULL MARKET STRATEGY LOGIC
// ==========================================
bool mpa_pass = close > d_sma150 and d_sma150 > d_sma200
bool micro_ok = not use_micro_edge or (close > d_pivot and close > m_vwap)
bool rs_ok    = not use_rs or rs_quadrant == "LEADING" or rs_quadrant == "IMPROVING"

// Calculate Alpha Score
bool adx_strong = ta.rma(math.max(ta.change(high), 0), 14) > ta.rma(math.max(-ta.change(low), 0), 14)
// v2.3: numeric ADX for v1 FINAL Hunter gate (adx_strong remains for alpha_score).
[_dp14, _dm14, adx_val] = ta.dmi(14, 14)
bool hunter_adx_ok = adx_val >= hunter_daily_adx_min
float alpha_score = f_calc_alpha_score(close, open, d_ema20, d_sma50, volume, vol_ma)
bool alpha_ok = alpha_score >= min_alpha

// Gap 5 restored: VWMA volume shelf (20-bar VWMA > 50-bar VWMA = sustained volume interest, not a spike)
bool vol_shelf_ok   = ta.vwma(volume, 20) > ta.vwma(volume, 50)

// --- Weinstein Setup Gates (Sync with Beta v2.6) ---
// vol_acc_ok: institutional-accumulation density — ≥3 of last 20 bars must be green-close
// in upper-60% of range with above-avg volume. v2.4: comment now matches code (was "≥6").
// VERIFY against Commander_Screener_Beta_Edition_v2.9.pine canonical threshold.
float _v_dr   = high - low
float _v_cr   = _v_dr == 0 ? 0 : (close - low) / _v_dr
bool  _v_one  = (close > close[1]) and (volume > vol_ma) and (_v_cr > 0.6)
float _v_sum  = math.sum(_v_one ? 1 : 0, 20)
bool  vol_acc_ok = _v_sum >= 3

// fresh_stage2: stock entered Stage 2 within last `stage2_fresh_max` weeks.
// B6: wrap with nz() so na (Stage 3/4 transitions) explicitly disqualifies.
// E3: stage2_fresh_max is now an input (was hardcoded 26).
bool stage2_fresh_ok = nz(wStageWks, 999) <= stage2_fresh_max

// ma_sqz_ok: SMA20 / SMA50 squeezed within 5%
float ma_dist   = math.abs(d_ema20 - d_sma50) / d_sma50
bool  ma_sqz_ok = ma_dist <= 0.05

// bb_sqz_ok: current BB width tighter than its 30-bar SMA
float _bb_basis = ta.sma(close, 20)
float _bb_dev   = 2.0 * ta.stdev(close, 20)
float _bb_w     = ((_bb_basis + _bb_dev) - (_bb_basis - _bb_dev)) / _bb_basis
bool  bb_sqz_ok = _bb_w < ta.sma(_bb_w, 30)

// Combined Weinstein Setup Gate
// E4: low_mult and high_pct thresholds now inputs (default 1.30 / 0.75 preserved)
bool trend_template_ok = close > (low52w * trend_template_low_mult) and close >= (high52w * trend_template_high_pct)
// stage2_fresh_ok REMOVED from the gate (2026-07-02, sync to bull_screener.py):
// maturity is eyeballed on the weekly chart, not hard-gated. The boolean stays
// defined and is surfaced as a "·mature" status tag on the POS-BO diagnostic.
bool weinstein_setup = (stage2_uptrend or stage1_base) and close > d_sma200 and rs_quadrant != "LAGGING" and vol_acc_ok and trend_template_ok

// E5: Mature Trend Exemption — established Stage 2 leaders can satisfy base_confirmed
//     WITHOUT the strict freshness / template gate, provided they have:
//     • Stage 2 active
//     • Mansfield RS = LEADING (top quadrant — best of best)
//     • Beyond standard freshness window (stage2_fresh_max weeks)
//     • Holding above EMA20 and SMA200 (trend intact)
// EXEMPTION REMOVED (2026-06-08, Jay): match the Bull Screener — no mature-trend
// bypass. base_confirmed is now weinstein_setup AND mpa_pass (strict Weinstein freshness
// applies to ALL POS catalysts). Hard-coded false so it takes effect regardless of the
// saved E5 input value. The `use_mature_trend_exempt` input (line 342) is now inert.
bool mature_trend_ok = false

// Positional Edges
bool base_confirmed = (weinstein_setup or mature_trend_ok) and mpa_pass

// ==========================================
// ML PROBABILITY SCORER
// ==========================================
float ml_pb_depth = high52w > 0 ? (high52w - close) / high52w : 0.0
float ml_vcp_val  = f_is_vcp(1.5) ? 1.0 : 0.0
float ml_atr_pct  = atr14 > 0 and close > 0 ? (atr14 / close) * 100 : 3.0

float ml_score = -0.510474 + (0.023048 * d_rsi) + (0.113267 * ml_atr_pct) + (-0.848810 * _bb_w) + (0.002488 * rsVal500) + (-0.013312 * alpha_score) + (-1.137420 * ml_pb_depth) + (0.072967 * ml_vcp_val) + (-1.658263 * ma_dist)
float ml_win_prob = (1.0 / (1.0 + math.exp(-ml_score))) * 100

// RSI "Dead Zone" Filter (ML Insight)
bool ml_rsi_dead_zone = d_rsi >= 47.0 and d_rsi <= 54.0

// ==========================================
// PY SCORE (Python-Aligned Conviction Rank)
// Mirrors Commander_Screener_Beta_Edition_v2.9.pine::pyScore
// and bull_screener.calculate_score() — same components, same weights.
// Ref: BACKTEST_RESULTS_v2.docx §7. No catalyst_id in strategy scope;
// setup-tier proxy: base_confirmed+TT=30, base_confirmed=20, partial=10.
// ==========================================
float py_rel_vol    = vol_ma > 0 ? volume / vol_ma : 0.0
int   py_score      = 0

// Catalyst tier proxy (max 30)
if base_confirmed and trend_template_ok
    py_score += 30   // Tier-1: full Weinstein + Trend Template
else if base_confirmed
    py_score += 20   // Tier-2: setup without Trend Template
else if (stage2_uptrend or stage1_base) and close > d_sma200
    py_score += 10   // Tier-3: partial/early base

// Stage 2 confirmation (10)
if stage2_uptrend
    py_score += 10

// Mansfield RS — cumulative tiers (10 + 10)
if not na(rsVal500)
    if rsVal500 > 0
        py_score += 10
    if rsVal500 >= 10
        py_score += 10

// Mansfield 4-bar RS momentum (5)
if not na(rs_momentum) and rs_momentum > 0
    py_score += 5

// v2.9 RRG scoring — replaced n=33 calibration with universe-wide validation
// (n=5,460 Nifty 500 × 12 anchors). Only signal that survived: RS-Ratio side.
//   RS-Ratio >= 100 (LEADING + WEAKENING): +2.07% mean 30d alpha
//   RS-Ratio <  100 (IMPROVING + LAGGING): -0.64% mean 30d alpha
// Single binary signal, +5 / -5. Trajectory now drives `rs_tradeable` (entry gate).
py_score += rs_rrg_score

// Volume confirmation (5 / 10 / 15)
if py_rel_vol >= 2.0
    py_score += 15
else if py_rel_vol >= 1.5
    py_score += 10
else if py_rel_vol >= 1.0
    py_score += 5

// Sector stage (+5 / -5)
if _sec_stage == 2
    py_score += 5
else if _sec_stage == 4
    py_score -= 5

// Trend Template (10)
if trend_template_ok
    py_score += 10

// Distance off 52W High (3 / 5 / 7 / 10)
if high52w > 0
    float _dist_high = (high52w - close) / high52w * 100
    if _dist_high <= 5
        py_score += 10
    else if _dist_high <= 10
        py_score += 7
    else if _dist_high <= 15
        py_score += 5
    else if _dist_high <= 25
        py_score += 3

// Clamp [0, 100]
py_score := math.max(0, math.min(py_score, 100))

float bo_level      = ta.highest(high, bo_len)[1]
// Breakout WINDOW (2026-07-02, sync to bull_screener.py): base ceiling = highest
// high of bo_len bars ending 3 bars ago; POS-BO fires if any of the last 3 closes
// cleared it AND price still holds above it — ~3-session window, not just today.
float bo_ceiling_w  = ta.highest(high, bo_len)[3]
bool  bo_window_ok  = math.max(close, math.max(close[1], close[2])) > bo_ceiling_w and close > bo_ceiling_w

// ── PRICE-ACTION catalyst gates (Jay's design — replace lagging indicators,
//    synced to bull_screener.py 2026-06-03). ───────────────────────────────
// PA directional strength (replaces ADX>=25). RELAXED 2026-07-02 (sync to
// bull_screener.py): >=5 of last 14 bars are up-close. The old ">=7 up AND higher
// high" clause rejected breakouts from a flat base (coiling = no higher highs).
// OFF-BY-ONE FIX (2026-07-03, parity sweep): window must INCLUDE the current bar
// (0..13) to match Python / Commander / v67 — the old 1..14 range excluded today
// and flipped marginal 4-vs-5 counts (GRANULES blocked here while Python fired).
int  pa_dir_cnt = 0
for _j = 0 to 13
    if close[_j] > open[_j]
        pa_dir_cnt += 1
bool pa_dir_ok = pa_dir_cnt >= 5
// PA pullback pocket (replaces RSI 30-70): 38-62% retrace of 20-bar range.
float pa_sw_hi20 = ta.highest(high, 20)
float pa_sw_lo20 = ta.lowest(low, 20)
float pa_retrace = (pa_sw_hi20 - pa_sw_lo20) > 0 ? (pa_sw_hi20 - close) / (pa_sw_hi20 - pa_sw_lo20) : 0.0
bool  pb_pocket_pa = pa_retrace >= 0.38 and pa_retrace <= 0.62
// PA oversold (replaces RSI<35): PRIOR weakness ending YESTERDAY
// (close[1]<close[2]<close[3]) so it is compatible with the reversal-bar confirm
// (close>open and close>high[1]). FIX 2026-06-03: the earlier version included
// today's down close, contradicting close>high[1] → gate never fired.
bool  pa_oversold_pa = close[1] < close[2] and close[2] < close[3]

// v3.6 (2026-06-03, part a): ADX -> pa_dir_ok AND weekly RSI -> PA weekly
//   momentum (weekly close above its TRUE 5-week-ago value — wClose5wAgo comes
//   from inside the weekly security context; MTF FIX 2026-07-03).
bool pa_wk_mom = not na(wClose5wAgo) and wClose > wClose5wAgo
// mkt_bull DEMOTED to overlay (2026-06-08): no longer vetoes the trigger — a Stage-2
// leader fires even in a bear tape. regime_risk (sizing) + active_ce_mult (trail) already
// modulate by mkt_bull; counter_trend is flagged in the panel. Matches Python + Bull Screener.
// alpha DEMOTED to status (2026-07-02, sync to bull_screener.py): alpha no longer
// vetoes POS-BO; it rides along as Asset-Quality context. Breakout + volume are now
// 3-session windows so a scan a day late still catches the breakout.
bool pos_bo_trigger = use_bull_mode and use_pos_bo and base_confirmed and
                      (bo_conf == "Daily Close" ? bo_window_ok : high > bo_level) and
                      (volume > vol_ma * 1.25 or volume[1] > vol_ma[1] * 1.25 or volume[2] > vol_ma[2] * 1.25) and
                      pa_wk_mom and pa_dir_ok

float pos_accum_sl  = lowest_low_10
float bo_level_30   = ta.highest(high, 30)[1]

// OBV DRIFT FIX (2026-07-03): the linreg-slope version diverged from Python /
// Commander / v67, which all use accumulation-bar density: >=8 of the last 20
// bars close up on rising volume. Parity sweep caught AXISBANK blocked here
// while the other three surfaces fired POS-ACCUM.
int _obv_acc_bars = 0
for _oi = 0 to 19
    if not na(close[_oi]) and not na(open[_oi]) and not na(volume[_oi + 1])
        if close[_oi] > open[_oi] and volume[_oi] > volume[_oi + 1]
            _obv_acc_bars += 1
bool  obv_trending_up = _obv_acc_bars >= 8

bool is_vcp_tight   = f_is_vcp(1.0)
bool is_vcp_accum   = f_is_vcp(1.5)   // looser VCP for POS-ACCUM (un-starve)

// v3.6 (2026-06-03, part a): daily RSI<=pos_accum_rsi_max -> PA anti-chase
//   (close <= close[5]*1.05 — accumulation entry must not chase a sharp run-up);
//   is_vcp_tight -> is_vcp_accum (1.5x) so accumulation isn't starved.
bool pa_not_extended = close <= close[5] * 1.05
// POS-ACCUM base (2026-07-02, sync to bull_screener.py): accumulation-appropriate —
// drops the near-52wH trend_template + full stack that base_confirmed requires (both
// contradict basing). alpha DEMOTED to status (same as POS-BO).
bool accum_base = (stage2_uptrend or stage1_base) and close > d_sma200 and rs_quadrant != "LAGGING" and vol_acc_ok
bool pos_ac_trigger = use_bull_mode and use_pos_accum and accum_base and
                      obv_trending_up and is_vcp_accum and close > (bo_level_30 * 0.9) and
                      pa_not_extended

// Swing Edges
bool is_sqz       = f_is_bb_sqz(20)
// Gap 3 restored: MA stack + RSI pocket + vol dry-up for SWG-PB quality filter
bool pb_ma_stack  = d_sma150 > d_sma200                          // Minervini 150>200 stack
bool pb_rsi_ok    = d_rsi > 30 and d_rsi < 70                    // RSI pocket (not extreme OB/OS)
// Relaxed volume and pullback conditions to match Screener/Python
bool vol_vdu_ok   = volume < (vol_ma * 0.85) and close < close[1]
float pb_dist_ema20 = math.abs((close - d_ema20) / d_ema20) * 100
bool is_ema_pb_zone = pb_dist_ema20 <= 2.5
// v3.5: pb_rsi_ok (RSI 30-70) -> pb_pocket_pa (38-62% retrace) per pure-PA design.
// REGIME-CONDITIONED (2026-07-02, Jay): + mkt_bull. SWG-PB is momentum-continuation
// that is robustly negative in corrective regimes — only fire it in a confirmed bull
// tape. (mkt_bull stays an overlay for the positional catalysts; hard gate here.)
bool swing_pb_trg = use_bull_mode and use_swing_pb and mkt_bull and is_ema_pb_zone and is_vcp_tight and pb_ma_stack and pb_pocket_pa and vol_vdu_ok

// SWG-BO SYNCED UP to Pine is_swing_bo / bull_screener.py (2026-07-02, Jay): Minervini
// uptrend + VCP(1.5x) + 15-bar pivot breakout + vol>1.25x + anti-algo (close in upper
// 60% of the bar AND up-close). Was is_vcp_tight(1.0) + bo_level + vol>1.5 with NO trend
// and NO anti-algo gate — the low-quality swing drag. Now Unified matches Commander + v67.
bool bo_minervini = close > d_sma50 and d_sma50 > d_sma150 and d_sma150 > d_sma200
bool bo_pivot15   = close > ta.highest(high, 15)[1]
bool bo_anti_algo = (high > low ? (close - low) / (high - low) : 0.5) >= 0.60 and close > open
bool is_vcp_swg   = f_is_vcp(1.5)
bool swing_bo_trg = use_bull_mode and use_swing_bo and bo_minervini and is_vcp_swg and bo_pivot15 and volume > (vol_ma * 1.25) and bo_anti_algo

bool oversold_rsi = d_rsi < 35
bool rev_struct   = close > d_sma200 and close < d_ema20
// B5: exclude Stage 4 (structural downtrend) — was firing on broken stocks
//     that happen to be above SMA200 mid-decline.
// v3.5: oversold_rsi (RSI<35) -> pa_oversold_pa (3 lower closes + low-in-range).
bool swing_rev_trg= use_bull_mode and use_swing_rev and not stage4_dntrend and rev_struct and pa_oversold_pa and close > open and close > high[1]

// Gap 4 restored: min 4% gap, intraday close in top 40% of bar, 3x volume
bool gap_up         = open > high[1] and close > open
float gap_pct       = high[1] > 0 ? (open - high[1]) / high[1] : 0.0         // gap size as % of prev high
float gap_bar_range = high - open                                               // range from open to high of gap bar
float gap_intra_pos = gap_bar_range > 0.0001 ? (close - open) / gap_bar_range : 0.0  // close position in gap bar
bool gap_go_trg     = use_bull_mode and use_swing_gap and gap_up and gap_pct >= 0.04 and gap_intra_pos >= 0.60 and volume > (vol_ma * 3.0)

// ── Bull signal hold-window trackers (var: persist across bars) ──────────────
var int last_pos_bo_bar  = -999
var int last_pos_ac_bar  = -999
var int last_swg_pb_bar  = -999
var int last_swg_bo_bar  = -999
var int last_swg_rev_bar = -999
var int last_gap_go_bar  = -999
if pos_bo_trigger
    last_pos_bo_bar  := bar_index
if pos_ac_trigger
    last_pos_ac_bar  := bar_index
if swing_pb_trg
    last_swg_pb_bar  := bar_index
if swing_bo_trg
    last_swg_bo_bar  := bar_index
if swing_rev_trg
    last_swg_rev_bar := bar_index
if gap_go_trg
    last_gap_go_bar  := bar_index

// ── Recovery signal hold-window trackers ───────────────────────────────
var int last_rev_cb_bar  = -999
var int last_rev_rs_bar  = -999
var int last_rev_ear_bar = -999
// v3.4.2 (2026-06-09): Wyckoff hold-window trackers — the v3.4 port added WYC
// triggers + entries but never surfaced them on the Recovery Signals panel row.
var int last_wyc_ssos_bar = -999  // WYC-SPRING+SOS
var int last_wyc_jac_bar  = -999  // WYC-JAC
var int last_wyc_sos_bar  = -999  // WYC-SOS
var int last_wyc_spr_bar  = -999  // WYC-SPRING
// (updates happen after recovery triggers are defined â€” see below section 10+)
float correction_depth = high52w > 0 ? (high52w - close) / high52w : 0.0
bool stock_corrected   = correction_depth >= min_correction_pct and correction_depth <= max_correction_pct
bool regime_ok = not use_regime_gate or mkt_idx_corrected or mkt_reclaim or stock_corrected

// REV-CB Edge
float cb_lookback_high_val = ta.highest(high, cb_lookback_high)
float cb_drawdown_pct_cur  = cb_lookback_high_val > 0 ? (cb_lookback_high_val - close) / cb_lookback_high_val : 0.0
bool is_stretched = cb_drawdown_pct_cur >= cb_drawdown_pct

float red_flag       = close < open ? 1.0 : 0.0
float red_count_f    = math.sum(red_flag, cb_washout_window)
float range10_high   = ta.highest(high, 10)
float range10_width  = range10_high - lowest_low_10
float pos_in_range10 = range10_width > 0 ? (close - lowest_low_10) / range10_width : 1.0
bool is_oversold = red_count_f >= cb_washout_red and pos_in_range10 <= 0.25

// B2: bar_range_max_cb now uses [1] offset — compare current bar to PRIOR N
//     bars, not itself. v2.3's "bar_range >= max-incl-self" reduced to
//     "bar_range == max" (tautology) and silently blocked most REV-CB firings.
float bar_range_max_cb = ta.highest(bar_range, cb_range_lookback)[1]
float rel_vol   = vol_ma > 0 ? volume / vol_ma : 0.0
bool climax_bar = rel_vol >= cb_vol_mult and close < open and bar_range > bar_range_max_cb

var int last_climax_bar = 0
if is_stretched and is_oversold and climax_bar
    last_climax_bar := bar_index

bool recent_climax = last_climax_bar > 0 and (bar_index - last_climax_bar) <= cb_climax_window

var float climax_low_snap = na
if recent_climax
    climax_low_snap := lowest_low_5

bool is_turn = close > open and close > (low + (high - low) * 0.60) and close > high[1]
float cb_sl_raw = not na(climax_low_snap) ? (climax_low_snap - atr14 * 0.5) : na
bool trigger_rev_cb = use_rec_mode and use_rev_cb and recent_climax and is_turn and rff_ok and regime_ok and not na(cb_sl_raw)

// REV-RS Edge
float hl_recent = ta.lowest(low, rs_hl_recent)
float hl_prior  = ta.lowest(low, rs_hl_prior)[rs_hl_recent]
bool  higher_low_ok = not na(hl_recent) and not na(hl_prior) and hl_recent > hl_prior
bool rs_recovery_state = higher_low_ok and trend_up
float rs_bo_level_val = ta.highest(high, rs_bo_len)[1]
// v3.4.1 (2026-06-08): LATCHED hold-window RS breakout — match Recovery Screener
// (line 1192) + Python canonical ("any of the last hold bars"). Was instantaneous
// (current bar only), which blocked names whose RS breakout fired a few bars ago but
// is still valid within the hold window (e.g. ZENTEC). vol threshold 1.5→1.25 to match
// the screener's vol_confirm_mult. Hold window = bull_hold_days (mirrors the rec hold).
var int _last_rs_break_bar = 0
bool _rs_fires_now = trend_up and higher_low_ok and close > rs_bo_level_val and volume >= vol_ma * 1.25 and rs_positive
if _rs_fires_now
    _last_rs_break_bar := bar_index
bool rs_breakout = _last_rs_break_bar > 0 and (bar_index - _last_rs_break_bar) <= bull_hold_days and trend_up
bool trigger_rev_rs = use_rec_mode and use_rev_rs and rs_positive and rs_recovery_state and stock_corrected and rs_breakout and sector_stage_ok and rff_ok and regime_ok

// REV-EARLY Edge
float early_trendline_high = ta.highest(high, early_tl_window)[early_tl_recent]
bool  trendline_reclaim    = not na(early_trendline_high) and close > early_trendline_high
float bar_range_min_nr7   = ta.lowest(bar_range, early_nr7_len)
float early_lowest_low    = ta.lowest(low, early_nr7_len)  // hoisted: used as SL for REV-EARLY entries
bool  is_nr7              = bar_range <= bar_range_min_nr7
float inside_flag         = (high < high[1] and low > low[1]) ? 1.0 : 0.0
float inside_count_f      = math.sum(inside_flag, early_inside_lb)
bool  base_compressed     = is_nr7 or inside_count_f >= early_inside_min

float early_pivot = ta.highest(high, 15)[1]
bool early_break  = close > early_pivot and volume > vol_ma * 1.5
bool trigger_rev_early = use_rec_mode and use_rev_early and trendline_reclaim and rs_recovery_state and base_compressed and early_break and rs_positive and sector_stage_ok and rff_ok and regime_ok

// ==========================================
// 10b. WYCKOFF RECOVERY (v3.4 — ported from Pine Recovery Screener v2.0)
// ==========================================
// Pure price + volume (no oscillators). Backtest-validated +6.39% cum alpha
// on Nifty 500 12-anchor vs legacy REV-* edges -5.25%. See Python
// recovery_screener.py v3.0 for the reference implementation.
float wyc_vol_avg50  = ta.sma(volume, 50)
float wyc_spread_avg = ta.sma(high - low, 20)

// Phase B: accumulation base — 60-bar sideways range max 25%, prior decline >=20%
int   wyc_base_lk    = 60
float wyc_pct_max    = 25.0
float wyc_min_dec    = 20.0
int   wyc_prior_lk   = 120
float wyc_base_high  = ta.highest(high, wyc_base_lk)
float wyc_base_low   = ta.lowest(low,  wyc_base_lk)
float wyc_pct_range  = wyc_base_low > 0 ? (wyc_base_high - wyc_base_low) / wyc_base_low * 100.0 : 999.0
float wyc_prior_high = ta.highest(high, wyc_prior_lk)[wyc_base_lk]
float wyc_decline    = wyc_prior_high > 0 ? (wyc_prior_high - wyc_base_low) / wyc_prior_high * 100.0 : 0.0
bool  wyc_in_base    = wyc_pct_range <= wyc_pct_max and wyc_decline >= wyc_min_dec

// Phase C: Spring — false breakdown on weak volume, recovery within 3 bars
int   wyc_spr_lk         = 10
float wyc_spr_max_below  = 3.0
float wyc_spr_max_vol    = 1.0
int   wyc_spr_recov_bars = 3
var int wyc_spring_bar = na
if wyc_in_base
    float _thr = wyc_base_low * (1.0 - wyc_spr_max_below / 100.0)
    for i = 0 to wyc_spr_lk - 1
        if not na(low[i]) and low[i] < wyc_base_low and low[i] >= _thr and not na(wyc_vol_avg50[i]) and volume[i] <= wyc_vol_avg50[i] * wyc_spr_max_vol
            bool _rec = false
            int _limit = math.max(0, i - wyc_spr_recov_bars)
            for j = _limit to i
                if not na(close[j]) and close[j] > wyc_base_low
                    _rec := true
                    break
            if _rec
                wyc_spring_bar := bar_index - i
                break
bool wyc_has_spring = not na(wyc_spring_bar) and (bar_index - wyc_spring_bar) <= wyc_spr_lk

// Phase D: SOS — wide-range up bar on heavy volume, closes upper third, above base mid
int   wyc_sos_lk        = 5
float wyc_sos_spread_x  = 1.5
float wyc_sos_upper     = 0.66
float wyc_sos_vol_x     = 1.5
var int wyc_sos_bar = na
if wyc_in_base
    float _mid = (wyc_base_high + wyc_base_low) / 2.0
    for i = 0 to wyc_sos_lk - 1
        float _r = high[i] - low[i]
        if _r > 0 and not na(wyc_spread_avg[i]) and not na(wyc_vol_avg50[i])
            float _cp = (close[i] - low[i]) / _r
            bool _wide  = (high[i] - low[i]) >= wyc_spread_avg[i] * wyc_sos_spread_x
            bool _upper = _cp >= wyc_sos_upper
            bool _heavy = volume[i] >= wyc_vol_avg50[i] * wyc_sos_vol_x
            bool _amid  = close[i] >= _mid
            if _wide and _upper and _heavy and _amid
                wyc_sos_bar := bar_index - i
                break
bool wyc_has_sos = not na(wyc_sos_bar) and (bar_index - wyc_sos_bar) <= wyc_sos_lk

// Phase D: JAC — close above base high on volume >= 2x avg
float wyc_jac_vol_x = 2.0
bool wyc_has_jac = wyc_in_base and close > wyc_base_high and close[1] <= wyc_base_high and not na(wyc_vol_avg50) and volume >= wyc_vol_avg50 * wyc_jac_vol_x

// Wyckoff triggers — priority: SPRING+SOS > JAC > SOS > SPRING
bool trigger_wyc_spring_sos = use_rec_mode and wyc_has_spring and wyc_has_sos and regime_ok
bool trigger_wyc_jac        = use_rec_mode and wyc_has_jac and regime_ok
bool trigger_wyc_sos        = use_rec_mode and wyc_has_sos and not wyc_has_spring and not wyc_has_jac and regime_ok
bool trigger_wyc_spring     = use_rec_mode and wyc_has_spring and not wyc_has_sos and not wyc_has_jac and regime_ok

// ==========================================
// 11. SIGNAL ROUTING
// ==========================================
// E11: WCL Context Layers gate — applied at routing layer (per-catalyst booleans
//      stay pure for diag panel attribution; WCL only blocks final entry).
bool wcl_ok = not use_wcl_gate or wcl_score_source >= wcl_score_min
// v3.4 (2026-05-21) sync fixes — Pine Strategy now mirrors Python+Pine Screener:
// v3.5 (2026-05-21): POS-ACCUM and REV-* RE-ENABLED. The v3.4 removals were
// based on a 30-day forward-window backtest, which is the wrong horizon for
// Stage 1->2 accumulation / recovery setups (designed for multi-month holds
// per CLAUDE.md). Roll-back pending re-validation with a catalyst-aware
// forward window. Wyckoff catalysts remain ADDITIVE alongside REV-*.
bool trigger_bull_raw = pos_bo_trigger or pos_ac_trigger or swing_pb_trg or swing_bo_trg or swing_rev_trg or gap_go_trg
bool trigger_rec_raw  = trigger_wyc_spring_sos or trigger_wyc_jac or trigger_wyc_sos or trigger_wyc_spring or trigger_rev_cb or trigger_rev_rs or trigger_rev_early
bool trigger_bull = trigger_bull_raw and wcl_ok
bool trigger_rec  = trigger_rec_raw  and wcl_ok
// ── Recovery tracker updates ──
if trigger_rev_cb
    last_rev_cb_bar  := bar_index
if trigger_rev_rs
    last_rev_rs_bar  := bar_index
if trigger_rev_early
    last_rev_ear_bar := bar_index
// v3.4.2: Wyckoff trackers (priority recovery edge)
if trigger_wyc_spring_sos
    last_wyc_ssos_bar := bar_index
if trigger_wyc_jac
    last_wyc_jac_bar  := bar_index
if trigger_wyc_sos
    last_wyc_sos_bar  := bar_index
if trigger_wyc_spring
    last_wyc_spr_bar  := bar_index
bool trigger_any  = trigger_bull or trigger_rec

var string active_catalyst = na
// Wyckoff catalysts have priority — backtest-validated as the only working recovery
if trigger_wyc_spring_sos
    active_catalyst := "WYC-SPRING+SOS"
else if trigger_wyc_jac
    active_catalyst := "WYC-JAC"
else if trigger_wyc_sos
    active_catalyst := "WYC-SOS"
else if trigger_wyc_spring
    active_catalyst := "WYC-SPRING"
else if pos_bo_trigger
    active_catalyst := "POS-BO"
else if swing_bo_trg
    active_catalyst := "SWG-BO"
else if swing_pb_trg
    active_catalyst := "SWG-PB"
else if swing_rev_trg
    active_catalyst := "SWG-REV"
else if gap_go_trg
    active_catalyst := "SWG-GAP"
else
    active_catalyst := na
// ==========================================
// 12. EXECUTION BLOCK
// ==========================================

// ── Chandelier Exit (CE) — must be at global scope (stateful ta.* calls) ────
float active_ce_mult  = mkt_bull ? ce_mult : (ce_mult + 0.5)
[ce_h_d, ce_atr_d] = request.security(syminfo.tickerid, "D", [ta.highest(close, ce_length), ta.atr(ce_length)], lookahead=barmerge.lookahead_off)
float ce_trailing_stop = ce_h_d - (ce_atr_d * active_ce_mult)

// ── Event snaps: populated once at trade open (var = persist across bars) ───
var float atr_entry_snap   = na
var float struct_low_snap  = na   // 10-bar structural low at open
var float entry_sl_pb_snap = na   // 5-bar swing low × (1-sl_pad_pb) at open
var float init_risk_snap   = na   // initial risk (entry − initial SL)
var bool  is_breakeven     = false
var bool  is_t2_hit        = false

bool is_new_trade = strategy.position_size > 0 and strategy.position_size[1] == 0
if is_new_trade
    atr_entry_snap   := atr14
    struct_low_snap  := lowest_low_10
    entry_sl_pb_snap := lowest_low_5 * (1.0 - sl_pad_pb)
    is_breakeven     := false
    is_t2_hit        := false
    // Compute initial risk for T1/T2 calculations
    // v3.6 (2026-05-21): catalyst-aware fallback ATR multipliers when the
    // structural SL anchor is above close. POS/WYC need wider room (multi-
    // month holds); SWG keeps 1.5x; REV uses 2.5x for its 90d horizon.
    string _nc = active_catalyst
    if str.startswith(_nc, "POS")
        float _s = struct_low_snap - (atr_entry_snap * 0.2)
        if _s >= close
            _s := close - (atr_entry_snap * 4.0)   // positional: wide fallback
        init_risk_snap := math.max(close - _s, close * 0.01)
    else if _nc == "REV-RS" or _nc == "REV-EARLY"
        float _s = struct_low_snap - (atr_entry_snap * 0.2)
        if _s >= close
            _s := close - (atr_entry_snap * 2.5)   // recovery: 90d hold
        init_risk_snap := math.max(close - _s, close * 0.01)
    else if str.startswith(_nc, "SWG")
        float _s = entry_sl_pb_snap
        if _s >= close
            _s := close * 0.99
        init_risk_snap := math.max(close - _s, close * 0.01)
    else if _nc == "REV-CB"
        init_risk_snap := math.max(close - nz(cb_sl_raw, close * 0.92), close * 0.01)

if strategy.position_size == 0
    is_breakeven := false
    is_t2_hit    := false

// ── Position Sizing ──────────────────────────────────────────────────────────
// Bull trades use stock_risk_pct with Kelly + vol discount
// Recovery trades use rec_risk_pct (more conservative — regime is uncertain)
bool _is_rec_entry = trigger_rec and not trigger_bull
float base_risk  = _is_rec_entry ? rec_risk_pct : stock_risk_pct
float regime_risk = mkt_bull ? base_risk : math.max(base_risk - 0.25, 0.25)
float atr_pct_sz  = atr14 > 0 and close > 0 ? (atr14 / close) * 100 : 3.0
float vol_disc    = math.min(3.0 / math.max(atr_pct_sz, 0.1), 1.0)
bool  _is2_k      = stage2_uptrend
bool  _rs_k       = rs_ok
bool  _vol_k      = volume > (vol_sma50_g * 1.1)
int   _kelly_pts  = (_is2_k ? 1 : 0) + (_rs_k ? 1 : 0) + (_vol_k ? 1 : 0)
float kelly_mult  = use_kelly and not _is_rec_entry ? (_kelly_pts >= 3 ? 1.25 : (_kelly_pts == 2 ? 1.0 : 0.75)) : 1.0
float active_risk_pct = math.max(regime_risk * math.max(vol_disc * kelly_mult, 0.75), 0.25)

f_get_qty_eco(_sl_dist) =>
    float risk_amt = portfolio_capital * (active_risk_pct / 100.0)
    float qty_risk = _sl_dist > 0 ? risk_amt / _sl_dist : 0.0
    float qty_cap  = close > 0 ? max_alloc / close : 0.0
    math.min(qty_risk, qty_cap)

// ── SL calculation for position sizing on entry bar ──────────────────────────
float current_sl = na
if pos_bo_trigger or pos_ac_trigger
    float _s = lowest_low_10 - (atr14 * 0.2)
    // v3.6 (2026-05-21): positional fallback widened 1.5x → 4.0x ATR
    current_sl := _s >= close ? close - (atr14 * 4.0) : _s
else if swing_pb_trg or swing_bo_trg or swing_rev_trg
    float _s = lowest_low_5 * (1.0 - sl_pad_pb)
    current_sl := _s >= close ? close * 0.99 : _s
else if gap_go_trg
    float _s = low * (1.0 - sl_pad_pb)   // Gap-bar low is the structural SL
    current_sl := _s >= close ? close * 0.99 : _s
else if trigger_rev_cb
    current_sl := nz(cb_sl_raw, close * 0.92)
else if trigger_rev_rs
    float _s = hl_recent * (1.0 - sl_pad_pb)
    current_sl := _s >= close ? close * 0.99 : _s
else if trigger_rev_early
    float _s = early_lowest_low * (1.0 - sl_pad_pb)
    current_sl := _s >= close ? close * 0.99 : _s
else if trigger_wyc_spring_sos or trigger_wyc_jac or trigger_wyc_sos or trigger_wyc_spring
    // Wyckoff SL: just below the accumulation base low (or spring low if active)
    float _wyc_sl_anchor = wyc_has_spring ? wyc_base_low * 0.98 : wyc_base_low - (atr14 * 0.3)
    // v3.6 (2026-05-21): Wyckoff fallback widened 1.5x → 3.5x ATR (120d hold)
    current_sl := _wyc_sl_anchor >= close ? close - (atr14 * 3.5) : _wyc_sl_anchor

// ── Webhook levels & qty pre-calculation ──────────────────────────────────────
float qty = na
float tp_price = na
if trigger_any
    float _sl_dist = math.max(close - nz(current_sl, close * 0.97), close * 0.005)
    qty := f_get_qty_eco(_sl_dist)
    float _init_risk = math.max(close - nz(current_sl, close * 0.97), close * 0.01)
    if pos_bo_trigger or pos_ac_trigger
        tp_price := close + (_init_risk * 5.0)
    else if swing_rev_trg
        tp_price := close + (_init_risk * 2.0)
    else if gap_go_trg
        tp_price := close + (_init_risk * 2.0)
    else if swing_pb_trg or swing_bo_trg
        tp_price := close + (_init_risk * 3.0)
    else if trigger_wyc_spring_sos or trigger_wyc_jac or trigger_wyc_sos or trigger_wyc_spring
        tp_price := close + (_init_risk * 5.0)

// ── Entry ────────────────────────────────────────────────────────────────────
// v3.1 FIX (2026-05-20): Removed `strategy.position_size == 0` guard.
// Backtest (LAURUSLABS/RELIANCE/TCS/BAJFINANCE) showed strategy made <1% over
// 20+ years vs Buy&Hold 3,691× on BAJFINANCE because single-position rule
// rejected 90%+ of catalyst signals. Now allows up to max_open_positions=6
// concurrent trades, letting the strategy pyramid into running winners.
if trigger_any and in_date and strategy.opentrades < max_open_positions
    if (pos_bo_trigger or swing_bo_trg) and bo_conf != "Daily Close"
        strategy.entry("Long", strategy.long, qty=qty, comment=active_catalyst, stop=bo_level + syminfo.mintick)
    else
        strategy.entry("Long", strategy.long, qty=qty, comment=active_catalyst)

// ── Exit Engine ──────────────────────────────────────────────────────────────
var float bo_sl      = na   // POS-* CE ratchet SL
var float pb_sl      = na   // SWG-* EMA20 trail SL
var float cb_sl_live = na   // REV-CB trailing SL
var float rec_sl     = na   // REV-RS / REV-EARLY CE ratchet SL

if strategy.position_size > 0
    string entry_cmt = strategy.opentrades.entry_comment(strategy.opentrades - 1)
    float  entry_px  = strategy.opentrades.entry_price(strategy.opentrades - 1)
    int    bars_open = bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)
    float  snap_risk = nz(init_risk_snap, entry_px * 0.02)

    // ── T1 (partial profit — activates breakeven protection) ─────────────────
    // v3.3 (2026-05-21): Catalyst-differentiated R-multiples respecting trade
    // timeframe. Swing trades (1-4 week holds) can't realistically reach 5R/10R;
    // setting wider targets just leaves the targets unused. Positional trades
    // (multi-month holds) can. Wyckoff recovery (1-3mo holds) also can.
    //   POS-BO/POS-ACCUM (positional): T1 5R, T2 10R
    //   SWG-BO/SWG-PB    (swing):      T1 3R, T2 5R    ← realistic for 1-4wk
    //   SWG-GAP          (gap-and-go): T1 2R, T2 4R    ← gaps fade fast
    //   SWG-REV          (mean rev):   T1 2R, T2 2R    ← quick exit
    //   REV-CB/RS/EARLY  (recovery):   T1 5R, T2 high52w (kept from v3.1)
    float t1_target  = na
    int   t1_qty_pct = 25     // default — keep more runner
    if str.startswith(entry_cmt, "POS")
        t1_target  := entry_px + (snap_risk * 5.0)    // positional 5R
    else if entry_cmt == "SWG-REV"
        t1_target  := entry_px + (snap_risk * 2.0)    // mean-rev 2R
        t1_qty_pct := 50
    else if entry_cmt == "SWG-GAP"
        t1_target  := entry_px + (snap_risk * 2.0)    // gap fade 2R
        t1_qty_pct := 50
    else if str.startswith(entry_cmt, "SWG")          // SWG-BO, SWG-PB
        t1_target  := entry_px + (snap_risk * 3.0)    // swing 3R
        t1_qty_pct := 33
    else if str.startswith(entry_cmt, "WYC")          // WYC-SPRING/SOS/JAC/SPRING+SOS
        t1_target  := entry_px + (snap_risk * 5.0)    // Wyckoff post-accumulation
    else if entry_cmt == "REV-CB"                     // legacy fallback
        t1_target  := entry_px + (snap_risk * 5.0)
    else if entry_cmt == "REV-RS" or entry_cmt == "REV-EARLY"
        t1_target  := entry_px + (snap_risk * 5.0)

    if not na(t1_target) and high >= t1_target and not is_breakeven
        is_breakeven := true
        strategy.exit("T1", "Long", qty_percent=t1_qty_pct, limit=t1_target, comment="T1 Hit")

    // ── T2 (runner exit — partial of remaining post-T1 position) ─────────────
    // v3.3 (2026-05-21): Catalyst-differentiated. Swing T2 dropped from 10R
    // back to 5R (realistic for 1-4wk holds). Positional + Wyckoff keep 10R.
    if not is_t2_hit
        float t2_target = na
        if entry_cmt == "SWG-REV"
            t2_target := entry_px + (snap_risk * 2.0)     // mean-rev quick
        else if entry_cmt == "SWG-GAP"
            t2_target := entry_px + (snap_risk * 4.0)     // gap fade
        else if str.startswith(entry_cmt, "SWG")          // SWG-BO/PB
            t2_target := entry_px + (snap_risk * 5.0)     // swing 5R
        else if str.startswith(entry_cmt, "POS")
            t2_target := entry_px + (snap_risk * 10.0)    // positional 10R
        else if str.startswith(entry_cmt, "WYC")
            t2_target := math.max(entry_px + (snap_risk * 10.0), high52w)  // 10R or 52wH, whichever larger
        else if entry_cmt == "REV-CB"
            t2_target := high52w
        else if entry_cmt == "REV-RS" or entry_cmt == "REV-EARLY"
            t2_target := high52w
        if not na(t2_target) and high >= t2_target
            is_t2_hit := true
            strategy.exit("T2", "Long", qty_percent=25, limit=t2_target, comment="T2 Hit")

    // ── POSITION A: POS-BO / POS-ACCUM — CE Ratchet trailing stop ────────────
    if str.startswith(entry_cmt, "POS")
        if strategy.position_size[1] == 0   // Snap SL at trade open
            float _s = struct_low_snap - (atr_entry_snap * 0.2)
            // v3.6 (2026-05-21): positional fallback widened 1.5x → 4.0x ATR
            bo_sl := _s >= entry_px ? entry_px - (atr_entry_snap * 4.0) : _s
        else
            bo_sl := math.max(nz(bo_sl, entry_px * 0.95), ce_trailing_stop)  // ratchet — only rises
        if is_breakeven
            bo_sl := math.max(bo_sl, entry_px)
        if stage4_dntrend
            strategy.close("Long", comment="Stage 4 Exit")
        else
            strategy.exit("SL-POS", "Long", stop=bo_sl, comment="CE Structural SL")

    // POSITION B: SWG-* -- EMA20 ratchet trail
    else if str.startswith(entry_cmt, "SWG")
        // v3.2 widened from d_ema20 to d_sma50 — matches T1@5R targets.
        // EMA20 was getting tagged on routine pullbacks (~5-10% on weekly).
        // SMA50 gives ~3x wider band (~15-25% pullback tolerance) so winners
        // can ride through normal consolidations to reach 5R/10R targets.
        float trail_level = d_sma50 * (1.0 - trail_buf_pb)
        if strategy.position_size[1] == 0
            pb_sl := nz(entry_sl_pb_snap, entry_px * 0.97)
            if pb_sl >= entry_px
                pb_sl := entry_px * 0.99
        else
            pb_sl := math.max(nz(pb_sl, entry_px * 0.97), trail_level)   // ratchet up
        if is_breakeven
            pb_sl := math.max(pb_sl, entry_px)
        // SWG contextual exits (trump the trail)
        if d_sma50 > 0 and close < d_sma50
            strategy.close("Long", comment="50MA Fail")
        else if entry_cmt == "SWG-REV" and bars_open >= 5
            strategy.close("Long", comment="Mean Rev 5D Stop")
        else
            strategy.exit("SL-SWG", "Long", stop=pb_sl, comment="SMA50 Trail")

    // POSITION C: REV-CB -- EMA20 trail after T1
    else if entry_cmt == "REV-CB"
        if strategy.position_size[1] == 0
            cb_sl_live := nz(cb_sl_raw, entry_px * 0.92)
        else if is_breakeven
            float cb_trail = d_ema20 * (1.0 - trail_buf_pb)
            cb_sl_live := math.max(nz(cb_sl_live, entry_px * 0.92), cb_trail, entry_px)
        strategy.exit("SL-CB", "Long", stop=nz(cb_sl_live, entry_px * 0.90), comment="REV-CB SL")

    // POSITION D: REV-RS / REV-EARLY -- CE Ratchet trail
    else if entry_cmt == "REV-RS" or entry_cmt == "REV-EARLY"
        if strategy.position_size[1] == 0
            float _s = hl_recent * (1.0 - sl_pad_pb)
            rec_sl := _s >= entry_px ? entry_px * 0.97 : _s
        else
            rec_sl := math.max(nz(rec_sl, entry_px * 0.97), ce_trailing_stop)  // ratchet
        if is_breakeven
            rec_sl := math.max(rec_sl, entry_px)
        strategy.exit("SL-REC", "Long", stop=nz(rec_sl, entry_px * 0.95), comment="REV CE Trail")

    // POSITION E: WYC-SPRING/SOS/JAC -- CE Ratchet trail (same as POS — base breakouts run)
    else if str.startswith(entry_cmt, "WYC")
        if strategy.position_size[1] == 0
            // SL = below spring low / base low, whichever applicable
            float _s_wyc = wyc_base_low - atr_entry_snap * 0.3
            rec_sl := _s_wyc >= entry_px ? entry_px - atr_entry_snap * 1.5 : _s_wyc
        else
            rec_sl := math.max(nz(rec_sl, entry_px * 0.95), ce_trailing_stop)
        if is_breakeven
            rec_sl := math.max(rec_sl, entry_px)
        strategy.exit("SL-WYC", "Long", stop=nz(rec_sl, entry_px * 0.92), comment="WYC CE Trail")

    // Time-Decay Exit: POS=6W, SWG=10D, REV=15D
    // Fires only when unrealised gain < 0.5R AND not yet breakeven
    int time_stop_bars = str.startswith(entry_cmt, "POS")  ? (pos_time_stop_weeks * 5) :
                         str.startswith(entry_cmt, "WYC")  ? (pos_time_stop_weeks * 5) :  // Wyckoff = positional timeframe
                         str.startswith(entry_cmt, "REV") ? 15 : swg_time_stop_days
    float unrealized_r = snap_risk > 0 ? (close - entry_px) / snap_risk : 0.0
    if bars_open >= time_stop_bars and unrealized_r < 0.5 and not is_breakeven
        strategy.close("Long", comment="Time-Decay (<0.5R)")

else
    // Reset ratchet SLs when flat (stale values must not carry into next trade)
    bo_sl      := na
    pb_sl      := na
    cb_sl_live := na
    rec_sl     := na

// ==========================================
// 13. PLOTTING & ALERTS
color bg_col = na
if stage2_uptrend
    bg_col := color.new(color.green, 85)
else if stage4_dntrend
    bg_col := color.new(color.red, 85)
else if stage1_base
    bg_col := color.new(color.yellow, 85)
else if stage3_top
    bg_col := color.new(color.orange, 85)

bgcolor(bg_col, title="Stage Background")
// ==========================================
plot(show_ma ? d_ema20 : na,  "EMA 20",  color=color.rgb(255, 235, 59, 31), linewidth=2)
plot(show_ma ? d_sma50 : na,  "SMA 50",  color=color.rgb(255, 82, 82, 32),  linewidth=2)
plot(show_ma ? d_sma150 : na, "SMA 150", color=color.blue, linewidth=2)
plot(show_ma ? d_sma200 : na, "SMA 200", color=color.white, linewidth=2)

// CE Trailing Stop -- fuchsia step-line, always visible as a real-time TSL guide
plot(enable_trail ? ce_trailing_stop : na, "CE Trailing Stop", color=color.new(color.fuchsia, 30), linewidth=1, style=plot.style_stepline)

// Active Stop Loss -- only visible when in a position; aggregates the live ratchet SL
float active_sl_plot = strategy.position_size > 0 ? nz(bo_sl, nz(pb_sl, nz(cb_sl_live, rec_sl))) : na
plot(active_sl_plot, "Active Stop Loss", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=2)

// Pre-Stage-2 early warning dot
plotshape(show_signals and wEarlyStage2, "Pre-S2 Warning", style=shape.circle, location=location.abovebar, color=color.new(color.yellow, 20), size=size.tiny, text="PRE-S2", textcolor=color.yellow)

plotshape(show_signals and pos_bo_trigger,  "POS-BO",   style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="BO")
plotshape(show_signals and pos_ac_trigger,  "POS-AC",   style=shape.triangleup, location=location.belowbar, color=color.new(color.teal, 0), size=size.small, text="AC")
plotshape(show_signals and swing_pb_trg,    "SWG-PB",   style=shape.triangleup, location=location.belowbar, color=color.new(color.yellow, 0), size=size.small, text="PB")
plotshape(show_signals and swing_bo_trg,    "SWG-BO",   style=shape.triangleup, location=location.belowbar, color=color.new(color.orange, 0), size=size.small, text="S-BO")
plotshape(show_signals and swing_rev_trg,   "SWG-REV",  style=shape.triangleup, location=location.belowbar, color=color.new(color.fuchsia, 0), size=size.small, text="REV")
plotshape(show_signals and gap_go_trg,      "GAP-GO",   style=shape.triangleup, location=location.belowbar, color=color.new(color.aqua, 0), size=size.small, text="GAP")
plotshape(show_signals and trigger_rev_cb,  "REV-CB",   style=shape.triangleup, location=location.belowbar, color=color.new(color.red, 0), size=size.small, text="CB")
plotshape(show_signals and trigger_rev_rs,  "REV-RS",   style=shape.triangleup, location=location.belowbar, color=color.new(color.purple, 0), size=size.small, text="RS")
plotshape(show_signals and trigger_rev_early,"REV-EAR", style=shape.triangleup, location=location.belowbar, color=color.new(color.blue, 0), size=size.small, text="EAR")

// alert() replaces alertcondition() â€” the latter has no effect inside strategy scripts.
if trigger_bull
    alert("Bullish Setup Triggered", alert.freq_once_per_bar)
if trigger_rec
    alert("Recovery Setup Triggered", alert.freq_once_per_bar)

// ==========================================
// 14. UNIFIED PANEL TABLE
// ==========================================
// Layout: 2 cols Ã— 36 rows
//   Rows  0-16 â†’ Bull Market section
//   Rows 17-35 â†’ Recovery section
// Each section opens with a coloured section-header spanning both columns.
// --- Global-scope calls (Pine CW10003: must run every bar, not inside `if` scope) ---
bool vcp_ok = f_is_vcp(1.5)
bool sqz_ok = f_is_bb_sqz(20)
var table dash = table.new(panel_position, 4, 40, border_width=1, border_color=color.new(color.gray, 40))  // v3.4.2: 36→40 for Wyckoff signal + diag rows

// v2.7 panel-stacking offset: tracks how many rows the main strategy panel used,
// so the CATALYST DIAG panel can start rendering immediately below it (rather
// than to the right). Updated at end of main-panel render block.
var int main_panel_end_row = 0

// ── Shared helpers ─────────────────────────────────────────────────────────
f_row(tbl, r, lbl, val, dynBgCol, lblBg, valTxtCol, lblTxtCol) =>
    table.cell(tbl, 0, r, lbl, bgcolor=lblBg,  text_color=lblTxtCol, text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, r, val, bgcolor=dynBgCol,  text_color=valTxtCol,    text_size=size.small, text_halign=text.align_center)

f_hdr(tbl, r, txt, bg) =>
    table.cell(tbl, 0, r, txt, bgcolor=bg, text_color=color.white, text_size=size.normal,
               text_halign=text.align_left)
    table.cell(tbl, 1, r, "",  bgcolor=bg, text_color=color.white, text_size=size.normal)

// Icon helper for signal hold-window display: 🟢 FIRE | 🟡 HOLD | 🔵 ACTIVE TRADE | ⚫ WAIT
f_bull_icon(int last_bar, int hold_days, string sig_name, string open_cat) =>
    int bars_ago = bar_index - last_bar
    bool is_active_trade = (open_cat == sig_name)
    bars_ago == 0 ? "🟢" : (bars_ago <= hold_days ? "🟡" : (is_active_trade ? "🔵" : "⚫"))

if barstate.islast and show_panel
    // v1.3 aesthetic update matching Beta Edition
    color c_lbl       = color.new(#ffffff, 0)    // pure white label bg
    color c_lbl_txt   = color.new(#000000, 0)    // black label text
    color c_val_txt   = color.new(#000000, 0)    // black value text
    color c_sig_on    = color.new(#26a69a, 0)    // teal (active / pass)
    color c_sig_warn  = color.new(#ff9800, 0)    // orange (hold / warn)
    color c_sig_off   = color.new(#f5f5f5, 0)    // neutral grey
    color c_sig_red   = color.new(#ef5350, 0)    // red (danger / fail)
    color c_head      = color.new(#1e222d, 0)    // dark header

    // ── Shared context ──
    string stage_txt  = "Stage " + str.tostring(current_stage)
    color  stage_col  = current_stage == 2 ? c_sig_on : current_stage == 1 ? c_sig_warn : current_stage == 4 ? c_sig_red : color.orange

    // ──────────────────────────────────────
    //  SECTION A: 🌿 BULL MARKET
    // ──────────────────────────────────────
    int r = 0
    f_hdr(dash, r, "🌿  BULL MARKET STRATEGY", c_head)
    r += 1

    // v2.6: REMOVED duplicate rows (Dashboard / Bull Screener own them):
    //   Weinstein Stage (W) → Dashboard "Market Structure" + "Stage 2 Age"
    //   Alpha Score → Dashboard "Asset Quality"
    //   Stage 2 Freshness → Dashboard "Stage 2 Age" (richer: leg + macro + tag)
    //   Trend Coiling (MA) → Bull Screener G8 "MA Squeeze"
    //   Volatility Squeeze → Bull Screener G9 "BB Squeeze"
    // Unified-unique rows kept: Base Confirmed, Py Score, Pos/Swing signal grids.

    // v2.7: Setup Quality merged into 1 compound row (was 2)
    color  py_col      = py_score >= 70 ? c_sig_on : (py_score >= 45 ? c_sig_warn : c_sig_red)
    string _bull_setup_str = (base_confirmed ? "✓ BASE" : "✗ NO BASE") + " · Py " + str.tostring(py_score) + "/100"
    color  _bull_setup_col = base_confirmed and py_score >= 70 ? c_sig_on : (base_confirmed or py_score >= 45) ? c_sig_warn : c_sig_off
    f_row(dash, r, "BULL SETUP", _bull_setup_str, _bull_setup_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1

    string _ml_prob_str = str.tostring(ml_win_prob, "#.#") + "%" + (ml_rsi_dead_zone ? " (DeadZone)" : "")
    color  _ml_prob_col = ml_win_prob >= 40.0 and not ml_rsi_dead_zone ? c_sig_on : (ml_win_prob >= 35.0 ? c_sig_warn : c_sig_red)
    f_row(dash, r, "ML WIN PROB", _ml_prob_str, _ml_prob_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1

    string current_open_cat = ""
    if strategy.position_size > 0
        current_open_cat := strategy.opentrades.entry_comment(strategy.opentrades - 1)

    color c_sig_active = color.new(#2962ff, 30)  // Blue for active trade state

    // Dominant color for the row: lime if any FIRE, yellow if any HOLD, blue if ACTIVE, gray if all WAIT
    bool any_pos_fire = pos_bo_trigger or pos_ac_trigger
    bool any_pos_hold = (not any_pos_fire) and ((bar_index - last_pos_bo_bar) <= bull_hold_days or (bar_index - last_pos_ac_bar) <= bull_hold_days)
    bool any_pos_active = (not any_pos_fire and not any_pos_hold) and (current_open_cat == "POS-BO" or current_open_cat == "POS-ACCUM")

    bool any_swg_fire = swing_pb_trg or swing_bo_trg or swing_rev_trg or gap_go_trg
    bool any_swg_hold = (not any_swg_fire) and ((bar_index - last_swg_pb_bar) <= bull_hold_days or (bar_index - last_swg_bo_bar) <= bull_hold_days or (bar_index - last_swg_rev_bar) <= bull_hold_days or (bar_index - last_gap_go_bar) <= bull_hold_days)
    bool any_swg_active = (not any_swg_fire and not any_swg_hold) and (current_open_cat == "SWG-PB" or current_open_cat == "SWG-BO" or current_open_cat == "SWG-REV" or current_open_cat == "SWG-GAP")

    color pos_row_col = any_pos_fire ? c_sig_on : (any_pos_hold ? c_sig_warn : (any_pos_active ? c_sig_active : c_sig_off))
    color swg_row_col = any_swg_fire ? c_sig_on : (any_swg_hold ? c_sig_warn : (any_swg_active ? c_sig_active : c_sig_off))

    // Inline text: "SIGNAL_NAME icon" pairs separated by spaces
    string pos_str = "POS-BO " + f_bull_icon(last_pos_bo_bar, bull_hold_days, "POS-BO", current_open_cat) + "  POS-AC " + f_bull_icon(last_pos_ac_bar, bull_hold_days, "POS-ACCUM", current_open_cat)
    string swg_str = "SWG-PB " + f_bull_icon(last_swg_pb_bar, bull_hold_days, "SWG-PB", current_open_cat) + "  SWG-BO " + f_bull_icon(last_swg_bo_bar, bull_hold_days, "SWG-BO", current_open_cat) + "  SWG-REV " + f_bull_icon(last_swg_rev_bar, bull_hold_days, "SWG-REV", current_open_cat) + "  GAP " + f_bull_icon(last_gap_go_bar, bull_hold_days, "SWG-GAP", current_open_cat)

    f_row(dash, r, "Positional Signals", pos_str, pos_row_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1
    f_row(dash, r, "Swing Signals",      swg_str, swg_row_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1

    // ──────────────────────────────────────
    //  SECTION B: 🔄 RECOVERY MARKET
    // ──────────────────────────────────────
    f_hdr(dash, r, "🔄  RECOVERY MARKET STRATEGY", c_head)
    r += 1

    // v2.6: REMOVED duplicate rows (Recovery Screener owns them):
    //   52W Correction (%) → Recovery Screener "CORRECTION" row
    //   CB Pillars         → Recovery Screener "4-pillar" panel
    //   Active Recovery Edge → Recovery Screener "SIGNAL" row
    //   Recovery Score     → Recovery Screener "SCORE / GRADE" row
    // Unified-unique rows kept: Recovery Regime Gate (cross-state aggregator),
    // Recovery Signals (multi-edge hold-window view), RFF.
    //
    // Internal computations preserved (n_pillars, rec_edge_txt, rec_score_val
    // still needed downstream for the catalyst-diag panel and alerts).

    // v2.7: Recovery Regime + RFF Filter merged into 1 compound row (was 2)
    string rec_regime_txt = mkt_idx_corrected ? "MKT-CORR" : mkt_reclaim ? "RECLAIM" : stock_corrected ? "STOCK-CORR" : "OFF"
    string rff_txt_short  = not rff_has_data ? "DATA N/A" : str.tostring(rff_score) + "/6" + (rff_ok ? "✓" : "✗")
    string _rec_state_str = "Regime: " + rec_regime_txt + " · RFF: " + rff_txt_short
    color  _rec_state_col = regime_ok and rff_ok ? c_sig_on : (regime_ok or rff_ok) ? c_sig_warn : c_sig_off
    f_row(dash, r, "REC STATE", _rec_state_str, _rec_state_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1

    // --- Internal computations (kept; used by catalyst-diag panel below and rec_score_val/rec_edge_col references downstream) ---
    int   n_pillars   = (is_stretched ? 1 : 0) + (is_oversold ? 1 : 0) + (climax_bar ? 1 : 0) + (is_turn ? 1 : 0)
    string rec_edge_txt = trigger_rev_early ? "REV-EARLY" : trigger_rev_rs ? "REV-RS" : trigger_rev_cb ? "REV-CB" : "NONE"
    color  rec_edge_col = (trigger_rev_early or trigger_rev_rs or trigger_rev_cb) ? c_sig_on : c_sig_off
    int   rec_score_val = trigger_rev_cb ? n_pillars : trigger_rev_rs ? 4 : trigger_rev_early ? 3 : n_pillars

    // --- Wyckoff Signals compact row (v3.4.2 — priority recovery edge; was missing) ---
    bool any_wyc_fire = trigger_wyc_spring_sos or trigger_wyc_jac or trigger_wyc_sos or trigger_wyc_spring
    bool any_wyc_hold = (not any_wyc_fire) and ((bar_index - last_wyc_ssos_bar) <= bull_hold_days or (bar_index - last_wyc_jac_bar) <= bull_hold_days or (bar_index - last_wyc_sos_bar) <= bull_hold_days or (bar_index - last_wyc_spr_bar) <= bull_hold_days)
    bool any_wyc_active = (not any_wyc_fire and not any_wyc_hold) and (current_open_cat == "WYC-SPRING+SOS" or current_open_cat == "WYC-JAC" or current_open_cat == "WYC-SOS" or current_open_cat == "WYC-SPRING")
    color wyc_sig_row_col = any_wyc_fire ? c_sig_on : (any_wyc_hold ? c_sig_warn : (any_wyc_active ? c_sig_active : c_sig_off))
    string wyc_str = "SPR+SOS " + f_bull_icon(last_wyc_ssos_bar, bull_hold_days, "WYC-SPRING+SOS", current_open_cat) + "  JAC " + f_bull_icon(last_wyc_jac_bar, bull_hold_days, "WYC-JAC", current_open_cat) + "  SOS " + f_bull_icon(last_wyc_sos_bar, bull_hold_days, "WYC-SOS", current_open_cat) + "  SPRING " + f_bull_icon(last_wyc_spr_bar, bull_hold_days, "WYC-SPRING", current_open_cat)
    f_row(dash, r, "Wyckoff Signals", wyc_str, wyc_sig_row_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1

    // --- Recovery Signals compact row (FIRE / HOLD / ACTIVE / WAIT per signal) ---
    bool any_rec_fire = trigger_rev_cb or trigger_rev_rs or trigger_rev_early
    bool any_rec_hold = (not any_rec_fire) and ((bar_index - last_rev_cb_bar) <= bull_hold_days or (bar_index - last_rev_rs_bar) <= bull_hold_days or (bar_index - last_rev_ear_bar) <= bull_hold_days)
    bool any_rec_active = (not any_rec_fire and not any_rec_hold) and (current_open_cat == "REV-CB" or current_open_cat == "REV-RS" or current_open_cat == "REV-EARLY")

    color rec_sig_row_col = any_rec_fire ? c_sig_on : (any_rec_hold ? c_sig_warn : (any_rec_active ? c_sig_active : c_sig_off))
    string rec_str = "REV-CB " + f_bull_icon(last_rev_cb_bar, bull_hold_days, "REV-CB", current_open_cat) + "  REV-RS " + f_bull_icon(last_rev_rs_bar, bull_hold_days, "REV-RS", current_open_cat) + "  REV-EAR " + f_bull_icon(last_rev_ear_bar, bull_hold_days, "REV-EARLY", current_open_cat)
    f_row(dash, r, "Recovery Signals", rec_str, rec_sig_row_col, c_lbl, c_val_txt, c_lbl_txt)
    r += 1

    // v2.8.1: "See Other Tools" footer moved to bottom of CATALYST DIAG panel
    //   (rendered there as the very last row, full-width).
    // v2.7: expose main panel end row so the catalyst-diag panel below can stack.
    main_panel_end_row := r

// ==========================================
// 16. v2.5 ENHANCEMENTS — Hit Counters, Alerts, Diagnostic Panel
// ==========================================

// ── E6: Per-catalyst hit counters (plotted to Data Window) ──────────────────
var int hits_pos_bo  = 0
var int hits_pos_ac  = 0
var int hits_swg_pb  = 0
var int hits_swg_bo  = 0
var int hits_swg_rev = 0
var int hits_gap_go  = 0
var int hits_rev_cb  = 0
var int hits_rev_rs  = 0
var int hits_rev_ear = 0
var int hits_wyc_ssos = 0  // v3.4.2
var int hits_wyc_jac  = 0
var int hits_wyc_sos  = 0
var int hits_wyc_spr  = 0
if pos_bo_trigger
    hits_pos_bo  += 1
if pos_ac_trigger
    hits_pos_ac  += 1
if swing_pb_trg
    hits_swg_pb  += 1
if swing_bo_trg
    hits_swg_bo  += 1
if swing_rev_trg
    hits_swg_rev += 1
if gap_go_trg
    hits_gap_go  += 1
if trigger_rev_cb
    hits_rev_cb  += 1
if trigger_rev_rs
    hits_rev_rs  += 1
if trigger_rev_early
    hits_rev_ear += 1
if trigger_wyc_spring_sos
    hits_wyc_ssos += 1
if trigger_wyc_jac
    hits_wyc_jac  += 1
if trigger_wyc_sos
    hits_wyc_sos  += 1
if trigger_wyc_spring
    hits_wyc_spr  += 1
plot(hits_pos_bo,  "Hits POS-BO",    display=display.data_window)
plot(hits_pos_ac,  "Hits POS-ACCUM", display=display.data_window)
plot(hits_swg_pb,  "Hits SWG-PB",    display=display.data_window)
plot(hits_swg_bo,  "Hits SWG-BO",    display=display.data_window)
plot(hits_swg_rev, "Hits SWG-REV",   display=display.data_window)
plot(hits_gap_go,  "Hits SWG-GAP",   display=display.data_window)
plot(hits_rev_cb,  "Hits REV-CB",    display=display.data_window)
plot(hits_rev_rs,  "Hits REV-RS",    display=display.data_window)
plot(hits_rev_ear, "Hits REV-EARLY", display=display.data_window)

// ── E12: Alerts per catalyst + composites (Pine v6: alert() in strategies) ──
// alertcondition() has no effect inside strategies — must use alert() runtime call.
// Configure a single TradingView alert on the strategy with frequency "Any alert
// function call" — every alert() below will route through it with its message.
f_send_alert(string txt_msg, float entry_px, float sl_px, float tp_px, float qty_val) =>
    string alert_msg = txt_msg
    if use_webhook_json
        alert_msg := '{"ticker":"' + syminfo.prefix + ':' + syminfo.ticker + '", "action":"BUY", "entry":' + str.tostring(nz(entry_px, close), "#.##") + ', "sl":' + str.tostring(nz(sl_px, close * 0.95), "#.##") + ', "tp":' + str.tostring(nz(tp_px, close * 1.10), "#.##") + ', "qty":' + str.tostring(math.max(1, math.round(nz(qty_val, 1.0))), "#") + '}'
    alert(alert_msg, alert.freq_once_per_bar_close)

if pos_bo_trigger
    f_send_alert("WCL v2.5: POS-BO catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if pos_ac_trigger
    f_send_alert("WCL v2.5: POS-ACCUM catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if swing_pb_trg
    f_send_alert("WCL v2.5: SWG-PB (Pullback) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if swing_bo_trg
    f_send_alert("WCL v2.5: SWG-BO (Breakout) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if swing_rev_trg
    f_send_alert("WCL v2.5: SWG-REV (Reversion) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if gap_go_trg
    f_send_alert("WCL v2.5: SWG-GAP (Gap & Go) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_rev_cb
    f_send_alert("WCL v2.5: REV-CB (Climax Bottom) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_rev_rs
    f_send_alert("WCL v2.5: REV-RS (RS Survivor) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_rev_early
    f_send_alert("WCL v2.5: REV-EARLY (Early Bird) catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_wyc_spring_sos
    f_send_alert("WCL v3.4: WYC-SPRING+SOS catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_wyc_jac
    f_send_alert("WCL v3.4: WYC-JAC catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_wyc_sos
    f_send_alert("WCL v3.4: WYC-SOS catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_wyc_spring
    f_send_alert("WCL v3.4: WYC-SPRING catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_bull
    f_send_alert("WCL v2.5: A Bull catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)
if trigger_rec
    f_send_alert("WCL v2.5: A Recovery catalyst fired on " + syminfo.ticker, close, current_sl, tp_price, qty)

// ── E1: Diagnostic Panel — per-catalyst first-blocking-gate attribution ─────
if use_diag_panel and barstate.islast

    _diag_position = position.bottom_right
    if diag_pos == "Top Left"
        _diag_position := position.top_left
    else if diag_pos == "Top Right"
        _diag_position := position.top_right
    else if diag_pos == "Middle Right"
        _diag_position := position.middle_right
    else if diag_pos == "Bottom Left"
        _diag_position := position.bottom_left
    _diag_size = diag_sz == "Tiny" ? size.tiny : diag_sz == "Normal" ? size.normal : size.small

    color D_BG       = color.new(#ffffff, 0)
    color D_HDR      = color.new(#1e222d, 0)
    color D_HDR_TXT  = color.new(#ffffff, 0)
    color D_LBL_BG   = color.new(#f7f9fc, 0)
    color D_VAL_TXT  = color.new(#000000, 0)
    color D_FIRE     = color.new(#1de9b6, 0)
    color D_PASS     = color.new(#26a69a, 0)
    color D_BLOCK    = color.new(#ef5350, 0)
    color D_NEUT     = color.new(#f5f5f5, 0)

    // POS-BO
    // ·mature = Stage-2 freshness is a STATUS tag now (eyeball), not a block (2026-07-02).
    string diag_pos_bo = (mkt_bull ? "✓ FIRE" : "✓ FIRE ½⚠ ctr-trend") + (stage2_fresh_ok ? "" : " ·mature")
    color  diag_pos_bo_c = D_FIRE
    if not pos_bo_trigger
        diag_pos_bo_c := D_BLOCK
        if not use_bull_mode
            diag_pos_bo := "✗ bull mode off"
        else if not use_pos_bo
            diag_pos_bo := "✗ edge off"
        else if not base_confirmed
            diag_pos_bo := "✗ base_confirmed"
        // alpha DEMOTED (2026-07-02): no longer a POS-BO block reason — alpha is status.
        else if not (bo_conf == "Daily Close" ? bo_window_ok : high > bo_level)
            diag_pos_bo := "✗ breakout (no 3-bar close>ceiling)"
        else if not (volume > vol_ma * 1.25 or volume[1] > vol_ma[1] * 1.25 or volume[2] > vol_ma[2] * 1.25)
            diag_pos_bo := "✗ vol<1.25× (last 3 bars)"
        // v3.4.1 (2026-06-08): diag matched to the ACTUAL PA trigger. POS-BO no longer
        // gates on weekly-RSI or ADX — it uses pa_wk_mom (wClose>wClose[5]) + pa_dir_ok
        // (>=7/14 up-bars). The stale wRSI/ADX reasons were reporting blocks that aren't
        // in the trigger (the diag-vs-trigger drift Jay caught correlating the guides).
        else if not pa_wk_mom
            diag_pos_bo := "✗ wk-momentum (wClose≤5w-ago close)"
        else if not pa_dir_ok
            diag_pos_bo := "✗ PA dir (<5/14 up-bars)"

    // POS-ACCUM
    string diag_pos_ac = mkt_bull ? "✓ FIRE" : "✓ FIRE ½⚠ ctr-trend"
    color  diag_pos_ac_c = D_FIRE
    if not pos_ac_trigger
        diag_pos_ac_c := D_BLOCK
        if not use_bull_mode
            diag_pos_ac := "✗ bull mode off"
        else if not use_pos_accum
            diag_pos_ac := "✗ edge off"
        else if not accum_base
            diag_pos_ac := "✗ accum_base (stage/200/RS/vol)"
        // alpha DEMOTED (2026-07-02): no longer a POS-ACCUM block reason — alpha is status.
        else if not obv_trending_up
            diag_pos_ac := "✗ OBV slope"
        else if not is_vcp_accum
            diag_pos_ac := "✗ VCP-accum (loose) fail"
        else if not (close > bo_level_30 * 0.9)
            diag_pos_ac := "✗ price<0.9×30dHi"
        else if not pa_not_extended
            diag_pos_ac := "✗ extended (close>close[5]×1.05)"

    // SWG-PB
    string diag_swg_pb = mkt_bull ? "✓ FIRE" : "✓ FIRE ½⚠ ctr-trend"
    color  diag_swg_pb_c = D_FIRE
    if not swing_pb_trg
        diag_swg_pb_c := D_BLOCK
        if not use_bull_mode
            diag_swg_pb := "✗ bull mode off"
        else if not use_swing_pb
            diag_swg_pb := "✗ edge off"
        else if not is_ema_pb_zone
            diag_swg_pb := "✗ ema pullback zone"
        else if not is_vcp_tight
            diag_swg_pb := "✗ VCP not tight"
        else if not pb_ma_stack
            diag_swg_pb := "✗ MA stack (150>200)"
        else if not pb_pocket_pa
            diag_swg_pb := "✗ pullback PA pocket"
        else if not vol_vdu_ok
            diag_swg_pb := "✗ vol not dry"

    // SWG-BO
    string diag_swg_bo = mkt_bull ? "✓ FIRE" : "✓ FIRE ½⚠ ctr-trend"
    color  diag_swg_bo_c = D_FIRE
    if not swing_bo_trg
        diag_swg_bo_c := D_BLOCK
        if not use_bull_mode
            diag_swg_bo := "✗ bull mode off"
        else if not use_swing_bo
            diag_swg_bo := "✗ edge off"
        else if not bo_minervini
            diag_swg_bo := "✗ trend (need close>50>150>200)"
        else if not is_vcp_swg
            diag_swg_bo := "✗ VCP not tight (1.5×)"
        else if not bo_pivot15
            diag_swg_bo := "✗ breakout (px<15-bar pivot)"
        else if not (volume > vol_ma * 1.25)
            diag_swg_bo := "✗ vol<1.25×"
        else if not bo_anti_algo
            diag_swg_bo := "✗ anti-algo (weak close)"

    // SWG-REV
    string diag_swg_rev = "✓ FIRE"
    color  diag_swg_rev_c = D_FIRE
    if not swing_rev_trg
        diag_swg_rev_c := D_BLOCK
        if not use_bull_mode
            diag_swg_rev := "✗ bull mode off"
        else if not use_swing_rev
            diag_swg_rev := "✗ edge off"
        else if stage4_dntrend
            diag_swg_rev := "✗ stage 4"
        else if not rev_struct
            diag_swg_rev := "✗ rev struct"
        else if not pa_oversold_pa
            diag_swg_rev := "✗ not 3 lower closes (PA oversold)"
        else if not (close > open)
            diag_swg_rev := "✗ not green bar"
        else if not (close > high[1])
            diag_swg_rev := "✗ close not > prev hi"

    // SWG-GAP
    string diag_swg_gap = mkt_bull ? "✓ FIRE" : "✓ FIRE ½⚠ ctr-trend"
    color  diag_swg_gap_c = D_FIRE
    if not gap_go_trg
        diag_swg_gap_c := D_BLOCK
        if not use_bull_mode
            diag_swg_gap := "✗ bull mode off"
        else if not use_swing_gap
            diag_swg_gap := "✗ edge off"
        else if not gap_up
            diag_swg_gap := "✗ no gap up"
        else if not (gap_pct >= 0.04)
            diag_swg_gap := "✗ gap<4% (" + str.tostring(gap_pct * 100, "#.#") + "%)"
        else if not (gap_intra_pos >= 0.60)
            diag_swg_gap := "✗ intra pos<60%"
        else if not (volume > vol_ma * 3.0)
            diag_swg_gap := "✗ vol<3×"

    // REV-CB
    string diag_rev_cb = "✓ FIRE"
    color  diag_rev_cb_c = D_FIRE
    if not trigger_rev_cb
        diag_rev_cb_c := D_BLOCK
        if not use_rec_mode
            diag_rev_cb := "✗ rec mode off"
        else if not use_rev_cb
            diag_rev_cb := "✗ edge off"
        else if not recent_climax
            diag_rev_cb := "✗ no climax (last " + str.tostring(cb_climax_window) + "b)"
        else if not is_turn
            diag_rev_cb := "✗ no turn bar"
        else if not rff_ok
            diag_rev_cb := "✗ RFF (" + str.tostring(rff_score) + ")"
        else if not regime_ok
            diag_rev_cb := "✗ regime"
        else if na(cb_sl_raw)
            diag_rev_cb := "✗ no SL anchor"

    // REV-RS
    string diag_rev_rs = "✓ FIRE"
    color  diag_rev_rs_c = D_FIRE
    if not trigger_rev_rs
        diag_rev_rs_c := D_BLOCK
        if not use_rec_mode
            diag_rev_rs := "✗ rec mode off"
        else if not use_rev_rs
            diag_rev_rs := "✗ edge off"
        else if not rs_positive
            diag_rev_rs := "✗ RS slope ≤0"
        else if not rs_recovery_state
            diag_rev_rs := "✗ no HL+trend up"
        else if not stock_corrected
            diag_rev_rs := "✗ not corrected (" + str.tostring(correction_depth * 100, "#.#") + "%)"
        else if not rs_breakout
            diag_rev_rs := "✗ no RS breakout"
        else if not sector_stage_ok
            diag_rev_rs := "✗ sector not S1/S2"
        else if not rff_ok
            diag_rev_rs := "✗ RFF (" + str.tostring(rff_score) + ")"
        else if not regime_ok
            diag_rev_rs := "✗ regime"

    // REV-EARLY
    string diag_rev_ear = "✓ FIRE"
    color  diag_rev_ear_c = D_FIRE
    if not trigger_rev_early
        diag_rev_ear_c := D_BLOCK
        if not use_rec_mode
            diag_rev_ear := "✗ rec mode off"
        else if not use_rev_early
            diag_rev_ear := "✗ edge off"
        else if not trendline_reclaim
            diag_rev_ear := "✗ no TL reclaim"
        else if not rs_recovery_state
            diag_rev_ear := "✗ no HL+trend up"
        else if not base_compressed
            diag_rev_ear := "✗ no NR7/inside"
        else if not early_break
            diag_rev_ear := "✗ no early break"
        else if not rs_positive
            diag_rev_ear := "✗ RS slope ≤0"
        else if not sector_stage_ok
            diag_rev_ear := "✗ sector not S1/S2"
        else if not rff_ok
            diag_rev_ear := "✗ RFF (" + str.tostring(rff_score) + ")"
        else if not regime_ok
            diag_rev_ear := "✗ regime"

    // WYC-SPRING+SOS (v3.4.2 — was missing from diag panel)
    string diag_wyc_ssos = "✓ FIRE"
    color  diag_wyc_ssos_c = D_FIRE
    if not trigger_wyc_spring_sos
        diag_wyc_ssos_c := D_BLOCK
        diag_wyc_ssos := not use_rec_mode ? "✗ rec mode off" : not wyc_in_base ? "✗ no Wyckoff base" : not wyc_has_spring ? "✗ no Spring (C)" : not wyc_has_sos ? "✗ no SOS (D)" : not regime_ok ? "✗ regime" : "✗"

    // WYC-JAC
    string diag_wyc_jac = "✓ FIRE"
    color  diag_wyc_jac_c = D_FIRE
    if not trigger_wyc_jac
        diag_wyc_jac_c := D_BLOCK
        diag_wyc_jac := not use_rec_mode ? "✗ rec mode off" : not wyc_in_base ? "✗ no Wyckoff base" : not wyc_has_jac ? "✗ no JAC (cross creek)" : not regime_ok ? "✗ regime" : "✗"

    // WYC-SOS (alone — not also Spring/JAC)
    string diag_wyc_sos = "✓ FIRE"
    color  diag_wyc_sos_c = D_FIRE
    if not trigger_wyc_sos
        diag_wyc_sos_c := D_BLOCK
        diag_wyc_sos := not use_rec_mode ? "✗ rec mode off" : not wyc_has_sos ? "✗ no SOS (D)" : (wyc_has_spring or wyc_has_jac) ? "✗ shown as SPR+SOS/JAC" : not regime_ok ? "✗ regime" : "✗"

    // WYC-SPRING (alone — not also SOS/JAC)
    string diag_wyc_spr = "✓ FIRE"
    color  diag_wyc_spr_c = D_FIRE
    if not trigger_wyc_spring
        diag_wyc_spr_c := D_BLOCK
        diag_wyc_spr := not use_rec_mode ? "✗ rec mode off" : not wyc_has_spring ? "✗ no Spring (C)" : (wyc_has_sos or wyc_has_jac) ? "✗ shown as SPR+SOS/JAC" : not regime_ok ? "✗ regime" : "✗"

    // ============================================================================
    // v2.7 LAYOUT: CATALYST DIAG now renders BELOW the main strategy panel,
    // distributed across all 4 columns (2 catalysts per row). Evens out the
    // table — no more right-side panel ending earlier than the main one.
    // Starts at row `main_panel_end_row` when show_panel is on; else row 0.
    // ============================================================================
    int dr = show_panel ? main_panel_end_row : 0

    // ── Main DIAG header (full width, merged cols 0-3) ──────────────────────
    table.cell(dash, 0, dr, "◈ CATALYST DIAG  (catalyst · ✓ FIRE / ✗ first-blocking-gate [hits])", text_color=D_HDR_TXT, text_size=_diag_size, bgcolor=D_HDR, text_halign=text.align_left)
    table.merge_cells(dash, 0, dr, 3, dr)
    dr += 1

    // ── BULL CATALYSTS section header (full width) ──────────────────────────
    table.cell(dash, 0, dr, "── 🌿 BULL ──", text_color=D_HDR_TXT, text_size=_diag_size, bgcolor=D_HDR, text_halign=text.align_center)
    table.merge_cells(dash, 0, dr, 3, dr)
    dr += 1

    // ── BULL: 6 catalysts → 3 paired rows (cols 0-1 = A, cols 2-3 = B) ──────
    table.cell(dash, 0, dr, "POS-BO",    text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_pos_bo + " [" + str.tostring(hits_pos_bo) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_pos_bo_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "POS-ACCUM", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, diag_pos_ac + " [" + str.tostring(hits_pos_ac) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_pos_ac_c, text_halign=text.align_left)
    dr += 1

    table.cell(dash, 0, dr, "SWG-PB",    text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_swg_pb + " [" + str.tostring(hits_swg_pb) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_swg_pb_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "SWG-BO",    text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, diag_swg_bo + " [" + str.tostring(hits_swg_bo) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_swg_bo_c, text_halign=text.align_left)
    dr += 1

    table.cell(dash, 0, dr, "SWG-REV",   text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_swg_rev + " [" + str.tostring(hits_swg_rev) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_swg_rev_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "SWG-GAP",   text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, diag_swg_gap + " [" + str.tostring(hits_gap_go) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_swg_gap_c, text_halign=text.align_left)
    dr += 1

    // ── RECOVERY section header (full width) ────────────────────────────────
    table.cell(dash, 0, dr, "── 🔄 RECOVERY ──", text_color=D_HDR_TXT, text_size=_diag_size, bgcolor=D_HDR, text_halign=text.align_center)
    table.merge_cells(dash, 0, dr, 3, dr)
    dr += 1

    // ── WYCKOFF (priority recovery edge): 4 catalysts → 2 paired rows ───────
    table.cell(dash, 0, dr, "WYC-SPR+SOS", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_wyc_ssos + " [" + str.tostring(hits_wyc_ssos) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_wyc_ssos_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "WYC-JAC",     text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, diag_wyc_jac + " [" + str.tostring(hits_wyc_jac) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_wyc_jac_c, text_halign=text.align_left)
    dr += 1

    table.cell(dash, 0, dr, "WYC-SOS",     text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_wyc_sos + " [" + str.tostring(hits_wyc_sos) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_wyc_sos_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "WYC-SPRING",  text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, diag_wyc_spr + " [" + str.tostring(hits_wyc_spr) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_wyc_spr_c, text_halign=text.align_left)
    dr += 1

    // ── RECOVERY (legacy REV-* edges): 3 catalysts → 1 paired row + 1 solo ──
    table.cell(dash, 0, dr, "REV-CB",    text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_rev_cb + " [" + str.tostring(hits_rev_cb) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_rev_cb_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "REV-RS",    text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, diag_rev_rs + " [" + str.tostring(hits_rev_rs) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_rev_rs_c, text_halign=text.align_left)
    dr += 1

    table.cell(dash, 0, dr, "REV-EARLY", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, diag_rev_ear + " [" + str.tostring(hits_rev_ear) + "]", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=diag_rev_ear_c, text_halign=text.align_left)
    table.cell(dash, 2, dr, "",          bgcolor=color.new(#1a1d28, 0))
    table.cell(dash, 3, dr, "",          bgcolor=color.new(#1a1d28, 0))
    dr += 1

    // ── v2.9 RRG section header (full width) ────────────────────────────────
    table.cell(dash, 0, dr, "── ◇ RRG (vs N500) ──", text_color=D_HDR_TXT, text_size=_diag_size, bgcolor=D_HDR, text_halign=text.align_center)
    table.merge_cells(dash, 0, dr, 3, dr)
    dr += 1

    // ── RRG row: quadrant + arrow + score + tradeable. Full-width merged. ───
    // Color: tradeable=true → green, tradeable=false → red (cliff-edge LEADING etc.)
    string _rrg_score_sign = rs_rrg_score > 0 ? "+" : ""
    string _rrg_tr_tag     = rs_tradeable ? "✓ BUY OK" : "✗ WAIT"
    string _rrg_row_txt    = rs_quadrant + " " + _rrg_arrow + "  " + _rrg_score_sign + str.tostring(rs_rrg_score) + "  ·  " + _rrg_traj + "  ·  " + _rrg_tr_tag + "  (RS-Ratio " + str.tostring(rsVal500 + 100, "#.#") + ")"
    color _rrg_row_bg      = rs_tradeable ? color.new(#26a69a, 70) : color.new(#ef5350, 50)
    table.cell(dash, 0, dr, _rrg_row_txt, text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=_rrg_row_bg, text_halign=text.align_left)
    table.merge_cells(dash, 0, dr, 3, dr)
    dr += 1

    // ── META section header (full width) ────────────────────────────────────
    table.cell(dash, 0, dr, "── 🛈 META ──", text_color=D_HDR_TXT, text_size=_diag_size, bgcolor=D_HDR, text_halign=text.align_center)
    table.merge_cells(dash, 0, dr, 3, dr)
    dr += 1

    // ── META: Sector Ticker + WCL Gate paired on 1 row ──────────────────────
    string sec_path = use_auto_sec ? "AUTO" : "MANUAL"
    string sec_val  = sectorTicker + " [" + sec_path + "] (S" + str.tostring(_sec_stage) + ")"
    string wcl_state = not use_wcl_gate ? "OFF" : (wcl_ok ? "✓ PASS (" + str.tostring(wcl_score_source, "#") + ")" : "✗ FAIL (" + str.tostring(wcl_score_source, "#") + "<" + str.tostring(wcl_score_min) + ")")
    color  wcl_col   = not use_wcl_gate ? D_NEUT : (wcl_ok ? D_FIRE : D_BLOCK)
    table.cell(dash, 0, dr, "Sector Ticker", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, sec_val,         text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=sector_stage_ok ? D_FIRE : D_BLOCK, text_halign=text.align_left)
    table.cell(dash, 2, dr, "WCL Gate",      text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 3, dr, wcl_state,       text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=wcl_col, text_halign=text.align_left)
    dr += 1

    // Base Confirm Path — solo row (right side empty)
    string bc_path = base_confirmed ? (mature_trend_ok ? "MATURE EXEMPT" : "WEINSTEIN") : "BLOCKED"
    color  bc_col  = base_confirmed ? (mature_trend_ok ? D_PASS : D_FIRE) : D_BLOCK
    table.cell(dash, 0, dr, "Base Confirm Path", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=D_LBL_BG, text_halign=text.align_left)
    table.cell(dash, 1, dr, bc_path + " (WStg:" + str.tostring(nz(wStageWks, 0)) + "w)", text_color=D_VAL_TXT, text_size=_diag_size, bgcolor=bc_col, text_halign=text.align_left)
    table.cell(dash, 2, dr, "", bgcolor=color.new(#1a1d28, 0))
    table.cell(dash, 3, dr, "", bgcolor=color.new(#1a1d28, 0))
    dr += 1

    // ── v2.8.3: "See Other Tools" footer — label in col 0, description merged across cols 1-3 ─
    //   Matches the rest of the panel's label/value pattern (label left, value right).
    //   Merge spans only cols 1-3, leaving col 0 free for the label. Writes
    //   must happen BEFORE the merge call (Pine v6 drops post-merge writes).
    table.cell(dash, 0, dr, "→ See Other Tools:", text_color=color.new(color.silver, 0), bgcolor=color.new(#0f2235, 0), text_size=_diag_size, text_halign=text.align_left)
    table.cell(dash, 1, dr, "Dashboard (RS/Stage/PA)  ·  Bull Screener (Gates/Levels)  ·  Recovery Screener (Pillars/RFF)", text_color=color.new(color.silver, 0), bgcolor=color.new(#0f2235, 0), text_size=_diag_size, text_halign=text.align_left)
    table.merge_cells(dash, 1, dr, 3, dr)
    dr += 1
