//@version=6
// ==========================================
// CHANGELOG v3.4.2 (2026-06-09) — Panel: surface Wyckoff catalysts (display-only)
// ==========================================
// The v3.4 port ADDED the WYC-SPRING/SOS/JAC triggers, entries, SL and targets
// but never surfaced them on the dashboard — the "Recovery Signals" row + the
// CATALYST DIAG sub-panel only listed REV-CB/REV-RS/REV-EARLY, so a live Wyckoff
// trade read as "WAIT" across the legacy edges. Pure display fix (zero signal/
// entry-logic change):
//   • New "Wyckoff Signals" row on the main panel (FIRE/HOLD/ACTIVE per WYC edge).
//   • Wyckoff hold-window bar trackers + hit counters.
//   • New WYCKOFF block in CATALYST DIAG (first-blocking-gate per WYC edge).
//   • dash table 36→40 rows to fit the new rows.
//
// CHANGELOG v3.4 (2026-05-21) — Ecosystem sync: POS-ACCUM out, Wyckoff in
// ==========================================
// Audit found Pine Strategy was still running pre-Wyckoff stack while Python +
// Pine Recovery Screener had moved on. This release fixes:
//   • POS-ACCUM entries DISABLED (was: -10.04% mean alpha, 0/5 wins in 12-anchor
//     backtest). Trigger still computed for funnel diagnostics, but not routed.
//   • REV-CB / REV-RS / REV-EARLY entries DISABLED (was: -5.25% cum alpha).
//     Logic kept for backward-compat trackers; no longer feeds active_catalyst.
//   • WYCKOFF Spring/SOS/JAC catalysts ADDED as primary recovery edges (+6.39%
//     cum alpha in same backtest). Ported from Pine Recovery Screener v2.0.
//   • Wyckoff SL = base low − 0.3 ATR (structural).
//   • Wyckoff T1 = 5R, T2 = max(10R, 52w high). T1 partial = 25%.
//   • Wyckoff trail = Chandelier ratchet (same as POS — let winners run).
//   • Wyckoff time-stop = positional (pos_time_stop_weeks × 5 bars).
//
// Now in sync with: Python bull_screener.py v1.9, recovery_screener.py v3.0,
// Pine Bull Screener v3.2, Pine Recovery Screener v2.0, Dashboard v67.4.4.
//
// ==========================================
// CHANGELOG v3.3 (2026-05-21) — Catalyst-differentiated T1/T2 targets
// ==========================================
// v3.1/v3.2 used 5R/10R for ALL non-mean-rev catalysts. Honest reflection:
// swing trades (SWG-BO/PB, 1-4 week holds) cannot realistically reach 10R
// targets. Setting wide targets they never hit just leaves the targets unused
// and the trade exits via trail. Positional trades CAN reach 10R because
// they hold for months. Recognizing this:
//
//   POS-BO/POS-ACCUM  : T1=5R, T2=10R  ← positional (2-12mo)
//   SWG-BO/SWG-PB     : T1=3R, T2=5R   ← swing (1-4 weeks)
//   SWG-GAP           : T1=2R, T2=4R   ← gap fades fast
//   SWG-REV           : T1=2R, T2=2R   ← mean-rev quick exit (kept)
//   WYC-* (recovery)  : T1=5R, T2=10R  ← post-accumulation runs
//
// T1 partial-take sizes also adjusted: SWG-BO/PB now 33% (was 25%) since
// shorter trades need to lock more profit on first target.
//
// ==========================================
// CHANGELOG v3.2 (2026-05-21) — Widened trails to match 5R/10R targets
// ==========================================
// v3.1 moved T1 from 2.5R → 5R and T2 from 3.5R → 10R, but trails stayed at
// EMA20 + Chandelier 3 ATR. Result: trades stopped on routine pullbacks
// before reaching the wider targets — defeated the purpose of "let winners run".
//
// FIXES:
//   • Chandelier ATR multiplier: 3.0 → 4.5 (allows ~30% pullback from peak
//     on a 10R runner instead of ~15%).
//   • SWG trail: EMA20 → SMA50 (~3× wider band, ~15-25% pullback tolerance
//     vs ~5-10% for EMA20). Trade comment renamed "EMA20 Trail" → "SMA50 Trail".
//   • 50MA Fail hard-close kept as fast structural exit (fires at EXACT SMA50
//     close vs trail's SMA50*0.99 stop — slight overlap, complementary).
//
// REV-CB / REV-RS / REV-EARLY trails UNCHANGED — those are tactical recovery
// trades by design; their post-T1 trail at EMA20 / Chandelier is appropriate.
//
// ==========================================
// CHANGELOG v3.1 (2026-05-20) — Let Winners Run
// ==========================================
// PROBLEM IDENTIFIED:
//   Backtest on 4 symbols (LAURUSLABS/RELIANCE/TCS/BAJFINANCE) showed the
//   v2.8.3 strategy made <0.3% net profit over 20+ years vs Buy & Hold of
//   3,691× on BAJFINANCE, 56× on RELIANCE. Three structural leaks:
//     1. `strategy.position_size == 0` guard rejected 90%+ of catalyst signals
//        despite max_open_positions=6 input being available.
//     2. T1 partial profit at 2-2.5R closed winners on first weekly pullback.
//     3. T2 at 3-3.5R locked in tiny gains; trail stop trimmed runners.
//   Profit factors were strong (1.89-14.13) — the strategy just wasn't
//   *in trades* long enough or often enough.
//
// FIXES:
//   • Removed `strategy.position_size == 0` guard. Now uses max_open_positions
//     (default 6) as the actual cap. Strategy can pyramid into running winners.
//   • T1 targets: POS 2.5R → 5R, SWG 2-2.5R → 5R, REV-* 2.5R → 5R
//     (SWG-REV kept at 2R — mean-reversion needs tight exits)
//   • T1 partial-take size: 30-50% → 25% (keep more runner)
//   • T2 targets: SWG 3-3.5R → 10R; POS now gets T2 (was none); REV-CB
//     upgraded from SMA200 reclaim to 52W high
//   • T2 partial size: 50% → 25%
//
// EXPECTED IMPACT:
//   Lower profit factor (more time in trade = more whipsaw exposure) but
//   dramatically larger absolute returns by capturing trends to completion.
//
// ==========================================
// CHANGELOG v2.9 (2026-05-19) — JdK RRG migration + validated score
// ==========================================
//   FORMULA: f_rs_math() switched from single-pass Mansfield to JdK 2-pass
//     RS-Ratio / RS-Momentum (StockCharts default, length=10). Now matches
//     Dashboard v67.4 and Bull Screener Python v1.6 — three components agree.
//
//   SCORING: RRG block at L1385-1391 (LEADING +5 / WEAKENING -10 / LAGGING -5)
//     replaced with validated +5/-5 binary on RS-Ratio side. Backed by n=5,460
//     universe-wide backtest (Nifty 500 × 12 anchors): only signal that survived
//     larger sample. Old matrix had cells inverted at higher n.
//
//   NEW: f_rrg_info() helper returns [arrow, traj, cur, nxt, score, tradeable].
//     `rs_tradeable` is now available downstream as an entry-timing gate
//     (separate from the ranking score). Cliff-edge LEADING -> WEAKENING and
//     all LAGGING positions evaluate to tradeable=false.
//
//   INPUTS ADDED: jdkLength (10), rrgTrailLen (4). Legacy rsLength/rs_slope_weeks
//     retained for the slope arrow direction.
//
// ==========================================
// CHANGELOG v2.5 (Enhancement pass over v2.4 — 2026-05-17)
//   ENHANCEMENTS
//   • E1  Catalyst Diagnostic Panel — toggleable floating table showing
//         per-catalyst gate pass/fail and the FIRST blocking gate. Removes
//         the "why isn't it firing" mystery on any chart in 5 seconds.
//   • E2  Hunter v1 FINAL gate wiring — DELIVERED in v2.4 as B1a + B1b
//         (the original v2.3 changelog promised them; v2.4 actually wired
//         them in). Explicitly noted here for traceability — see v2.4
//         changelog block below for details.
//   • E3  stage2_fresh_max is now an input (default 26, range 4–104).
//         Lets you widen the freshness gate for mature trends without
//         editing source. Replaces hardcoded 26 in stage2_fresh_ok.
//   • E4  trend_template_low_mult and trend_template_high_pct inputs.
//         Defaults preserve v2.4 behavior (1.30 / 0.75); surface for tuning.
//   • E5  Mature Trend Exemption — `mature_trend_ok` bypass path that
//         allows established Stage 2 leaders (LEADING RS, beyond freshness
//         window, holding above EMA20) to satisfy base_confirmed.
//         Toggle via use_mature_trend_exempt input. Default ON.
//   • E6  Per-catalyst hit counters plotted to Data Window. Lets you
//         see firing-frequency funnel across backtest range.
//   • E7  Sector lookup diagnostics — resolved sector ticker + path
//         (DB vs keyword fallback) shown in diagnostic panel.
//   • E8  cb_vol_mult default range surfaced; tooltip clarifies 1.8–3.0
//         is typical. (Existing input now better documented.)
//   • E9  RFF FY → FQ fallback. When use_rff_fq_fallback is on, missing
//         FY fields are backfilled with the latest FQ value. Improves
//         coverage on small/midcap NSE listings with sparse FY data.
//   • E10 calc_on_every_tick — REVERTED to true (compile pass v2.5.1):
//         Pine v6 warns when barstate.islast is used without calc_on_every_tick.
//         Both the existing dashboard panel (line ~1746) and the new diag panel
//         depend on barstate.islast firing on realtime bars. Performance gain
//         not worth the operational friction. Accept the per-tick recalc cost.
//   • E11 Optional WCL Context Layers gate — input.source for WCL setup
//         priority plot. When use_wcl_gate is on, catalysts require
//         wcl_score_source >= wcl_score_min before firing. Bring in
//         Context Layers cross-confirmation without re-implementing it.
//   • E12 alert() per catalyst (9 alerts) + composite alerts for trigger_bull
//         and trigger_rec. Compile pass v2.5.1: switched from alertcondition()
//         (no effect in strategies — Pine v6 warning) to alert() runtime calls
//         with freq_once_per_bar_close. Configure ONE TradingView alert on the
//         strategy with frequency "Any alert function call" and all 11 routes
//         will fire through it with their distinct messages.
//
//   PRIOR v2.4 BUG FIXES PRESERVED (see commit log for full list)
// ==========================================
// CHANGELOG v2.4 (Bug-fix pass over v2.3 — 2026-05-17)
//   FIXES
//   • B1a Hunter v1 FINAL gates ACTUALLY wired into pos_bo_trigger
//         (v2.3 declared them in changelog but never applied them).
//         Now: wRSI >= hunter_weekly_rsi_min AND hunter_adx_ok.
//   • B1b v2 LOCK gate ACTUALLY wired into pos_ac_trigger — same compliance
//         break as B1a. v2.3 declared d_rsi <= pos_accum_rsi_max but the
//         expression never referenced it. POS-ACCUM was therefore firing on
//         late-stage high-RSI chase setups (HCLTECH-style failure mode).
//   • B2  REV-CB climax_bar tautology fixed — bar_range_max_cb now uses
//         [1] offset so current bar is compared against PRIOR N bars,
//         not itself. v2.3 condition (bar_range >= max-incl-self) was
//         tautological and silently blocked most REV-CB firings.
//   • B3  vol_acc_ok comment reconciled with code (threshold = 3, not 6).
//         Code behavior unchanged; comment now matches actual logic.
//   • B4  mkt_bull gate added to pos_bo_trigger and pos_ac_trigger for
//         consistency with all other Bull catalysts (POS edges had been
//         silently fire-able in Stage 4 regimes).
//   • B5  swing_rev_trg now requires NOT stage4_dntrend (was firing on
//         broken stocks where close > SMA200 but underlying trend was
//         already structurally down).
//   • B6  stage2_fresh_ok now uses nz(wStageWks, 999) so na case
//         explicitly disqualifies instead of silently propagating na.
//   • B13 Mansfield RS symbol concat now strips any pre-existing "NSE:"
//         prefix from syminfo.ticker before re-prefixing. Prevents
//         double-prefix "NSE:NSE:RELIANCE" silent failures.
//
//   PRIOR (v2.3) CHANGES PRESERVED
//   • v2 LOCK on pos_ac_trigger: d_rsi <= pos_accum_rsi_max (default 50)
//   • Hunter v1 FINAL inputs surfaced under "Bull: v1+v2 Locked Filters"
//   • Source: BACKTEST_RESULTS_v2.docx §7.1 + §2.4 + v2.4 bug-fix audit.
// ==========================================
// ============================================================================
//  CROSS-TOOL ARCHITECTURE — v2.6 (Decision-Mode Compression Pass)
// ============================================================================
//  The Dashboard (Weinstein & Swing Pro Dashboard v67.3.0+) is now the canonical
//  source for: RS engine · Stage anchors · Strict trend · Price Action Structure
//  · Portfolio · Persona / Style · Volume Trend · Momentum.
//
//  This Strategy stays canonical for: Cross-engine verdict aggregation · RFF
//  Lite fundamental gate · Strategy-level position sizing / pyramiding rules.
//
//  Bull setup detail → see Commander Bull Screener v3.0.
//  Recovery setup detail → see Commander Recovery Screener v1.6.
// ============================================================================

// ==========================================
// CHANGELOG v2.6 — DECISION-MODE COMPRESSION + RS ENGINE MIRROR
// ==========================================
// ARCHITECTURAL: Dashboard is the canonical source for the RS / Mansfield
//   engine. f_rs_math() ported to Dashboard's dual-SMA spec.
//
// CHANGE: f_rs_math — was 26w-SMA-only level + price-ratio slope (Δ rp/rp[4w]).
//   Now: dual-SMA (26w slope-Mansfield + 52w level-Mansfield), Δ Mansfield
//   slope, 4-bar momentum, 130-bar warm-up. Tuple expanded:
//     OLD: [mansfield, slope, rs_mom]    (3-tuple, slope = Δ price ratio)
//     NEW: [mansfield, slope, rs_mom]    (3-tuple, slope = Δ Mansfield — canonical)
//   Signature unchanged; only the internal math is now Dashboard-canonical.
//   rsLength stays at 26w (slope SMA); new internal const for 52w level SMA.
//
// REMOVED display rows (Dashboard owns):
//   STAGE row · RS N500 row · RS Momentum row · all per-engine duplicates
//   that mirrored Dashboard / Bull Screener / Recovery Screener.
//
// REORGANIZED — table now exposes only the Unified-unique value:
//   COMPOSITE VERDICT · BULL ENGINE summary · RECOVERY ENGINE summary ·
//   STRATEGY ALIGNMENT · RFF LITE · FINAL DECISION
// ==========================================

// ==========================================
// CHANGELOG v2.8.3 — FOOTER LABEL/VALUE SPLIT
// ==========================================
// REFINEMENT to v2.8.2's footer fix. v2.8.2 packed label + description into
// one merged cell (cols 0-3); that worked but lost the panel's standard
// label-left / value-right rhythm. v2.8.3 splits them:
//   col 0          = "→ See Other Tools:"  (label)
//   cols 1-3 merged = "Dashboard (...) · Bull Screener (...) · Recovery (...)"  (value)
// Matches every other row's visual structure.
// ==========================================
// CHANGELOG v2.8.2 — FOOTER RENDER FIX
// ==========================================
// FIX: v2.8.1's footer label rendered but the description ("Dashboard (RS/Stage/PA)
// · Bull (Gates/Levels) · Recovery (Pillars/RFF)") was blank. Cause: Pine v6
// table.merge_cells subsumes columns into the FIRST cell's content; the
// follow-up write to column 1 (where the description was) targeted a sub-cell
// that no longer existed after the merge, so the description silently dropped.
// v2.8.2: label + description packed into ONE string, written to col 0, then
// merged across cols 0-3. Footer now renders the full text.
// ==========================================
// CHANGELOG v2.8.1 — FOOTER PLACEMENT
// ==========================================
// "See Other Tools:" cross-reference footer moved from the end of the BULL +
// RECOVERY main panel down to the very bottom of the CATALYST DIAG panel.
// Spans all 4 columns. Renders as the last row of the table so the cross-tool
// pointer is the last thing the eye lands on after the full diagnostics.
// ==========================================
// CHANGELOG v2.8 — 4-COLUMN STACKED DIAG LAYOUT
// ==========================================
// FOLLOW-UP to v2.7: the CATALYST DIAG panel was rendering on the right side
// (columns 2-3) parallel to the main strategy panel (columns 0-1). This left
// the right side ending earlier than the left, producing the uneven table the
// user flagged.
//
// CHANGE: CATALYST DIAG now renders BELOW the main strategy panel, distributed
//   across all 4 columns (2 catalysts per row). The table is now visually
//   even — every row uses all 4 columns.
//
// LAYOUT:
//   ── 🌿 BULL MARKET STRATEGY ── (full-width header)
//   BULL SETUP                                          (label, value)
//   Positional Signals                                  (label, value)
//   Swing Signals                                       (label, value)
//   ── 🔄 RECOVERY MARKET STRATEGY ── (full-width header)
//   REC STATE                                           (label, value)
//   Recovery Signals                                    (label, value)
//   → See Other Tools:                                  (label, value)
//   ── ◈ CATALYST DIAG ── (full-width header, stacked below)
//   ── 🌿 BULL ──                       (full-width subheader)
//   POS-BO       | status  | POS-ACCUM | status         (paired)
//   SWG-PB       | status  | SWG-BO    | status         (paired)
//   SWG-REV      | status  | SWG-GAP   | status         (paired)
//   ── 🔄 RECOVERY ──                   (full-width subheader)
//   REV-CB       | status  | REV-RS    | status         (paired)
//   REV-EARLY    | status  |           |                (solo)
//   ── 🛈 META ──                       (full-width subheader)
//   Sector Ticker| value   | WCL Gate  | value          (paired)
//   Base Confirm Path | value |        |                (solo)
//
// IMPL: New global `main_panel_end_row` exposes main-panel row count to the
//   diag block. Diag's `dr` starts at `main_panel_end_row` when show_panel is
//   on, else 0. Section headers use `table.merge_cells` to span all 4 columns.
// ==========================================
// CHANGELOG v2.7 — COMPOSITE-MERGE PASS
// ==========================================
// FOLLOW-UP to v2.6: v2.6 removed duplicate rows but didn't merge the remaining
// rows. v2.7 applies Dashboard-style composite merging:
//
// MERGED:
//   BULL section (was 2 separate rows: Base Confirmed + Py Score)
//      → 1 compound BULL SETUP row:
//          "✓ BASE · Py 75/100"
//   RECOVERY section (was 2 separate rows: Recovery Regime + RFF Filter)
//      → 1 compound REC STATE row:
//          "Regime: MKT-CORR · RFF: 4/6✓"
//   FOOTER (was 3 separate cross-ref rows)
//      → 1 compound row:
//          "Dashboard (RS/Stage/PA) · Bull (Gates/Levels) · Recovery (Pillars/RFF)"
//
// Net: ~5 rows removed from the main strategy panel.
// LOGIC UNCHANGED — display-layer-only compression.
// ==========================================

strategy("Weinstein Unified Ecosystem [v3.4.2]", overlay=true,
         initial_capital=100000,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=10,
         currency=currency.INR,
         process_orders_on_close=true,
         calc_on_every_tick=true,     // E10 reverted: needed so barstate.islast fires on realtime bars (panel + diag update)
         pyramiding=6)


// ==========================================
// 1. MASTER TOGGLES
// ==========================================
grp_master = "Master Toggles"
use_bull_mode = input.bool(true, title="Enable Bull Market Strategy?", group=grp_master, tooltip="Enables Positional and Swing setups.")
use_rec_mode  = input.bool(true, title="Enable Recovery Market Strategy?", group=grp_master, tooltip="Enables Climax Bottom, RS Survivor, and Early Bird setups.")

// ==========================================
// 2. INPUTS: BULL MARKET STRATEGIES
// ==========================================
grp_bull_pos = "Bull: Positional"
use_pos_bo    = input.bool(true, title="[EDGE] Positional Breakout", group=grp_bull_pos)
use_pos_accum = input.bool(true, title="[EDGE] Positional Accumulation", group=grp_bull_pos)
bo_conf       = input.string("Daily Close", title="Breakout Confirmation", options=["Daily Close", "Intraday Penetration"], group=grp_bull_pos)
bo_len        = input.int(20, title="Breakout Lookback (Bars)", minval=10, group=grp_bull_pos)
pos_time_stop_weeks = input.int(6, title="Positional Time Stop (Weeks)", minval=2, group=grp_bull_pos)

// v1 + v2 LOCKED filters — must mirror Python chartink_replay.SCAN_PARAMS
// and v2_fixes.V2_PARAMS to enforce zero signal drift across surfaces.
grp_v1v2 = "Bull: v1+v2 Locked Filters (Backtest-Verified)"
hunter_weekly_rsi_min = input.int(60, title="Hunter Weekly RSI Min (POS-BO)",   group=grp_v1v2, minval=40, maxval=80, tooltip="v1 FINAL: 60 (was 55). Mirrors chartink_replay.SCAN_PARAMS[hunter][weekly_rsi_min].")
hunter_daily_adx_min  = input.int(25, title="Hunter Daily ADX Min (POS-BO)",    group=grp_v1v2, minval=10, maxval=50, tooltip="v1 FINAL: 25 (was 20). Mirrors chartink_replay.SCAN_PARAMS[hunter][daily_adx_min].")
pos_accum_rsi_max     = input.int(50, title="POS-ACCUM Daily RSI Max",          group=grp_v1v2, minval=30, maxval=70, tooltip="v2 LOCKED: POS-ACCUM trigger suppressed when d_rsi > this value. Mirrors v2_fixes.V2_PARAMS[pos_accum_rsi_threshold]. Reason: late-stage POS-ACCUM at high RSI is a chase trap (HCLTECH-style failure, BACKTEST_RESULTS_v2.docx §7.1).")

// E3/E4/E5: Base-confirmation tuning surface
grp_base = "Bull: Base Confirmation Tuning (v2.5)"
stage2_fresh_max         = input.int(26,    title="E3 — Stage 2 Freshness Cap (Weeks)",   minval=4,   maxval=104, group=grp_base, tooltip="Stocks in Stage 2 longer than this fail stage2_fresh_ok. Default 26 (~6 months) per Weinstein. Widen to 52+ for positional mode that includes mature leaders.")
trend_template_low_mult  = input.float(1.30, title="E4 — Min Distance Above 52w Low (×)",  minval=1.0, maxval=2.5, step=0.05, group=grp_base, tooltip="close must be ≥ this multiple × 52w low. Default 1.30 (Minervini). Lower to 1.15 for recovery candidates.")
trend_template_high_pct  = input.float(0.75, title="E4 — Min % of 52w High",               minval=0.50, maxval=0.95, step=0.05, group=grp_base, tooltip="close must be ≥ this fraction × 52w high. Default 0.75 (Minervini). Lower to 0.60 for early-base setups.")
use_mature_trend_exempt  = input.bool(true,  title="E5 — Enable Mature Trend Exemption", group=grp_base, tooltip="Allows established Stage 2 leaders (LEADING RS, beyond freshness window, above EMA20, above SMA200) to satisfy base_confirmed WITHOUT the strict Weinstein gate. Default ON. Turn off for pure-Weinstein backtests.")

// E1 + E7: Diagnostic panel
grp_diag = "Diagnostics (v2.5)"
use_diag_panel = input.bool(true,  title="E1 — Show Catalyst Diagnostic Panel", group=grp_diag, tooltip="Floating table showing pass/fail per catalyst gate and first blocking gate. Removes the 'why isn't it firing' mystery.")
diag_pos       = input.string("Bottom Right", title="Diagnostic Panel Position",   options=["Top Left","Top Right","Middle Right","Bottom Left","Bottom Right"], group=grp_diag)
diag_sz        = input.string("Small",        title="Diagnostic Panel Text Size",  options=["Tiny","Small","Normal"], group=grp_diag)

// E9: RFF FY → FQ fallback
grp_rff_fb = "Recovery: RFF FY→FQ Fallback (v2.5)"
use_rff_fq_fallback = input.bool(true, title="E9 — Backfill RFF FY gaps with FQ", group=grp_rff_fb, tooltip="Improves RFF coverage on small/midcap NSE listings where FY data is sparse. When a FY field is na, falls back to the latest FQ value.")

// E11: WCL Context Layers integration (external source)
grp_wcl = "WCL Context Layers Gate (v2.5)"
use_wcl_gate    = input.bool(false, title="E11 — Require WCL setup ≥ threshold", group=grp_wcl, tooltip="When ON, every catalyst must additionally satisfy wcl_score_source >= wcl_score_min. Wire this to a plot from Weinstein_Context_Layers_v1.1.pine (add `plot(_setup_pri, 'WCL_Setup_Pri', display=display.data_window)` to the WCL script and select that plot here).")
wcl_score_source = input.source(close, title="WCL Setup Source",            group=grp_wcl, tooltip="Source from Context Layers indicator (typically _setup_pri 0–5). Defaults to close so this gate is inert until you wire a real source.")
wcl_score_min    = input.int(3,     title="WCL Setup Min Priority",         minval=0, maxval=5, group=grp_wcl, tooltip="Default 3 = require S1/S3/S7 level. Set to 5 for S2 (Spring/LPS Reversal) only.")

grp_bull_swg = "Bull: Hybrid Swing"
use_swing_pb  = input.bool(true, title="[EDGE] Swing Pullback", group=grp_bull_swg)
use_swing_bo  = input.bool(true, title="[EDGE] Swing Breakout (VCP)", group=grp_bull_swg)
use_swing_rev = input.bool(true, title="[EDGE] Swing Reversion", group=grp_bull_swg)
use_swing_gap = input.bool(true, title="[EDGE] Gap & Go", group=grp_bull_swg)
swg_time_stop_days = input.int(10, title="Swing Time Stop (Days)", minval=3, group=grp_bull_swg)
use_dyn_rr    = input.bool(true, title="Dynamic T1 RR (Market Aware)", group=grp_bull_swg)
rr_t1_pb      = input.float(2.0, title="Fixed T1 R-Multiple", step=0.1, group=grp_bull_swg)

grp_bull_filters = "Bull: Filters & Edge Gates"
use_macro_edge = input.bool(true, title="Require Macro Edge (Trend+Vol)", group=grp_bull_filters)
use_micro_edge = input.bool(true, title="Require Micro Edge (CPR/VWAP)", group=grp_bull_filters)
