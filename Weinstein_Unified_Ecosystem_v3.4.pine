// ==========================================
// CONSTANTS
// ==========================================
var int   maLengthW   = 30
var int   wSlopeLen   = 6
var float slopeThresh = 0.0012
var int   piv_w_left  = 5
var int   piv_w_right = 5
var int   piv_d_left  = 2
var int   rsLength    = 26
var int   jdkLength   = 12            // v3.0: Strike-matched 1-pass length (was 10 / 2-pass)
var int   rrgTrailLen = 4             // v2.9: RRG trajectory tail (weeks) — standard
var string bench500   = "NSE:CNX500"
var int   vol_avg_len = 50

// ==========================================
// 6. HELPER FUNCTIONS
// ==========================================

f_classifyHigh(float newHigh, float prevHigh) =>
    string result = "HH"
    if not na(prevHigh) and prevHigh > 0
        float diff = math.abs(newHigh - prevHigh) / prevHigh
        if diff < 0.002
            result := "EH"
        else if newHigh < prevHigh
            result := "LH"
    result

f_classifyLow(float newLow, float prevLow) =>
    string result = "LL"
    if not na(prevLow) and prevLow > 0
        float diff = math.abs(newLow - prevLow) / prevLow
        if diff < 0.002
            result := "EL"
        else if newLow > prevLow
            result := "HL"
    result

f_getStrictTrend(float h, float l, int left, int right) =>
    var int trendState     = 0
    var int confirmedTrend = 0
    var float lockedHigh   = na
    var float lockedLow    = na
    var string lastHighClass   = na
    var string lastLowClass    = na
    var string activePivotType = na
    var float activePivotPrice = na
    var int activePivotIndex   = na
    // v6.2: previous structural references for correct extension-path classification
    var float prevLockedHigh   = na
    var float prevLockedLow    = na

    ph = ta.pivothigh(h, left, right)
    pl = ta.pivotlow(l, left, right)

    // 1. New Pivot High Found
    if not na(ph)
        if activePivotType == "H" and ph > activePivotPrice
            // EXTENDING existing high — re-classify against PREVIOUS structural high
            // (prevLockedHigh), NOT lockedHigh (which equals THIS direction's initial price).
            activePivotPrice := ph
            activePivotIndex := bar_index[right]
            string hClass = f_classifyHigh(ph, prevLockedHigh)  // v6.2: was lockedHigh
            lastHighClass := hClass
        else if activePivotType == "L" or na(activePivotType)
            // NEW direction change: Low → High. Lock the previous low.
            if activePivotType == "L"
                lockedLow := activePivotPrice

            string hClass = f_classifyHigh(ph, lockedHigh)

            // v6.2 strict f_updateTrend: EL on the low side does NOT confirm uptrend.
            // Only strict HL (after HH) or LL (after LH) confirms.
            int newTrend = 0
            if hClass == "HH"
                if lastLowClass == "HL"     // v6.2: removed EL from gate
                    newTrend := 1
                else
                    newTrend := 0
            else if hClass == "LH"
                if lastLowClass == "LL"     // v6.2: removed EL from gate
                    newTrend := -1
                else
                    newTrend := 0
            else  // EH → SIDEWAYS
                newTrend := 0

            trendState     := newTrend
            confirmedTrend := newTrend
            prevLockedHigh := lockedHigh   // v6.2: save structural previous high
            lockedHigh     := ph
            lastHighClass  := hClass
            activePivotPrice := ph
            activePivotIndex := bar_index[right]
            activePivotType  := "H"

    // 2. New Pivot Low Found
    if not na(pl)
        if activePivotType == "L" and pl < activePivotPrice
            // EXTENDING existing low — re-classify against PREVIOUS structural low
            // (prevLockedLow), NOT lockedLow (which equals THIS direction's initial price).
            activePivotPrice := pl
            activePivotIndex := bar_index[right]
            string lClass = f_classifyLow(pl, prevLockedLow)  // v6.2: was lockedLow
            lastLowClass := lClass
        else if activePivotType == "H" or na(activePivotType)
            // NEW direction change: High → Low. Lock the previous high.
            if activePivotType == "H"
                lockedHigh := activePivotPrice

            string lClass = f_classifyLow(pl, lockedLow)

            int newTrend = 0
            if lClass == "LL"
                if lastHighClass == "LH"
                    newTrend := -1
                else
                    newTrend := 0
            else if lClass == "HL"
                if lastHighClass == "HH"
                    newTrend := 1
                else
                    newTrend := 0
            else  // EL → SIDEWAYS
                newTrend := 0

            trendState     := newTrend
            confirmedTrend := newTrend
            prevLockedLow  := lockedLow
            lockedLow      := pl
            lastLowClass   := lClass
            activePivotPrice := pl
            activePivotIndex := bar_index[right]
            activePivotType  := "L"

    // 3. LIVE TREND SYNC (Projection BoS) — v6.2 fully synced
    // syncBars includes the pivot bar itself (+1) so projSync extremes capture the pivot.
    int _syncBars = na(activePivotIndex) ? 1 : (bar_index - activePivotIndex + 1)
    int syncBars  = math.max(1, _syncBars)
    float projSyncLow  = ta.lowest(l, syncBars)
    float projSyncHigh = ta.highest(h, syncBars)

    // Pre-compute classifications unconditionally
    string _projHighClass = f_classifyHigh(projSyncHigh, lockedHigh)
    string _projLowClass  = f_classifyLow(projSyncLow,  lockedLow)

    // GATED by activePivotType: only evaluate the DEVELOPING side.
    // activePivotType == "L" → developing upward → check HH BoS only.
    //   Opposite-side class uses CONFIRMED lastLowClass (v6.2 fix: no re-classification).
    // activePivotType == "H" → developing downward → check LL BoS only.
    //   Opposite-side class uses CONFIRMED lastHighClass (v6.2 fix).
    if activePivotType == "L" and _projHighClass == "HH"
        string _devLowClass = na(lastLowClass) ? "HL" : lastLowClass  // confirmed, not re-classified
        if _devLowClass == "HL"
            trendState := 1
        else
            trendState := 0
    else if activePivotType == "H" and _projLowClass == "LL"
        string _devHighClass = na(lastHighClass) ? "LH" : lastHighClass  // confirmed, not re-classified
        if _devHighClass == "LH"
            trendState := -1
        else
            trendState := 0

    [trendState, lockedHigh, lockedLow]

f_get_daily_indicators(int ema_len, int atr_len) =>
    [ta.ema(close, ema_len), ta.sma(close, 50), ta.sma(close, 150), ta.sma(close, 200), ta.atr(atr_len)]

f_get_cpr() =>
    float p = (high[1] + low[1] + close[1]) / 3
    float bc = (high[1] + low[1]) / 2
    float tc = (p - bc) + p
    [p, math.min(bc, tc), math.max(bc, tc)]

f_get_mvwap() =>
    var float sumSrcVol = 0.0
    var float sumVol    = 0.0
    bool isNewMonth = timeframe.change("M")
    if isNewMonth
        sumSrcVol := 0.0
        sumVol    := 0.0
    sumSrcVol += hlc3 * volume
    sumVol    += volume
    sumVol > 0 ? sumSrcVol / sumVol : na

f_is_vcp(mult) =>
    vcp_atr = ta.atr(10)
    avg_atr = ta.sma(vcp_atr, 50)
    is_tight = vcp_atr < (avg_atr * mult)
    is_dry = ta.vwma(volume, 5) < ta.sma(volume, 50) 
    is_tight and is_dry

f_is_bb_sqz(len) =>
    basis = ta.sma(close, len)
    dev = 2.0 * ta.stdev(close, len)
    bbw = ((basis + dev) - (basis - dev)) / basis
    avg_bbw = ta.sma(bbw, 30)
    bbw < avg_bbw

f_calc_alpha_score(float c, float o, float ema20, float sma50, float v, float va) =>
    float _score = 0.0
    if not na(c)
        if c > ema20
            _score += 15
        if c > sma50
            _score += 15
        // PRICE ACTION momentum (replaces RSI>60/50 — mirrors Python R1):
        // close above its 10-bar-ago and 5-bar-ago values.
        bool _m10 = c > close[10]
        bool _m5  = c > close[5]
        if _m10 and _m5
            _score += 20
        else if _m10
            _score += 10
        // PRICE ACTION directional strength (replaces ADX — mirrors Python R4):
        // >=7 of the last 14 bars are up-closes making higher highs.
        int _dir = 0
        for _i = 1 to 14
            if close[_i] > open[_i] and high[_i] > high[_i + 1]
                _dir += 1
        if _dir >= 7
            _score += 10
        if c > o and v > (va * 1.5)
            _score += 20
        else if c > o and v > va
            _score += 10
        float dist_ema = math.abs((c - ema20) / ema20) * 100
        if dist_ema < 5.0
            _score += 20
        else if dist_ema < 10.0
            _score += 10
        if use_macro_edge
            if v > va
                _score += 10
            else
                _score -= 20
    _score

f_rs_math() =>
    // v3.0 (2026-05-19): Strike.Money-matched JdK formula.
    // Replaces 2-pass StockCharts default. Calibration vs Strike's 15 published
    // symbols showed quadrant agreement jumped from 66.7% (2-pass) to 93.8%
    // (1-pass + 5-bar smooth). Strike uses single normalization, NOT double.
    // Default length raised 10 → 12. Returns CENTERED values so legacy >0
    // checks (mansfield > 0, rs_mom > 0) continue to work unchanged.
    rs           = close
    rs_sma       = ta.sma(rs, jdkLength)
    rs_ratio_raw = 100.0 + ((rs - rs_sma) / rs_sma) * 100.0
    rs_ratio     = ta.sma(rs_ratio_raw, 5)                 // 5-bar smooth — Strike-match
    rs_mom       = ta.sma(100.0 * (rs_ratio / rs_ratio[1]), jdkLength)
    float val   = rs_ratio - 100.0
    float mom_c = rs_mom   - 100.0
    float slope = val - nz(val[rs_slope_weeks], val)
    float val_trail = nz(val[rrgTrailLen],   val)
    float mom_trail = nz(mom_c[rrgTrailLen], mom_c)
    bool _warmed = bar_index >= math.max(jdkLength * 3 + 10, 60) and not na(rs) and rs > 0
    [_warmed ? val : na, _warmed ? slope : na, _warmed ? mom_c : na, _warmed ? val_trail : na, _warmed ? mom_trail : na]

// v2.9: Combined RRG trajectory + score + tradeable (parity with Dashboard f_rrg_info
// and bull_screener.py _rrg_trajectory). Inputs centered on 0.
// Returns [arrow, traj, cur, nxt, score, tradeable].
f_rrg_info(float v, float m, float vt, float mt) =>
    float dv = v - vt
    float dm = m - mt
    string cur = v >= 0 and m >= 0 ? "LEADING" : v >= 0 ? "WEAKENING" : v < 0 and m < 0 ? "LAGGING" : "IMPROVING"
    string nxt = cur
    if cur == "LEADING"
        nxt := dm < -0.3 ? "WEAKENING" : (dv < -0.3 and dm < 0.3 ? "IMPROVING" : cur)
    else if cur == "WEAKENING"
        nxt := dv < -0.3 ? "LAGGING"   : (dm >  0.3 and dv > -0.3 ? "LEADING"   : cur)
    else if cur == "LAGGING"
        nxt := dm >  0.3 ? "IMPROVING" : (dv >  0.3 and dm > -0.3 ? "WEAKENING" : cur)
    else
        nxt := dv >  0.3 ? "LEADING"   : (dm < -0.3 and dv <  0.3 ? "LAGGING"   : cur)
    string arrow = dv > 0.3 ? (dm > 0.3 ? "↗" : dm < -0.3 ? "↘" : "→") : dv < -0.3 ? (dm > 0.3 ? "↖" : dm < -0.3 ? "↙" : "←") : dm > 0.3 ? "↑" : dm < -0.3 ? "↓" : "•"
    string traj = nxt == cur ? cur + " (stable)" : cur + " → " + nxt
    // v3.0.1: recalibrated on n=5,020 new-formula backtest (parity with bull_screener v1.7).
    // Score: only LEADING earns bonus (+2). Tradeable: cell-level positive-alpha cells only.
    int sc = cur == "LEADING" ? 2 : 0
    bool tr = (cur == "LEADING"   and (nxt == "LEADING"   or nxt == "IMPROVING")) or
              (cur == "IMPROVING" and  nxt == "LEADING")  or
              (cur == "LAGGING"   and  nxt == "IMPROVING") or
              (cur == "WEAKENING" and  nxt == "LEADING")
    [arrow, traj, cur, nxt, sc, tr]

f_get_weekly_bundle(maLen, slopeLen, l, r, thresh) =>
    c = close
    ma = ta.sma(close, maLen)
    float old_ma = ma[slopeLen]
    slope = (ma - nz(old_ma, ma)) / math.max(1, slopeLen)
    [trend, _, _] = f_getStrictTrend(high, low, l, r)
    rsi = ta.rsi(close, 14)
    float dynThresh = ma * thresh
    bool is_ma_uptrend   = slope > dynThresh 
    bool is_ma_downtrend = slope < -dynThresh
    bool is_above_ma     = c > ma

    var int current_stage_htf = 4
    if current_stage_htf == 1
        if is_ma_uptrend and is_above_ma
            current_stage_htf := 2
        else if is_ma_downtrend and not is_above_ma and trend != 1
            current_stage_htf := 4
    else if current_stage_htf == 2
        if is_ma_downtrend and not is_above_ma and trend != 1
            current_stage_htf := 4
        else if (not is_ma_uptrend and not is_above_ma) or (trend == -1 and not is_above_ma)
            current_stage_htf := 3
    else if current_stage_htf == 3
        if is_ma_downtrend and not is_above_ma and trend != 1
            current_stage_htf := 4
        else if is_ma_uptrend and is_above_ma
            current_stage_htf := 2
    else if current_stage_htf == 4
        if is_ma_uptrend and is_above_ma
            current_stage_htf := 2
        else if not is_ma_downtrend and is_above_ma
            current_stage_htf := 1

    if trend == 1 and current_stage_htf == 4
        current_stage_htf := 1
    if trend == -1 and current_stage_htf == 2
        current_stage_htf := 3

    // --- Weeks-in-Stage Counter (Sync with Beta v2.6) ---
    var int _prev_stage_htf = 4
    var int _stage_start_time = time
    if current_stage_htf != _prev_stage_htf
        _stage_start_time := time
        _prev_stage_htf := current_stage_htf
    float stage_wks = (time - _stage_start_time) / (7.0 * 86400000.0)

    float wMA10 = ta.sma(close, 10)
    bool early_stage2 = current_stage_htf == 1 and wMA10 > wMA10[1] and c > wMA10 and c > ma

    // MTF FIX (2026-07-03): 5-weeks-ago close must be computed INSIDE the weekly
    // context. The old `wClose[5]` at the call site indexed the ffilled series on
    // the DAILY chart = weekly close 5 trading DAYS ago (~1 week), not 5 weeks —
    // the POS-BO weekly-momentum gate was testing the wrong bar entirely.
    [c, ma, slope, trend, rsi, current_stage_htf, early_stage2, stage_wks, close[5]]

f_get_mkt_bundle() =>
    [close, ta.sma(close, 50), ta.sma(close, 200), ta.highest(high, 250), ta.lowest(low, 10), ta.lowest(low, 10)[10]]

f_get_sector_ticker() =>
    string s = syminfo.sector
    string i = syminfo.industry
    string t = "NSE:CNX500" // Default fallback
    string n = "Nifty 500"
    
    // Prioritize by Industry keywords first (more specific)
    if str.contains(i, "Bank") or str.contains(s, "Finance")
        t := "NSE:BANKNIFTY"
        n := "Bank Nifty"
    else if str.contains(s, "Technology") or str.contains(i, "Software") or str.contains(i, "IT")
        t := "NSE:CNXIT"
        n := "Nifty IT"
    else if str.contains(s, "Health") or str.contains(i, "Pharma")
        t := "NSE:CNXPHARMA"
        n := "Pharma"
    else if str.contains(i, "Auto") or str.contains(s, "Consumer Durables")
        t := "NSE:CNXAUTO"
        n := "Nifty Auto"
    else if str.contains(s, "Consumer Non") or str.contains(i, "Food") or str.contains(i, "Beverage")
        t := "NSE:CNXFMCG"
        n := "FMCG"
    else if str.contains(s, "Minerals") or str.contains(i, "Steel") or str.contains(i, "Metal")
        t := "NSE:CNXMETAL"
        n := "Metal"
    else if str.contains(s, "Energy") or str.contains(i, "Oil") or str.contains(i, "Gas")
        t := "NSE:CNXENERGY"
        n := "Energy"
    else if str.contains(s, "Real Estate") or str.contains(i, "Construction")
        t := "NSE:CNXREALTY"
        n := "Realty"
    else if str.contains(s, "Infrastructure")
        t := "NSE:CNXINFRA"
        n := "Infra"
    
    // Return Tuple
    [t, n]

