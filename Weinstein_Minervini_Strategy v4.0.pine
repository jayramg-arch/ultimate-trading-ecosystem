    sectorMap.put("VOLTAS", "NSE:CNXAUTO")
    sectorMap.put("WHIRLPOOL", "NSE:CNXAUTO")
    sectorMap.put("WIPRO", "NSE:CNXIT")
    sectorMap.put("YESBANK", "NSE:BANKNIFTY")
    sectorMap.put("ZEEL", "NSE:CNXMEDIA")
    sectorMap.put("ZYDUSLIFE", "NSE:CNXPHARMA")

f_db_sector_lookup(string t) =>
    sectorMap.get(t)

f_resolve_sector() =>
    string s = manualSector
    if use_auto_sec
        // 1. Try DB first
        string dbSec = f_db_sector_lookup(str.replace_all(str.upper(syminfo.ticker), "NSE:", ""))
        if dbSec != ""
            s := dbSec
        else
            // 2. Fallback to generic auto mapper
            s := f_get_sector_ticker()
    s

// --- Helper: Market Health ---
f_get_market_health(bm) =>
    m_close  = request.security(bm, "D", close)
    m_sma50  = request.security(bm, "D", ta.sma(close, 50))
    m_sma200 = request.security(bm, "D", ta.sma(close, 200))
    // Strict Long-Only rules: Market must be above 200 SMA AND in a Golden Cross state
    m_close > m_sma200 and m_sma50 > m_sma200

// --- Helper: Volume Accumulation ---
f_get_vol_accum(lookback, min_days, avg_len) =>
    vol_sma = ta.sma(volume, avg_len)
    daily_range = high - low
    closing_range = daily_range == 0 ? 0 : (close - low) / daily_range
    is_accum = (close > close[1]) and (volume > vol_sma) and (closing_range > 0.6)
    accum_density = math.sum(is_accum ? 1 : 0, lookback)
    accum_density >= min_days 

// --- Helper: VCP Tightness ---
f_is_vcp(mult) =>
    vcp_atr = ta.atr(10)
    avg_atr = ta.sma(vcp_atr, 50)
    is_tight = vcp_atr < (avg_atr * mult)
    is_dry = ta.vwma(volume, 5) < ta.sma(volume, 50) 
    is_tight and is_dry

// --- Helper: BB Squeeze ---
f_is_bb_sqz(len) =>
    basis = ta.sma(close, len)
    dev = 2.0 * ta.stdev(close, len)
    bbw = ((basis + dev) - (basis - dev)) / basis
    avg_bbw = ta.sma(bbw, 100)
    bbw < avg_bbw // Current bandwidth is less than the 100-day average

// --- ALPHA SCREENER ENGINE (v60.0 Ported) ---
f_calc_alpha_score(float c, float o, float ema20, float sma50, float rsi, float v, float va, bool adx) =>
    float _score = 0.0
    if not na(c)
        if c > ema20
            _score += 15
        if c > sma50
            _score += 15
        if rsi > 60
            _score += 20
        else if rsi > 50
            _score += 10
        if adx
            _score += 10
        if c > o and v > (va * 1.5)
            _score += 20
        else if c > o and v > va
            _score += 10
        float dist_ema = math.abs((c - ema20) / ema20) * 100
        if dist_ema < 5.0
            _score += 20
        else if dist_ema < 10.0
            _score += 10
            
        // --- 5. MACRO EDGE BACKTEST OVERLAY ---
        // Based on 5-Year Categorical Backtest: Vol Bias (Shelf + Accumulation) provides highest P-Factor edge
        if use_macro_edge
            // Implicit requirement: Vol > SMA50 AND VWMA > SMA (Simulated proxy via V > VA)
            if v > va 
                _score += 10 // Boost score if Macro Edge is met
            else
                _score -= 20 // Heavily penalize breakouts lacking institutional volume bias
    _score

var string sectorTicker = f_resolve_sector()

f_mansfield_rs(bm) =>
    int actual_len = timeframe.isdaily ? rsLength * 5 : (timeframe.isintraday ? int(rsLength * 5 * 6.5) : rsLength)
    base = close
    bench = request.security(bm, timeframe.period, close)
    rp = base / bench
    sma_rp = ta.sma(rp, actual_len)
    ((rp / sma_rp) - 1) * 10

f_get_weekly_bundle(maLen, slopeLen, l, r) =>
    c = close
    ma = ta.sma(close, maLen)
    slope = ta.linreg(ma, slopeLen, 0) - ta.linreg(ma, slopeLen, 1)
    trend = f_getStrictTrend(high, low, l, r)
    rsi = ta.rsi(close, 14)
    [c, ma, slope, trend, rsi]

[wClose, wMA30, wSlope, wTrend, wRSI] = request.security(syminfo.tickerid, "W", f_get_weekly_bundle(maLengthW, wSlopeLen, piv_w_left, piv_w_right))

f_get_daily_pb() =>
    [close, ta.sma(close, len50), ta.sma(close, len150), ta.sma(close, len200), ta.rsi(close, 14), volume, ta.sma(volume, 50)]

[d_close_raw, d_50, d_150, d_200, d_rsi, d_vol, d_vma] = request.security(syminfo.tickerid, "D", f_get_daily_pb(), lookahead=barmerge.lookahead_off)
float d_close = timeframe.isdaily ? close : d_close_raw

float d_ema20 = ta.ema(close, ema20_len)

f_get_cpr() =>
    p  = (high[1] + low[1] + close[1]) / 3
    bc = (high[1] + low[1]) / 2
    tc = (p - bc) + p
    [p, bc, tc]

[d_pivot, d_bc, d_tc] = request.security(syminfo.tickerid, "D", f_get_cpr(), lookahead=barmerge.lookahead_off)
cpr_ok = not use_micro_edge or (close > d_tc)

f_get_mvwap() =>
    var float pv_sum = 0.0
    var float v_sum  = 0.0
    if timeframe.change("M")
        pv_sum := 0.0
        v_sum  := 0.0
    pv_sum := pv_sum + (close * volume)
    v_sum  := v_sum + volume
    pv_sum / v_sum

m_vwap = request.security(syminfo.tickerid, "D", f_get_mvwap())
mvwap_ok = not use_micro_edge or (close > m_vwap)

d_vwma_20 = ta.vwma(volume, 20)
d_sma_20  = ta.sma(volume, 20)
vol_shelf_ok = not use_macro_edge or (d_vwma_20 > d_sma_20)

mkt_health_res = f_get_market_health(bench500)
mkt_ok         = not use_macro_edge or mkt_health_res
vol_accum_res  = f_get_vol_accum(vol_acc_days, vol_acc_min, vol_avg_len)
vol_acc_ok     = not use_macro_edge or vol_accum_res

vcp_res        = f_is_vcp(vcp_thresh)
vcp_ok         = vcp_res // Always require VCP for optimal setups

ma_dist        = math.abs(d_ema20 - d_50) / d_50
ma_sqz_ok      = not use_micro_edge or (ma_dist <= ma_sqz_pct)

bb_sqz_res     = f_is_bb_sqz(bb_sqz_len)
bb_sqz_ok      = not use_micro_edge or bb_sqz_res

[di_plus, di_minus, adx_line] = ta.dmi(14, 14)
adx_proxy_ok = adx_line > 20 and di_plus > di_minus

current_alpha_score = f_calc_alpha_score(d_close, open, d_ema20, d_50, d_rsi, d_vol, d_vma, adx_proxy_ok)
alpha_ok = current_alpha_score >= min_alpha

var bool is_breakeven = false
if strategy.position_size == 0
    is_breakeven := false

// ==========================================
// 3. INDICATOR LOGIC
// ==========================================

rsVal500 = f_mansfield_rs(bench500)
rsValSec = f_mansfield_rs(sectorTicker)
bool rs_ok = not use_rs or (rsVal500 > 0 and rsValSec > 0)

high_52w = ta.highest(high, 250)
low_52w  = ta.lowest(low, 250)
trend_template_ok = (close > low_52w * (1 + min_dist_52L)) and (close >= high_52w * (1 - max_dist_52H))

dTrend     = f_getStrictTrend(high, low, piv_d_left, piv_d_right)

// --- Stage Analysis (Stateless - Synced with Dashboard v60.0) ---
is_ma_uptrend   = (wSlope > (wMA30 * slopeThresh)) 
is_ma_downtrend = (wSlope < -(wMA30 * slopeThresh))
is_ma_flat      = not is_ma_uptrend and not is_ma_downtrend
is_above_ma     = close > wMA30

int current_stage = 0
if is_ma_uptrend
    if is_above_ma
        current_stage := 2
    else
        current_stage := 2 // Stage 2 Pullback (Rising MA, price dipped)
else if is_ma_downtrend
    current_stage := 4
else // Flat
    if is_above_ma
        current_stage := 1
    else
        current_stage := 3

stage1_base    = (current_stage == 1)
stage2_uptrend = (current_stage == 2)
stage3_top     = (current_stage == 3)
stage4_dntrend = (current_stage == 4)

trend_aligned  = (dTrend == 1) 
breakout_level = ta.highest(high, bo_len)[1]
is_breakout    = (bo_conf == "Daily Close") ? (close > breakout_level) : (high > breakout_level)
vol_ma = ta.sma(volume, vol_avg_len)
vol_expansion_ok = volume > vol_ma * vol_spike_mult
bo_entry_ext     = (close - breakout_level) / breakout_level
gap_ext_ok       = bo_entry_ext <= max_bo_ext
weekly_stage_run = ta.barssince(not stage2_uptrend)
stage2_fresh_ok  = weekly_stage_run <= max_stage2_bars 

vol_contraction_ok = volume < (vol_ma * (1 - vdu_pct))
pa_bullish = close > open and (close - low) > (high - close)

// --- Pullback Logic (Institutional) ---
stage2_pb   = (d_close > d_150) and (d_close > d_200) and (d_150 > d_200) and (d_50 > d_150)
// NEW (v3.0): Replaces basic d_rsi > 40 with strict Pocket constraint
mom_check   = (d_rsi >= rsi_pb_min) and (d_rsi <= rsi_pb_max) and (wRSI > rsi_w_th)
trend_ok_pb = stage2_pb and mom_check

upper_zone = d_ema20 * (1 + ema_zone)
lower_zone = d_ema20 * (1 - ema_zone)
in_zone    = (low <= upper_zone) and (high >= lower_zone)
pb_swing_high = ta.highest(high, bo_len)
pb_depth   = (pb_swing_high - low) / pb_swing_high
depth_ok   = pb_depth <= max_pb_depth 

vdu_ok = (d_close < d_close[1]) ? (d_vol < (d_vma * (1 - vdu_pct))) : true
prev_day_vdu = (d_close[1] < d_close[2]) ? (d_vol[1] < (d_vma * (1 - vdu_pct))) : true 
is_hammer = (close > open) and ((open - low) > 2 * (close - open)) and ((high - close) < 0.2 * (close - open))
is_engulf = (close > open) and (close > open[1]) and (close[1] < open[1]) and (open < close[1])
is_morn   = (close[2] < open[2]) and (math.abs(close[1] - open[1]) < (high[1]-low[1])*0.5) and (close > open) and (close > (open[2] + close[2])/2)
valid_pattern = (use_ham and is_hammer) or (use_eng and is_engulf) or (use_morn and is_morn)

// Unified Positional Engine
weinstein_setup    = stage2_uptrend and trend_aligned and rs_ok and vol_acc_ok and stage2_fresh_ok and ma_sqz_ok and bb_sqz_ok
weinstein_trigger  = is_breakout and vol_expansion_ok and pa_bullish and gap_ext_ok
trigger_pos_bo = use_pos_bo and weinstein_setup and weinstein_trigger and alpha_ok

// Edge 2 (Positional): Smart Money Accumulation (OBV Divergence)
obv = ta.cum(math.sign(ta.change(close)) * volume)
obv_50h = ta.highest(obv, 50)[1]
is_obv_bo = obv > obv_50h
price_50h = ta.highest(high, 50)[1]
is_price_lagging = close < (price_50h * 0.90) 
is_flat = ta.stdev(close, 50) < (ta.sma(close, 50) * 0.10)
in_base = stage1_base or stage2_uptrend
trigger_pos_accum = use_pos_accum and is_obv_bo and is_price_lagging and is_flat and in_base and rs_ok

bool trigger_weinstein_pos = trigger_pos_bo or trigger_pos_accum
var string pos_catalyst = na
if trigger_pos_bo
    pos_catalyst := "POS-BO"
else if trigger_pos_accum
    pos_catalyst := "POS-ACCUM"

// Unified Hybrid Swing Engine Setups
minervini_trend = (d_close > d_50) and (d_50 > d_150) and (d_150 > d_200) and trend_template_ok
pivot_level     = ta.highest(high, 10)[1] 
is_pivot_break  = close > pivot_level

// Edge 1: Pullback / MA Bounce
edge1_pb_cond = minervini_trend and trend_ok_pb and in_zone and valid_pattern
trigger_swing_pb = use_swing_pb and edge1_pb_cond and alpha_ok

// Edge 2: Momentum Breakout (VCP)
edge2_bo_cond = minervini_trend and vcp_ok and is_pivot_break and vol_expansion_ok
trigger_swing_bo = use_swing_bo and edge2_bo_cond 

// Edge 3: Mean Reversion (Oversold)
rsi_3 = ta.rsi(close, 3)
edge3_rev_cond = (rsi_3 < 20 or d_rsi < 30) and valid_pattern and (volume > d_vma * 1.5)
trigger_swing_rev = use_swing_rev and edge3_rev_cond and mkt_ok

// Edge 4: Gap & Go
gap_up_pct = (open - high[1]) / high[1] * 100
edge4_gap_cond = (gap_up_pct >= 4.0) and (volume > d_vma * 3.0) and (close > open)
trigger_swing_gap = use_swing_gap and edge4_gap_cond and mkt_ok

// Unified Trigger & Catalyst Route
bool trigger_minervini_swing = trigger_swing_pb or trigger_swing_bo or trigger_swing_rev or trigger_swing_gap
var string swing_catalyst = na
if trigger_swing_pb
    swing_catalyst := "SWG-PB"
else if trigger_swing_bo
    swing_catalyst := "SWG-BO"
else if trigger_swing_rev
    swing_catalyst := "SWG-REV"
else if trigger_swing_gap
    swing_catalyst := "SWG-GAP"

// Event Snaps
atr_14 = ta.atr(14)
is_new_trade = (strategy.position_size > 0 and strategy.position_size[1] == 0)
atr_entry_snap = ta.valuewhen(is_new_trade, atr_14, 0)
struct_low_snap = ta.valuewhen(is_new_trade, ta.lowest(low, 10), 0)
entry_sl_pb_snap = ta.valuewhen(is_new_trade, ta.lowest(low, 5) * (1 - sl_pad_pb), 0)

// ==========================================
// 4. STRATEGY EXECUTION
// ==========================================

in_date = not use_date or (time >= start_date and time <= end_date)
allow_bo = (strat_mode != "Pullback Only")
allow_pb = (strat_mode != "Breakout Only")

float base_risk_pct = asset_type == "ETF" ? etf_risk_pct : stock_risk_pct

f_get_adjusted_risk_pct() =>
    // 1. Market Regime Discount (mkt_health_res evaluated globally above)
    float regime_discount = mkt_health_res ? 1.0 : 0.5 
    
    // 2. Volatility Discount
    float _atr_14 = ta.atr(14)
    float atr_pct = (_atr_14 / close) * 100
    // Base expected volatility is ~3%. If it's higher, we scale down risk proportionally
    float vol_discount = atr_pct > 0 ? (3.0 / atr_pct) : 1.0
    if vol_discount > 1.0 
        vol_discount := 1.0 
        
    float adj_risk = base_risk_pct * regime_discount * vol_discount
    
    // 3. Minimum Risk Floor (0.25%)
    math.max(adj_risk, 0.25)

float active_risk_pct = f_get_adjusted_risk_pct()

f_get_qty(_sl_dist) =>
    float risk_amt = portfolio_capital * (active_risk_pct / 100.0)
    float qty_risk = _sl_dist > 0 ? risk_amt / _sl_dist : 0
    float qty_cap  = close > 0 ? max_alloc / close : 0
    math.min(qty_risk, qty_cap)

// Pre-calculate lowest lows in global scope for consistent historical series
float lowest_low_10 = ta.lowest(low, 10)
float lowest_low_5  = ta.lowest(low, 5)

// Entry A (Positional)
if allow_bo and trigger_weinstein_pos and strategy.position_size == 0 and in_date
    float struct_low = lowest_low_10
    float sl_price = struct_low - (atr_14 * 0.2) 
    if sl_price >= close
        sl_price := close - (atr_14 * 1.5) 
    float qty = f_get_qty(close - sl_price)
    if bo_conf == "Daily Close" or pos_catalyst == "POS-ACCUM"
        strategy.entry("Long", strategy.long, qty=qty, comment=pos_catalyst)
    else
        strategy.entry("Long", strategy.long, qty=qty, comment=pos_catalyst, stop=breakout_level + syminfo.mintick)

// Entry B (Swing)
if allow_pb and trigger_minervini_swing and strategy.position_size == 0 and in_date
    float sl_price = lowest_low_5 * (1 - sl_pad_pb)
    if sl_price >= close
        sl_price := close * 0.99
    float qty = f_get_qty(close - sl_price)
    strategy.entry("Long", strategy.long, qty=qty, comment=swing_catalyst)

// Context Exits
var float active_sl = na
if strategy.position_size > 0
    int bars_open = bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)
    bool time_stop_triggered = bars_open >= time_stop_days and not is_breakeven
    if time_stop_triggered
        strategy.close("Long", comment="Time Stop")
        
    string entry_id = strategy.opentrades.entry_comment(0)
    float entry_px  = strategy.opentrades.entry_price(0)
    
    // --- POSITION A: WEINSTEIN POSITIONAL (Unified) ---
    if str.startswith(entry_id, "POS")
        var float bo_sl = na
        if strategy.position_size[1] == 0 // New trade
            bo_sl := struct_low_snap - (atr_entry_snap * 0.2)
            if bo_sl >= entry_px
                bo_sl := entry_px - (atr_entry_snap * 1.5)
        else
            // NEW (v3.0): Instead of the sloppy lowest_low_20 anchor, we use the pure, dynamic CE trailing manager
            bo_sl := math.max(bo_sl, ce_trailing_stop) // Ratchet effect ensures it only goes up
            
        if is_breakeven
            bo_sl := math.max(bo_sl, entry_px)
            
        active_sl := bo_sl
        
        if stage4_dntrend
            strategy.close("Long", comment="Stage 4 Exit")
        else
            strategy.exit("Exit", "Long", stop=bo_sl, comment="CE Structural SL")
            
    // --- POSITION B: SWING (Unified) ---
    else if str.startswith(entry_id, "SWG") // Matches SWG-PB, SWG-BO, SWG-REV, SWG-GAP
        float trail_level = d_ema20 * (1 - trail_buf_pb)
        var float pb_sl = na
        if strategy.position_size[1] == 0 
            pb_sl := entry_sl_pb_snap
            if pb_sl >= entry_px
                pb_sl := entry_px * 0.99
        else
            pb_sl := math.max(pb_sl, trail_level)
            
        if is_breakeven
            pb_sl := math.max(pb_sl, entry_px)
            
        active_sl := pb_sl
        
        if d_close < d_50
            strategy.close("Long", comment="50MA Fail Exit")
        else if entry_id == "SWG-REV" and bars_open >= 5 // Hard 5-day time stop for mean reversion
            strategy.close("Long", comment="Mean Rev Time Stop")
        else
            strategy.exit("Exit", "Long", stop=pb_sl, comment="20EMA Trail")
else
    active_sl := na

// Partial Profits
if strategy.opentrades > 0
    entry_price = strategy.opentrades.entry_price(0)
    string entry_id = strategy.opentrades.entry_comment(0)
    
    float target1 = na
    if str.startswith(entry_id, "POS")
        target1 := na
    else if str.startswith(entry_id, "SWG")
        float init_sl = entry_sl_pb_snap
        if init_sl >= entry_price
            init_sl := entry_price * 0.99
        float initial_risk = entry_price - init_sl
        
        float resolved_t1_r = use_dyn_rr ? (mkt_health_res ? 2.5 : 1.5) : rr_t1_pb
        if entry_id == "SWG-REV"
            resolved_t1_r := 1.5 // Strict 1.5R target for Reversals
            
        target1 := entry_price + (initial_risk * resolved_t1_r)  
        
    if not na(target1) and high >= target1
        is_breakeven := true 
        strategy.exit("T1", "Long", qty_percent=50, limit=target1, comment="Target 1 Hit")


// ==========================================
// 5. PLOTTING
// ==========================================
// NEW (v3.0): Plotted Active EMA Structural Floor universally so it works perfectly across MTF
plot(allow_bo ? active_struct_floor : na, color=color.white, linewidth=2, title="Active Structural Floor")

// NEW (v3.0): Plot the Chandelier Exit universally as a real-time TSL Guide (even when flat)
plot(allow_bo ? ce_trailing_stop : na, color=color.fuchsia, linewidth=1, style=plot.style_stepline, title="Chandelier Exit (Positional TSL Guide)")

plot(strategy.position_size > 0 ? active_sl : na, color=color.red, style=plot.style_linebr, title="Active Stop Loss")

color bg_col = na
if stage2_uptrend
    bg_col := color.new(color.green, 85)
else if stage4_dntrend
    bg_col := color.new(color.red, 85)
else if stage1_base
    bg_col := color.new(color.yellow, 85)
else if stage3_top
    bg_col := color.new(color.orange, 85)

bgcolor(bg_col, title="Stage Background")

bool showSignals = input.bool(true, title="Show Entry Signals on Chart?", group="Display")
plotshape(showSignals and trigger_pos_bo, title="Positional Breakout (Weinstein)", style=shape.triangleup, location=location.belowbar, color=color.blue, text="★ W-POS", size=size.small, textcolor=color.white)
plotshape(showSignals and trigger_pos_accum, title="Positional Accumulation (OBV)", style=shape.triangleup, location=location.belowbar, color=color.lime, text="★ ACCUM", size=size.small, textcolor=color.white)
plotshape(showSignals and trigger_swing_pb, title="Swing Edge: Pullback", style=shape.triangleup, location=location.belowbar, color=color.yellow, text="Pullback", size=size.small, textcolor=color.white)
plotshape(showSignals and trigger_swing_bo, title="Swing Edge: Breakout", style=shape.triangleup, location=location.belowbar, color=color.purple, text="VCP Break", size=size.small, textcolor=color.white)
plotshape(showSignals and trigger_swing_rev, title="Swing Edge: Reversion", style=shape.triangleup, location=location.belowbar, color=color.orange, text="Reversal", size=size.small, textcolor=color.white)
plotshape(showSignals and trigger_swing_gap, title="Swing Edge: Gap & Go", style=shape.triangleup, location=location.belowbar, color=color.aqua, text="Gap Up", size=size.small, textcolor=color.white)


// ==========================================
// 6. MANUAL RISK ALLOCATOR
// ==========================================
if show_alloc_table and barstate.islast
    float m_entry = entry_input > 0 ? entry_input : close
    float m_stop  = stop_input > 0 ? stop_input : (m_entry * 0.95) 
    float m_base_risk_pct = asset_type == "ETF" ? etf_risk_pct : stock_risk_pct
    float m_adj_risk_pct = active_risk_pct // Use dynamic volatility-adjusted risk
    float m_risk_amt = portfolio_capital * (m_adj_risk_pct / 100.0)
    float m_dist = math.abs(m_entry - m_stop)
    float qty_r = m_dist > 0 ? math.floor((m_risk_amt / m_dist) / multiplier) : 0
    float qty_c = m_entry > 0 ? math.floor((max_alloc / m_entry) / multiplier) : 0
    float m_final_qty = math.min(qty_r, qty_c)
    bool m_long = m_entry > m_stop
    float m_t1 = m_long ? m_entry + (m_dist * 2) : m_entry - (m_dist * 2)
    float m_t2 = m_long ? m_entry + (m_dist * 3) : m_entry - (m_dist * 3)
    float m_invested = m_final_qty * m_entry * multiplier
    float m_act_risk = m_final_qty * m_dist * multiplier
    
    var table tbl_alloc = table.new(alloc_table_pos, 2, 9, bgcolor=color.new(color.black, 40), border_width=1)
    table.cell(tbl_alloc, 0, 0, "Risk Allocator (v4.1)", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 1, 0, asset_type, bgcolor=color.blue, text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 0, 1, "Entry", text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 1, 1, str.tostring(m_entry, "#.##"), text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 0, 2, "Stop", text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 1, 2, str.tostring(m_stop, "#.##"), text_color=color.red, text_size=size.small)
    table.cell(tbl_alloc, 0, 3, "Adjusted Risk %", text_color=color.orange, text_size=size.small)
    table.cell(tbl_alloc, 1, 3, str.tostring(m_adj_risk_pct, "#.##") + "% (Base: " + str.tostring(m_base_risk_pct) + "%)", text_color=color.orange, text_size=size.small)
    table.cell(tbl_alloc, 0, 4, "Quantity", text_color=color.yellow, text_size=size.normal)
    table.cell(tbl_alloc, 1, 4, str.tostring(m_final_qty), text_color=color.yellow, text_size=size.normal)
    table.cell(tbl_alloc, 0, 5, "Invested", text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 1, 5, str.tostring(m_invested, format.volume), text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 0, 6, "Risk Amt", text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 1, 6, str.tostring(m_act_risk, format.volume), text_color=color.white, text_size=size.small)
    table.cell(tbl_alloc, 0, 7, "Target 1 (2R)", text_color=color.green, text_size=size.small)
    table.cell(tbl_alloc, 1, 7, str.tostring(m_t1, "#.##"), text_color=color.green, text_size=size.small)
    table.cell(tbl_alloc, 0, 8, "Target 2 (3R)", text_color=color.green, text_size=size.small)
    table.cell(tbl_alloc, 1, 8, str.tostring(m_t2, "#.##"), text_color=color.lime, text_size=size.small)
    
    if entry_input > 0 and stop_input > 0
        line.new(bar_index, m_entry, bar_index+5, m_entry, color=color.blue, style=line.style_dashed, width=1)
        line.new(bar_index, m_stop, bar_index+5, m_stop, color=color.red, style=line.style_dashed, width=1)
        line.new(bar_index, m_t1, bar_index+5, m_t1, color=color.green, style=line.style_dashed, width=1)
        line.new(bar_index, m_t2, bar_index+5, m_t2, color=color.green, style=line.style_dashed, width=1)
