// --- HIGHS (ATH LIMIT FIX) ---
// Custom function to track ATH without hitting 15000 bar limit
f_trackATH() =>
    var float h = high
    h := math.max(h, high)
    h

[dHighest52, dHighestATH] = request.security(syminfo.tickerid, "D", [ta.highest(high, 252), f_trackATH()])
dev52 = ((close - dHighest52) / dHighest52) * 100
devATH = ((close - dHighestATH) / dHighestATH) * 100

// --- EMA 20 LOGIC ---
float d_ema20 = request.security(syminfo.tickerid, "D", ta.ema(close, 20))
float c_ema20 = ta.ema(close, 20)
bool isIntra = timeframe.isintraday
float use_ema20 = isIntra ? d_ema20 : c_ema20
string ema_lbl  = isIntra ? "Price vs EMA20 (Daily)" : "Price vs EMA20 (Chart)"

emaDist = 0.0
absDist = 0.0
emaState = "WAITING DATA..." 
color emaColor = color.gray

if not na(use_ema20)
    emaDist := (close - use_ema20) / close * 100
    absDist := math.abs(emaDist)
    if high > use_ema20 and close < use_ema20
        emaState := "RESISTANCE (Hit Head)"
        emaColor := color.red
    else if low < use_ema20 and close > use_ema20
        emaState := "SUPPORT (Bounced)"
        emaColor := color.green
    else if absDist < 1.0
        emaState := "NEAR (" + str.tostring(emaDist, "#.1") + "%)"
        emaColor := color.blue
    else if close > use_ema20
        emaState := "PRICE ABOVE" 
        emaColor := color.green
    else
        emaState := "PRICE BELOW"
        emaColor := color.red

