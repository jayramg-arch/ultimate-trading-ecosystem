// ==========================================
// CALCULATIONS (GLOBAL SCOPE)
// ==========================================

// --- Slope Logic with FLAT State ---
f_getLinRegSlope(float src, int len, float thresh) =>
    float slopeVal = ta.linreg(src, len, 0) - ta.linreg(src, len, 1)
    float dynamicThresh = src * thresh 
    string state = "FLAT"
    if slopeVal > dynamicThresh
        state := "RISING"
    else if slopeVal < -dynamicThresh
        state := "FALLING"
    state

// --- MARKET STRUCTURE (TIME-BASED FIX) ---
f_getStageAndTime(int maLen, int slopeLen, float thresh) =>
    float wCl = close
    float wMA = ta.sma(close, maLen)
    float slopeVal = ta.linreg(wMA, slopeLen, 0) - ta.linreg(wMA, slopeLen, 1)
    float dynThresh = wMA * thresh
    
    string s = "TRANSITION"
    if wCl > wMA
        if slopeVal > dynThresh
            s := "STAGE 2 (UP)"
        else if slopeVal < -dynThresh
            s := "STAGE 3 (TOP)"
        else
            s := "STAGE 1 (BASE)"
    else
        if slopeVal < -dynThresh
            s := "STAGE 4 (DOWN)"
        else if slopeVal > dynThresh
            s := "STAGE 1 (BASE)"
        else
            s := "STAGE 3 (TOP)" 
    
    var string lastS = ""
    var int startTime = 0
    
    if bar_index == 0
        lastS := s
        startTime := time
    
    if s != lastS
        startTime := time
        lastS := s
    
    [s, startTime]

// Get Stage Data from Weekly timeframe
[stageID, stageStart] = request.security(syminfo.tickerid, "W", f_getStageAndTime(maLengthW, wmaSlopeLen, flatThresh))

int msPerWeek = 604800000
int timeDiff = timenow - stageStart
if timeDiff < 0 
    timeDiff := 0
int stageWeeks = math.ceil(timeDiff / msPerWeek)
if stageWeeks < 1 
    stageWeeks := 1

string stageDisplay = stageID + " (" + str.tostring(stageWeeks) + " Wks)"
color stageCol = color.orange
if stageID == "STAGE 2 (UP)"
    stageCol := color.green
else if stageID == "STAGE 4 (DOWN)"
    stageCol := color.red
else if stageID == "STAGE 1 (BASE)"
    stageCol := color.blue

// --- RS & BENCHMARKS ---
cleanTicker = syminfo.prefix + ":" + syminfo.ticker
f_calc_rs_spread(int rsl, int slen) =>
    rp = close 
    rpSMA = ta.sma(rp, rsl)
    mrs = ((rp / rpSMA) - 1) * 10
    slope = ta.linreg(mrs, slen, 0) - ta.linreg(mrs, slen, 1)
    slope

slope50  = request.security(cleanTicker + " / " + bench50,  "W", f_calc_rs_spread(rsLength, rsSlopeLen))
slope500 = request.security(cleanTicker + " / " + bench500, "W", f_calc_rs_spread(rsLength, rsSlopeLen))
slopeSec = request.security(cleanTicker + " / " + benchSector, "W", f_calc_rs_spread(rsLength, rsSlopeLen))

f_slopeStr(float s) => 
    string st = "FLAT"
    if s > 0.02
        st := "RISING"
    else if s < -0.02
        st := "FALLING"
    st

rs50State  = f_slopeStr(slope50)
rs500State = f_slopeStr(slope500)
rsSecState = f_slopeStr(slopeSec)

