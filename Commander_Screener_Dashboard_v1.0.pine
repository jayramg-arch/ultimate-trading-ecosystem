s6  = input.symbol("NSE:BHARTIARTL", group=grpSym, inline="s3")
s7  = input.symbol("NSE:LT", group=grpSym, inline="s4")
s8  = input.symbol("NSE:ITC", group=grpSym, inline="s4")
