//@version=5
indicator("Commander Screener Dashboard [Multi-Ticker Ranker] v1.0", overlay=true)

// ==========================================
// 1. INPUTS
// ==========================================
grpSym = "Watchlist Symbols (Max 40)"
s1  = input.symbol("NSE:RELIANCE", group=grpSym, inline="s1")
s2  = input.symbol("NSE:TCS", group=grpSym, inline="s1")
s3  = input.symbol("NSE:HDFCBANK", group=grpSym, inline="s2")
s4  = input.symbol("NSE:INFY", group=grpSym, inline="s2")
